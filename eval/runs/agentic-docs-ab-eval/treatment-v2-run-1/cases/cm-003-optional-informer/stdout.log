nableTrustManager: trustManagerEnabled,\n\t\t\tProxyInformer:      optProxyInformer,\n\t\t})\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"failed to create unified controller manager: %w\", err)\n\t\t}\n\n\t\tgo func() {\n\t\t\tif err := manager.Start(ctx); err != nil {\n\t\t\t\tctrl.Log.Error(err, \"failed to start unified controller manager\")\n\t\t\t}\n\t\t}()\n\t}\n\n\t<-ctx.Done()\n\treturn nil\n}\n\n// setupFeatureGates — unchanged\n```\n\n---\n\n### 6. `pkg/controller/trustmanager/test_utils.go`\n\nUpdate `testReconciler` to include the proxy informer (not applicable, for existing tests):\n\n```go\npackage trustmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"strings\"\n\t\"testing\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/tools/record\"\n\n\t\"github.com/go-logr/logr/testr\"\n\n\tconfiginformers \"github.com/openshift/client-go/config/informers/externalversions\"\n\n\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n\t\"github.com/openshift/cert-manager-operator/pkg/operator/utils\"\n\t\"github.com/openshift/cert-manager-operator/pkg/testutil\"\n)\n\nvar errTestClient = fmt.Errorf(\"test client error\")\n\n// ... (trustManagerBuilder and its methods — unchanged) ...\n\nfunc testReconciler(t *testing.T) *Reconciler {\n\treturn &Reconciler{\n\t\tctx:           context.Background(),\n\t\teventRecorder: record.NewFakeRecorder(100),\n\t\tlog:           testr.New(t),\n\t\tscheme:        testutil.Scheme,\n\t\tproxyInformer: &utils.OptionalInformer[configinformers.SharedInformerFactory]{},\n\t}\n}\n\n// ... (rest unchanged) ...\n```\n\n---\n\n## Commands to run\n\n```bash\n# 1. Regenerate CRD manifests and deepcopy (picks up any new RBAC markers)\nmake update\n\n# 2. Verify the code compiles\nmake build\n\n# 3. Run unit tests\nmake test\n```\n\n---\n\n## Summary of changes\n\n| File | What changed |\n|---|---|\n| `pkg/operator/utils/apidiscovery.go` | Added `NewProxyInformer
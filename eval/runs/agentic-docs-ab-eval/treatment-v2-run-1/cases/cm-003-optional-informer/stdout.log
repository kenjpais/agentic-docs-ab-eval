{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01R4dDToXVTdszTqXGTM4HtW","type":"tool_result","content":"180\t}\n181\t\n182\t// withProxyEnv patches the operand deployment if operator\n183\t// has proxy variables set. Sets HTTPS_PROXY, HTTP_PROXY and NO_PROXY.\n184\tfunc withProxyEnv(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {\n185\t\tdeployment.Spec.Template.Spec.Containers[0].Env = mergeContainerEnvs(deployment.Spec.Template.Spec.Containers[0].Env, proxy.ReadProxyVarsFromEnv())\n186\t\treturn nil\n187\t}\n188\t\n189\t// withCAConfigMap patches the operand deployment to include the custom\n190\t// ca bundle as a volume. This is set when a trusted ca configmap is provided.\n191\tfunc withCAConfigMap(configmapinformer coreinformersv1.ConfigMapInformer, deployment *appsv1.Deployment, trustedCAConfigmapName string) func(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {\n192\t\treturn func(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {\n193\t\t\tif len(trustedCAConfigmapName) == 0 {\n194\t\t\t\treturn nil\n195\t\t\t}\n196\t\n197\t\t\t_, err := configmapinformer.Lister().ConfigMaps(operatorclient.TargetNamespace).Get(trustedCAConfigmapName)\n198\t\t\tif err != nil && apierrors.IsNotFound(err) {\n199\t\t\t\treturn fmt.Errorf(\"(Retrying) trusted CA config map %q doesn't exist due to %w\", trustedCAConfigmapName, err)\n200\t\t\t} else if err != nil {\n201\t\t\t\treturn err\n202\t\t\t}\n203\t\n204\t\t\tdeployment.Spec.Template.Spec.Volumes = append(deployment.Spec.Template.Spec.Volumes, corev1.Volume{\n205\t\t\t\tName: trustedCAVolumeName,\n206\t\t\t\tVolumeSource: corev1.VolumeSource{\n207\t\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n208\t\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n209\t\t\t\t\t\t\tName: trustedCAConfigmapName,\n210\t\t\t\t\t\t},\n211\t\t\t\t\t},\n212\t\t\t\t},\n213\t\t\t})\n214\t\n215\t\t\tfor i := range deployment.Spec.Template.Spec.Containers {\n216\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts = append(deployment.Spec.Template.Spec.Containers[i].VolumeMounts, corev1.VolumeMount{\n217\t\t\t\t\tName:      trustedCAVolumeName,\n218\t\t\t\t\tMountPath: trustedCAPath,\n219\t\t\t\t\tSubPath:   defaultCABundleKey,\n220\t\t\t\t})\n221\t\t\t}\n222\t\n223\t\t\treturn nil\n224\t\t}\n225\t}\n226\t\n227\t// withPodLabels patches the operand deployment to include custom pod labels.\n228\tfunc withPodLabelsOverrideHook(certmanagerinformer certmanagerinformer.CertManagerInformer, deploymentName string, fn overrideLabelsFunc) func(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {\n229\t\treturn func(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {"}]},"parent_tool_use_id":null,"session_id":"07ea1630-67ed-4715-951f-59d24e018baf","uuid":"a61944f3-72b7-4988-bc23-95f6ddabd6e1","timestamp":"2026-07-20T16:55:16.670Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/controller/certmanager/deployment_overrides.go","content":"}\n\n// withProxyEnv patches the operand deployment if operator\n// has proxy variables set. Sets HTTPS_PROXY, HTTP_PROXY and NO_PROXY.\nfunc withProxyEnv(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {\n\tdeployment.Spec.Template.Spec.Containers[0].Env = mergeContainerEnvs(deployment.Spec.Template.Spec.Containers[0].Env, proxy.ReadProxyVarsFromEnv())\n\treturn nil\n}\n\n// withCAConfigMap patches the operand deployment to include the custom\n// ca bundle as a volume. This is set when a trusted ca configmap is provided.\nfunc withCAConfigMap(configmapinformer coreinformersv1.ConfigMapInformer, deployment *appsv1.Deployment, trustedCAConfigmapName string) func(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {\n\treturn func(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {\n\t\tif len(trustedCAConfigmapName) == 0 {\n\t\t\treturn nil\n\t\t}\n\n\t\t_, err := configmapinformer.Lister().ConfigMaps(operatorclient.TargetNamespace).Get(trustedCAConfigmapName)\n\t\tif err != nil && apierrors.IsNotFound(err) {\n\t\t\treturn fmt.Errorf(\"(Retrying) trusted CA config map %q doesn't exist due to %w\", trustedCAConfigmapName, err)\n\t\t} else if err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tdeployment.Spec.Template.Spec.Volumes = append(deployment.Spec.Template.Spec.Volumes, corev1.Volume{\n\t\t\tName: trustedCAVolumeName,\n\t\t\tVolumeSource: corev1.VolumeSource{\n\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n\t\t\t\t\t\tName: trustedCAConfigmapName,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t})\n\n\t\tfor i := range deployment.Spec.Template.Spec.Containers {\n\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts = append(deployment.Spec.Template.Spec.Containers[i].VolumeMounts, corev1.VolumeMount{\n\t\t\t\tName:      trustedCAVolumeName,\n\t\t\t\tMountPath: trustedCAPath,\n\t\t\t\tSubPath:   defaultCABundleKey,\n\t\t\t})\n\t\t}\n\n\t\treturn nil\n\t}\n}\n\n// withPodLabels patches the operand deployment to include custom pod labels.\nfunc withPodLabelsOverrideHook(certmanagerinformer certmanagerinformer.CertManagerInformer, deploymentName string, fn overrideLabelsFunc) func(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {\n\treturn func(operatorSpec *operatorv1.OperatorSpec, deployment *appsv1.Deployment) error {","numLines":50,"startLine":180,"totalLines":276}}}

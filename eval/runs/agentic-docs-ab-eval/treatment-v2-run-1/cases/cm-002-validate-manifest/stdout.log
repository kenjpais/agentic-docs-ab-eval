st missing required container %q\", istiocsrContainerName),\n\t\t},\n\t\t{\n\t\t\tname: \"empty containers returns error\",\n\t\t\tmodify: func(d *appsv1.Deployment) {\n\t\t\t\td.Spec.Template.Spec.Containers = nil\n\t\t\t},\n\t\t\twantErr: fmt.Sprintf(\"deployment manifest missing required container %q\", istiocsrContainerName),\n\t\t},\n\t\t{\n\t\t\tname: \"missing required volume returns error\",\n\t\t\tmodify: func(d *appsv1.Deployment) {\n\t\t\t\td.Spec.Template.Spec.Volumes = nil\n\t\t\t},\n\t\t\toverrideRequiredVolumes: []string{\"must-have-volume\"},\n\t\t\twantErr:                `deployment manifest missing required volume \"must-have-volume\"`,\n\t\t},\n\t\t{\n\t\t\tname: \"required volume present passes\",\n\t\t\tmodify: func(d *appsv1.Deployment) {\n\t\t\t\td.Spec.Template.Spec.Volumes = []corev1.Volume{\n\t\t\t\t\t{Name: \"must-have-volume\"},\n\t\t\t\t}\n\t\t\t},\n\t\t\toverrideRequiredVolumes: []string{\"must-have-volume\"},\n\t\t},\n\t\t{\n\t\t\tname: \"one of multiple required volumes missing\",\n\t\t\tmodify: func(d *appsv1.Deployment) {\n\t\t\t\td.Spec.Template.Spec.Volumes = []corev1.Volume{\n\t\t\t\t\t{Name: \"vol-a\"},\n\t\t\t\t}\n\t\t\t},\n\t\t\toverrideRequiredVolumes: []string{\"vol-a\", \"vol-b\"},\n\t\t\twantErr:                `deployment manifest missing required volume \"vol-b\"`,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdeployment := testDeployment()\n\t\t\ttt.modify(deployment)\n\n\t\t\tif tt.overrideRequiredVolumes != nil {\n\t\t\t\toriginal := requiredVolumes\n\t\t\t\trequiredVolumes = tt.overrideRequiredVolumes\n\t\t\t\tdefer func() { requiredVolumes = original }()\n\t\t\t}\n\n\t\t\terr := validateDeploymentManifest(deployment)\n\n\t\t\tif tt.wantErr == \"\" {\n\t\t\t\tif err != nil {\n\t\t\t\t\tt.Fatalf(\"expected no error, got: %v\", err)\n\t\t\t\t}\n\t\t\t\treturn\n\t\t\t}\n\n\t\t\tif err == nil {\n\t\t\t\tt.Fatalf(\"expected error %q, got nil\", tt.wantErr)\n\t\t\t}\n\t\t\tif
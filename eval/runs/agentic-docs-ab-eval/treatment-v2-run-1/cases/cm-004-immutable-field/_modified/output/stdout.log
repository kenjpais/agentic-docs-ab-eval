{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_019v2gN6Ef8fvjwumK9CtxEs","type":"tool_result","content":"1\tpackage v1alpha1\n2\t\n3\timport (\n4\t\tcorev1 \"k8s.io/api/core/v1\"\n5\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n6\t\n7\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/meta/v1\"\n8\t)\n9\t\n10\tfunc init() {\n11\t\tSchemeBuilder.Register(&IstioCSR{}, &IstioCSRList{})\n12\t}\n13\t\n14\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n15\t// +kubebuilder:object:root=true\n16\t\n17\t// IstioCSRList is a list of IstioCSR objects.\n18\ttype IstioCSRList struct {\n19\t\tmetav1.TypeMeta `json:\",inline\"`\n20\t\n21\t\t// metadata is the standard list's metadata.\n22\t\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n23\t\tmetav1.ListMeta `json:\"metadata\"`\n24\t\n25\t\tItems []IstioCSR `json:\"items\"`\n26\t}\n27\t\n28\t// +genclient\n29\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n30\t// +kubebuilder:object:root=true\n31\t// +kubebuilder:subresource:status\n32\t// +kubebuilder:resource:path=istiocsrs,scope=Namespaced,categories={cert-manager-operator, istio-csr, istiocsr}\n33\t// +kubebuilder:printcolumn:name=\"GRPC Endpoint\",type=\"string\",JSONPath=\".status.istioCSRGRPCEndpoint\"\n34\t// +kubebuilder:printcolumn:name=\"Ready\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].status\"\n35\t// +kubebuilder:printcolumn:name=\"Message\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].message\"\n36\t// +kubebuilder:printcolumn:name=\"AGE\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n37\t// +kubebuilder:metadata:labels={\"app.kubernetes.io/name=istiocsr\", \"app.kubernetes.io/part-of=cert-manager-operator\"}\n38\t\n39\t// IstioCSR describes the configuration and information about the managed istio-csr agent.\n40\t// The name must be `default` to make IstioCSR a singleton that is, to allow only one instance of IstioCSR per namespace.\n41\t//\n42\t// When an IstioCSR is created, istio-csr agent is deployed in the IstioCSR-created namespace.\n43\t//\n44\t// +kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'default'\",message=\"istiocsr is a singleton, .metadata.name must be 'default'\"\n45\t// +operator-sdk:csv:customresourcedefinitions:displayName=\"IstioCSR\"\n46\ttype IstioCSR struct {\n47\t\tmetav1.TypeMeta `json:\",inline\"`\n48\t\n49\t\t// metadata is the standard object's metadata.\n50\t\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n51\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n52\t\n53\t\t// spec is the specification of the desired behavior of the IstioCSR.\n54\t\t// +kubebuilder:validation:Required\n55\t\t// +required\n56\t\tSpec IstioCSRSpec `json:\"spec\"`\n57\t\n58\t\t// status is the most recently observed status of the IstioCSR.\n59\t\t// +kubebuilder:validation:Optional\n60\t\t// +optional\n61\t\tStatus IstioCSRStatus `json:\"status,omitempty\"`\n62\t}\n63\t\n64\t// IstioCSRSpec is the specification of the desired behavior of the IstioCSR.\n65\ttype IstioCSRSpec struct {\n66\t\t// istioCSRConfig configures the istio-csr agent's behavior.\n67\t\t// +kubebuilder:validation:Required\n68\t\t// +required\n69\t\tIstioCSRConfig IstioCSRConfig `json:\"istioCSRConfig\"`\n70\t\n71\t\t// controllerConfig configures the controller for setting up defaults to enable the istio-csr agent.\n72\t\t// +kubebuilder:validation:Optional\n73\t\t// +optional\n74\t\tControllerConfig *ControllerConfig `json:\"controllerConfig,omitempty\"`\n75\t}\n76\t\n77\t// IstioCSRConfig configures the istio-csr agent's behavior.\n78\ttype IstioCSRConfig struct {\n79\t\t// logLevel supports a value range as per [Kubernetes logging guidelines](https://github.com/kubernetes/community/blob/master/contributors/devel/sig-instrumentation/logging.md#what-method-to-use).\n80\t\t// +kubebuilder:default:=1\n81\t\t// +kubebuilder:validation:Minimum:=1\n82\t\t// +kubebuilder:validation:Maximum:=5\n83\t\t// +kubebuilder:validation:Optional\n84\t\t// +optional\n85\t\tLogLevel int32 `json:\"logLevel,omitempty\"`\n86\t\n87\t\t// logFormat specifies the output format for istio-csr agent logging.\n88\t\t// Supported log formats are text and json.\n89\t\t// +kubebuilder:validation:Enum:=\"text\";\"json\"\n90\t\t// +kubebuilder:default:=\"text\"\n91\t\t// +kubebuilder:validation:Optional\n92\t\t// +optional\n93\t\tLogFormat string `json:\"logFormat,omitempty\"`\n94\t\n95\t\t// Istio-csr creates a ConfigMap named `istio-ca-root-cert` containing the root CA certificate, which the Istio data plane uses to verify server certificates. Its default behavior is to create and monitor ConfigMaps in all namespaces.\n96\t\t// The istioDataPlaneNamespaceSelector restricts the namespaces where the ConfigMap is created by using label selectors, such as maistra.io/member-of=istio-system. This selector is also attached to all desired namespaces that are part of the data plane.\n97\t\t// This field can have a maximum of 4096 characters.\n98\t\t// +kubebuilder:example:=\"maistra.io/member-of=istio-system\"\n99\t\t// +kubebuilder:validation:MinLength:=0\n100\t\t// +kubebuilder:validation:MaxLength:=4096\n101\t\t// +kubebuilder:validation:Optional\n102\t\t// +optional\n103\t\tIstioDataPlaneNamespaceSelector string `json:\"istioDataPlaneNamespaceSelector,omitempty\"`\n104\t\n105\t\t// certManager is for configuring cert-manager specifics.\n106\t\t// +kubebuilder:validation:Required\n107\t\t// +required\n108\t\tCertManager CertManagerConfig `json:\"certManager\"`\n109\t\n110\t\t// istiodTLSConfig is for configuring istiod certificate specifics.\n111\t\t// +kubebuilder:validation:Required\n112\t\t// +required\n113\t\tIstiodTLSConfig IstiodTLSConfig `json:\"istiodTLSConfig\"`\n114\t\n115\t\t// server is for configuring the server endpoint used by istio for obtaining the certificates.\n116\t\t// +kubebuilder:validation:Optional\n117\t\t// +optional\n118\t\tServer *ServerConfig `json:\"server,omitempty\"`\n119\t\n120\t\t// istio is for configuring the istio specifics.\n121\t\t// +kubebuilder:validation:Required\n122\t\t// +required\n123\t\tIstio IstioConfig `json:\"istio\"`\n124\t\n125\t\t// resources is for defining the resource requirements.\n126\t\t// Cannot be updated.\n127\t\t// ref: https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/\n128\t\t// +kubebuilder:validation:Optional\n129\t\t// +optional\n130\t\tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n131\t\n132\t\t// affinity is for setting scheduling affinity rules.\n133\t\t// ref: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/\n134\t\t// +kubebuilder:validation:Optional\n135\t\t// +optional\n136\t\tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n137\t\n138\t\t// tolerations is for setting the pod tolerations.\n139\t\t// This field can have a maximum of 50 entries.\n140\t\t// ref: https://kubernetes.io/docs/concepts/scheduling-eviction/taint-and-toleration/\n141\t\t// +listType=atomic\n142\t\t// +kubebuilder:validation:MinItems:=0\n143\t\t// +kubebuilder:validation:MaxItems:=50\n144\t\t// +kubebuilder:validation:Optional\n145\t\t// +optional\n146\t\tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n147\t\n148\t\t// nodeSelector is for defining the scheduling criteria using node labels.\n149\t\t// This field can have a maximum of 50 entries.\n150\t\t// ref: https://kubernetes.io/docs/concepts/configuration/assign-pod-node/\n151\t\t// +mapType=atomic\n152\t\t// +kubebuilder:validation:MinProperties:=0\n153\t\t// +kubebuilder:validation:MaxProperties:=50\n154\t\t// +kubebuilder:validation:Optional\n155\t\t// +optional\n156\t\tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n157\t}\n158\t\n159\t// CertManagerConfig is for configuring cert-manager specifics.\n160\t// +kubebuilder:validation:XValidation:rule=\"!has(oldSelf.issuerRef) && !has(self.issuerRef) || has(oldSelf.issuerRef) && has(self.issuerRef)\",message=\"issuerRef may only be configured during creation\"\n161\ttype CertManagerConfig struct {\n162\t\t// issuerRef contains details of the referenced object used for obtaining certificates.\n163\t\t// When `issuerRef.Kind` is `Issuer`, it must exist in the `.spec.istioCSRConfig.istio.namespace`.\n164\t\t// This field is immutable once set.\n165\t\t// +kubebuilder:validation:XValidation:rule=\"self == oldSelf\",message=\"issuerRef is immutable once set\"\n166\t\t// +kubebuilder:validation:XValidation:rule=\"self.kind.lowerAscii() == 'issuer' || self.kind.lowerAscii() == 'clusterissuer'\",message=\"kind must be either 'Issuer' or 'ClusterIssuer'\"\n167\t\t// +kubebuilder:validation:XValidation:rule=\"self.group.lowerAscii() == 'cert-manager.io'\",message=\"group must be 'cert-manager.io'\"\n168\t\t// +kubebuilder:validation:Required\n169\t\t// +required\n170\t\tIssuerRef certmanagerv1.ObjectReference `json:\"issuerRef\"`\n171\t\n172\t\t// istioCACertificate when provided, the operator will use the CA certificate from the specified ConfigMap.\n173\t\t// If empty, the operator will automatically extract the CA certificate from the Secret containing the istiod certificate obtained from cert-manager.\n174\t\t// +kubebuilder:validation:Optional\n175\t\t// +optional\n176\t\tIstioCACertificate *ConfigMapReference `json:\"istioCACertificate,omitempty\"`\n177\t}\n178\t\n179\t// IstiodTLSConfig is for configuring istiod certificate specifics.\n180\t// +kubebuilder:validation:XValidation:rule=\"!has(oldSelf.privateKeyAlgorithm) && !has(self.privateKeyAlgorithm) || has(oldSelf.privateKeyAlgorithm) && has(self.privateKeyAlgorithm)\",message=\"privateKeyAlgorithm may only be configured during creation\"\n181\t// +kubebuilder:validation:XValidation:rule=\"!has(oldSelf.privateKeySize) && !has(self.privateKeySize) || has(oldSelf.privateKeySize) && has(self.privateKeySize)\",message=\"privateKeySize may only be configured during creation\"\n182\t// +kubebuilder:validation:XValidation:rule=\"(!has(self.privateKeyAlgorithm) || self.privateKeyAlgorithm == 'RSA') ? (self.privateKeySize in [2048,4096,8192]) : (self.privateKeySize in [256,384])\",message=\"privateKeySize must match with configured privateKeyAlgorithm\"\n183\ttype IstiodTLSConfig struct {\n184\t\t// commonName is the common name to be set in the cert-manager.io Certificate created for istiod.\n185\t\t// The commonName will be of the form istiod.<istio_namespace>.svc when not set.\n186\t\t// This field can have a maximum of 64 characters.\n187\t\t// +kubebuilder:validation:MinLength:=0\n188\t\t// +kubebuilder:validation:MaxLength:=64\n189\t\t// +kubebuilder:example:=\"istiod.istio-system.svc\"\n190\t\t// +kubebuilder:validation:Optional\n191\t\t// +optional\n192\t\tCommonName string `json:\"commonName,omitempty\"`\n193\t\n194\t\t// trustDomain is the Istio cluster's trust domain, which will also be used for deriving the SPIFFE URI.\n195\t\t// This field can have a maximum of 63 characters.\n196\t\t// +kubebuilder:validation:MinLength:=1\n197\t\t// +kubebuilder:validation:MaxLength:=63\n198\t\t// +kubebuilder:validation:Required\n199\t\t// +required\n200\t\tTrustDomain string `json:\"trustDomain\"`\n201\t\n202\t\t// certificateDNSNames contains the additional DNS names to be added to the istiod certificate SAN.\n203\t\t// This field can have a maximum of 25 entries.\n204\t\t// +kubebuilder:validation:MinItems:=0\n205\t\t// +kubebuilder:validation:MaxItems:=25\n206\t\t// +kubebuilder:validation:items:MinLength:=1\n207\t\t// +kubebuilder:validation:items:MaxLength:=253\n208\t\t// +listType=set\n209\t\t// +kubebuilder:validation:Optional\n210\t\t// +optional\n211\t\tCertificateDNSNames []string `json:\"certificateDNSNames,omitempty\"`\n212\t\n213\t\t// certificateDuration is the validity period for the istio-csr and istiod certificates.\n214\t\t// +kubebuilder:default:=\"1h\"\n215\t\t// +kubebuilder:validation:Optional\n216\t\t// +optional\n217\t\tCertificateDuration *metav1.Duration `json:\"certificateDuration,omitempty\"`\n218\t\n219\t\t// certificateRenewBefore is the time before expiry to renew the istio-csr and istiod certificates.\n220\t\t// +kubebuilder:default:=\"30m\"\n221\t\t// +kubebuilder:validation:Optional\n222\t\t// +optional\n223\t\tCertificateRenewBefore *metav1.Duration `json:\"certificateRenewBefore,omitempty\"`\n224\t\n225\t\t// privateKeySize is the key size for the istio-csr and istiod certificates. Allowed values when privateKeyAlgorithm is RSA are 2048, 4096, 8192; and for ECDSA, they are 256, 384.\n226\t\t// This field is immutable once set.\n227\t\t// +kubebuilder:validation:Enum:=256;384;2048;4096;8192\n228\t\t// +kubebuilder:default:=2048\n229\t\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == 0 || self == oldSelf\",message=\"privateKeySize is immutable once set\"\n230\t\t// +kubebuilder:validation:Optional\n231\t\t// +optional\n232\t\tPrivateKeySize int32 `json:\"privateKeySize,omitempty\"`\n233\t\n234\t\t// privateKeyAlgorithm is the algorithm to use when generating private keys. Allowed values are RSA, and ECDSA.\n235\t\t// This field is immutable once set.\n236\t\t// +kubebuilder:default:=\"RSA\"\n237\t\t// +kubebuilder:validation:Enum:=\"RSA\";\"ECDSA\"\n238\t\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"privateKeyAlgorithm is immutable once set\"\n239\t\t// +kubebuilder:validation:Optional\n240\t\t// +optional\n241\t\tPrivateKeyAlgorithm string `json:\"privateKeyAlgorithm,omitempty\"`\n242\t\n243\t\t// MaxCertificateDuration is the maximum validity duration that can be requested for a certificate.\n244\t\t// +kubebuilder:default:=\"1h\"\n245\t\t// +kubebuilder:validation:Optional\n246\t\t// +optional\n247\t\tMaxCertificateDuration *metav1.Duration `json:\"maxCertificateDuration,omitempty\"`\n248\t}\n249\t\n250\t// ServerConfig is for configuring the server endpoint used by istio\n251\t// for obtaining the certificates.\n252\ttype ServerConfig struct {\n253\t\t// clusterID is the Istio cluster ID used to verify incoming CSRs.\n254\t\t// This field can have a maximum of 253 characters.\n255\t\t// +kubebuilder:default:=\"Kubernetes\"\n256\t\t// +kubebuilder:validation:MinLength:=0\n257\t\t// +kubebuilder:validation:MaxLength:=253\n258\t\t// +kubebuilder:validation:Optional\n259\t\t// +optional\n260\t\tClusterID string `json:\"clusterID,omitempty\"`\n261\t\n262\t\t// port to serve the istio-csr gRPC service.\n263\t\t// +kubebuilder:default:=443\n264\t\t// +kubebuilder:validation:Minimum:=1\n265\t\t// +kubebuilder:validation:Maximum:=65535\n266\t\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == 0 || self == oldSelf\",message=\"port is immutable once set\"\n267\t\t// +kubebuilder:validation:Optional\n268\t\t// +optional\n269\t\tPort int32 `json:\"port,omitempty\"`\n270\t}\n271\t\n272\t// IstioConfig is for configuring the istio specifics.\n273\ttype IstioConfig struct {\n274\t\t// revisions are the Istio revisions that are currently installed in the cluster.\n275\t\t// Changing this field will modify the DNS names that will be requested for the istiod certificate.\n276\t\t// This field can have a maximum of 25 entries.\n277\t\t// +listType=set\n278\t\t// +kubebuilder:default:={\"default\"}\n279\t\t// +kubebuilder:validation:MinItems=0\n280\t\t// +kubebuilder:validation:MaxItems=25\n281\t\t// +kubebuilder:validation:items:MinLength:=1\n282\t\t// +kubebuilder:validation:items:MaxLength:=63\n283\t\t// +kubebuilder:validation:Optional\n284\t\t// +optional\n285\t\tRevisions []string `json:\"revisions,omitempty\"`\n286\t\n287\t\t// namespace of the Istio control plane.\n288\t\t// This field can have a maximum of 63 characters.\n289\t\t// +kubebuilder:validation:XValidation:rule=\"self == oldSelf\",message=\"namespace is immutable once set\"\n290\t\t// +kubebuilder:validation:MinLength:=1\n291\t\t// +kubebuilder:validation:MaxLength:=63\n292\t\t// +kubebuilder:validation:Required\n293\t\t// +required\n294\t\tNamespace string `json:\"namespace\"`\n295\t}\n296\t\n297\t// ControllerConfig configures the controller for setting up defaults to\n298\t// enable the istio-csr agent.\n299\ttype ControllerConfig struct {\n300\t\t// labels to apply to all resources created for the istio-csr agent deployment.\n301\t\t// This field can have a maximum of 20 entries.\n302\t\t// +mapType=granular\n303\t\t// +kubebuilder:validation:MinProperties:=0\n304\t\t// +kubebuilder:validation:MaxProperties:=20\n305\t\t// +kubebuilder:validation:Optional\n306\t\t// +optional\n307\t\tLabels map[string]string `json:\"labels,omitempty\"`\n308\t}\n309\t\n310\t// IstioCSRStatus is the most recently observed status of the IstioCSR.\n311\ttype IstioCSRStatus struct {\n312\t\t// conditions holds information about the current state of the istio-csr agent deployment.\n313\t\tConditionalStatus `json:\",inline,omitempty\"`\n314\t\n315\t\t// istioCSRImage is the name of the image and the tag used for deploying istio-csr.\n316\t\tIstioCSRImage string `json:\"istioCSRImage,omitempty\"`\n317\t\n318\t\t// istioCSRGRPCEndpoint is the service endpoint of istio-csr, made available for users to configure in the istiod config to enable Istio to use istio-csr for certificate requests.\n319\t\tIstioCSRGRPCEndpoint string `json:\"istioCSRGRPCEndpoint,omitempty\"`\n320\t\n321\t\t// serviceAccount created by the controller for the istio-csr agent.\n322\t\tServiceAccount string `json:\"serviceAccount,omitempty\"`\n323\t\n324\t\t// clusterRole created by the controller for the istio-csr agent.\n325\t\tClusterRole string `json:\"clusterRole,omitempty\"`\n326\t\n327\t\t// clusterRoleBinding created by the controller for the istio-csr agent.\n328\t\tClusterRoleBinding string `json:\"clusterRoleBinding,omitempty\"`\n329\t}\n330\t"}]},"parent_tool_use_id":null,"session_id":"7761e1db-6892-412e-af40-5c732f6d271b","uuid":"8bc95c45-83ac-4408-84fb-b7579287fb7e","timestamp":"2026-07-20T16:55:51.643Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/api/operator/v1alpha1/istiocsr_types.go","content":"package v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\n\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/meta/v1\"\n)\n\nfunc init() {\n\tSchemeBuilder.Register(&IstioCSR{}, &IstioCSRList{})\n}\n\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n\n// IstioCSRList is a list of IstioCSR objects.\ntype IstioCSRList struct {\n\tmetav1.TypeMeta `json:\",inline\"`\n\n\t// metadata is the standard list's metadata.\n\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n\tmetav1.ListMeta `json:\"metadata\"`\n\n\tItems []IstioCSR `json:\"items\"`\n}\n\n// +genclient\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n// +kubebuilder:subresource:status\n// +kubebuilder:resource:path=istiocsrs,scope=Namespaced,categories={cert-manager-operator, istio-csr, istiocsr}\n// +kubebuilder:printcolumn:name=\"GRPC Endpoint\",type=\"string\",JSONPath=\".status.istioCSRGRPCEndpoint\"\n// +kubebuilder:printcolumn:name=\"Ready\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].status\"\n// +kubebuilder:printcolumn:name=\"Message\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].message\"\n// +kubebuilder:printcolumn:name=\"AGE\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n// +kubebuilder:metadata:labels={\"app.kubernetes.io/name=istiocsr\", \"app.kubernetes.io/part-of=cert-manager-operator\"}\n\n// IstioCSR describes the configuration and information about the managed istio-csr agent.\n// The name must be `default` to make IstioCSR a singleton that is, to allow only one instance of IstioCSR per namespace.\n//\n// When an IstioCSR is created, istio-csr agent is deployed in the IstioCSR-created namespace.\n//\n// +kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'default'\",message=\"istiocsr is a singleton, .metadata.name must be 'default'\"\n// +operator-sdk:csv:customresourcedefinitions:displayName=\"IstioCSR\"\ntype IstioCSR struct {\n\tmetav1.TypeMeta `json:\",inline\"`\n\n\t// metadata is the standard object's metadata.\n\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n\n\t// spec is the specification of the desired behavior of the IstioCSR.\n\t// +kubebuilder:validation:Required\n\t// +required\n\tSpec IstioCSRSpec `json:\"spec\"`\n\n\t// status is the most recently observed status of the IstioCSR.\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tStatus IstioCSRStatus `json:\"status,omitempty\"`\n}\n\n// IstioCSRSpec is the specification of the desired behavior of the IstioCSR.\ntype IstioCSRSpec struct {\n\t// istioCSRConfig configures the istio-csr agent's behavior.\n\t// +kubebuilder:validation:Required\n\t// +required\n\tIstioCSRConfig IstioCSRConfig `json:\"istioCSRConfig\"`\n\n\t// controllerConfig configures the controller for setting up defaults to enable the istio-csr agent.\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tControllerConfig *ControllerConfig `json:\"controllerConfig,omitempty\"`\n}\n\n// IstioCSRConfig configures the istio-csr agent's behavior.\ntype IstioCSRConfig struct {\n\t// logLevel supports a value range as per [Kubernetes logging guidelines](https://github.com/kubernetes/community/blob/master/contributors/devel/sig-instrumentation/logging.md#what-method-to-use).\n\t// +kubebuilder:default:=1\n\t// +kubebuilder:validation:Minimum:=1\n\t// +kubebuilder:validation:Maximum:=5\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tLogLevel int32 `json:\"logLevel,omitempty\"`\n\n\t// logFormat specifies the output format for istio-csr agent logging.\n\t// Supported log formats are text and json.\n\t// +kubebuilder:validation:Enum:=\"text\";\"json\"\n\t// +kubebuilder:default:=\"text\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tLogFormat string `json:\"logFormat,omitempty\"`\n\n\t// Istio-csr creates a ConfigMap named `istio-ca-root-cert` containing the root CA certificate, which the Istio data plane uses to verify server certificates. Its default behavior is to create and monitor ConfigMaps in all namespaces.\n\t// The istioDataPlaneNamespaceSelector restricts the namespaces where the ConfigMap is created by using label selectors, such as maistra.io/member-of=istio-system. This selector is also attached to all desired namespaces that are part of the data plane.\n\t// This field can have a maximum of 4096 characters.\n\t// +kubebuilder:example:=\"maistra.io/member-of=istio-system\"\n\t// +kubebuilder:validation:MinLength:=0\n\t// +kubebuilder:validation:MaxLength:=4096\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tIstioDataPlaneNamespaceSelector string `json:\"istioDataPlaneNamespaceSelector,omitempty\"`\n\n\t// certManager is for configuring cert-manager specifics.\n\t// +kubebuilder:validation:Required\n\t// +required\n\tCertManager CertManagerConfig `json:\"certManager\"`\n\n\t// istiodTLSConfig is for configuring istiod certificate specifics.\n\t// +kubebuilder:validation:Required\n\t// +required\n\tIstiodTLSConfig IstiodTLSConfig `json:\"istiodTLSConfig\"`\n\n\t// server is for configuring the server endpoint used by istio for obtaining the certificates.\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tServer *ServerConfig `json:\"server,omitempty\"`\n\n\t// istio is for configuring the istio specifics.\n\t// +kubebuilder:validation:Required\n\t// +required\n\tIstio IstioConfig `json:\"istio\"`\n\n\t// resources is for defining the resource requirements.\n\t// Cannot be updated.\n\t// ref: https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n\n\t// affinity is for setting scheduling affinity rules.\n\t// ref: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n\n\t// tolerations is for setting the pod tolerations.\n\t// This field can have a maximum of 50 entries.\n\t// ref: https://kubernetes.io/docs/concepts/scheduling-eviction/taint-and-toleration/\n\t// +listType=atomic\n\t// +kubebuilder:validation:MinItems:=0\n\t// +kubebuilder:validation:MaxItems:=50\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n\n\t// nodeSelector is for defining the scheduling criteria using node labels.\n\t// This field can have a maximum of 50 entries.\n\t// ref: https://kubernetes.io/docs/concepts/configuration/assign-pod-node/\n\t// +mapType=atomic\n\t// +kubebuilder:validation:MinProperties:=0\n\t// +kubebuilder:validation:MaxProperties:=50\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n}\n\n// CertManagerConfig is for configuring cert-manager specifics.\n// +kubebuilder:validation:XValidation:rule=\"!has(oldSelf.issuerRef) && !has(self.issuerRef) || has(oldSelf.issuerRef) && has(self.issuerRef)\",message=\"issuerRef may only be configured during creation\"\ntype CertManagerConfig struct {\n\t// issuerRef contains details of the referenced object used for obtaining certificates.\n\t// When `issuerRef.Kind` is `Issuer`, it must exist in the `.spec.istioCSRConfig.istio.namespace`.\n\t// This field is immutable once set.\n\t// +kubebuilder:validation:XValidation:rule=\"self == oldSelf\",message=\"issuerRef is immutable once set\"\n\t// +kubebuilder:validation:XValidation:rule=\"self.kind.lowerAscii() == 'issuer' || self.kind.lowerAscii() == 'clusterissuer'\",message=\"kind must be either 'Issuer' or 'ClusterIssuer'\"\n\t// +kubebuilder:validation:XValidation:rule=\"self.group.lowerAscii() == 'cert-manager.io'\",message=\"group must be 'cert-manager.io'\"\n\t// +kubebuilder:validation:Required\n\t// +required\n\tIssuerRef certmanagerv1.ObjectReference `json:\"issuerRef\"`\n\n\t// istioCACertificate when provided, the operator will use the CA certificate from the specified ConfigMap.\n\t// If empty, the operator will automatically extract the CA certificate from the Secret containing the istiod certificate obtained from cert-manager.\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tIstioCACertificate *ConfigMapReference `json:\"istioCACertificate,omitempty\"`\n}\n\n// IstiodTLSConfig is for configuring istiod certificate specifics.\n// +kubebuilder:validation:XValidation:rule=\"!has(oldSelf.privateKeyAlgorithm) && !has(self.privateKeyAlgorithm) || has(oldSelf.privateKeyAlgorithm) && has(self.privateKeyAlgorithm)\",message=\"privateKeyAlgorithm may only be configured during creation\"\n// +kubebuilder:validation:XValidation:rule=\"!has(oldSelf.privateKeySize) && !has(self.privateKeySize) || has(oldSelf.privateKeySize) && has(self.privateKeySize)\",message=\"privateKeySize may only be configured during creation\"\n// +kubebuilder:validation:XValidation:rule=\"(!has(self.privateKeyAlgorithm) || self.privateKeyAlgorithm == 'RSA') ? (self.privateKeySize in [2048,4096,8192]) : (self.privateKeySize in [256,384])\",message=\"privateKeySize must match with configured privateKeyAlgorithm\"\ntype IstiodTLSConfig struct {\n\t// commonName is the common name to be set in the cert-manager.io Certificate created for istiod.\n\t// The commonName will be of the form istiod.<istio_namespace>.svc when not set.\n\t// This field can have a maximum of 64 characters.\n\t// +kubebuilder:validation:MinLength:=0\n\t// +kubebuilder:validation:MaxLength:=64\n\t// +kubebuilder:example:=\"istiod.istio-system.svc\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tCommonName string `json:\"commonName,omitempty\"`\n\n\t// trustDomain is the Istio cluster's trust domain, which will also be used for deriving the SPIFFE URI.\n\t// This field can have a maximum of 63 characters.\n\t// +kubebuilder:validation:MinLength:=1\n\t// +kubebuilder:validation:MaxLength:=63\n\t// +kubebuilder:validation:Required\n\t// +required\n\tTrustDomain string `json:\"trustDomain\"`\n\n\t// certificateDNSNames contains the additional DNS names to be added to the istiod certificate SAN.\n\t// This field can have a maximum of 25 entries.\n\t// +kubebuilder:validation:MinItems:=0\n\t// +kubebuilder:validation:MaxItems:=25\n\t// +kubebuilder:validation:items:MinLength:=1\n\t// +kubebuilder:validation:items:MaxLength:=253\n\t// +listType=set\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tCertificateDNSNames []string `json:\"certificateDNSNames,omitempty\"`\n\n\t// certificateDuration is the validity period for the istio-csr and istiod certificates.\n\t// +kubebuilder:default:=\"1h\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tCertificateDuration *metav1.Duration `json:\"certificateDuration,omitempty\"`\n\n\t// certificateRenewBefore is the time before expiry to renew the istio-csr and istiod certificates.\n\t// +kubebuilder:default:=\"30m\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tCertificateRenewBefore *metav1.Duration `json:\"certificateRenewBefore,omitempty\"`\n\n\t// privateKeySize is the key size for the istio-csr and istiod certificates. Allowed values when privateKeyAlgorithm is RSA are 2048, 4096, 8192; and for ECDSA, they are 256, 384.\n\t// This field is immutable once set.\n\t// +kubebuilder:validation:Enum:=256;384;2048;4096;8192\n\t// +kubebuilder:default:=2048\n\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == 0 || self == oldSelf\",message=\"privateKeySize is immutable once set\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tPrivateKeySize int32 `json:\"privateKeySize,omitempty\"`\n\n\t// privateKeyAlgorithm is the algorithm to use when generating private keys. Allowed values are RSA, and ECDSA.\n\t// This field is immutable once set.\n\t// +kubebuilder:default:=\"RSA\"\n\t// +kubebuilder:validation:Enum:=\"RSA\";\"ECDSA\"\n\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"privateKeyAlgorithm is immutable once set\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tPrivateKeyAlgorithm string `json:\"privateKeyAlgorithm,omitempty\"`\n\n\t// MaxCertificateDuration is the maximum validity duration that can be requested for a certificate.\n\t// +kubebuilder:default:=\"1h\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tMaxCertificateDuration *metav1.Duration `json:\"maxCertificateDuration,omitempty\"`\n}\n\n// ServerConfig is for configuring the server endpoint used by istio\n// for obtaining the certificates.\ntype ServerConfig struct {\n\t// clusterID is the Istio cluster ID used to verify incoming CSRs.\n\t// This field can have a maximum of 253 characters.\n\t// +kubebuilder:default:=\"Kubernetes\"\n\t// +kubebuilder:validation:MinLength:=0\n\t// +kubebuilder:validation:MaxLength:=253\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tClusterID string `json:\"clusterID,omitempty\"`\n\n\t// port to serve the istio-csr gRPC service.\n\t// +kubebuilder:default:=443\n\t// +kubebuilder:validation:Minimum:=1\n\t// +kubebuilder:validation:Maximum:=65535\n\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == 0 || self == oldSelf\",message=\"port is immutable once set\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tPort int32 `json:\"port,omitempty\"`\n}\n\n// IstioConfig is for configuring the istio specifics.\ntype IstioConfig struct {\n\t// revisions are the Istio revisions that are currently installed in the cluster.\n\t// Changing this field will modify the DNS names that will be requested for the istiod certificate.\n\t// This field can have a maximum of 25 entries.\n\t// +listType=set\n\t// +kubebuilder:default:={\"default\"}\n\t// +kubebuilder:validation:MinItems=0\n\t// +kubebuilder:validation:MaxItems=25\n\t// +kubebuilder:validation:items:MinLength:=1\n\t// +kubebuilder:validation:items:MaxLength:=63\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tRevisions []string `json:\"revisions,omitempty\"`\n\n\t// namespace of the Istio control plane.\n\t// This field can have a maximum of 63 characters.\n\t// +kubebuilder:validation:XValidation:rule=\"self == oldSelf\",message=\"namespace is immutable once set\"\n\t// +kubebuilder:validation:MinLength:=1\n\t// +kubebuilder:validation:MaxLength:=63\n\t// +kubebuilder:validation:Required\n\t// +required\n\tNamespace string `json:\"namespace\"`\n}\n\n// ControllerConfig configures the controller for setting up defaults to\n// enable the istio-csr agent.\ntype ControllerConfig struct {\n\t// labels to apply to all resources created for the istio-csr agent deployment.\n\t// This field can have a maximum of 20 entries.\n\t// +mapType=granular\n\t// +kubebuilder:validation:MinProperties:=0\n\t// +kubebuilder:validation:MaxProperties:=20\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tLabels map[string]string `json:\"labels,omitempty\"`\n}\n\n// IstioCSRStatus is the most recently observed status of the IstioCSR.\ntype IstioCSRStatus struct {\n\t// conditions holds information about the current state of the istio-csr agent deployment.\n\tConditionalStatus `json:\",inline,omitempty\"`\n\n\t// istioCSRImage is the name of the image and the tag used for deploying istio-csr.\n\tIstioCSRImage string `json:\"istioCSRImage,omitempty\"`\n\n\t// istioCSRGRPCEndpoint is the service endpoint of istio-csr, made available for users to configure in the istiod config to enable Istio to use istio-csr for certificate requests.\n\tIstioCSRGRPCEndpoint string `json:\"istioCSRGRPCEndpoint,omitempty\"`\n\n\t// serviceAccount created by the controller for the istio-csr agent.\n\tServiceAccount string `json:\"serviceAccount,omitempty\"`\n\n\t// clusterRole created by the controller for the istio-csr agent.\n\tClusterRole string `json:\"clusterRole,omitempty\"`\n\n\t// clusterRoleBinding created by the controller for the istio-csr agent.\n\tClusterRoleBinding string `json:\"clusterRoleBinding,omitempty\"`\n}\n","numLines":330,"startLine":1,"totalLines":330}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_vrtx_01L1NYNGMaWxk1DCGRZzEtE7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_vrtx_01Ei5ud9Ga8LqXoH74373YVG","name":"Read","input":{"file_path":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/controller/istiocsr/deployments.go"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2100,"cache_creation_input_tokens":1121,"cache_read_input_tokens":33036,"cache_creation":{"ephemeral_5m_input_tokens":1121,"ephemeral_1h_input_tokens":0},"output_tokens":25},"context_management":null},"parent_tool_use_id":null,"session_id":"7761e1db-6892-412e-af40-5c732f6d271b","uuid":"dcee1adc-6597-4c80-af43-96502230d450","timestamp":"2026-07-20T16:55:52.535Z","request_id":"req_vrtx_011CdDfJ4J4VRh8LEDPyjav6"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_vrtx_01L1NYNGMaWxk1DCGRZzEtE7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_vrtx_01HT7F7GXWj7oFuHPPzaVeEM","name":"Read","input":{"file_path":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/agentic/SECURITY.md"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2100,"cache_creation_input_tokens":1121,"cache_read_input_tokens":33036,"cache_creation":{"ephemeral_5m_input_tokens":1121,"ephemeral_1h_input_tokens":0},"output_tokens":25},"context_management":null},"parent_tool_use_id":null,"session_id":"7761e1db-6892-412e-af40-5c732f6d271b","uuid":"0741de09-c4d7-4caf-bf00-3192e836ebdf","timestamp":"2026-07-20T16:55:52.888Z","request_id":"req_vrtx_011CdDfJ4J4VRh8LEDPyjav6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01HT7F7GXWj7oFuHPPzaVeEM","type":"tool_result","content":"1\t# Security\n2\t\n3\t## CEL Immutability Rules\n4\t\n5\tThe operator uses `x-kubernetes-validations` (CEL expressions on CRD fields) to enforce immutability on security-sensitive fields. Once set, these fields cannot be changed without deleting and recreating the CR. The rules are defined in `api/operator/v1alpha1/istiocsr_types.go` and `trustmanager_types.go`.\n6\t\n7\t### IstioCSR immutable fields\n8\t\n9\t**`issuerRef` (inside `CertManagerConfig`)**\n10\t\n11\t```yaml\n12\t# kubebuilder:validation:XValidation:rule=\"self == oldSelf\",message=\"issuerRef is immutable once set\"\n13\t# kubebuilder:validation:XValidation:rule=\"!has(oldSelf.issuerRef) && !has(self.issuerRef) || has(oldSelf.issuerRef) && has(self.issuerRef)\",message=\"issuerRef may only be configured during creation\"\n14\t```\n15\t\n16\tThe presence rule prevents a user from removing `issuerRef` after it has been set. The equality rule prevents changing the issuer name, kind, or group in place.\n17\t\n18\tAdditional static validations on `issuerRef` enforce that `kind` must be `Issuer` or `ClusterIssuer` and `group` must be `cert-manager.io`. These are checked at admission time rather than at runtime.\n19\t\n20\t**`privateKeyAlgorithm` (inside `IstiodTLSConfig`)**\n21\t\n22\t```yaml\n23\t# kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"privateKeyAlgorithm is immutable once set\"\n24\t# kubebuilder:validation:XValidation:rule=\"!has(oldSelf.privateKeyAlgorithm) && !has(self.privateKeyAlgorithm) || has(oldSelf.privateKeyAlgorithm) && has(self.privateKeyAlgorithm)\",message=\"privateKeyAlgorithm may only be configured during creation\"\n25\t```\n26\t\n27\tAllowed values are `RSA` and `ECDSA`. The type-level CEL rule also cross-validates that key size is compatible with the algorithm: RSA requires 2048, 4096, or 8192; ECDSA requires 256 or 384.\n28\t\n29\t**`privateKeySize` (inside `IstiodTLSConfig`)**\n30\t\n31\t```yaml\n32\t# kubebuilder:validation:XValidation:rule=\"oldSelf == 0 || self == oldSelf\",message=\"privateKeySize is immutable once set\"\n33\t# kubebuilder:validation:XValidation:rule=\"!has(oldSelf.privateKeySize) && !has(self.privateKeySize) || has(oldSelf.privateKeySize) && has(self.privateKeySize)\",message=\"privateKeySize may only be configured during creation\"\n34\t```\n35\t\n36\t**`namespace` (inside `IstioConfig`)**\n37\t\n38\t```yaml\n39\t# kubebuilder:validation:XValidation:rule=\"self == oldSelf\",message=\"namespace is immutable once set\"\n40\t```\n41\t\n42\tThe Istio control plane namespace is part of certificate SAN generation and RBAC scoping. It cannot move without invalidating all issued workload certificates.\n43\t\n44\t**`port` (inside `ServerConfig`)**\n45\t\n46\t```yaml\n47\t# kubebuilder:validation:XValidation:rule=\"oldSelf == 0 || self == oldSelf\",message=\"port is immutable once set\"\n48\t```\n49\t\n50\tThe gRPC server port is baked into the Service resource and the Istio mesh configuration. Changing it mid-life would break all existing mesh connections.\n51\t\n52\t### TrustManager immutable fields\n53\t\n54\t**`trustNamespace` (inside `TrustManagerConfig`)**\n55\t\n56\t```yaml\n57\t# kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"trustNamespace is immutable once set\"\n58\t```\n59\t\n60\tThe trust namespace determines where trust-manager looks for CA bundle sources (ConfigMaps and Secrets). RBAC resources (Role, RoleBinding) are scoped to this namespace. Changing the namespace mid-life would leave orphaned RBAC resources in the old namespace and deny trust-manager access to sources in the new namespace without a controlled migration.\n61\t\n62\t### CertManager immutable fields\n63\t\n64\t**`defaultNetworkPolicy` (inside `CertManagerSpec`)**\n65\t\n66\t```yaml\n67\t# kubebuilder:validation:XValidation:rule=\"oldSelf != 'true' || self == 'true'\",message=\"defaultNetworkPolicy cannot be changed from 'true' to 'false' once set\"\n68\t```\n69\t\n70\tNetwork policies cannot be disabled once enabled. This prevents accidental security degradation of the cert-manager component network boundary.\n71\t\n72\t**`networkPolicies` entries**\n73\t\n74\t```yaml\n75\t# kubebuilder:validation:XValidation:rule=\"oldSelf.all(op, self.exists(p, p.name == op.name && p.componentName == op.componentName))\",message=\"name and componentName fields in networkPolicies are immutable\"\n76\t```\n77\t\n78\tExisting network policy entries (identified by `name` + `componentName`) cannot be removed or renamed once `defaultNetworkPolicy` is `true`.\n79\t\n80\t### tlsMinVersion pattern\n81\t\n82\tThe operator does not expose `tlsMinVersion` as a CRD field. Instead, it derives TLS settings from the OpenShift cluster-level API server TLS profile (`apiserver.config.openshift.io/cluster`) and translates them into operand flags at reconcile time via `pkg/tlsprofile/tlsprofile.go`. The effective minimum TLS version is passed as `--tls-min-version` to cert-manager-webhook and `--metrics-tls-min-version` to all three core operands. When the minimum version is TLS 1.3, cipher suite flags are automatically suppressed (Go does not honor cipher configuration for TLS 1.3).\n83\t\n84\t---\n85\t\n86\t## Why Security Fields Are Immutable\n87\t\n88\tChanging a CA issuer or key algorithm mid-flight would invalidate the trust chain for all certificates already issued through the operator. Concretely:\n89\t\n90\t- **`issuerRef` on IstioCSR**: The issuer's CA certificate is extracted and distributed to the entire Istio data plane as the root of trust. All mesh workload certificates are chained to it. Switching issuers would break mutual TLS verification for every pod in the mesh until certificates cycled, causing silent connectivity failures.\n91\t- **`privateKeyAlgorithm` / `privateKeySize` on IstioCSR**: The key algorithm determines the certificate profile of the istiod serving certificate and all workload certificates. Changing from RSA-2048 to ECDSA-256 mid-life mixes certificate types that may not be compatible with older Istio control plane versions.\n92\t- **`namespace` on IstioCSR**: Certificate SANs are derived from the namespace (e.g., `istiod.istio-system.svc`). A namespace change would require re-issuing the istiod certificate and all in-flight CSRs with new SANs.\n93\t- **`trustNamespace` on TrustManager**: The RBAC Role granting trust-manager read access to CA sources is bound in this namespace. Changing it leaves trust-manager without permission to read from the new namespace until a full re-reconcile including RBAC teardown and recreation in the new namespace.\n94\t\n95\tThe CEL admission webhook enforces these constraints before any reconciliation runs, so the controller never needs to detect or roll back an invalid mid-flight change.\n96\t\n97\t---\n98\t\n99\t## Singleton Enforcement\n100\t\n101\tAll three operand CRDs enforce that only one instance of each may exist per applicable scope.\n102\t\n103\t### TrustManager (cluster-scoped)\n104\t\n105\tTrustManager is a cluster-scoped CRD. The CEL rule on the type enforces the name:\n106\t\n107\t```yaml\n108\t# kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'cluster'\",message=\"TrustManager is a singleton, .metadata.name must be 'cluster'\"\n109\t```\n110\t\n111\tBecause the resource is cluster-scoped, there is exactly one namespace-independent slot at name `cluster`. Any attempt to create a second TrustManager (impossible given Kubernetes uniqueness for cluster-scoped resources) or one named anything other than `cluster` is rejected at admission.\n112\t\n113\t### IstioCSR (namespace-scoped, singleton-per-namespace)\n114\t\n115\tIstioCSR is namespace-scoped. The CEL rule enforces the instance name within each namespace:\n116\t\n117\t```yaml\n118\t# kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'default'\",message=\"istiocsr is a singleton, .metadata.name must be 'default'\"\n119\t```\n120\t\n121\tThis means only one IstioCSR named `default` can exist per namespace. The controller also has a runtime guard `disallowMultipleIstioCSRInstances()` that emits a `MultiIstioCSRInstance` warning event and skips reconciliation if it detects more than one IstioCSR in the namespace (e.g. if an older version of the CRD predating the CEL rule permitted duplicates).\n122\t\n123\t### CertManager (cluster-scoped)\n124\t\n125\tThe CertManager CRD (which wraps cert-manager core) is cluster-scoped but does not have a CEL name enforcement rule in its type definition. Singleton behavior relies on convention: operators and documentation require the instance be named `cluster`. The cluster-scoped nature of the resource prevents parallel instances at the same name, but a user could create a second instance with a different name — however the cert-manager-operator controller ignores any CertManager resource not named `cluster`.\n126\t\n127\t---\n128\t\n129\t## Image Source Policy\n130\t\n131\tContainer images for all operands are sourced exclusively from **`RELATED_IMAGE_*` environment variables** on the operator pod. Images are never hardcoded in the CRD spec or taken from user input.\n132\t\n133\t### Environment variable map\n134\t\n135\t| Environment variable | Operand |\n136\t|---------------------|---------|\n137\t| `RELATED_IMAGE_CERT_MANAGER_CONTROLLER` | cert-manager controller |\n138\t| `RELATED_IMAGE_CERT_MANAGER_WEBHOOK` | cert-manager webhook |\n139\t| `RELATED_IMAGE_CERT_MANAGER_CA_INJECTOR` | cert-manager cainjector |\n140\t| `RELATED_IMAGE_CERT_MANAGER_ACMESOLVER` | cert-manager ACME solver |\n141\t| `RELATED_IMAGE_CERT_MANAGER_TRUST_MANAGER` | trust-manager |\n142\t| `RELATED_IMAGE_CERT_MANAGER_ISTIOCSR` | istio-csr agent |\n143\t\n144\tThese are set by the Operator Lifecycle Manager (OLM) from the operator bundle's `relatedImages` manifest, which in turn is populated from the release image digest list at build time.\n145\t\n146\t### Why this pattern prevents supply chain attacks\n147\t\n148\t- Image references in `RELATED_IMAGE_*` variables are digest-pinned in the OLM bundle, not tag-based. The image pulled at runtime is the exact sha256 that was validated and shipped with the operator version.\n149\t- No user-facing CRD field accepts an image override for operands. A compromised CRD CR cannot redirect an operand to an arbitrary registry.\n150\t- The operator raises an `IrrecoverableError` (blocking reconciliation) if the environment variable is empty or missing, making the missing-image state immediately visible in the CR's `Degraded` condition rather than silently pulling a wrong image.\n151\t\n152\tThe cert-manager controller's `certManagerImage()` function (`pkg/controller/certmanager/related_images.go`) uses the default image from the bindata manifest as a fallback only when no override variable is set — in practice, OLM always sets these variables in managed deployments.\n153\t\n154\t---\n155\t\n156\t## RBAC\n157\t\n158\tThe operator creates RBAC resources for each operand it manages. The operator's own permissions are declared via `+kubebuilder:rbac` markers on the reconciler types and compiled into the ClusterRole at operator build time.\n159\t\n160\t### Operator's own required permissions\n161\t\n162\tFrom the `+kubebuilder:rbac` markers on `pkg/controller/trustmanager/controller.go`:\n163\t\n164\t| Resource | Verbs | Purpose |\n165\t|----------|-------|---------|\n166\t| `trustmanagers`, `trustmanagers/status`, `trustmanagers/finalizers` | get, list, watch, update, patch | Manage the TrustManager CR lifecycle |\n167\t| `namespaces` | get, list, watch | Validate that `trustNamespace` exists before reconciling |\n168\t| `configmaps` | get, list, watch, create, update, patch | Manage CA package ConfigMap and watch CNO-injected CA bundle |\n169\t| `serviceaccounts`, `services` | get, list, watch, create, update, patch | Create operand service account and services |\n170\t| `deployments` | get, list, watch, create, update, patch | Manage trust-manager Deployment |\n171\t| `clusterroles`, `clusterrolebindings`, `roles`, `rolebindings` | get, list, watch, create, update, patch | Manage trust-manager operand RBAC |\n172\t| `certificates`, `issuers` (cert-manager.io) | get, list, watch, create, update, patch | Manage TLS certificate for trust-manager webhook |\n173\t| `validatingwebhookconfigurations` | get, list, watch, create, update, patch | Manage trust-manager's admission webhook |\n174\t| `bundles`, `bundles/finalizers`, `bundles/status` (trust.cert-manager.io) | get, list, watch; update; patch | Observe and update trust-manager Bundle resources |\n175\t\n176\tFrom `pkg/controller/istiocsr/controller.go`:\n177\t\n178\t| Resource | Verbs | Purpose |\n179\t|----------|-------|---------|\n180\t| `istiocsrs`, `istiocsrs/status`, `istiocsrs/finalizers` | get, list, watch, update, patch | Manage the IstioCSR CR lifecycle |\n181\t| `networkpolicies` | get, list, watch, create, update, patch, delete | Manage network isolation for istio-csr agent |\n182\t\n183\t### Trust-manager operand RBAC (created by the operator)\n184\t\n185\tThe operator creates the following RBAC resources for the trust-manager pod:\n186\t\n187\t- **ClusterRole `trust-manager`**: Read access to `bundles` cluster-wide; read/write to `configmaps` for distributing trust bundles across namespaces. When `secretTargets.policy=Custom`, the ClusterRole is extended with cluster-wide Secret read access and name-scoped Secret write access for the listed `authorizedSecrets`.\n188\t- **ClusterRoleBinding `trust-manager`**: Binds the ClusterRole to the trust-manager ServiceAccount in the `cert-manager` namespace.\n189\t- **Role `trust-manager`** (in `trustNamespace`): Read access to ConfigMaps and Secrets in the trust source namespace.\n190\t- **RoleBinding `trust-manager`** (in `trustNamespace`): Binds the namespace-scoped role.\n191\t- **Role / RoleBinding `trust-manager:leaderelection`** (in `cert-manager`): Lease management for leader election.\n192\t\n193\tThe use of `ForceOwnership` in Server-Side Apply (`client.ForceOwnership`) ensures the operator's field manager wins over any manual edits to these resources, preventing configuration drift.\n194\t\n195\t---\n196\t\n197\t## The `validateDeploymentManifest` Guard\n198\t\n199\tBefore the deployment mutation pipeline runs, the operator calls `validateDeploymentManifest()` (`pkg/controller/trustmanager/deployments.go`) to assert that the bindata-embedded YAML manifest contains exactly the structure the mutation helpers expect.\n200\t\n201\t```go\n202\tfunc validateDeploymentManifest(deployment *appsv1.Deployment) error {\n203\t    hasContainer := false\n204\t    for _, c := range deployment.Spec.Template.Spec.Containers {\n205\t        if c.Name == trustManagerContainerName {\n206\t            hasContainer = true\n207\t            break\n208\t        }\n209\t    }\n210\t    if !hasContainer {\n211\t        return fmt.Errorf(\"deployment manifest missing required container %q\", trustManagerContainerName)\n212\t    }\n213\t\n214\t    hasVolume := false\n215\t    for _, v := range deployment.Spec.Template.Spec.Volumes {\n216\t        if v.Name == tlsVolumeName && v.Secret != nil {\n217\t            hasVolume = true\n218\t            break\n219\t        }\n220\t    }\n221\t    if !hasVolume {\n222\t        return fmt.Errorf(\"deployment manifest missing required secret volume %q\", tlsVolumeName)\n223\t    }\n224\t\n225\t    return nil\n226\t}\n227\t```\n228\t\n229\tThe guard checks:\n230\t1. A container named `trust-manager` exists in the pod spec.\n231\t2. A volume named `tls` backed by a Secret exists in the pod spec.\n232\t\n233\tIf either check fails, the function returns an error that is wrapped as an `IrrecoverableError`, setting `Degraded=True` and halting all further reconciliation without attempting to patch the deployment. This prevents a partially mutated deployment from being applied with stale defaults when a bindata upgrade has introduced a structural change that the operator code has not yet accounted for.\n234\t\n235\tThe guard is defensive — it protects against the scenario where a developer adds a new mutation helper that targets a container or volume by name, but the bindata manifest has not been updated to include that target. Without the guard, the helper would silently no-op, resulting in a deployment that appears reconciled but is missing the intended configuration change.\n236\t"}]},"parent_tool_use_id":null,"session_id":"7761e1db-6892-412e-af40-5c732f6d271b","uuid":"43ee16c6-df2d-4f2f-85f3-a78a7156cf4f","timestamp":"2026-07-20T16:55:52.896Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/agentic/SECURITY.md","content":"# Security\n\n## CEL Immutability Rules\n\nThe operator uses `x-kubernetes-validations` (CEL expressions on CRD fields) to enforce immutability on security-sensitive fields. Once set, these fields cannot be changed without deleting and recreating the CR. The rules are defined in `api/operator/v1alpha1/istiocsr_types.go` and `trustmanager_types.go`.\n\n### IstioCSR immutable fields\n\n**`issuerRef` (inside `CertManagerConfig`)**\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"self == oldSelf\",message=\"issuerRef is immutable once set\"\n# kubebuilder:validation:XValidation:rule=\"!has(oldSelf.issuerRef) && !has(self.issuerRef) || has(oldSelf.issuerRef) && has(self.issuerRef)\",message=\"issuerRef may only be configured during creation\"\n```\n\nThe presence rule prevents a user from removing `issuerRef` after it has been set. The equality rule prevents changing the issuer name, kind, or group in place.\n\nAdditional static validations on `issuerRef` enforce that `kind` must be `Issuer` or `ClusterIssuer` and `group` must be `cert-manager.io`. These are checked at admission time rather than at runtime.\n\n**`privateKeyAlgorithm` (inside `IstiodTLSConfig`)**\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"privateKeyAlgorithm is immutable once set\"\n# kubebuilder:validation:XValidation:rule=\"!has(oldSelf.privateKeyAlgorithm) && !has(self.privateKeyAlgorithm) || has(oldSelf.privateKeyAlgorithm) && has(self.privateKeyAlgorithm)\",message=\"privateKeyAlgorithm may only be configured during creation\"\n```\n\nAllowed values are `RSA` and `ECDSA`. The type-level CEL rule also cross-validates that key size is compatible with the algorithm: RSA requires 2048, 4096, or 8192; ECDSA requires 256 or 384.\n\n**`privateKeySize` (inside `IstiodTLSConfig`)**\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"oldSelf == 0 || self == oldSelf\",message=\"privateKeySize is immutable once set\"\n# kubebuilder:validation:XValidation:rule=\"!has(oldSelf.privateKeySize) && !has(self.privateKeySize) || has(oldSelf.privateKeySize) && has(self.privateKeySize)\",message=\"privateKeySize may only be configured during creation\"\n```\n\n**`namespace` (inside `IstioConfig`)**\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"self == oldSelf\",message=\"namespace is immutable once set\"\n```\n\nThe Istio control plane namespace is part of certificate SAN generation and RBAC scoping. It cannot move without invalidating all issued workload certificates.\n\n**`port` (inside `ServerConfig`)**\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"oldSelf == 0 || self == oldSelf\",message=\"port is immutable once set\"\n```\n\nThe gRPC server port is baked into the Service resource and the Istio mesh configuration. Changing it mid-life would break all existing mesh connections.\n\n### TrustManager immutable fields\n\n**`trustNamespace` (inside `TrustManagerConfig`)**\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"trustNamespace is immutable once set\"\n```\n\nThe trust namespace determines where trust-manager looks for CA bundle sources (ConfigMaps and Secrets). RBAC resources (Role, RoleBinding) are scoped to this namespace. Changing the namespace mid-life would leave orphaned RBAC resources in the old namespace and deny trust-manager access to sources in the new namespace without a controlled migration.\n\n### CertManager immutable fields\n\n**`defaultNetworkPolicy` (inside `CertManagerSpec`)**\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"oldSelf != 'true' || self == 'true'\",message=\"defaultNetworkPolicy cannot be changed from 'true' to 'false' once set\"\n```\n\nNetwork policies cannot be disabled once enabled. This prevents accidental security degradation of the cert-manager component network boundary.\n\n**`networkPolicies` entries**\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"oldSelf.all(op, self.exists(p, p.name == op.name && p.componentName == op.componentName))\",message=\"name and componentName fields in networkPolicies are immutable\"\n```\n\nExisting network policy entries (identified by `name` + `componentName`) cannot be removed or renamed once `defaultNetworkPolicy` is `true`.\n\n### tlsMinVersion pattern\n\nThe operator does not expose `tlsMinVersion` as a CRD field. Instead, it derives TLS settings from the OpenShift cluster-level API server TLS profile (`apiserver.config.openshift.io/cluster`) and translates them into operand flags at reconcile time via `pkg/tlsprofile/tlsprofile.go`. The effective minimum TLS version is passed as `--tls-min-version` to cert-manager-webhook and `--metrics-tls-min-version` to all three core operands. When the minimum version is TLS 1.3, cipher suite flags are automatically suppressed (Go does not honor cipher configuration for TLS 1.3).\n\n---\n\n## Why Security Fields Are Immutable\n\nChanging a CA issuer or key algorithm mid-flight would invalidate the trust chain for all certificates already issued through the operator. Concretely:\n\n- **`issuerRef` on IstioCSR**: The issuer's CA certificate is extracted and distributed to the entire Istio data plane as the root of trust. All mesh workload certificates are chained to it. Switching issuers would break mutual TLS verification for every pod in the mesh until certificates cycled, causing silent connectivity failures.\n- **`privateKeyAlgorithm` / `privateKeySize` on IstioCSR**: The key algorithm determines the certificate profile of the istiod serving certificate and all workload certificates. Changing from RSA-2048 to ECDSA-256 mid-life mixes certificate types that may not be compatible with older Istio control plane versions.\n- **`namespace` on IstioCSR**: Certificate SANs are derived from the namespace (e.g., `istiod.istio-system.svc`). A namespace change would require re-issuing the istiod certificate and all in-flight CSRs with new SANs.\n- **`trustNamespace` on TrustManager**: The RBAC Role granting trust-manager read access to CA sources is bound in this namespace. Changing it leaves trust-manager without permission to read from the new namespace until a full re-reconcile including RBAC teardown and recreation in the new namespace.\n\nThe CEL admission webhook enforces these constraints before any reconciliation runs, so the controller never needs to detect or roll back an invalid mid-flight change.\n\n---\n\n## Singleton Enforcement\n\nAll three operand CRDs enforce that only one instance of each may exist per applicable scope.\n\n### TrustManager (cluster-scoped)\n\nTrustManager is a cluster-scoped CRD. The CEL rule on the type enforces the name:\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'cluster'\",message=\"TrustManager is a singleton, .metadata.name must be 'cluster'\"\n```\n\nBecause the resource is cluster-scoped, there is exactly one namespace-independent slot at name `cluster`. Any attempt to create a second TrustManager (impossible given Kubernetes uniqueness for cluster-scoped resources) or one named anything other than `cluster` is rejected at admission.\n\n### IstioCSR (namespace-scoped, singleton-per-namespace)\n\nIstioCSR is namespace-scoped. The CEL rule enforces the instance name within each namespace:\n\n```yaml\n# kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'default'\",message=\"istiocsr is a singleton, .metadata.name must be 'default'\"\n```\n\nThis means only one IstioCSR named `default` can exist per namespace. The controller also has a runtime guard `disallowMultipleIstioCSRInstances()` that emits a `MultiIstioCSRInstance` warning event and skips reconciliation if it detects more than one IstioCSR in the namespace (e.g. if an older version of the CRD predating the CEL rule permitted duplicates).\n\n### CertManager (cluster-scoped)\n\nThe CertManager CRD (which wraps cert-manager core) is cluster-scoped but does not have a CEL name enforcement rule in its type definition. Singleton behavior relies on convention: operators and documentation require the instance be named `cluster`. The cluster-scoped nature of the resource prevents parallel instances at the same name, but a user could create a second instance with a different name — however the cert-manager-operator controller ignores any CertManager resource not named `cluster`.\n\n---\n\n## Image Source Policy\n\nContainer images for all operands are sourced exclusively from **`RELATED_IMAGE_*` environment variables** on the operator pod. Images are never hardcoded in the CRD spec or taken from user input.\n\n### Environment variable map\n\n| Environment variable | Operand |\n|---------------------|---------|\n| `RELATED_IMAGE_CERT_MANAGER_CONTROLLER` | cert-manager controller |\n| `RELATED_IMAGE_CERT_MANAGER_WEBHOOK` | cert-manager webhook |\n| `RELATED_IMAGE_CERT_MANAGER_CA_INJECTOR` | cert-manager cainjector |\n| `RELATED_IMAGE_CERT_MANAGER_ACMESOLVER` | cert-manager ACME solver |\n| `RELATED_IMAGE_CERT_MANAGER_TRUST_MANAGER` | trust-manager |\n| `RELATED_IMAGE_CERT_MANAGER_ISTIOCSR` | istio-csr agent |\n\nThese are set by the Operator Lifecycle Manager (OLM) from the operator bundle's `relatedImages` manifest, which in turn is populated from the release image digest list at build time.\n\n### Why this pattern prevents supply chain attacks\n\n- Image references in `RELATED_IMAGE_*` variables are digest-pinned in the OLM bundle, not tag-based. The image pulled at runtime is the exact sha256 that was validated and shipped with the operator version.\n- No user-facing CRD field accepts an image override for operands. A compromised CRD CR cannot redirect an operand to an arbitrary registry.\n- The operator raises an `IrrecoverableError` (blocking reconciliation) if the environment variable is empty or missing, making the missing-image state immediately visible in the CR's `Degraded` condition rather than silently pulling a wrong image.\n\nThe cert-manager controller's `certManagerImage()` function (`pkg/controller/certmanager/related_images.go`) uses the default image from the bindata manifest as a fallback only when no override variable is set — in practice, OLM always sets these variables in managed deployments.\n\n---\n\n## RBAC\n\nThe operator creates RBAC resources for each operand it manages. The operator's own permissions are declared via `+kubebuilder:rbac` markers on the reconciler types and compiled into the ClusterRole at operator build time.\n\n### Operator's own required permissions\n\nFrom the `+kubebuilder:rbac` markers on `pkg/controller/trustmanager/controller.go`:\n\n| Resource | Verbs | Purpose |\n|----------|-------|---------|\n| `trustmanagers`, `trustmanagers/status`, `trustmanagers/finalizers` | get, list, watch, update, patch | Manage the TrustManager CR lifecycle |\n| `namespaces` | get, list, watch | Validate that `trustNamespace` exists before reconciling |\n| `configmaps` | get, list, watch, create, update, patch | Manage CA package ConfigMap and watch CNO-injected CA bundle |\n| `serviceaccounts`, `services` | get, list, watch, create, update, patch | Create operand service account and services |\n| `deployments` | get, list, watch, create, update, patch | Manage trust-manager Deployment |\n| `clusterroles`, `clusterrolebindings`, `roles`, `rolebindings` | get, list, watch, create, update, patch | Manage trust-manager operand RBAC |\n| `certificates`, `issuers` (cert-manager.io) | get, list, watch, create, update, patch | Manage TLS certificate for trust-manager webhook |\n| `validatingwebhookconfigurations` | get, list, watch, create, update, patch | Manage trust-manager's admission webhook |\n| `bundles`, `bundles/finalizers`, `bundles/status` (trust.cert-manager.io) | get, list, watch; update; patch | Observe and update trust-manager Bundle resources |\n\nFrom `pkg/controller/istiocsr/controller.go`:\n\n| Resource | Verbs | Purpose |\n|----------|-------|---------|\n| `istiocsrs`, `istiocsrs/status`, `istiocsrs/finalizers` | get, list, watch, update, patch | Manage the IstioCSR CR lifecycle |\n| `networkpolicies` | get, list, watch, create, update, patch, delete | Manage network isolation for istio-csr agent |\n\n### Trust-manager operand RBAC (created by the operator)\n\nThe operator creates the following RBAC resources for the trust-manager pod:\n\n- **ClusterRole `trust-manager`**: Read access to `bundles` cluster-wide; read/write to `configmaps` for distributing trust bundles across namespaces. When `secretTargets.policy=Custom`, the ClusterRole is extended with cluster-wide Secret read access and name-scoped Secret write access for the listed `authorizedSecrets`.\n- **ClusterRoleBinding `trust-manager`**: Binds the ClusterRole to the trust-manager ServiceAccount in the `cert-manager` namespace.\n- **Role `trust-manager`** (in `trustNamespace`): Read access to ConfigMaps and Secrets in the trust source namespace.\n- **RoleBinding `trust-manager`** (in `trustNamespace`): Binds the namespace-scoped role.\n- **Role / RoleBinding `trust-manager:leaderelection`** (in `cert-manager`): Lease management for leader election.\n\nThe use of `ForceOwnership` in Server-Side Apply (`client.ForceOwnership`) ensures the operator's field manager wins over any manual edits to these resources, preventing configuration drift.\n\n---\n\n## The `validateDeploymentManifest` Guard\n\nBefore the deployment mutation pipeline runs, the operator calls `validateDeploymentManifest()` (`pkg/controller/trustmanager/deployments.go`) to assert that the bindata-embedded YAML manifest contains exactly the structure the mutation helpers expect.\n\n```go\nfunc validateDeploymentManifest(deployment *appsv1.Deployment) error {\n    hasContainer := false\n    for _, c := range deployment.Spec.Template.Spec.Containers {\n        if c.Name == trustManagerContainerName {\n            hasContainer = true\n            break\n        }\n    }\n    if !hasContainer {\n        return fmt.Errorf(\"deployment manifest missing required container %q\", trustManagerContainerName)\n    }\n\n    hasVolume := false\n    for _, v := range deployment.Spec.Template.Spec.Volumes {\n        if v.Name == tlsVolumeName && v.Secret != nil {\n            hasVolume = true\n            break\n        }\n    }\n    if !hasVolume {\n        return fmt.Errorf(\"deployment manifest missing required secret volume %q\", tlsVolumeName)\n    }\n\n    return nil\n}\n```\n\nThe guard checks:\n1. A container named `trust-manager` exists in the pod spec.\n2. A volume named `tls` backed by a Secret exists in the pod spec.\n\nIf either check fails, the function returns an error that is wrapped as an `IrrecoverableError`, setting `Degraded=True` and halting all further reconciliation without attempting to patch the deployment. This prevents a partially mutated deployment from being applied with stale defaults when a bindata upgrade has introduced a structural change that the operator code has not yet accounted for.\n\nThe guard is defensive — it protects against the scenario where a developer adds a new mutation helper that targets a container or volume by name, but the bindata manifest has not been updated to include that target. Without the guard, the helper would silently no-op, resulting in a deployment that appears reconciled but is missing the intended configuration change.\n","numLines":236,"startLine":1,"totalLines":236}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01Ei5ud9Ga8LqXoH74373YVG","type":"tool_result","content":"1\tpackage istiocsr\n2\t\n3\timport (\n4\t\t\"crypto/x509\"\n5\t\t\"encoding/pem\"\n6\t\t\"fmt\"\n7\t\t\"os\"\n8\t\t\"reflect\"\n9\t\t\"strings\"\n10\t\n11\t\tappsv1 \"k8s.io/api/apps/v1\"\n12\t\tcorev1 \"k8s.io/api/core/v1\"\n13\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n14\t\t\"k8s.io/apimachinery/pkg/types\"\n15\t\t\"k8s.io/apimachinery/pkg/util/validation/field\"\n16\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n17\t\n18\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n19\t\n20\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n21\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n22\t\t\"github.com/openshift/cert-manager-operator/pkg/operator/assets\"\n23\t)\n24\t\n25\tconst (\n26\t\tcaVolumeMountPath = \"/var/run/configmaps/istio-csr\"\n27\t)\n28\t\n29\tvar errInvalidIssuerRefConfig = fmt.Errorf(\"invalid issuerRef config\")\n30\t\n31\tfunc (r *Reconciler) createOrApplyDeployments(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, istioCSRCreateRecon bool) error {\n32\t\tdesired, err := r.getDeploymentObject(istiocsr, resourceLabels)\n33\t\tif err != nil {\n34\t\t\treturn fmt.Errorf(\"failed to generate deployment resource for creation in %s: %w\", istiocsr.GetNamespace(), err)\n35\t\t}\n36\t\n37\t\tdeploymentName := fmt.Sprintf(\"%s/%s\", desired.GetNamespace(), desired.GetName())\n38\t\tr.log.V(4).Info(\"reconciling deployment resource\", \"name\", deploymentName)\n39\t\tfetched := &appsv1.Deployment{}\n40\t\texist, err := r.Exists(r.ctx, client.ObjectKeyFromObject(desired), fetched)\n41\t\tif err != nil {\n42\t\t\treturn common.FromClientError(err, \"failed to check %s deployment resource already exists\", deploymentName)\n43\t\t}\n44\t\n45\t\tif exist {\n46\t\t\tif istioCSRCreateRecon {\n47\t\t\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeWarning, \"ResourceAlreadyExists\", \"%s deployment resource already exists, maybe from previous installation\", deploymentName)\n48\t\t\t}\n49\t\t\tif hasObjectChanged(desired, fetched) {\n50\t\t\t\tr.log.V(1).Info(\"deployment has been modified, updating to desired state\", \"name\", deploymentName)\n51\t\t\t\tif err := r.UpdateWithRetry(r.ctx, desired); err != nil {\n52\t\t\t\t\treturn common.FromClientError(err, \"failed to update %s deployment resource\", deploymentName)\n53\t\t\t\t}\n54\t\t\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"deployment resource %s reconciled back to desired state\", deploymentName)\n55\t\t\t} else {\n56\t\t\t\tr.log.V(4).Info(\"deployment resource already exists and is in expected state\", \"name\", deploymentName)\n57\t\t\t}\n58\t\t}\n59\t\n60\t\tif !exist {\n61\t\t\tif err := r.Create(r.ctx, desired); err != nil {\n62\t\t\t\treturn common.FromClientError(err, \"failed to create %s deployment resource\", deploymentName)\n63\t\t\t}\n64\t\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"deployment resource %s created\", deploymentName)\n65\t\t}\n66\t\n67\t\tif err := r.updateImageInStatus(istiocsr, desired); err != nil {\n68\t\t\treturn common.FromClientError(err, \"failed to update %s/%s istiocsr status with image info\", istiocsr.GetNamespace(), istiocsr.GetName())\n69\t\t}\n70\t\treturn nil\n71\t}\n72\t\n73\tfunc (r *Reconciler) getDeploymentObject(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) (*appsv1.Deployment, error) {\n74\t\tif err := r.assertIssuerRefExists(istiocsr); err != nil {\n75\t\t\treturn nil, fmt.Errorf(\"failed to verify issuer in %s/%s: %w\", istiocsr.GetNamespace(), istiocsr.GetName(), err)\n76\t\t}\n77\t\n78\t\tdeployment := decodeDeploymentObjBytes(assets.MustAsset(deploymentAssetName))\n79\t\n80\t\tcommon.UpdateNamespace(deployment, istiocsr.GetNamespace())\n81\t\tcommon.UpdateResourceLabels(deployment, resourceLabels)\n82\t\tupdatePodTemplateLabels(deployment, resourceLabels)\n83\t\n84\t\tupdateArgList(deployment, istiocsr)\n85\t\n86\t\tif err := updateResourceRequirement(deployment, istiocsr); err != nil {\n87\t\t\treturn nil, fmt.Errorf(\"failed to update resource requirements: %w\", err)\n88\t\t}\n89\t\tif err := updateAffinityRules(deployment, istiocsr); err != nil {\n90\t\t\treturn nil, fmt.Errorf(\"failed to update affinity rules: %w\", err)\n91\t\t}\n92\t\tif err := updatePodTolerations(deployment, istiocsr); err != nil {\n93\t\t\treturn nil, fmt.Errorf(\"failed to update pod tolerations: %w\", err)\n94\t\t}\n95\t\tif err := updateNodeSelector(deployment, istiocsr); err != nil {\n96\t\t\treturn nil, fmt.Errorf(\"failed to update node selector: %w\", err)\n97\t\t}\n98\t\tif err := r.updateImage(deployment); err != nil {\n99\t\t\treturn nil, common.NewIrrecoverableError(err, \"failed to update image %s/%s\", istiocsr.GetNamespace(), istiocsr.GetName())\n100\t\t}\n101\t\tif err := r.updateVolumes(deployment, istiocsr, resourceLabels); err != nil {\n102\t\t\treturn nil, fmt.Errorf(\"failed to update volume %s/%s: %w\", istiocsr.GetNamespace(), istiocsr.GetName(), err)\n103\t\t}\n104\t\n105\t\treturn deployment, nil\n106\t}\n107\t\n108\tfunc (r *Reconciler) updateImage(deployment *appsv1.Deployment) error {\n109\t\timage := os.Getenv(istiocsrImageNameEnvVarName)\n110\t\tif image == \"\" {\n111\t\t\treturn fmt.Errorf(\"%s environment variable with istiocsr image not set\", istiocsrImageNameEnvVarName)\n112\t\t}\n113\t\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n114\t\t\tif container.Name == istiocsrContainerName {\n115\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].Image = image\n116\t\t\t}\n117\t\t}\n118\t\treturn nil\n119\t}\n120\t\n121\tfunc (r *Reconciler) updateImageInStatus(istiocsr *v1alpha1.IstioCSR, deployment *appsv1.Deployment) error {\n122\t\tfor _, container := range deployment.Spec.Template.Spec.Containers {\n123\t\t\tif container.Name == istiocsrContainerName {\n124\t\t\t\tif istiocsr.Status.IstioCSRImage == container.Image {\n125\t\t\t\t\treturn nil\n126\t\t\t\t}\n127\t\t\t\tistiocsr.Status.IstioCSRImage = container.Image\n128\t\t\t}\n129\t\t}\n130\t\treturn r.updateStatus(r.ctx, istiocsr)\n131\t}\n132\t\n133\tfunc updatePodTemplateLabels(deployment *appsv1.Deployment, resourceLabels map[string]string) {\n134\t\tdeployment.Spec.Template.Labels = resourceLabels\n135\t}\n136\t\n137\tfunc updateArgList(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) {\n138\t\tistiocsrConfigs := istiocsr.Spec.IstioCSRConfig\n139\t\t// Default clusterID to \"Kubernetes\" if not provided.\n140\t\tclusterID := defaultClusterID\n141\t\tif istiocsrConfigs.Server != nil && istiocsrConfigs.Server.ClusterID != \"\" {\n142\t\t\tclusterID = istiocsrConfigs.Server.ClusterID\n143\t\t}\n144\t\targs := []string{\n145\t\t\tfmt.Sprintf(\"--log-level=%d\", istiocsrConfigs.LogLevel),\n146\t\t\tfmt.Sprintf(\"--log-format=%s\", istiocsrConfigs.LogFormat),\n147\t\t\t\"--metrics-port=9402\", \"--readiness-probe-port=6060\", \"--readiness-probe-path=/readyz\",\n148\t\t\tfmt.Sprintf(\"--certificate-namespace=%s\", istiocsrConfigs.Istio.Namespace),\n149\t\t\t\"--issuer-enabled=true\", \"--preserve-certificate-requests=false\",\n150\t\t\tfmt.Sprintf(\"--issuer-name=%s\", istiocsrConfigs.CertManager.IssuerRef.Name),\n151\t\t\tfmt.Sprintf(\"--issuer-kind=%s\", istiocsrConfigs.CertManager.IssuerRef.Kind),\n152\t\t\tfmt.Sprintf(\"--issuer-group=%s\", istiocsrConfigs.CertManager.IssuerRef.Group),\n153\t\t\tfmt.Sprintf(\"--root-ca-file=%s/%s\", caVolumeMountPath, IstiocsrCAKeyName),\n154\t\t\tfmt.Sprintf(\"--serving-certificate-dns-names=cert-manager-istio-csr.%s.svc\", istiocsr.GetNamespace()),\n155\t\t\tfmt.Sprintf(\"--serving-certificate-duration=%.0fm\", istiocsrConfigs.IstiodTLSConfig.CertificateDuration.Minutes()),\n156\t\t\tfmt.Sprintf(\"--trust-domain=%s\", istiocsrConfigs.IstiodTLSConfig.TrustDomain),\n157\t\t\tfmt.Sprintf(\"--cluster-id=%s\", clusterID),\n158\t\t\tfmt.Sprintf(\"--max-client-certificate-duration=%.0fm\", istiocsrConfigs.IstiodTLSConfig.MaxCertificateDuration.Minutes()),\n159\t\t\t\"--serving-address=0.0.0.0:6443\",\n160\t\t\tfmt.Sprintf(\"--serving-certificate-key-size=%d\", istiocsrConfigs.IstiodTLSConfig.PrivateKeySize),\n161\t\t\tfmt.Sprintf(\"--serving-signature-algorithm=%s\", istiocsrConfigs.IstiodTLSConfig.PrivateKeyAlgorithm),\n162\t\t\t\"--enable-client-cert-authenticator=false\",\n163\t\t\tfmt.Sprintf(\"--leader-election-namespace=%s\", istiocsrConfigs.Istio.Namespace),\n164\t\t\t\"--disable-kubernetes-client-rate-limiter=false\", \"--istiod-cert-enabled=false\",\n165\t\t\tfmt.Sprintf(\"--istiod-cert-namespace=%s\", istiocsrConfigs.Istio.Namespace),\n166\t\t\tfmt.Sprintf(\"--istiod-cert-duration=%.0fm\", istiocsrConfigs.IstiodTLSConfig.CertificateDuration.Minutes()),\n167\t\t\tfmt.Sprintf(\"--istiod-cert-renew-before=%.0fm\", istiocsrConfigs.IstiodTLSConfig.CertificateRenewBefore.Minutes()),\n168\t\t\tfmt.Sprintf(\"--istiod-cert-key-algorithm=%s\", istiocsrConfigs.IstiodTLSConfig.PrivateKeyAlgorithm),\n169\t\t\tfmt.Sprintf(\"--istiod-cert-key-size=%d\", istiocsrConfigs.IstiodTLSConfig.PrivateKeySize),\n170\t\t\tfmt.Sprintf(\"--istiod-cert-additional-dns-names=%s\", strings.Join(istiocsr.Spec.IstioCSRConfig.IstiodTLSConfig.CertificateDNSNames, \",\")),\n171\t\t\tfmt.Sprintf(\"--istiod-cert-istio-revisions=%s\", strings.Join(istiocsrConfigs.Istio.Revisions, \",\")),\n172\t\t}\n173\t\n174\t\t// Add configmap-namespace-selector argument if configured\n175\t\tif istiocsrConfigs.IstioDataPlaneNamespaceSelector != \"\" {\n176\t\t\targs = append(args, fmt.Sprintf(\"--configmap-namespace-selector=%s\", istiocsrConfigs.IstioDataPlaneNamespaceSelector))\n177\t\t}\n178\t\n179\t\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n180\t\t\tif container.Name == istiocsrContainerName {\n181\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].Args = args\n182\t\t\t}\n183\t\t}\n184\t}\n185\t\n186\tfunc updateResourceRequirement(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) error {\n187\t\tif reflect.ValueOf(istiocsr.Spec.IstioCSRConfig.Resources).IsZero() {\n188\t\t\treturn nil\n189\t\t}\n190\t\tif err := common.ValidateResourceRequirements(istiocsr.Spec.IstioCSRConfig.Resources,\n191\t\t\tfield.NewPath(\"spec\", \"istioCSRConfig\")); err != nil {\n192\t\t\treturn err\n193\t\t}\n194\t\tfor i := range deployment.Spec.Template.Spec.Containers {\n195\t\t\tdeployment.Spec.Template.Spec.Containers[i].Resources = istiocsr.Spec.IstioCSRConfig.Resources\n196\t\t}\n197\t\treturn nil\n198\t}\n199\t\n200\tfunc updateAffinityRules(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) error {\n201\t\tif istiocsr.Spec.IstioCSRConfig.Affinity == nil {\n202\t\t\treturn nil\n203\t\t}\n204\t\tif err := common.ValidateAffinityRules(istiocsr.Spec.IstioCSRConfig.Affinity,\n205\t\t\tfield.NewPath(\"spec\", \"istioCSRConfig\")); err != nil {\n206\t\t\treturn err\n207\t\t}\n208\t\tdeployment.Spec.Template.Spec.Affinity = istiocsr.Spec.IstioCSRConfig.Affinity\n209\t\treturn nil\n210\t}\n211\t\n212\tfunc updatePodTolerations(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) error {\n213\t\tif istiocsr.Spec.IstioCSRConfig.Tolerations == nil {\n214\t\t\treturn nil\n215\t\t}\n216\t\tif err := common.ValidateTolerationsConfig(istiocsr.Spec.IstioCSRConfig.Tolerations,\n217\t\t\tfield.NewPath(\"spec\", \"istioCSRConfig\")); err != nil {\n218\t\t\treturn err\n219\t\t}\n220\t\tdeployment.Spec.Template.Spec.Tolerations = istiocsr.Spec.IstioCSRConfig.Tolerations\n221\t\treturn nil\n222\t}\n223\t\n224\tfunc updateNodeSelector(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) error {\n225\t\tif istiocsr.Spec.IstioCSRConfig.NodeSelector == nil {\n226\t\t\treturn nil\n227\t\t}\n228\t\tif err := common.ValidateNodeSelectorConfig(istiocsr.Spec.IstioCSRConfig.NodeSelector,\n229\t\t\tfield.NewPath(\"spec\", \"istioCSRConfig\")); err != nil {\n230\t\t\treturn err\n231\t\t}\n232\t\tdeployment.Spec.Template.Spec.NodeSelector = istiocsr.Spec.IstioCSRConfig.NodeSelector\n233\t\treturn nil\n234\t}\n235\t\n236\tfunc (r *Reconciler) assertIssuerRefExists(istiocsr *v1alpha1.IstioCSR) error {\n237\t\tissuerRefKind := strings.ToLower(istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Kind)\n238\t\tif issuerRefKind != clusterIssuerKind && issuerRefKind != issuerKind {\n239\t\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"spec.istioCSRConfig.certManager.issuerRef.kind can be any of `%s` or `%s`, configured: %s\", clusterIssuerKind, issuerKind, issuerRefKind)\n240\t\t}\n241\t\n242\t\tissuerRefGroup := strings.ToLower(istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Group)\n243\t\tif issuerRefGroup != issuerGroup {\n244\t\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"spec.istioCSRConfig.certManager.issuerRef.group can be only `%s`, configured: %s\", issuerGroup, issuerRefGroup)\n245\t\t}\n246\t\n247\t\tobj, err := r.getIssuer(istiocsr)\n248\t\tif err != nil {\n249\t\t\treturn common.FromClientError(err, \"failed to fetch issuer\")\n250\t\t}\n251\t\n252\t\tvar issuerConfig certmanagerv1.IssuerConfig\n253\t\tswitch issuerRefKind {\n254\t\tcase clusterIssuerKind:\n255\t\t\tclusterIssuer, ok := obj.(*certmanagerv1.ClusterIssuer)\n256\t\t\tif !ok {\n257\t\t\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"failed to convert to ClusterIssuer\")\n258\t\t\t}\n259\t\t\tissuerConfig = clusterIssuer.Spec.IssuerConfig\n260\t\tcase issuerKind:\n261\t\t\tissuer, ok := obj.(*certmanagerv1.Issuer)\n262\t\t\tif !ok {\n263\t\t\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"failed to convert to Issuer\")\n264\t\t\t}\n265\t\t\tissuerConfig = issuer.Spec.IssuerConfig\n266\t\t}\n267\t\tif issuerConfig.ACME != nil {\n268\t\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"spec.istioCSRConfig.certManager.issuerRef uses unsupported ACME issuer\")\n269\t\t}\n270\t\n271\t\tif err := r.updateWatchLabel(obj, istiocsr); err != nil {\n272\t\t\treturn common.FromClientError(err, \"failed to update watch label on cert-manager issuer %s\", istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Name)\n273\t\t}\n274\t\n275\t\treturn nil\n276\t}\n277\t\n278\tfunc (r *Reconciler) updateVolumes(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) error {\n279\t\t// Use user-configured CA certificate if provided\n280\t\tif istiocsr.Spec.IstioCSRConfig.CertManager.IstioCACertificate != nil {\n281\t\t\tif err := r.handleUserProvidedCA(deployment, istiocsr, resourceLabels); err != nil {\n282\t\t\t\treturn common.FromError(err, \"failed to validate and mount CA certificate ConfigMap\")\n283\t\t\t}\n284\t\t\treturn nil\n285\t\t}\n286\t\n287\t\t// Fall back to issuer-based CA certificate if CA certificate is not configured\n288\t\t// Handle issuer-based CA configuration\n289\t\tif err := r.handleIssuerBasedCA(deployment, istiocsr, resourceLabels); err != nil {\n290\t\t\treturn err\n291\t\t}\n292\t\n293\t\treturn nil\n294\t}\n295\t\n296\t// handleUserProvidedCA processes user-provided CA certificate configuration.\n297\t//\n298\t// It performs the following operations:\n299\t//  1. Validates that the source ConfigMap exists\n300\t//  2. Adds a watch label to the source ConfigMap for change tracking\n301\t//  3. Validates that the ConfigMap contains the specified key and is a valid CA certificate\n302\t//  4. Creates or updates a copy of the ConfigMap in the IstioCSR namespace\n303\t//  5. Configures the deployment to mount the CA certificate volume\n304\t//\n305\t// The caller must ensure that `istiocsr.Spec.IstioCSRConfig.CertManager.IstioCACertificate`\n306\t// is not nil before calling this function to avoid a panic.\n307\t//\n308\t// Returns an error if any validation fails or if ConfigMap operations fail.\n309\tfunc (r *Reconciler) handleUserProvidedCA(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) error {\n310\t\tcaCertConfig := istiocsr.Spec.IstioCSRConfig.CertManager.IstioCACertificate\n311\t\n312\t\t// Determine the namespace - use specified namespace or default to IstioCSR namespace\n313\t\tnamespace := caCertConfig.Namespace\n314\t\tif namespace == \"\" {\n315\t\t\tnamespace = istiocsr.GetNamespace()\n316\t\t}\n317\t\n318\t\t// Validate that the source ConfigMap exists\n319\t\tsourceConfigMapKey := types.NamespacedName{\n320\t\t\tName:      caCertConfig.Name,\n321\t\t\tNamespace: namespace,\n322\t\t}\n323\t\n324\t\tsourceConfigMap := &corev1.ConfigMap{}\n325\t\tif err := r.Get(r.ctx, sourceConfigMapKey, sourceConfigMap); err != nil {\n326\t\t\treturn common.NewIrrecoverableError(err, \"failed to fetch CA certificate ConfigMap %s/%s\", sourceConfigMapKey.Namespace, sourceConfigMapKey.Name)\n327\t\t}\n328\t\n329\t\t// Add watch label to the source ConfigMap to trigger reconciliation on changes.\n330\t\t// This is done before validation so that if validation fails now, fixing the ConfigMap\n331\t\t// will trigger reconciliation.\n332\t\tif err := r.updateWatchLabel(sourceConfigMap, istiocsr); err != nil {\n333\t\t\treturn common.FromClientError(err, \"failed to update watch label on CA certificate ConfigMap %s/%s\", sourceConfigMapKey.Namespace, sourceConfigMapKey.Name)\n334\t\t}\n335\t\n336\t\t// Validate that the specified key exists in the ConfigMap\n337\t\tif _, exists := sourceConfigMap.Data[caCertConfig.Key]; !exists {\n338\t\t\treturn common.NewIrrecoverableError(fmt.Errorf(\"key %q not found in ConfigMap %s/%s\", caCertConfig.Key, sourceConfigMapKey.Namespace, sourceConfigMapKey.Name), \"invalid CA certificate ConfigMap %s/%s\", sourceConfigMapKey.Namespace, sourceConfigMapKey.Name)\n339\t\t}\n340\t\n341\t\t// Validate that the key contains PEM-formatted content\n342\t\tpemData := sourceConfigMap.Data[caCertConfig.Key]\n343\t\tif err := r.validatePEMData(pemData); err != nil {\n344\t\t\treturn common.NewIrrecoverableError(err, \"invalid PEM data in CA certificate ConfigMap %s/%s key %q\", sourceConfigMapKey.Namespace, sourceConfigMapKey.Name, caCertConfig.Key)\n345\t\t}\n346\t\n347\t\t// Create a managed copy of the ConfigMap in the IstioCSR namespace.\n348\t\t// The operator does not directly mount the user-provided ConfigMap but creates a managed copy\n349\t\t// (cert-manager-istio-csr-issuer-ca-copy) in the IstioCSR namespace. This approach enables the\n350\t\t// operator to validate any changes to the source ConfigMap before propagating them to the istio-csr\n351\t\t// agent, as ConfigMap changes automatically propagate to mounted pods. The watch label on the source\n352\t\t// ConfigMap triggers reconciliation when modified, allowing the operator to re-validate and update\n353\t\t// its managed copy. Additionally, if a user directly modifies the operator-managed copy, it will be\n354\t\t// reconciled back to the desired state derived from the validated source ConfigMap.\n355\t\tif err := r.createOrUpdateCAConfigMap(istiocsr, pemData, resourceLabels); err != nil {\n356\t\t\treturn common.FromClientError(err, \"failed to create CA certificate ConfigMap copy\")\n357\t\t}\n358\t\n359\t\t// Mount the copied CA certificate ConfigMap (always uses the standard name)\n360\t\tupdateVolumeWithIssuerCA(deployment)\n361\t\n362\t\treturn nil\n363\t}\n364\t\n365\t// handleIssuerBasedCA handles the creation of CA ConfigMap from issuer secret and volume mounting.\n366\tfunc (r *Reconciler) handleIssuerBasedCA(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) error {\n367\t\tvar (\n368\t\t\tissuerConfig certmanagerv1.IssuerConfig\n369\t\t)\n370\t\n371\t\tobj, err := r.getIssuer(istiocsr)\n372\t\tif err != nil {\n373\t\t\treturn common.FromClientError(err, \"failed to fetch issuer\")\n374\t\t}\n375\t\n376\t\tissuerRefKind := strings.ToLower(istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Kind)\n377\t\tswitch issuerRefKind {\n378\t\tcase clusterIssuerKind:\n379\t\t\tclusterIssuer, ok := obj.(*certmanagerv1.ClusterIssuer)\n380\t\t\tif !ok {\n381\t\t\t\treturn common.FromClientError(fmt.Errorf(\"failed to convert to ClusterIssuer\"), \"failed to fetch issuer\")\n382\t\t\t}\n383\t\t\tissuerConfig = clusterIssuer.Spec.IssuerConfig\n384\t\tcase issuerKind:\n385\t\t\tissuer, ok := obj.(*certmanagerv1.Issuer)\n386\t\t\tif !ok {\n387\t\t\t\treturn common.FromClientError(fmt.Errorf(\"failed to convert to Issuer\"), \"failed to fetch issuer\")\n388\t\t\t}\n389\t\t\tissuerConfig = issuer.Spec.IssuerConfig\n390\t\t}\n391\t\n392\t\tshouldUpdateVolume := false\n393\t\n394\t\tif issuerConfig.CA != nil && issuerConfig.CA.SecretName != \"\" {\n395\t\t\tif err := r.createCAConfigMapFromIssuerSecret(istiocsr, issuerConfig, resourceLabels); err != nil {\n396\t\t\t\treturn common.FromClientError(err, \"failed to create CA ConfigMap\")\n397\t\t\t}\n398\t\t\tshouldUpdateVolume = true\n399\t\t}\n400\t\n401\t\tif issuerConfig.CA == nil {\n402\t\t\tif err := r.createCAConfigMapFromIstiodCertificate(istiocsr, resourceLabels); err != nil {\n403\t\t\t\treturn common.FromClientError(err, \"failed to create CA ConfigMap\")\n404\t\t\t}\n405\t\t\tshouldUpdateVolume = true\n406\t\t}\n407\t\n408\t\tif shouldUpdateVolume {\n409\t\t\tupdateVolumeWithIssuerCA(deployment)\n410\t\t}\n411\t\n412\t\treturn nil\n413\t}\n414\t\n415\tfunc updateVolumeWithIssuerCA(deployment *appsv1.Deployment) {\n416\t\tconst (\n417\t\t\tcaVolumeName = \"root-ca\"\n418\t\t)\n419\t\tvar (\n420\t\t\tdefaultMode = int32(420)\n421\t\t)\n422\t\n423\t\tdesiredVolumeMount := corev1.VolumeMount{\n424\t\t\tName:      caVolumeName,\n425\t\t\tMountPath: caVolumeMountPath,\n426\t\t\tReadOnly:  true,\n427\t\t}\n428\t\n429\t\tdesiredVolume := corev1.Volume{\n430\t\t\tName: caVolumeName,\n431\t\t\tVolumeSource: corev1.VolumeSource{\n432\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n433\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n434\t\t\t\t\t\tName: IstiocsrCAConfigMapName,\n435\t\t\t\t\t},\n436\t\t\t\t\tItems: []corev1.KeyToPath{\n437\t\t\t\t\t\t{\n438\t\t\t\t\t\t\tKey:  IstiocsrCAKeyName,\n439\t\t\t\t\t\t\tPath: IstiocsrCAKeyName,\n440\t\t\t\t\t\t\tMode: &defaultMode,\n441\t\t\t\t\t\t},\n442\t\t\t\t\t},\n443\t\t\t\t\tDefaultMode: &defaultMode,\n444\t\t\t\t},\n445\t\t\t},\n446\t\t}\n447\t\n448\t\t// Update or append volume mount in the istio-csr container\n449\t\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n450\t\t\tif container.Name == istiocsrContainerName {\n451\t\t\t\tvolumeMountExists := false\n452\t\t\t\tfor j, vm := range container.VolumeMounts {\n453\t\t\t\t\tif vm.Name == caVolumeName {\n454\t\t\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts[j] = desiredVolumeMount\n455\t\t\t\t\t\tvolumeMountExists = true\n456\t\t\t\t\t\tbreak\n457\t\t\t\t\t}\n458\t\t\t\t}\n459\t\t\t\tif !volumeMountExists {\n460\t\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts = append(\n461\t\t\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts,\n462\t\t\t\t\t\tdesiredVolumeMount,\n463\t\t\t\t\t)\n464\t\t\t\t}\n465\t\t\t\tbreak\n466\t\t\t}\n467\t\t}\n468\t\n469\t\t// Update or append volume in the deployment\n470\t\tvolumeExists := false\n471\t\tfor i, vol := range deployment.Spec.Template.Spec.Volumes {\n472\t\t\tif vol.Name == caVolumeName {\n473\t\t\t\tdeployment.Spec.Template.Spec.Volumes[i] = desiredVolume\n474\t\t\t\tvolumeExists = true\n475\t\t\t\tbreak\n476\t\t\t}\n477\t\t}\n478\t\tif !volumeExists {\n479\t\t\tdeployment.Spec.Template.Spec.Volumes = append(\n480\t\t\t\tdeployment.Spec.Template.Spec.Volumes,\n481\t\t\t\tdesiredVolume,\n482\t\t\t)\n483\t\t}\n484\t}\n485\t\n486\tfunc (r *Reconciler) getIssuer(istiocsr *v1alpha1.IstioCSR) (client.Object, error) {\n487\t\tissuerRefKind := strings.ToLower(istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Kind)\n488\t\tkey := client.ObjectKey{\n489\t\t\tName:      istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Name,\n490\t\t\tNamespace: istiocsr.Spec.IstioCSRConfig.Istio.Namespace,\n491\t\t}\n492\t\n493\t\tvar object client.Object\n494\t\tswitch issuerRefKind {\n495\t\tcase clusterIssuerKind:\n496\t\t\tobject = &certmanagerv1.ClusterIssuer{}\n497\t\tcase issuerKind:\n498\t\t\tobject = &certmanagerv1.Issuer{}\n499\t\t}\n500\t\n501\t\tif err := r.Get(r.ctx, key, object); err != nil {\n502\t\t\treturn nil, fmt.Errorf(\"failed to fetch %q issuer: %w\", key, err)\n503\t\t}\n504\t\treturn object, nil\n505\t}\n506\t\n507\tfunc (r *Reconciler) createCAConfigMapFromIstiodCertificate(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) error {\n508\t\tistiodCertificate, err := r.getCertificateObject(istiocsr, resourceLabels)\n509\t\tif err != nil {\n510\t\t\treturn common.FromClientError(err, \"failed to fetch istiod certificate\")\n511\t\t}\n512\t\n513\t\tsecretKey := client.ObjectKey{\n514\t\t\tName:      istiodCertificate.Spec.SecretName,\n515\t\t\tNamespace: istiodCertificate.GetNamespace(),\n516\t\t}\n517\t\tsecret := &corev1.Secret{}\n518\t\tif err := r.Get(r.ctx, secretKey, secret); err != nil {\n519\t\t\treturn fmt.Errorf(\"failed to fetch secret in issuer: %w\", err)\n520\t\t}\n521\t\tif err := r.updateWatchLabel(secret, istiocsr); err != nil {\n522\t\t\treturn err\n523\t\t}\n524\t\n525\t\tcertData := string(secret.Data[IstiocsrCAKeyName])\n526\t\treturn r.createOrUpdateCAConfigMap(istiocsr, certData, resourceLabels)\n527\t}\n528\t\n529\tfunc (r *Reconciler) createCAConfigMapFromIssuerSecret(istiocsr *v1alpha1.IstioCSR, issuerConfig certmanagerv1.IssuerConfig, resourceLabels map[string]string) error {\n530\t\tif issuerConfig.CA.SecretName == \"\" {\n531\t\t\treturn fmt.Errorf(\"failed to fetch CA certificate configured for the %s issuer of CA type\", istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Name)\n532\t\t}\n533\t\n534\t\tsecretKey := client.ObjectKey{\n535\t\t\tName:      issuerConfig.CA.SecretName,\n536\t\t\tNamespace: istiocsr.Spec.IstioCSRConfig.Istio.Namespace,\n537\t\t}\n538\t\tsecret := &corev1.Secret{}\n539\t\tif err := r.Get(r.ctx, secretKey, secret); err != nil {\n540\t\t\treturn fmt.Errorf(\"failed to fetch secret in issuer: %w\", err)\n541\t\t}\n542\t\tif err := r.updateWatchLabel(secret, istiocsr); err != nil {\n543\t\t\treturn err\n544\t\t}\n545\t\n546\t\tcertData := string(secret.Data[IstiocsrCAKeyName])\n547\t\treturn r.createOrUpdateCAConfigMap(istiocsr, certData, resourceLabels)\n548\t}\n549\t\n550\t// createOrUpdateCAConfigMap creates or updates the CA ConfigMap with the provided certificate data.\n551\tfunc (r *Reconciler) createOrUpdateCAConfigMap(istiocsr *v1alpha1.IstioCSR, certData string, resourceLabels map[string]string) error {\n552\t\tif certData == \"\" {\n553\t\t\treturn fmt.Errorf(\"failed to find CA certificate\")\n554\t\t}\n555\t\n556\t\tconfigmapKey := client.ObjectKey{\n557\t\t\tName:      IstiocsrCAConfigMapName,\n558\t\t\tNamespace: istiocsr.GetNamespace(),\n559\t\t}\n560\t\tfetched := &corev1.ConfigMap{}\n561\t\texist, err := r.Exists(r.ctx, configmapKey, fetched)\n562\t\tif err != nil {\n563\t\t\treturn fmt.Errorf(\"failed to check if CA configmap exists: %w\", err)\n564\t\t}\n565\t\n566\t\tdesired := &corev1.ConfigMap{\n567\t\t\tObjectMeta: metav1.ObjectMeta{\n568\t\t\t\tName:      configmapKey.Name,\n569\t\t\t\tNamespace: configmapKey.Namespace,\n570\t\t\t\tLabels:    resourceLabels,\n571\t\t\t},\n572\t\t\tData: map[string]string{\n573\t\t\t\tIstiocsrCAKeyName: certData,\n574\t\t\t},\n575\t\t}\n576\t\n577\t\tif exist && hasObjectChanged(desired, fetched) {\n578\t\t\tr.log.V(1).Info(\"ca configmap need update\", \"name\", configmapKey)\n579\t\t\tif err := r.UpdateWithRetry(r.ctx, desired); err != nil {\n580\t\t\t\treturn fmt.Errorf(\"failed to update %s configmap resource: %w\", configmapKey, err)\n581\t\t\t}\n582\t\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"configmap resource %s reconciled back to desired state\", configmapKey)\n583\t\t} else {\n584\t\t\tr.log.V(4).Info(\"configmap resource already exists and is in expected state\", \"name\", configmapKey)\n585\t\t}\n586\t\n587\t\tif !exist {\n588\t\t\tif err := r.Create(r.ctx, desired); err != nil {\n589\t\t\t\treturn fmt.Errorf(\"failed to create %s configmap resource: %w\", configmapKey, err)\n590\t\t\t}\n591\t\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"configmap resource %s created\", configmapKey)\n592\t\t}\n593\t\n594\t\treturn nil\n595\t}\n596\t\n597\tfunc (r *Reconciler) validatePEMData(pemData string) error {\n598\t\tif pemData == \"\" {\n599\t\t\treturn fmt.Errorf(\"PEM data is empty\")\n600\t\t}\n601\t\n602\t\t// Parse the first certificate from PEM data\n603\t\tblock, _ := pem.Decode([]byte(pemData))\n604\t\tif block == nil {\n605\t\t\treturn fmt.Errorf(\"no valid PEM data found\")\n606\t\t}\n607\t\n608\t\tif block.Type != \"CERTIFICATE\" {\n609\t\t\treturn fmt.Errorf(\"PEM block is not a certificate, found: %s\", block.Type)\n610\t\t}\n611\t\n612\t\tcert, err := x509.ParseCertificate(block.Bytes)\n613\t\tif err != nil {\n614\t\t\treturn fmt.Errorf(\"failed to parse certificate: %w\", err)\n615\t\t}\n616\t\n617\t\tif !cert.BasicConstraintsValid {\n618\t\t\treturn fmt.Errorf(\"certificate does not have valid Basic Constraints extension\")\n619\t\t}\n620\t\n621\t\tif !cert.IsCA {\n622\t\t\treturn fmt.Errorf(\"certificate is not a CA certificate\")\n623\t\t}\n624\t\n625\t\t// Check Key Usage for certificate signing\n626\t\tif cert.KeyUsage&x509.KeyUsageCertSign == 0 {\n627\t\t\treturn fmt.Errorf(\"certificate does not have Certificate Sign key usage\")\n628\t\t}\n629\t\n630\t\treturn nil\n631\t}\n632\t\n633\t// updateWatchLabel adds a watch label to any Kubernetes object that supports labels.\n634\tfunc (r *Reconciler) updateWatchLabel(obj client.Object, istiocsr *v1alpha1.IstioCSR) error {\n635\t\tlabels := obj.GetLabels()\n636\t\tif labels == nil {\n637\t\t\tlabels = make(map[string]string)\n638\t\t}\n639\t\tlabels[IstiocsrResourceWatchLabelName] = fmt.Sprintf(istiocsrResourceWatchLabelValueFmt, istiocsr.GetNamespace(), istiocsr.GetName())\n640\t\tobj.SetLabels(labels)\n641\t\n642\t\tif err := r.UpdateWithRetry(r.ctx, obj); err != nil {\n643\t\t\treturn fmt.Errorf(\"failed to update %s resource with watch label: %w\", obj.GetName(), err)\n644\t\t}\n645\t\treturn nil\n646\t}\n647\t"}]},"parent_tool_use_id":null,"session_id":"7761e1db-6892-412e-af40-5c732f6d271b","uuid":"dc527fcc-167e-4549-a392-40d976b49d0f","timestamp":"2026-07-20T16:55:54.676Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/controller/istiocsr/deployments.go","content":"package istiocsr\n\nimport (\n\t\"crypto/x509\"\n\t\"encoding/pem\"\n\t\"fmt\"\n\t\"os\"\n\t\"reflect\"\n\t\"strings\"\n\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/apimachinery/pkg/util/validation/field\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n\n\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n\t\"github.com/openshift/cert-manager-operator/pkg/operator/assets\"\n)\n\nconst (\n\tcaVolumeMountPath = \"/var/run/configmaps/istio-csr\"\n)\n\nvar errInvalidIssuerRefConfig = fmt.Errorf(\"invalid issuerRef config\")\n\nfunc (r *Reconciler) createOrApplyDeployments(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, istioCSRCreateRecon bool) error {\n\tdesired, err := r.getDeploymentObject(istiocsr, resourceLabels)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to generate deployment resource for creation in %s: %w\", istiocsr.GetNamespace(), err)\n\t}\n\n\tdeploymentName := fmt.Sprintf(\"%s/%s\", desired.GetNamespace(), desired.GetName())\n\tr.log.V(4).Info(\"reconciling deployment resource\", \"name\", deploymentName)\n\tfetched := &appsv1.Deployment{}\n\texist, err := r.Exists(r.ctx, client.ObjectKeyFromObject(desired), fetched)\n\tif err != nil {\n\t\treturn common.FromClientError(err, \"failed to check %s deployment resource already exists\", deploymentName)\n\t}\n\n\tif exist {\n\t\tif istioCSRCreateRecon {\n\t\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeWarning, \"ResourceAlreadyExists\", \"%s deployment resource already exists, maybe from previous installation\", deploymentName)\n\t\t}\n\t\tif hasObjectChanged(desired, fetched) {\n\t\t\tr.log.V(1).Info(\"deployment has been modified, updating to desired state\", \"name\", deploymentName)\n\t\t\tif err := r.UpdateWithRetry(r.ctx, desired); err != nil {\n\t\t\t\treturn common.FromClientError(err, \"failed to update %s deployment resource\", deploymentName)\n\t\t\t}\n\t\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"deployment resource %s reconciled back to desired state\", deploymentName)\n\t\t} else {\n\t\t\tr.log.V(4).Info(\"deployment resource already exists and is in expected state\", \"name\", deploymentName)\n\t\t}\n\t}\n\n\tif !exist {\n\t\tif err := r.Create(r.ctx, desired); err != nil {\n\t\t\treturn common.FromClientError(err, \"failed to create %s deployment resource\", deploymentName)\n\t\t}\n\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"deployment resource %s created\", deploymentName)\n\t}\n\n\tif err := r.updateImageInStatus(istiocsr, desired); err != nil {\n\t\treturn common.FromClientError(err, \"failed to update %s/%s istiocsr status with image info\", istiocsr.GetNamespace(), istiocsr.GetName())\n\t}\n\treturn nil\n}\n\nfunc (r *Reconciler) getDeploymentObject(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) (*appsv1.Deployment, error) {\n\tif err := r.assertIssuerRefExists(istiocsr); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to verify issuer in %s/%s: %w\", istiocsr.GetNamespace(), istiocsr.GetName(), err)\n\t}\n\n\tdeployment := decodeDeploymentObjBytes(assets.MustAsset(deploymentAssetName))\n\n\tcommon.UpdateNamespace(deployment, istiocsr.GetNamespace())\n\tcommon.UpdateResourceLabels(deployment, resourceLabels)\n\tupdatePodTemplateLabels(deployment, resourceLabels)\n\n\tupdateArgList(deployment, istiocsr)\n\n\tif err := updateResourceRequirement(deployment, istiocsr); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to update resource requirements: %w\", err)\n\t}\n\tif err := updateAffinityRules(deployment, istiocsr); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to update affinity rules: %w\", err)\n\t}\n\tif err := updatePodTolerations(deployment, istiocsr); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to update pod tolerations: %w\", err)\n\t}\n\tif err := updateNodeSelector(deployment, istiocsr); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to update node selector: %w\", err)\n\t}\n\tif err := r.updateImage(deployment); err != nil {\n\t\treturn nil, common.NewIrrecoverableError(err, \"failed to update image %s/%s\", istiocsr.GetNamespace(), istiocsr.GetName())\n\t}\n\tif err := r.updateVolumes(deployment, istiocsr, resourceLabels); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to update volume %s/%s: %w\", istiocsr.GetNamespace(), istiocsr.GetName(), err)\n\t}\n\n\treturn deployment, nil\n}\n\nfunc (r *Reconciler) updateImage(deployment *appsv1.Deployment) error {\n\timage := os.Getenv(istiocsrImageNameEnvVarName)\n\tif image == \"\" {\n\t\treturn fmt.Errorf(\"%s environment variable with istiocsr image not set\", istiocsrImageNameEnvVarName)\n\t}\n\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == istiocsrContainerName {\n\t\t\tdeployment.Spec.Template.Spec.Containers[i].Image = image\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc (r *Reconciler) updateImageInStatus(istiocsr *v1alpha1.IstioCSR, deployment *appsv1.Deployment) error {\n\tfor _, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == istiocsrContainerName {\n\t\t\tif istiocsr.Status.IstioCSRImage == container.Image {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tistiocsr.Status.IstioCSRImage = container.Image\n\t\t}\n\t}\n\treturn r.updateStatus(r.ctx, istiocsr)\n}\n\nfunc updatePodTemplateLabels(deployment *appsv1.Deployment, resourceLabels map[string]string) {\n\tdeployment.Spec.Template.Labels = resourceLabels\n}\n\nfunc updateArgList(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) {\n\tistiocsrConfigs := istiocsr.Spec.IstioCSRConfig\n\t// Default clusterID to \"Kubernetes\" if not provided.\n\tclusterID := defaultClusterID\n\tif istiocsrConfigs.Server != nil && istiocsrConfigs.Server.ClusterID != \"\" {\n\t\tclusterID = istiocsrConfigs.Server.ClusterID\n\t}\n\targs := []string{\n\t\tfmt.Sprintf(\"--log-level=%d\", istiocsrConfigs.LogLevel),\n\t\tfmt.Sprintf(\"--log-format=%s\", istiocsrConfigs.LogFormat),\n\t\t\"--metrics-port=9402\", \"--readiness-probe-port=6060\", \"--readiness-probe-path=/readyz\",\n\t\tfmt.Sprintf(\"--certificate-namespace=%s\", istiocsrConfigs.Istio.Namespace),\n\t\t\"--issuer-enabled=true\", \"--preserve-certificate-requests=false\",\n\t\tfmt.Sprintf(\"--issuer-name=%s\", istiocsrConfigs.CertManager.IssuerRef.Name),\n\t\tfmt.Sprintf(\"--issuer-kind=%s\", istiocsrConfigs.CertManager.IssuerRef.Kind),\n\t\tfmt.Sprintf(\"--issuer-group=%s\", istiocsrConfigs.CertManager.IssuerRef.Group),\n\t\tfmt.Sprintf(\"--root-ca-file=%s/%s\", caVolumeMountPath, IstiocsrCAKeyName),\n\t\tfmt.Sprintf(\"--serving-certificate-dns-names=cert-manager-istio-csr.%s.svc\", istiocsr.GetNamespace()),\n\t\tfmt.Sprintf(\"--serving-certificate-duration=%.0fm\", istiocsrConfigs.IstiodTLSConfig.CertificateDuration.Minutes()),\n\t\tfmt.Sprintf(\"--trust-domain=%s\", istiocsrConfigs.IstiodTLSConfig.TrustDomain),\n\t\tfmt.Sprintf(\"--cluster-id=%s\", clusterID),\n\t\tfmt.Sprintf(\"--max-client-certificate-duration=%.0fm\", istiocsrConfigs.IstiodTLSConfig.MaxCertificateDuration.Minutes()),\n\t\t\"--serving-address=0.0.0.0:6443\",\n\t\tfmt.Sprintf(\"--serving-certificate-key-size=%d\", istiocsrConfigs.IstiodTLSConfig.PrivateKeySize),\n\t\tfmt.Sprintf(\"--serving-signature-algorithm=%s\", istiocsrConfigs.IstiodTLSConfig.PrivateKeyAlgorithm),\n\t\t\"--enable-client-cert-authenticator=false\",\n\t\tfmt.Sprintf(\"--leader-election-namespace=%s\", istiocsrConfigs.Istio.Namespace),\n\t\t\"--disable-kubernetes-client-rate-limiter=false\", \"--istiod-cert-enabled=false\",\n\t\tfmt.Sprintf(\"--istiod-cert-namespace=%s\", istiocsrConfigs.Istio.Namespace),\n\t\tfmt.Sprintf(\"--istiod-cert-duration=%.0fm\", istiocsrConfigs.IstiodTLSConfig.CertificateDuration.Minutes()),\n\t\tfmt.Sprintf(\"--istiod-cert-renew-before=%.0fm\", istiocsrConfigs.IstiodTLSConfig.CertificateRenewBefore.Minutes()),\n\t\tfmt.Sprintf(\"--istiod-cert-key-algorithm=%s\", istiocsrConfigs.IstiodTLSConfig.PrivateKeyAlgorithm),\n\t\tfmt.Sprintf(\"--istiod-cert-key-size=%d\", istiocsrConfigs.IstiodTLSConfig.PrivateKeySize),\n\t\tfmt.Sprintf(\"--istiod-cert-additional-dns-names=%s\", strings.Join(istiocsr.Spec.IstioCSRConfig.IstiodTLSConfig.CertificateDNSNames, \",\")),\n\t\tfmt.Sprintf(\"--istiod-cert-istio-revisions=%s\", strings.Join(istiocsrConfigs.Istio.Revisions, \",\")),\n\t}\n\n\t// Add configmap-namespace-selector argument if configured\n\tif istiocsrConfigs.IstioDataPlaneNamespaceSelector != \"\" {\n\t\targs = append(args, fmt.Sprintf(\"--configmap-namespace-selector=%s\", istiocsrConfigs.IstioDataPlaneNamespaceSelector))\n\t}\n\n\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == istiocsrContainerName {\n\t\t\tdeployment.Spec.Template.Spec.Containers[i].Args = args\n\t\t}\n\t}\n}\n\nfunc updateResourceRequirement(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) error {\n\tif reflect.ValueOf(istiocsr.Spec.IstioCSRConfig.Resources).IsZero() {\n\t\treturn nil\n\t}\n\tif err := common.ValidateResourceRequirements(istiocsr.Spec.IstioCSRConfig.Resources,\n\t\tfield.NewPath(\"spec\", \"istioCSRConfig\")); err != nil {\n\t\treturn err\n\t}\n\tfor i := range deployment.Spec.Template.Spec.Containers {\n\t\tdeployment.Spec.Template.Spec.Containers[i].Resources = istiocsr.Spec.IstioCSRConfig.Resources\n\t}\n\treturn nil\n}\n\nfunc updateAffinityRules(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) error {\n\tif istiocsr.Spec.IstioCSRConfig.Affinity == nil {\n\t\treturn nil\n\t}\n\tif err := common.ValidateAffinityRules(istiocsr.Spec.IstioCSRConfig.Affinity,\n\t\tfield.NewPath(\"spec\", \"istioCSRConfig\")); err != nil {\n\t\treturn err\n\t}\n\tdeployment.Spec.Template.Spec.Affinity = istiocsr.Spec.IstioCSRConfig.Affinity\n\treturn nil\n}\n\nfunc updatePodTolerations(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) error {\n\tif istiocsr.Spec.IstioCSRConfig.Tolerations == nil {\n\t\treturn nil\n\t}\n\tif err := common.ValidateTolerationsConfig(istiocsr.Spec.IstioCSRConfig.Tolerations,\n\t\tfield.NewPath(\"spec\", \"istioCSRConfig\")); err != nil {\n\t\treturn err\n\t}\n\tdeployment.Spec.Template.Spec.Tolerations = istiocsr.Spec.IstioCSRConfig.Tolerations\n\treturn nil\n}\n\nfunc updateNodeSelector(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR) error {\n\tif istiocsr.Spec.IstioCSRConfig.NodeSelector == nil {\n\t\treturn nil\n\t}\n\tif err := common.ValidateNodeSelectorConfig(istiocsr.Spec.IstioCSRConfig.NodeSelector,\n\t\tfield.NewPath(\"spec\", \"istioCSRConfig\")); err != nil {\n\t\treturn err\n\t}\n\tdeployment.Spec.Template.Spec.NodeSelector = istiocsr.Spec.IstioCSRConfig.NodeSelector\n\treturn nil\n}\n\nfunc (r *Reconciler) assertIssuerRefExists(istiocsr *v1alpha1.IstioCSR) error {\n\tissuerRefKind := strings.ToLower(istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Kind)\n\tif issuerRefKind != clusterIssuerKind && issuerRefKind != issuerKind {\n\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"spec.istioCSRConfig.certManager.issuerRef.kind can be any of `%s` or `%s`, configured: %s\", clusterIssuerKind, issuerKind, issuerRefKind)\n\t}\n\n\tissuerRefGroup := strings.ToLower(istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Group)\n\tif issuerRefGroup != issuerGroup {\n\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"spec.istioCSRConfig.certManager.issuerRef.group can be only `%s`, configured: %s\", issuerGroup, issuerRefGroup)\n\t}\n\n\tobj, err := r.getIssuer(istiocsr)\n\tif err != nil {\n\t\treturn common.FromClientError(err, \"failed to fetch issuer\")\n\t}\n\n\tvar issuerConfig certmanagerv1.IssuerConfig\n\tswitch issuerRefKind {\n\tcase clusterIssuerKind:\n\t\tclusterIssuer, ok := obj.(*certmanagerv1.ClusterIssuer)\n\t\tif !ok {\n\t\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"failed to convert to ClusterIssuer\")\n\t\t}\n\t\tissuerConfig = clusterIssuer.Spec.IssuerConfig\n\tcase issuerKind:\n\t\tissuer, ok := obj.(*certmanagerv1.Issuer)\n\t\tif !ok {\n\t\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"failed to convert to Issuer\")\n\t\t}\n\t\tissuerConfig = issuer.Spec.IssuerConfig\n\t}\n\tif issuerConfig.ACME != nil {\n\t\treturn common.NewIrrecoverableError(errInvalidIssuerRefConfig, \"spec.istioCSRConfig.certManager.issuerRef uses unsupported ACME issuer\")\n\t}\n\n\tif err := r.updateWatchLabel(obj, istiocsr); err != nil {\n\t\treturn common.FromClientError(err, \"failed to update watch label on cert-manager issuer %s\", istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Name)\n\t}\n\n\treturn nil\n}\n\nfunc (r *Reconciler) updateVolumes(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) error {\n\t// Use user-configured CA certificate if provided\n\tif istiocsr.Spec.IstioCSRConfig.CertManager.IstioCACertificate != nil {\n\t\tif err := r.handleUserProvidedCA(deployment, istiocsr, resourceLabels); err != nil {\n\t\t\treturn common.FromError(err, \"failed to validate and mount CA certificate ConfigMap\")\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Fall back to issuer-based CA certificate if CA certificate is not configured\n\t// Handle issuer-based CA configuration\n\tif err := r.handleIssuerBasedCA(deployment, istiocsr, resourceLabels); err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\n// handleUserProvidedCA processes user-provided CA certificate configuration.\n//\n// It performs the following operations:\n//  1. Validates that the source ConfigMap exists\n//  2. Adds a watch label to the source ConfigMap for change tracking\n//  3. Validates that the ConfigMap contains the specified key and is a valid CA certificate\n//  4. Creates or updates a copy of the ConfigMap in the IstioCSR namespace\n//  5. Configures the deployment to mount the CA certificate volume\n//\n// The caller must ensure that `istiocsr.Spec.IstioCSRConfig.CertManager.IstioCACertificate`\n// is not nil before calling this function to avoid a panic.\n//\n// Returns an error if any validation fails or if ConfigMap operations fail.\nfunc (r *Reconciler) handleUserProvidedCA(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) error {\n\tcaCertConfig := istiocsr.Spec.IstioCSRConfig.CertManager.IstioCACertificate\n\n\t// Determine the namespace - use specified namespace or default to IstioCSR namespace\n\tnamespace := caCertConfig.Namespace\n\tif namespace == \"\" {\n\t\tnamespace = istiocsr.GetNamespace()\n\t}\n\n\t// Validate that the source ConfigMap exists\n\tsourceConfigMapKey := types.NamespacedName{\n\t\tName:      caCertConfig.Name,\n\t\tNamespace: namespace,\n\t}\n\n\tsourceConfigMap := &corev1.ConfigMap{}\n\tif err := r.Get(r.ctx, sourceConfigMapKey, sourceConfigMap); err != nil {\n\t\treturn common.NewIrrecoverableError(err, \"failed to fetch CA certificate ConfigMap %s/%s\", sourceConfigMapKey.Namespace, sourceConfigMapKey.Name)\n\t}\n\n\t// Add watch label to the source ConfigMap to trigger reconciliation on changes.\n\t// This is done before validation so that if validation fails now, fixing the ConfigMap\n\t// will trigger reconciliation.\n\tif err := r.updateWatchLabel(sourceConfigMap, istiocsr); err != nil {\n\t\treturn common.FromClientError(err, \"failed to update watch label on CA certificate ConfigMap %s/%s\", sourceConfigMapKey.Namespace, sourceConfigMapKey.Name)\n\t}\n\n\t// Validate that the specified key exists in the ConfigMap\n\tif _, exists := sourceConfigMap.Data[caCertConfig.Key]; !exists {\n\t\treturn common.NewIrrecoverableError(fmt.Errorf(\"key %q not found in ConfigMap %s/%s\", caCertConfig.Key, sourceConfigMapKey.Namespace, sourceConfigMapKey.Name), \"invalid CA certificate ConfigMap %s/%s\", sourceConfigMapKey.Namespace, sourceConfigMapKey.Name)\n\t}\n\n\t// Validate that the key contains PEM-formatted content\n\tpemData := sourceConfigMap.Data[caCertConfig.Key]\n\tif err := r.validatePEMData(pemData); err != nil {\n\t\treturn common.NewIrrecoverableError(err, \"invalid PEM data in CA certificate ConfigMap %s/%s key %q\", sourceConfigMapKey.Namespace, sourceConfigMapKey.Name, caCertConfig.Key)\n\t}\n\n\t// Create a managed copy of the ConfigMap in the IstioCSR namespace.\n\t// The operator does not directly mount the user-provided ConfigMap but creates a managed copy\n\t// (cert-manager-istio-csr-issuer-ca-copy) in the IstioCSR namespace. This approach enables the\n\t// operator to validate any changes to the source ConfigMap before propagating them to the istio-csr\n\t// agent, as ConfigMap changes automatically propagate to mounted pods. The watch label on the source\n\t// ConfigMap triggers reconciliation when modified, allowing the operator to re-validate and update\n\t// its managed copy. Additionally, if a user directly modifies the operator-managed copy, it will be\n\t// reconciled back to the desired state derived from the validated source ConfigMap.\n\tif err := r.createOrUpdateCAConfigMap(istiocsr, pemData, resourceLabels); err != nil {\n\t\treturn common.FromClientError(err, \"failed to create CA certificate ConfigMap copy\")\n\t}\n\n\t// Mount the copied CA certificate ConfigMap (always uses the standard name)\n\tupdateVolumeWithIssuerCA(deployment)\n\n\treturn nil\n}\n\n// handleIssuerBasedCA handles the creation of CA ConfigMap from issuer secret and volume mounting.\nfunc (r *Reconciler) handleIssuerBasedCA(deployment *appsv1.Deployment, istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) error {\n\tvar (\n\t\tissuerConfig certmanagerv1.IssuerConfig\n\t)\n\n\tobj, err := r.getIssuer(istiocsr)\n\tif err != nil {\n\t\treturn common.FromClientError(err, \"failed to fetch issuer\")\n\t}\n\n\tissuerRefKind := strings.ToLower(istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Kind)\n\tswitch issuerRefKind {\n\tcase clusterIssuerKind:\n\t\tclusterIssuer, ok := obj.(*certmanagerv1.ClusterIssuer)\n\t\tif !ok {\n\t\t\treturn common.FromClientError(fmt.Errorf(\"failed to convert to ClusterIssuer\"), \"failed to fetch issuer\")\n\t\t}\n\t\tissuerConfig = clusterIssuer.Spec.IssuerConfig\n\tcase issuerKind:\n\t\tissuer, ok := obj.(*certmanagerv1.Issuer)\n\t\tif !ok {\n\t\t\treturn common.FromClientError(fmt.Errorf(\"failed to convert to Issuer\"), \"failed to fetch issuer\")\n\t\t}\n\t\tissuerConfig = issuer.Spec.IssuerConfig\n\t}\n\n\tshouldUpdateVolume := false\n\n\tif issuerConfig.CA != nil && issuerConfig.CA.SecretName != \"\" {\n\t\tif err := r.createCAConfigMapFromIssuerSecret(istiocsr, issuerConfig, resourceLabels); err != nil {\n\t\t\treturn common.FromClientError(err, \"failed to create CA ConfigMap\")\n\t\t}\n\t\tshouldUpdateVolume = true\n\t}\n\n\tif issuerConfig.CA == nil {\n\t\tif err := r.createCAConfigMapFromIstiodCertificate(istiocsr, resourceLabels); err != nil {\n\t\t\treturn common.FromClientError(err, \"failed to create CA ConfigMap\")\n\t\t}\n\t\tshouldUpdateVolume = true\n\t}\n\n\tif shouldUpdateVolume {\n\t\tupdateVolumeWithIssuerCA(deployment)\n\t}\n\n\treturn nil\n}\n\nfunc updateVolumeWithIssuerCA(deployment *appsv1.Deployment) {\n\tconst (\n\t\tcaVolumeName = \"root-ca\"\n\t)\n\tvar (\n\t\tdefaultMode = int32(420)\n\t)\n\n\tdesiredVolumeMount := corev1.VolumeMount{\n\t\tName:      caVolumeName,\n\t\tMountPath: caVolumeMountPath,\n\t\tReadOnly:  true,\n\t}\n\n\tdesiredVolume := corev1.Volume{\n\t\tName: caVolumeName,\n\t\tVolumeSource: corev1.VolumeSource{\n\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n\t\t\t\t\tName: IstiocsrCAConfigMapName,\n\t\t\t\t},\n\t\t\t\tItems: []corev1.KeyToPath{\n\t\t\t\t\t{\n\t\t\t\t\t\tKey:  IstiocsrCAKeyName,\n\t\t\t\t\t\tPath: IstiocsrCAKeyName,\n\t\t\t\t\t\tMode: &defaultMode,\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t\tDefaultMode: &defaultMode,\n\t\t\t},\n\t\t},\n\t}\n\n\t// Update or append volume mount in the istio-csr container\n\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == istiocsrContainerName {\n\t\t\tvolumeMountExists := false\n\t\t\tfor j, vm := range container.VolumeMounts {\n\t\t\t\tif vm.Name == caVolumeName {\n\t\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts[j] = desiredVolumeMount\n\t\t\t\t\tvolumeMountExists = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !volumeMountExists {\n\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts = append(\n\t\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts,\n\t\t\t\t\tdesiredVolumeMount,\n\t\t\t\t)\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Update or append volume in the deployment\n\tvolumeExists := false\n\tfor i, vol := range deployment.Spec.Template.Spec.Volumes {\n\t\tif vol.Name == caVolumeName {\n\t\t\tdeployment.Spec.Template.Spec.Volumes[i] = desiredVolume\n\t\t\tvolumeExists = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !volumeExists {\n\t\tdeployment.Spec.Template.Spec.Volumes = append(\n\t\t\tdeployment.Spec.Template.Spec.Volumes,\n\t\t\tdesiredVolume,\n\t\t)\n\t}\n}\n\nfunc (r *Reconciler) getIssuer(istiocsr *v1alpha1.IstioCSR) (client.Object, error) {\n\tissuerRefKind := strings.ToLower(istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Kind)\n\tkey := client.ObjectKey{\n\t\tName:      istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Name,\n\t\tNamespace: istiocsr.Spec.IstioCSRConfig.Istio.Namespace,\n\t}\n\n\tvar object client.Object\n\tswitch issuerRefKind {\n\tcase clusterIssuerKind:\n\t\tobject = &certmanagerv1.ClusterIssuer{}\n\tcase issuerKind:\n\t\tobject = &certmanagerv1.Issuer{}\n\t}\n\n\tif err := r.Get(r.ctx, key, object); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to fetch %q issuer: %w\", key, err)\n\t}\n\treturn object, nil\n}\n\nfunc (r *Reconciler) createCAConfigMapFromIstiodCertificate(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) error {\n\tistiodCertificate, err := r.getCertificateObject(istiocsr, resourceLabels)\n\tif err != nil {\n\t\treturn common.FromClientError(err, \"failed to fetch istiod certificate\")\n\t}\n\n\tsecretKey := client.ObjectKey{\n\t\tName:      istiodCertificate.Spec.SecretName,\n\t\tNamespace: istiodCertificate.GetNamespace(),\n\t}\n\tsecret := &corev1.Secret{}\n\tif err := r.Get(r.ctx, secretKey, secret); err != nil {\n\t\treturn fmt.Errorf(\"failed to fetch secret in issuer: %w\", err)\n\t}\n\tif err := r.updateWatchLabel(secret, istiocsr); err != nil {\n\t\treturn err\n\t}\n\n\tcertData := string(secret.Data[IstiocsrCAKeyName])\n\treturn r.createOrUpdateCAConfigMap(istiocsr, certData, resourceLabels)\n}\n\nfunc (r *Reconciler) createCAConfigMapFromIssuerSecret(istiocsr *v1alpha1.IstioCSR, issuerConfig certmanagerv1.IssuerConfig, resourceLabels map[string]string) error {\n\tif issuerConfig.CA.SecretName == \"\" {\n\t\treturn fmt.Errorf(\"failed to fetch CA certificate configured for the %s issuer of CA type\", istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Name)\n\t}\n\n\tsecretKey := client.ObjectKey{\n\t\tName:      issuerConfig.CA.SecretName,\n\t\tNamespace: istiocsr.Spec.IstioCSRConfig.Istio.Namespace,\n\t}\n\tsecret := &corev1.Secret{}\n\tif err := r.Get(r.ctx, secretKey, secret); err != nil {\n\t\treturn fmt.Errorf(\"failed to fetch secret in issuer: %w\", err)\n\t}\n\tif err := r.updateWatchLabel(secret, istiocsr); err != nil {\n\t\treturn err\n\t}\n\n\tcertData := string(secret.Data[IstiocsrCAKeyName])\n\treturn r.createOrUpdateCAConfigMap(istiocsr, certData, resourceLabels)\n}\n\n// createOrUpdateCAConfigMap creates or updates the CA ConfigMap with the provided certificate data.\nfunc (r *Reconciler) createOrUpdateCAConfigMap(istiocsr *v1alpha1.IstioCSR, certData string, resourceLabels map[string]string) error {\n\tif certData == \"\" {\n\t\treturn fmt.Errorf(\"failed to find CA certificate\")\n\t}\n\n\tconfigmapKey := client.ObjectKey{\n\t\tName:      IstiocsrCAConfigMapName,\n\t\tNamespace: istiocsr.GetNamespace(),\n\t}\n\tfetched := &corev1.ConfigMap{}\n\texist, err := r.Exists(r.ctx, configmapKey, fetched)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to check if CA configmap exists: %w\", err)\n\t}\n\n\tdesired := &corev1.ConfigMap{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      configmapKey.Name,\n\t\t\tNamespace: configmapKey.Namespace,\n\t\t\tLabels:    resourceLabels,\n\t\t},\n\t\tData: map[string]string{\n\t\t\tIstiocsrCAKeyName: certData,\n\t\t},\n\t}\n\n\tif exist && hasObjectChanged(desired, fetched) {\n\t\tr.log.V(1).Info(\"ca configmap need update\", \"name\", configmapKey)\n\t\tif err := r.UpdateWithRetry(r.ctx, desired); err != nil {\n\t\t\treturn fmt.Errorf(\"failed to update %s configmap resource: %w\", configmapKey, err)\n\t\t}\n\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"configmap resource %s reconciled back to desired state\", configmapKey)\n\t} else {\n\t\tr.log.V(4).Info(\"configmap resource already exists and is in expected state\", \"name\", configmapKey)\n\t}\n\n\tif !exist {\n\t\tif err := r.Create(r.ctx, desired); err != nil {\n\t\t\treturn fmt.Errorf(\"failed to create %s configmap resource: %w\", configmapKey, err)\n\t\t}\n\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"configmap resource %s created\", configmapKey)\n\t}\n\n\treturn nil\n}\n\nfunc (r *Reconciler) validatePEMData(pemData string) error {\n\tif pemData == \"\" {\n\t\treturn fmt.Errorf(\"PEM data is empty\")\n\t}\n\n\t// Parse the first certificate from PEM data\n\tblock, _ := pem.Decode([]byte(pemData))\n\tif block == nil {\n\t\treturn fmt.Errorf(\"no valid PEM data found\")\n\t}\n\n\tif block.Type != \"CERTIFICATE\" {\n\t\treturn fmt.Errorf(\"PEM block is not a certificate, found: %s\", block.Type)\n\t}\n\n\tcert, err := x509.ParseCertificate(block.Bytes)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to parse certificate: %w\", err)\n\t}\n\n\tif !cert.BasicConstraintsValid {\n\t\treturn fmt.Errorf(\"certificate does not have valid Basic Constraints extension\")\n\t}\n\n\tif !cert.IsCA {\n\t\treturn fmt.Errorf(\"certificate is not a CA certificate\")\n\t}\n\n\t// Check Key Usage for certificate signing\n\tif cert.KeyUsage&x509.KeyUsageCertSign == 0 {\n\t\treturn fmt.Errorf(\"certificate does not have Certificate Sign key usage\")\n\t}\n\n\treturn nil\n}\n\n// updateWatchLabel adds a watch label to any Kubernetes object that supports labels.\nfunc (r *Reconciler) updateWatchLabel(obj client.Object, istiocsr *v1alpha1.IstioCSR) error {\n\tlabels := obj.GetLabels()\n\tif labels == nil {\n\t\tlabels = make(map[string]string)\n\t}\n\tlabels[IstiocsrResourceWatchLabelName] = fmt.Sprintf(istiocsrResourceWatchLabelValueFmt, istiocsr.GetNamespace(), istiocsr.GetName())\n\tobj.SetLabels(labels)\n\n\tif err := r.UpdateWithRetry(r.ctx, obj); err != nil {\n\t\treturn fmt.Errorf(\"failed to update %s resource with watch label: %w\", obj.GetName(), err)\n\t}\n\treturn nil\n}\n","numLines":647,"startLine":1,"totalLines":647}}}

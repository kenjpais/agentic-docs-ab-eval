 affinity application\n46\t\t// and helps operators understand which configurations affected a pod's scheduling.\n47\t\t//\n48\t\t// Note: The annotation may grow with multiple PodPlacementConfigs. Kubernetes has a\n49\t\t// 256KB total annotation limit per object. No per-annotation size validation is\n50\t\t// currently enforced by the operator.\n51\t\tPreferredNodeAffinitySourcesAnnotation = \"multiarch.openshift.io/preferred-affinity-sources\"\n52\t\tNodeAffinityLabelValueSet              = \"set\"\n53\t\tLabelValueNotSet                       = \"not-set\"\n54\t\tHostnameLabel                          = \"kubernetes.io/hostname\"\n55\t\tSchedulingGateLabel                    = \"multiarch.openshift.io/scheduling-gate\"\n56\t\tSchedulingGateLabelValueGated          = \"gated\"\n57\t\tSchedulingGateLabelValueRemoved        = \"removed\"\n58\t\tPodPlacementFinalizerName              = \"finalizers.multiarch.openshift.io/pod-placement\"\n59\t\tCPPCNoPPCObjectFinalizer               = \"finalizers.multiarch.openshift.io/no-pod-placement-config\"\n60\t\tSingleArchLabel                        = \"multiarch.openshift.io/single-arch\"\n61\t\tMultiArchLabel                         = \"multiarch.openshift.io/multi-arch\"\n62\t\tNoSupportedArchLabel                   = \"multiarch.openshift.io/no-supported-arch\"\n63\t\tFallbackArchitectureLabel              = \"multiarch.openshift.io/fallback-arch\"\n64\t\tImageInspectionErrorLabel              = \"multiarch.openshift.io/image-inspect-error\"\n65\t\tImageInspectionErrorCountLabel         = \"multiarch.openshift.io/image-inspect-error-count\"\n66\t\tLabelGroup                             = \"multiarch.openshift.io\"\n67\t)\n68\t\n69\tconst (\n70\t\t// SchedulingGateName is the name of the Scheduling Gate\n71\t\tSchedulingGateName            = \"multiarch.openshift.io/scheduling-gate\"\n72\t\tMasterNodeSelectorLabel       = \"node-role.kubernetes.io/master\"\n73\t\tControlPlaneNodeSelectorLabel = \"node-role.kubernetes.io/co
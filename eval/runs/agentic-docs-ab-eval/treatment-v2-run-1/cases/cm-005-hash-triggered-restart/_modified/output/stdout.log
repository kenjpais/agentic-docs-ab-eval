{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01TkgW7YxSCcHAPSjszaAj8a","type":"tool_result","content":"1\tpackage istiocsr\n2\t\n3\timport (\n4\t\t\"os\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\tcertmanagerapi \"github.com/cert-manager/cert-manager/pkg/apis/certmanager\"\n9\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n10\t)\n11\t\n12\tconst (\n13\t\t// istiocsrCommonName is the name commonly used for naming resources.\n14\t\tistiocsrCommonName = \"cert-manager-istio-csr\"\n15\t\n16\t\t// ControllerName is the name of the controller used in logs and events.\n17\t\tControllerName = istiocsrCommonName + \"-controller\"\n18\t\n19\t\t// controllerProcessedAnnotation is the annotation added to istiocsr resource once after\n20\t\t// successful reconciliation by the controller.\n21\t\tcontrollerProcessedAnnotation = \"operator.openshift.io/istio-csr-processed\"\n22\t\n23\t\t// controllerProcessingRejectedAnnotation is the annotation added to istiocsr resource when multiple\n24\t\t// instances of istiocsr resource is created.\n25\t\tcontrollerProcessingRejectedAnnotation = \"operator.openshift.io/istio-csr-reject-multiple-instance\"\n26\t\n27\t\t// finalizer name for istiocsr.openshift.operator.io resource.\n28\t\tfinalizer = \"istiocsr.openshift.operator.io/\" + ControllerName\n29\t\n30\t\t// defaultRequeueTime is the default reconcile requeue time.\n31\t\tdefaultRequeueTime = time.Second * 30\n32\t\n33\t\t// istiocsrObjectName is the name of the istio-csr resource created by user.\n34\t\t// istio-csr CRD enforces name to be `default`.\n35\t\tistiocsrObjectName = \"default\"\n36\t\n37\t\t// istiocsrContainerName is the name of the container created for istiocsr.\n38\t\tistiocsrContainerName = istiocsrCommonName\n39\t\n40\t\t// istiocsrImageNameEnvVarName is the environment variable key name\n41\t\t// containing the image name of the istiocsr as value.\n42\t\tistiocsrImageNameEnvVarName = \"RELATED_IMAGE_CERT_MANAGER_ISTIOCSR\"\n43\t\n44\t\t// istiocsrImageVersionEnvVarName is the environment variable key name\n45\t\t// containing the image version of the istiocsr as value.\n46\t\tistiocsrImageVersionEnvVarName = \"ISTIOCSR_OPERAND_IMAGE_VERSION\"\n47\t\n48\t\t// defaultClusterID is the default Kubernetes cluster identifier used by istio-csr\n49\t\t// when no custom cluster ID is configured.\n50\t\tdefaultClusterID = \"Kubernetes\"\n51\t\n52\t\t// defaultIstioRevision is the Istio default revision name. When this revision is\n53\t\t// specified, the DNS SAN uses the base istiod service name rather than a\n54\t\t// revision-prefixed name.\n55\t\tdefaultIstioRevision = \"default\"\n56\t\n57\t\t// istiocsrGRPCEndpointFmt is the format string for the istiocsr GRPC service endpoint.\n58\t\tistiocsrGRPCEndpointFmt = \"%s.%s.svc:%d\"\n59\t\n60\t\t// istiodCertificateCommonNameFmt is the format string for deriving the istiod certificate common name\n61\t\t// and default DNS name.\n62\t\tistiodCertificateCommonNameFmt = \"istiod.%s.svc\"\n63\t\n64\t\t// istiodCertificateRevisionBasedDNSName is the format string for deriving the istiod certificate DNS name\n65\t\t// for each defined revision.\n66\t\tistiodCertificateRevisionBasedDNSName = \"istiod-%s.%s.svc\"\n67\t\n68\t\t// istiodCertificateSpiffeURIFmt is the format string for deriving the istiod certificate URI.\n69\t\tistiodCertificateSpiffeURIFmt = \"spiffe://%s/ns/%s/sa/istiod-service-account\"\n70\t\n71\t\t// istiocsrNamespaceMappingLabelName is the label name for identifying the cluster resources or resources\n72\t\t// created in other namespaces by the controller.\n73\t\tistiocsrNamespaceMappingLabelName = \"cert-manager-istio-csr-namespace\"\n74\t\n75\t\t// IstiocsrResourceWatchLabelName is the label name for identifying the resources of interest for the\n76\t\t// controller but does not create or manage the resource.\n77\t\tIstiocsrResourceWatchLabelName = \"istiocsr.openshift.operator.io/watched-by\"\n78\t\n79\
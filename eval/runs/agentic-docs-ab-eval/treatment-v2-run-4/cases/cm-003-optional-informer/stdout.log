}\n```\n\nAppend the new function at the end of the file (after `deploymentModified` and friends):\n\n```go\n// updateProxyEnv injects HTTP_PROXY, HTTPS_PROXY, and NO_PROXY environment\n// variables into the trust-manager container when the cluster Proxy API is\n// available. Values are read from the config.openshift.io/v1 Proxy/cluster\n// status, which contains the effective proxy settings computed by the cluster\n// network operator. On clusters without the Proxy API (MicroShift, vanilla\n// Kubernetes), this is a no-op.\nfunc (r *Reconciler) updateProxyEnv(deployment *appsv1.Deployment) error {\n\tif !r.proxyInformer.Applicable() {\n\t\treturn nil\n\t}\n\n\tproxyConfig, err := (*r.proxyInformer.InformerFactory).Config().V1().Proxies().Lister().Get(\"cluster\")\n\tif err != nil {\n\t\tr.log.V(2).Info(\"unable to read cluster proxy settings, skipping proxy env injection\", \"error\", err)\n\t\treturn nil\n\t}\n\n\tvar proxyEnvVars []corev1.EnvVar\n\tif proxyConfig.Status.HTTPProxy != \"\" {\n\t\tproxyEnvVars = append(proxyEnvVars, corev1.EnvVar{Name: \"HTTP_PROXY\", Value: proxyConfig.Status.HTTPProxy})\n\t}\n\tif proxyConfig.Status.HTTPSProxy != \"\" {\n\t\tproxyEnvVars = append(proxyEnvVars, corev1.EnvVar{Name: \"HTTPS_PROXY\", Value: proxyConfig.Status.HTTPSProxy})\n\t}\n\tif proxyConfig.Status.NoProxy != \"\" {\n\t\tproxyEnvVars = append(proxyEnvVars, corev1.EnvVar{Name: \"NO_PROXY\", Value: proxyConfig.Status.NoProxy})\n\t}\n\n\tif len(proxyEnvVars) == 0 {\n\t\treturn nil\n\t}\n\n\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == trustManagerContainerName {\n\t\t\tdeployment.Spec.Template.Spec.Containers[i].Env = append(\n\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].Env,\n\t\t\t\tproxyEnvVars...,\n\t\t\t)\n\t\t\tbreak\n\t\t}\n\t}\n\n\treturn nil\n}\n```\n\n---\n\n## Summary of all changes\n\n| File | Change |\n|---|---|\n| `pkg/operator/utils/apidiscovery.go` | Add `NewProxyInformerIfAvailable` convenience function + OpenShift imports |\n| `pkg/operator/starter.go` | Create proxy informer, start its factory, pass via `ControllerConfig` |\n| `pkg/operator/setup_manager.go` | Add `ProxyInformer` to `ControllerConfig`, thread to `setupTrustManagerController` \u2192 `trustmanager.New` |\n| `pkg/controller/trustmanager/controller.go` | Add `proxyInformer` field to `Reconciler`, accept in `New()`, add RBAC marker |\n| `pkg/controller/trustmanager/deployments.go` | Add `updateProxyEnv` method, call from `getDeploymentObject` |\n\n## Commands to run\n\n```bash\n# 1. Regenerate CRD manifests and deepcopy (picks up the new RBAC marker)\nmake update\n\n# 2. Verify vendor dependencies are consistent (no new deps needed \u2014\n#    configv1, configv1client, configinformers are already vendored)\ngo build ./...\n\n# 3. Run unit tests\nmake test\n```\n\nNo new Go module dependencies are required \u2014 `github.com/openshift/api/config/v1`, `github.com/openshift/client-go/config/clientset/versioned`, and `github.com/openshift/client-go/config/informers/externalversions` are already vendored and used by `pkg/operator/starter.go` and `pkg/controller/certmanager/`.", "stop_reason": "end_turn", "session_id": "20d91e02-72c5-45a5-97e1-59adfca2ee70", "total_cost_usd": 1.2550485, "usage": {"input_tokens": 2117, "cache_creation_input_tokens": 51958, "cache_read_input_tokens": 894552, "output_tokens": 18898, "server_tool_use": {"web_search_requests": 0, "web_fetch_requests": 0}, "service_tier": "standard", "cache_creation": {"ephemeral_1h_input_tokens": 0, "ephemeral_5m_input_tokens": 51958}, "inference_geo": "", "iterations": [], "speed": "standard"}, "modelUsage": {"claude-opus-4-6": {"inputTokens": 2117, "outputTokens": 18898, "cacheReadInputTokens": 894552, "cacheCreationInputTokens": 51958, "webSearchRequests": 0, "costUSD": 1.2550485, "contextWindow": 200000, "maxOutputTokens": 64000}}, "permission_denials": [], "terminal_reason": "completed", "fast_mode_state": "off", "uuid": "3e600b50
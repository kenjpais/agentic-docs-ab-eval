{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01TXNu5wG17V9zcAvA5WeuWA","type":"tool_result","content":"1\tpackage istiocsr\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\t\"strings\"\n8\t\n9\t\tappsv1 \"k8s.io/api/apps/v1\"\n10\t\tcorev1 \"k8s.io/api/core/v1\"\n11\t\tnetworkingv1 \"k8s.io/api/networking/v1\"\n12\t\trbacv1 \"k8s.io/api/rbac/v1\"\n13\t\t\"k8s.io/apimachinery/pkg/api/errors\"\n14\t\t\"k8s.io/apimachinery/pkg/runtime\"\n15\t\t\"k8s.io/apimachinery/pkg/types\"\n16\t\t\"k8s.io/client-go/tools/record\"\n17\t\n18\t\tctrl \"sigs.k8s.io/controller-runtime\"\n19\t\t\"sigs.k8s.io/controller-runtime/pkg/builder\"\n20\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n21\t\t\"sigs.k8s.io/controller-runtime/pkg/handler\"\n22\t\t\"sigs.k8s.io/controller-runtime/pkg/predicate\"\n23\t\t\"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n24\t\n25\t\t\"github.com/go-logr/logr\"\n26\t\n27\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n28\t\n29\t\tv1alpha1 \"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n30\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n31\t)\n32\t\n33\t// RequestEnqueueLabelValue is the label value used for filtering reconcile\n34\t// events to include only the resources created by the IstioCSR controller.\n35\t// The label key is common.ManagedResourceLabelKey.\n36\tconst RequestEnqueueLabelValue = \"cert-manager-istio-csr\"\n37\t\n38\t// Reconciler reconciles a IstioCSR object.\n39\ttype Reconciler struct {\n40\t\tcommon.CtrlClient\n41\t\n42\t\tctx           context.Context\n43\t\teventRecorder record.EventRecorder\n44\t\tlog           logr.Logger\n45\t\tscheme        *runtime.Scheme\n46\t}\n47\t\n48\t// +kubebuilder:rbac:groups=operator.openshift.io,resources=istiocsrs,verbs=get;list;watch;update;patch\n49\t// +kubebuilder:rbac:groups=operator.openshift.io,resources=istiocsrs/status,verbs=get;update;patch\n50\t// +kubebuilder:rbac:groups=operator.openshift.io,resources=istiocsrs/finalizers,verbs=update\n51\t// +kubebuilder:rbac:groups=networking.k8s.io,resources=networkpolicies,verbs=get;list;watch;create;update;patch;delete\n52\t\n53\t// New returns a new Reconciler instance.\n54\tfunc New(mgr ctrl.Manager) (*Reconciler, error) {\n55\t\tc, err := common.NewClient(mgr)\n56\t\tif err != nil {\n57\t\t\treturn nil, err\n58\t\t}\n59\t\treturn &Reconciler{\n60\t\t\tCtrlClient:    c,\n61\t\t\tctx:           context.Background(),\n62\t\t\teventRecorder: mgr.GetEventRecorderFor(ControllerName),\n63\t\t\tlog:           ctrl.Log.WithName(ControllerName),\n64\t\t\tscheme:        mgr.GetScheme(),\n65\t\t}, nil\n66\t}\n67\t\n68\t// SetupWithManager sets up the controller with the Manager.\n69\tfunc (r *Reconciler) SetupWithManager(mgr ctrl.Manager) error {\n70\t\tmapFunc := func(ctx context.Context, obj client.Object) []reconcile.Request {\n71\t\t\tr.log.V(4).Info(\"received reconcile event\", \"object\", fmt.Sprintf(\"%T\", obj), \"name\", obj.GetName(), \"namespace\", obj.GetNamespace())\n72\t\n73\t\t\tobjLabels := obj.GetLabels()\n74\t\t\tif objLabels != nil {\n75\t\t\t\t// will look for custom label set on objects not created in istiocsr namespace, and if it exists,\n76\t\t\t\t// namespace in the reconcile request will be set same, else since label check matches is an object\n77\t\t\t\t// created by controller, and we safely assume, it's in the istiocsr namespace.\n78\t\t\t\tnamespace := objLabels[istiocsrNamespaceMappingLabelName]\n79\t\t\t\tif namespace == \"\" {\n80\t\t\t\t\tnamespace = obj.GetNamespace()\n81\t\t\t\t}\n82\t\n83\t\t\t\tlabelOk := func() bool {\n84\t\t\t\t\tif objLabels[common.ManagedResourceLabelKey] == RequestEnqueueLabelValue {\n85\t\t\t\t\t\treturn true\n86\t\t\t\t\t}\n87\t\t\t\t\tvalue := objLabels[IstiocsrResourceWatchLabelName]\n88\t\t\t\t\tif value == \"\" {\n89\t\t\t\t\t\treturn false\n90\t\t\t\t\t}\n91\t\t\t\t\tkey := strings.Split(value, \"_\")\n92\t\t\t\
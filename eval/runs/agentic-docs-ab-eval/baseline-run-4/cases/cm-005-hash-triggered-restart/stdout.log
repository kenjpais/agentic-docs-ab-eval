{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01NXdiCDUkcxDZPRhLbcJgdq","type":"tool_result","content":"27\t\n28\t// ObjectMetadataModified compares the labels of two objects and returns true if they differ.\n29\tfunc ObjectMetadataModified(desired, fetched client.Object) bool {\n30\t\treturn !reflect.DeepEqual(desired.GetLabels(), fetched.GetLabels())\n31\t}\n32\t\n33\t// ContainsAnnotation checks if the given object has the specified annotation.\n34\tfunc ContainsAnnotation(obj client.Object, annotation string) bool {\n35\t\t_, exist := obj.GetAnnotations()[annotation]\n36\t\treturn exist\n37\t}\n38\t\n39\t// AddAnnotation adds an annotation to the object if it doesn't already exist.\n40\t// Returns true if the annotation was added, false if it already existed.\n41\tfunc AddAnnotation(obj client.Object, annotation, value string) bool {\n42\t\tannotations := obj.GetAnnotations()\n43\t\tif annotations == nil {\n44\t\t\tannotations = make(map[string]string, 1)\n45\t\t}\n46\t\tif _, exist := annotations[annotation]; !exist {"}]},"parent_tool_use_id":null,"session_id":"27ec2a12-2220-465b-808b-093680f52196","uuid":"145e7703-f5e5-47ff-b116-e4d8415a2ee5","timestamp":"2026-07-16T13:40:57.322Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-baseline/pkg/controller/common/utils.go","content":"\n// ObjectMetadataModified compares the labels of two objects and returns true if they differ.\nfunc ObjectMetadataModified(desired, fetched client.Object) bool {\n\treturn !reflect.DeepEqual(desired.GetLabels(), fetched.GetLabels())\n}\n\n// ContainsAnnotation checks if the given object has the specified annotation.\nfunc ContainsAnnotation(obj client.Object, annotation string) bool {\n\t_, exist := obj.GetAnnotations()[annotation]\n\treturn exist\n}\n\n// AddAnnotation adds an annotation to the object if it doesn't already exist.\n// Returns true if the annotation was added, false if it already existed.\nfunc AddAnnotation(obj client.Object, annotation, value string) bool {\n\tannotations := obj.GetAnnotations()\n\tif annotations == nil {\n\t\tannotations = make(map[string]string, 1)\n\t}\n\tif _, exist := annotations[annotation]; !exist {","numLines":20,"startLine":27,"totalLines":67}}}

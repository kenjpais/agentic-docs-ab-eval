{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_017TSMkgh4AbxkaoJQUpjAxo","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"testing\"\n7\t\n8\t\tcorev1 \"k8s.io/api/core/v1\"\n9\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n10\t\n11\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n12\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n13\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common/fakes\"\n14\t)\n15\t\n16\tconst testCABundle = \"-----BEGIN CERTIFICATE-----\\nthisIsATestCABundle\\n-----END CERTIFICATE-----\"\n17\t\n18\tfunc TestFormatCAPackage(t *testing.T) {\n19\t\tpkgJSON, err := formatCAPackage(testCABundle, \"12345\")\n20\t\tif err != nil {\n21\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n22\t\t}\n23\t\n24\t\tvar pkg caPackage\n25\t\tif err := json.Unmarshal(pkgJSON, &pkg); err != nil {\n26\t\t\tt.Fatalf(\"failed to unmarshal package JSON: %v\", err)\n27\t\t}\n28\t\tif pkg.Name != defaultCAPackageName {\n29\t\t\tt.Errorf(\"expected package name %q, got %q\", defaultCAPackageName, pkg.Name)\n30\t\t}\n31\t\tif pkg.Version != \"12345\" {\n32\t\t\tt.Errorf(\"expected package version %q, got %q\", \"12345\", pkg.Version)\n33\t\t}\n34\t\tif pkg.Bundle != testCABundle {\n35\t\t\tt.Errorf(\"expected bundle to match input, got different content\")\n36\t\t}\n37\t}\n38\t\n39\tfunc TestComputeCABundleHash(t *testing.T) {\n40\t\ttests := []struct {\n41\t\t\tname     string\n42\t\t\tbundle1  string\n43\t\t\tbundle2  string\n44\t\t\twantSame bool\n45\t\t}{\n46\t\t\t{\n47\t\t\t\tname:     \"same bundle produces same hash\",\n48\t\t\t\tbundle1:  testCABundle,\n49\t\t\t\tbundle2:  testCABundle,\n50\t\t\t\twantSame: true,\n51\t\t\t},\n52\t\t\t{\n53\t\t\t\tname:     \"different bundles produce different hashes\",\n54\t\t\t\tbundle1:  testCABundle,\n55\t\t\t\tbundle2:  \"-----BEGIN CERTIFICATE-----\\ndifferent\\n-----END CERTIFICATE-----\",\n56\t\t\t\twantSame: false,\n57\t\t\t},\n58\t\t}\n59\t\n60\t\tfor _, tt := range tests {\n61\t\t\tt.Run(tt.name, func(t *testing.T) {\n62\t\t\t\thash1 := computeCABundleHash(tt.bundle1)\n63\t\t\t\thash2 := computeCABundleHash(tt.bundle2)\n64\t\n65\t\t\t\tif hash1 == \"\" {\n66\t\t\t\t\tt.Fatal(\"expected non-empty hash\")\n67\t\t\t\t}\n68\t\t\t\tif (hash1 == hash2) != tt.wantSame {\n69\t\t\t\t\tt.Errorf(\"hash equality=%v, want %v (hash1=%s, hash2=%s)\", hash1 == hash2, tt.wantSame, hash1, hash2)\n70\t\t\t\t}\n71\t\t\t})\n72\t\t}\n73\t}\n74\t\n75\tfunc TestBuildDefaultCAPackageConfigMap(t *testing.T) {\n76\t\tpkgJSON := []byte(`{\"name\":\"test\",\"bundle\":\"test\",\"version\":\"1\"}`)\n77\t\tlabels := map[string]string{\"app\": \"test\"}\n78\t\tannotations := map[string]string{\"note\": \"test\"}\n79\t\n80\t\tcm := buildDefaultCAPackageConfigMap(pkgJSON, labels, annotations)\n81\t\n82\t\tif cm.Name != defaultCAPackageConfigMapName {\n83\t\t\tt.Errorf(\"expected name %q, got %q\", defaultCAPackageConfigMapName, cm.Name)\n84\t\t}\n85\t\tif cm.Namespace != operandNamespace {\n86\t\t\tt.Errorf(\"expected namespace %q, got %q\", operandNamespace, cm.Namespace)\n87\t\t}\n88\t\tif cm.Labels[\"app\"] != \"test\" {\n89\t\t\tt.Errorf(\"expected label app=test, got %v\", cm.Labels)\n90\t\t}\n91\t\tif cm.Annotations[\"note\"] != \"test\" {\n92\t\t\tt.Errorf(\"expected annotation note=test, got %v\", cm.Annotations)\n93\t\t}\n94\t\tif cm.Data[defaultCAPackageFilename] != string(pkgJSON) {\n95\t\t\tt.Errorf(\"expected data key %q to contain package JSON\", defaultCAPackageFilename)\n96\t\t}\n97\t}\n98\t\n99\tfunc TestConfigMapModified(t *testing.T) {\n100\t\tbase := func() *corev1.ConfigMap {\n101\t\t\treturn &corev1.ConfigMap{\n102\t\t\t\tData: map[string]string{defaultCAPackageFilename: `{\"name\":\"test\"}`},\n103\t\t\t}\n104\t\t}\n105\t\n106\t\ttests := []struct {\n107\t\t\tname     string\n108\t\t\tdesired  *corev1.ConfigMap\n109\t\t\texisting *corev1.ConfigMap\n110\t\t\twant     bool\n111\t\t}{\n112\t\t\t{\n113\t\t\t\tname:     \"identical ConfigMaps are not modified\",\n114\t\t\t\tdesired:  base(),\n115\t\t\t\texisting: base(),\n116\t\t\t\twant:     false,\n117\t\t\t},\n118\t\t\t{\n119\t\t\t\tname:    \"different data is detected as modified\",\n120\t\t\t\tdesired: base(),\n121\t\t\t\texisting: func() *corev1.ConfigMap {\n122\t\t\t\t\tcm := base()\n123\t\t\t\t\tcm.Data[defaultCAPackageFilename] = `{\"name\":\"changed\"}`\n124\t\t\t\t\treturn cm\n125\t\t\t\t}(),\n126\t\t\t\twant: true,\n127\t\t\t},\n128\t\t\t{\n129\t\t\t\tname:    \"extra key in existing is detected as modified\",\n130\t\t\t\tdesired: base(),\n131\t\t\t\texisting: func() *corev1.ConfigMap {\n132\t\t\t\t\tcm := base()\n133\t\t\t\t\tcm.Data[\"extra\"] = \"value\"\n134\t\t\t\t\treturn cm\n135\t\t\t\t}(),\n136\t\t\t\twant: true,\n137\t\t\t},\n138\t\t}\n139\t\n140\t\tfor _, tt := range tests {\n141\t\t\tt.Run(tt.name, func(t *testing.T) {\n142\t\t\t\tgot := configMapModified(tt.desired, tt.existing)\n143\t\t\t\tif got != tt.want {\n144\t\t\t\t\tt.Errorf(\"configMapModified() = %v, want %v\", got, tt.want)\n145\t\t\t\t}\n146\t\t\t})\n147\t\t}\n148\t}\n149\t\n150\tfunc TestDefaultCAPackageConfigMapReconciliation(t *testing.T) {\n151\t\ttests := []struct {\n152\t\t\tname            string\n153\t\t\ttm              *trustManagerBuilder\n154\t\t\tpreReq          func(*Reconciler, *fakes.FakeCtrlClient)\n155\t\t\twantHash        bool\n156\t\t\twantErr         string\n157\t\t\twantExistsCount int\n158\t\t\twantPatchCount  int\n159\t\t}{\n160\t\t\t{\n161\t\t\t\tname: \"skips when policy is Disabled\",\n162\t\t\t\ttm:   testTrustManager().WithDefaultCAPackage(v1alpha1.DefaultCAPackagePolicyDisabled),\n163\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n164\t\t\t\t},\n165\t\t\t\twantExistsCount: 0,\n166\t\t\t\twantPatchCount:  0,\n167\t\t\t},\n168\t\t\t{\n169\t\t\t\tname: \"skips when policy is unset (defaults to Disabled)\",\n170\
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01HpHuXq6c1SA3Mu2X7ANSeh","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"slices\"\n7\t\t\"testing\"\n8\t\n9\t\tappsv1 \"k8s.io/api/apps/v1\"\n10\t\tcorev1 \"k8s.io/api/core/v1\"\n11\t\t\"k8s.io/apimachinery/pkg/api/resource\"\n12\t\t\"k8s.io/utils/ptr\"\n13\t\n14\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n15\t\n16\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n17\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common/fakes\"\n18\t)\n19\t\n20\tconst testImage = \"registry.redhat.io/cert-manager/cert-manager-trust-manager-rhel9:latest\"\n21\t\n22\tfunc TestDeploymentObject(t *testing.T) {\n23\t\ttests := []struct {\n24\t\t\tname            string\n25\t\t\ttm              *trustManagerBuilder\n26\t\t\twantName        string\n27\t\t\twantNamespace   string\n28\t\t\twantLabels      map[string]string\n29\t\t\twantAnnotations map[string]string\n30\t\t}{\n31\t\t\t{\n32\t\t\t\tname:          \"sets correct name and namespace\",\n33\t\t\t\ttm:            testTrustManager(),\n34\t\t\t\twantName:      trustManagerDeploymentName,\n35\t\t\t\twantNamespace: operandNamespace,\n36\t\t\t\twantLabels: map[string]string{\n37\t\t\t\t\t\"app\": trustManagerCommonName,\n38\t\t\t\t},\n39\t\t\t},\n40\t\t\t{\n41\t\t\t\tname: \"default labels take precedence over user labels\",\n42\t\t\t\ttm:   testTrustManager().WithLabels(map[string]string{\"app\": \"should-be-overridden\"}),\n43\t\t\t\twantLabels: map[string]string{\n44\t\t\t\t\t\"app\": trustManagerCommonName,\n45\t\t\t\t},\n46\t\t\t},\n47\t\t\t{\n48\t\t\t\tname: \"merges custom labels and annotations\",\n49\t\t\t\ttm: testTrustManager().\n50\t\t\t\t\tWithLabels(map[string]string{\"user-label\": \"test-value\"}).\n51\t\t\t\t\tWithAnnotations(map[string]string{\"user-annotation\": \"test-value\"}),\n52\t\t\t\twantLabels:      map[string]string{\"user-label\": \"test-value\"},\n53\t\t\t\twantAnnotations: map[string]string{\"user-annotation\": \"test-value\"},\n54\t\t\t},\n55\t\t}\n56\t\n57\t\tfor _, tt := range tests {\n58\t\t\tt.Run(tt.name, func(t *testing.T) {\n59\t\t\t\tt.Setenv(trustManagerImageNameEnvVarName, testImage)\n60\t\t\t\tr := testReconciler(t)\n61\t\t\t\ttm := tt.tm.Build()\n62\t\t\t\tdep, err := r.getDeploymentObject(tm, getResourceLabels(tm), getResourceAnnotations(tm), \"\")\n63\t\t\t\tif err != nil {\n64\t\t\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n65\t\t\t\t}\n66\t\n67\t\t\t\tif tt.wantName != \"\" && dep.Name != tt.wantName {\n68\t\t\t\t\tt.Errorf(\"expected name %q, got %q\", tt.wantName, dep.Name)\n69\t\t\t\t}\n70\t\t\t\tif tt.wantNamespace != \"\" && dep.Namespace != tt.wantNamespace {\n71\t\t\t\t\tt.Errorf(\"expected namespace %q, got %q\", tt.wantNamespace, dep.Namespace)\n72\t\t\t\t}\n73\t\t\t\tfor key, val := range tt.wantLabels {\n74\t\t\t\t\tif dep.Labels[key] != val {\n75\t\t\t\t\t\tt.Errorf(\"expected label %s=%q, got %q\", key, val, dep.Labels[key])\n76\t\t\t\t\t}\n77\t\t\t\t}\n78\t\t\t\tfor key, val := range tt.wantAnnotations {\n79\t\t\t\t\tif dep.Annotations[key] != val {\n80\t\t\t\t\t\tt.Errorf(\"expected annotation %s=%q, got %q\", key, val, dep.Annotations[key])\n81\t\t\t\t\t}\n82\t\t\t\t}\n83\t\t\t})\n84\t\t}\n85\t}\n86\t\n87\tfunc TestDeploymentSpec(t *testing.T) {\n88\t\tt.Setenv(trustManagerImageNameEnvVarName, testImage)\n89\t\tr := testReconciler(t)\n90\t\ttm := testTrustManager().Build()\n91\t\tdep, err := r.getDeploymentObject(tm, getResourceLabels(tm), getResourceAnnotations(tm), \"\")\n92\t\tif err != nil {\n93\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n94\t\t}\n95\t\n96\t\tt.Run(\"sets correct container image\", func(t *testing.T) {\n97\t\t\tif len(dep.Spec.Template.Spec.Containers) == 0 {\n98\t\t\t\tt.Fatal(\"expected at least one container\")\n99\t\t\t}\n100\t\t\tif dep.Spec.Template.Spec.Containers[0].Image != testImage {\n101\t\t\t\tt.Errorf(\"expected image %q, got %q\", testImage, dep.Spec.Template.Spec.Containers[0].Image)\n102\t\t\t}\n103\t\t})\n104\t\n105\t\tt.Run(\"configures TLS volume\", func(t *testing.T) {\n106\t\t\tfound := false\n107\t\t\tfor _, vol := range dep.Spec.Template.Spec.Volumes {\n108\t\t\t\tif vol.Name == \"tls\" && vol.Secret != nil && vol.Secret.SecretName == trustManagerTLSSecretName {\n109\t\t\t\t\tfound = true\n110\t\t\t\t\tbreak\n111\t\t\t\t}\n112\t\t\t}\n113\t\t\tif !found {\n114\t\t\t\tt.Errorf(\"expected TLS volume with secret name %q not found\", trustManagerTLSSecretName)\n115\t\t\t}\n116\t\t})\n117\t\n118\t\tt.Run(\"sets correct service account name\", func(t *testing.T) {\n119\t\t\tif dep.Spec.Template.Spec.ServiceAccountName != trustManagerServiceAccountName {\n120\t\t\t\tt.Errorf(\"expected serviceAccountName %q, got %q\", trustManagerServiceAccountName, dep.Spec.Template.Spec.ServiceAccountName)\n121\t\t\t}\n122\t\t})\n123\t\n124\t\tt.Run(\"sets pod template labels\", func(t *testing.T) {\n125\t\t\tif dep.Spec.Template.Labels[\"app\"] != trustManagerCommonName {\n126\t\t\t\tt.Errorf(\"expected pod template label app=%q, got %q\", trustManagerCommonName, dep.Spec.Template.Labels[\"app\"])\n127\t\t\t}\n128\t\t})\n129\t}\n130\t\n131\tfunc TestDeploymentContainerArgs(t *testing.T) {\n132\t\ttests := []struct {\n133\t\t\tname            string\n134\t\t\ttmBuilder       *trustManagerBuilder\n135\t\t\texpectedArgs    []string\n136\t\t\tnotExpectedArgs []string\n137\t\t}{\n138\t\t\t{\n139\t\t\t\tname: \"default values\",\n140\t\t\t\texpectedArgs: []string{\n141\t\t\t\t\t\"--log-level=1\",\n142\t\t\t\t\t\"--log-format=text\",\n143\t\t\t\t\t\"--trust-namespace=cert-manager\",\n144\t\t\t\t\t\"--leader-elect=true\",\n145\t\t\t\t\t\"--webhook-port=6443\",\n146\t\t\t\t\t\"--metrics-port=9402\",\n147\t\t\t\t},\n148\t\t\t\tnotExpectedArgs: []string{\n149\t\t\t\t\t\"--secret-targets-enabled=true\",\n150\t\t\t\t\t\"--filter-expired-certificates=true\",\n151\t\t\t\t\tfmt.Sprintf(\"--default-package-location=%s\", defaultCAPackageLocation),\n152\t\t\t\t},\n153\t\t\t},\n154\t\t\t{\n155\t\t\t\tname: \"custom values\",\n156\t\t\t\ttmBuilder: testTrustManager().\n157\t\t\t\t\tWithLogLevel(5).\n158\t\t\t\t\tWithLogFormat(\"json\").\n159\t\t\t\t\tWithTrustNamespace(\"custom-ns\").\n160\t\t\t\t\tWithFilterExpiredCertificates(v1alpha1.FilterExpiredCertificatesPolicyEnabled),\n161\t\t\t\texpectedArgs: []string{\n162\t\t\t\t\t\"--log-level=5\",\n163\t\t\t\t\t\"--log-format=json\",\n164\t\t\t\t\t\"--trust-namespace=custom-ns\",\n165\t\t\t\t\t\"--filter-expired-certificates=true\",\n166\t\t\t\t},\n167\t\t\t\tnotExpectedArgs: []string{\n168\t\t\t\t\t\"--log-level=1\",\n169\t\t\t\t\t\"--trust-namespace=cert-manager\",\n170\t\t\t\t},\n171\t\t\t},\n172\t\t\t{\n173\t\t\t\tname:      \"falls back to default trust namespace when empty\",\n174\t\t\t\ttmBuilder: testTrustManager().WithTrustNamespace(\"\"),\n175\t\t\t\texpectedArgs: []string{\n176\t\t\t\t\tfmt.Sprintf(\"--trust-namespace=%s\", defaultTrustNamespace),\n177\t\t\t\t},\n178\t\t\t},\n179\t\t\t{\n180\t\t\t\tname:      \"includes secret-targets-enabled when policy is Custom with authorized secrets\",\n181\t\t\t\ttmBuilder: testTrustManager().WithSecretTargets(v1alpha1.SecretTargetsPolicyCustom, []string{\"my-bundle\"}),\n182\t\t\t\texpectedArgs: []string{\n183\t\t\t\t\t\"--secret-targets-enabled=true\",\n184\t\t\t\t},\n185\t\t\t},\n186\t\t\t{\n187\t\t\t\tname:      \"excludes secret-targets-enabled when policy is Disabled\",\n188\t\t\t\ttmBuilder: testTrustManager().WithSecretTargets(v1alpha1.SecretTargetsPolicyDisabled, nil),\n189\t\t\t\tnotExpectedArgs: []string{\n190\t\t\t\t\t\"--secret-targets-enabled=true\",\n191\t\t\t\t},\n192\t\t\t},\n193\t\t\t{\n194\t\t\t\tname:      \"excludes secret-targets-enabled when policy is Custom but no authorized secrets\",\n195\t\t\t\ttmBuilder: testTrustManager().WithSecretTargets(v1alpha1.SecretTargetsPolicyCustom, nil),\n196\t\t\t\tnotExpectedArgs: []string{\n197\t\t\t\t\t\"--secret-targets-enabled=true\",\n198\t\t\t\t},\n199\t\t\t},\n200\t\t\t{\n201\t\t\t\tname:      \"includes default-package-location when defaultCAPackage is Enabled\",\n202\t\t\t\ttmBuilder: testTrustManager().WithDefaultCAPackage(v1alpha1.DefaultCAPackagePolicyEnabled),\n203\t\t\t\texpectedArgs: []string{\n204\t\t\t\t\tfmt.Sprintf(\"--default-package-location=%s\", defaultCAPackageLocation),\n205\t\t\t\t},\n206\t\t\t},\n207\t\t\t{\n208\t\t\t\tname: \"excludes default-package-location when defaultCAPackage is Disabled\",\n209\t\t\t\tnotExpectedArgs: []string{\n210\t\t\t\t\tfmt.Sprintf(\"--default-package-location=%s\", defaultCAPackageLocation),\n211\t\t\t\t},\n212\t\t\t},\n213\t\t}\n214\t\n215\t\tfor _, tt := range tests {\n216\t\t\tt.Run(tt.name, func(t *testing.T) {\n217\t\t\t\tt.Setenv(trustManagerImageNameEnvVarName, testImage)\n218\t\t\t\tr := testReconciler(t)\n219\t\n220\t\t\t\ttmBuilder := tt.tmBuilder\n221\t\t\t\tif tmBuilder == nil {\n222\t\t\t\t\ttmBuilder = testTrustManager()\n223\t\t\t\t}\n224\t\t\t\ttm := tmBuilder.Build()\n225\t\n226\t\t\t\tdep, err := r.getDeploymentObject(tm, testResourceLabels(), testResourceAnnotations(), \"\")\n227\t\t\t\tif err != nil {\n228\t\t\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n229\t\t\t\t}\n230\t\n231\t\t\t\targs := dep.Spec.Template.Spec.Containers[0].Args\n232\t\t\t\tfor _, expected := range tt.expectedArgs {\n233\t\t\t\t\tif !slices.Contains(args, expected) {\n234\t\t\t\t\t\tt.Errorf(\"expected arg %q not found in %v\", expected, args)\n235\t\t\t\t\t}\n236\t\t\t\t}\n237\t\t\t\tfor _, notExpected := range tt.notExpectedArgs {\n238\t\t\t\t\tif slices.Contains(args, notExpected) {\n239\t\t\t\t\t\tt.Errorf(\"unexpected arg %q found in %v\", notExpected, args)\n240\t\t\t\t\t}\n241\t\t\t\t}\n242\t\t\t})\n243\t\t}\n244\t}\n245\t\n246\tfunc TestDeploymentDefaultCAPackage(t *testing.T) {\n247\t\tt.Setenv(trustManagerImageNameEnvVarName, testImage)\n248\t\n249\t\tt.Run(\"adds arg, volume, mount, and hash annotation when enabled\", func(t *testing.T) {\n250\t\t\tr := testReconciler(t)\n251\t\t\ttm := testTrustManager().WithDefaultCAPackage(v1alpha1.DefaultCAPackagePolicyEnabled).Build()\n252\t\t\tdep, err := r.getDeploymentObject(tm, testResourceLabels(), testResourceAnnotations(), \"abc123hash\")\n253\t\t\tif err != nil {\n254\t\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n255\t\t\t}\n256\t\n257\t\t\texpectedArg := fmt.Sprintf(\"--default-package-location=%s\", defaultCAPackageLocation)\n258\t\t\tif !slices.Contains(dep.Spec.Template.Spec.Containers[0].Args, expectedArg) {\n259\t\t\t\tt.Errorf(\"expected arg %q not found in %v\", expectedArg, dep.Spec.Template.Spec.Containers[0].Args)\n260\t\t\t}\n261\t\n262\t\t\thasVolume := false\n263\t\t\tfor _, v := range dep.Spec.Template.Spec.Volumes {\n264\t\t\t\tif v.Name == defaultCAPackageVolumeName && v.ConfigMap != nil &&\n265\t\t\t\t\tv.ConfigMap.Name == defaultCAPackageConfigMapName {\n266\t\t\t\t\thasVolume = true\n267\t\t\t\t\tbreak\n268\t\t\t\t}\n269\t\t\t}\n270\t\t\tif !hasVolume {\n271\t\t\t\tt.Errorf(\"expected volume %q with configMap %q, got volumes: %v\",\n272\t\t\t\t\tdefaultCAPackageVolumeName, defaultCAPackageConfigMapName, dep.Spec.Template.Spec.Volumes)\n273\t\t\t}\n274\t\n275\t\t\thasMount := false\n276\t\t\tfor _, vm := range dep.Spec.Template.Spec.Containers[0].VolumeMounts {\n277\t\t\t\tif vm.Name == defaultCAPackageVolumeName && vm.MountPath == defaultCAPackageMountPath && vm.ReadOnly {\n278\t\t\t\t\thasMount = true\n279\t\t\t\t\tbreak\n280\t\t\t\t}\n281\t\t\t}\n282\t\t\tif !hasMount {\n283\t\t\t\tt.Errorf(\"expected volume mount %q at %q (readOnly), got mounts: %v\",\n284\t\t\t\t\tdefaultCAPackageVolumeName, defaultCAPackageMountPath, dep.Spec.Template.Spec.Containers[0].VolumeMounts)\n285\t\t\t}\n286\t\n287\t\t\tgot, ok := dep.Spec.Template.Annotations[defaultCAPackageHashAnnotation]\n288\t\t\tif !ok {\n289\t\t\t\tt.Fatalf(\"expected pod template annotation %q to be set\", defaultCAPackageHashAnnotation)\n290\t\t\
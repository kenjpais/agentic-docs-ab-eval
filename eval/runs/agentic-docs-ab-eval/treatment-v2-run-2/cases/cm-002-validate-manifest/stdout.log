estResourceLabels(), testResourceAnnotations(), \"\")\n393\t\t\t\tif err != nil {\n394\t\t\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n395\t\t\t\t}\n396\t\n397\t\t\t\tcontainer := dep.Spec.Template.Spec.Containers[0]\n398\t\t\t\tif tt.wantCPURequest != \"\" && container.Resources.Requests.Cpu().String() != tt.wantCPURequest {\n399\t\t\t\t\tt.Errorf(\"expected CPU request %s, got %s\", tt.wantCPURequest, container.Resources.Requests.Cpu().String())\n400\t\t\t\t}\n401\t\t\t\tif tt.wantMemoryLimit != \"\" && container.Resources.Limits.Memory().String() != tt.wantMemoryLimit {\n402\t\t\t\t\tt.Errorf(\"expected memory limit %s, got %s\", tt.wantMemoryLimit, container.Resources.Limits.Memory().String())\n403\t\t\t\t}\n404\t\t\t\tif tt.wantTolerationKey != \"\" {\n405\t\t\t\t\tif len(dep.Spec.Template.Spec.Tolerations) == 0 {\n406\t\t\t\t\t\tt.Fatal(\"expected tolerations to be set\")\n407\t\t\t\t\t}\n408\t\t\t\t\tif dep.Spec.Template.Spec.Tolerations[0].Key != tt.wantTolerationKey {\n409\t\t\t\t\t\tt.Errorf(\"expected toleration key %q, got %q\", tt.wantTolerationKey, dep.Spec.Template.Spec.Tolerations[0].Key)\n410\t\t\t\t\t}\n411\t\t\t\t}\n412\t\t\t\tfor key, val := range tt.wantNodeSelector {\n413\t\t\t\t\tif dep.Spec.Template.Spec.NodeSelector[key] != val {\n414\t\t\t\t\t\tt.Errorf(\"expected nodeSelector %s=%q, got %q\", key, val, dep.Spec.Template.Spec.NodeSelector[key])\n415\t\t\t\t\t}\n416\t\t\t\t}\n417\t\t\t\tif tt.wantAffinity && dep.Spec.Template.Spec.Affinity == nil {\n418\t\t\t\t\tt.Error(\"expected affinity to be set\")\n419\t\t\t\t}\n420\t\t\t})\n421\t\t}\n422\t}\n423\t\n424\tfunc TestDeploymentReconciliation(t *testing.T) {\n425\t\ttests := []struct {\n426\t\t\tname            string\n427\t\t\ttmBuilder       *trustManagerBuilder\n428\t\t\tcaBundleHash    string\n429\t\t\tsetImage        bool\n430\t\t\tpreReq          func(*Reconciler, *fakes.FakeCtrlClient)\n431\t\t\twantErr         string\n432\t\t\twantExistsCount int\n433\t\t\twantPatchCount  int\n434\
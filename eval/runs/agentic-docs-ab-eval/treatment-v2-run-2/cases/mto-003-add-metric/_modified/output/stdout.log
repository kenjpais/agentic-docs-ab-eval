authJSON, err := marshaledImagePullSecrets(imageReference, secrets)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tlog := ctrllog.FromContext(ctx).WithValues(\"imageReference\", imageReference)\n\thash := computeHash(imageReference, authJSON)\n\tif architectures, ok := c.imageRefsCache.Get(hash); ok && !skipCache {\n\t\tlog.V(3).Info(\"Cache hit\", \"architectures\", architectures, \"hash\", hash)\n\t\tctrlmetrics.ImageCacheHits.With(prometheus.Labels{\"image_ref\": imageReference}).Inc()\n\t\tdefer utils.HistogramObserve(now, metrics.TimeToInspectImageGivenHit)\n\t\treturn architectures, nil\n\t}\n\tarchitectures, err := c.registryInspector.GetCompatibleArchitecturesSet(ctx, imageReference, true, secrets)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tlog.V(3).Info(\"Cache miss...adding to cache\", \"architectures\", architectures, \"hash\", hash)\n\tif !skipCache {\n\t\tc.imageRefsCache.Add(hash, architectures)\n\t}\n\tdefer utils.HistogramObserve(now, metrics.TimeToInspectImageGivenMiss)\n\treturn architectures, nil\n}\n\nfunc (c *cacheProxy) GetRegistryInspector() IRegistryInspector {\n\treturn c.registryInspector\n}\n\n// clearCache purges the image metadata cache\nfunc (c *cacheProxy) clearCache() {\n\tc.imageRefsCache.Purge()\n}\n\nfunc newCacheProxy() *cacheProxy {\n\treturn &cacheProxy{\n\t\tregistryInspector: newRegistryInspector(),\n\t\timageRefsCache:    expirable.NewLRU[string, sets.Set[string]](256, nil, time.Hour*6),\n\t}\n}\n\nfunc computeHash(imageReference string, secrets []byte) string {\n\th := sha256.New()\n\th.Write([]byte(imageReference))\n\th.Write([]byte{0})\n\th.Write(secrets)\n\treturn hex.EncodeToString(h.Sum(nil))\n}\n```\n\n---\n\n### Summary of changes\n\n| File | What changed |\n|---|---|\n| `internal/controller/podplacement/metrics/controller.go` | Added `ImageCacheHits *prometheus.CounterVec` variable; initialized it as `prometheus.NewCounterVec` with name `mto_ppo_ctrl_image_cache_hits_total` and label `image_ref`; added it to `MustRegister` |\n| `pkg/image/cache.go` | Imported `ctrlmetrics` and `prometheus`; incremented `ctrlmetrics.ImageCacheHits.With(prometheus.Labels{\"image_ref\": imageReference}).Inc()` in the cache-hit branch |\n\n### Commands to run\n\n```bash\n# Verify it compiles\nmake build\n\n# Run unit tests\nmake unit\n```\n\n### Design notes\n\n- Used `*prometheus.CounterVec` (not `prometheus.Counter`) because the metric has a label (`image_ref`). This follows Prometheus best practices for labeled metrics.\n- The metric is declared in the controller metrics package (prefix `mto_ppo_ctrl_`) per the AGENTS.md convention, since it's a controller-scoped metric.\n- The increment is placed inside the cache-hit `if` branch in `cacheProxy.GetCompatibleArchitecturesSet`, which is the exact point where an architecture result is returned from cache instead of fetched from the registry.\n- The `imageReference` (e.g. `quay.io/example/app:latest`) is used as the label value, giving per-image observability into cache hit rates."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":197,"cache_read_input_tokens":41064,"cache_creation":{"ephemeral_5m_input_tokens":197,"ephemeral_1h_input_tokens":0},"output_tokens":1},"context_management":null},"parent_tool_use_id":null,"session_id":"dc132406-b5b0-4870-b603-8f84b81cf06d","uuid":"eafaab76-0fd7-4880-b5ed-be4ab7559c34","timestamp":"2026-07-20T17:26:35.376Z","request_id":"req_vrtx_011CdDhbNmmPXmhKudcuGMkC"}

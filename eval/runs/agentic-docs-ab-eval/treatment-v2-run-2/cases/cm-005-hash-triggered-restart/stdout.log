hed.Spec.Template.Annotations`. When CA content is unchanged, the hash annotation is the same, `hasObjectChanged` returns false, and the `UpdateWithRetry` call is skipped entirely."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":15442,"cache_read_input_tokens":89750,"cache_creation":{"ephemeral_5m_input_tokens":15442,"ephemeral_1h_input_tokens":0},"output_tokens":9},"context_management":null},"parent_tool_use_id":null,"session_id":"e448ac16-8089-42df-8a5f-f54a209422fc","uuid":"9f9383ff-581a-419a-a1d8-7ae0ff542669","timestamp":"2026-07-20T17:25:07.851Z","request_id":"req_vrtx_011CdDhCc9o3MWSEvERGzwU1"}

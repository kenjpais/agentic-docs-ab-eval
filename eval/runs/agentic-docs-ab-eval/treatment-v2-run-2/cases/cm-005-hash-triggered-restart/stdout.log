{Kind: \"ServiceAccount\", Name: \"y\", Namespace: \"z\"}},\n382\t\t\t}\n383\t\t\tif !hasObjectChanged(desired, fetched) {\n384\t\t\t\tt.Error(\"hasObjectChanged() = false, want true for RoleBinding RoleRef different\")\n385\t\t\t}\n386\t\t})\n387\t}\n388\t\n389\tfunc TestServiceSpecModified(t *testing.T) {\n390\t\ttests := []struct {\n391\t\t\tname     string\n392\t\t\tdesired  *corev1.Service\n393\t\t\tfetched  *corev1.Service\n394\t\t\twantTrue bool\n395\t\t}{\n396\t\t\t{\n397\t\t\t\tname: \"identical\",\n398\t\t\t\tdesired: &corev1.Service{\n399\t\t\t\t\tSpec: corev1.ServiceSpec{\n400\t\t\t\t\t\tType:     corev1.ServiceTypeClusterIP,\n401\t\t\t\t\t\tPorts:    []corev1.ServicePort{{Port: 443}},\n402\t\t\t\t\t\tSelector: map[string]string{\"app\": \"x\"},\n403\t\t\t\t\t},\n404\t\t\t\t},\n405\t\t\t\tfetched: &corev1.Service{\n406\t\t\t\t\tSpec: corev1.ServiceSpec{\n407\t\t\t\t\t\tType:     corev1.ServiceTypeClusterIP,\n408\t\t\t\t\t\tPorts:    []corev1.ServicePort{{Port: 443}},\n409\t\t\t\t\t\tSelector: map[string]string{\"app\": \"x\"},\n410\t\t\t\t\t},\n411\t\t\t\t},\n412\t\t\t\twantTrue: false,\n413\t\t\t},\n414\t\t\t{\n415\t\t\t\tname: \"different type\",\n416\t\t\t\tdesired: &corev1.Service{\n417\t\t\t\t\tSpec: corev1.ServiceSpec{\n418\t\t\t\t\t\tType:     corev1.ServiceTypeClusterIP,\n419\t\t\t\t\t\tPorts:    []corev1.ServicePort{{Port: 443}},\n420\t\t\t\t\t\tSelector: map[string]string{\"app\": \"x\"},\n421\t\t\t\t\t},\n422\t\t\t\t},\n423\t\t\t\tfetched: &corev1.Service{\n424\t\t\t\t\tSpec: corev1.ServiceSpec{\n425\t\t\t\t\t\tType:     corev1.ServiceTypeNodePort,\n426\t\t\t\t\t\tPorts:    []corev1.ServicePort{{Port: 443}},\n427\t\t\t\t\t\tSelector: map[string]string{\"app\": \"x\"},\n428\t\t\t\t\t},\n429\t\t\t\t},\n430\t\t\t\twantTrue: true,\n431\t\t\t},\n432\t\t}\n433\t\tfor _, tt := range tests {\n434\t\t\tt.Run(tt.name, func(t *testing.T) {\n435\t\t\t\tgot := serviceSpecModified(tt.desired, tt.fetched)\n436\t\t\t\tif got != tt.wantTrue {\n437\t\t\t\t\tt.Errorf(\"serviceSpecModified() = %v, want %v\", got, tt.wantTrue)\n438\t\t\t\t}\n439\t\t\t})\n440\t\t}\n441\t}\n442\t\n443\tfunc TestCertificateSpecModified(t *testing.T) {\n444\t\ttests := []struct {\n445\t\t\tname     string\n446\t\t\tdesired  *certmanagerv1.Certificate\n447\t\t\tfetched  *certmanagerv1.Certificate\n448\t\t\twantTrue bool\n449\t\t}{\n450\t\t\t{\n451\t\t\t\tname:     \"identical\",\n452\t\t\t\tdesired:  &certmanagerv1.Certificate{Spec: certmanagerv1.CertificateSpec{DNSNames: []string{\"a.example.com\"}}},\n453\t\t\t\tfetched:  &certmanagerv1.Certificate{Spec: certmanagerv1.CertificateSpec{DNSNames: []string{\"a.example.com\"}}},\n454\t\t\t\twantTrue: false,\n455\t\t\t},\n456\t\t\t{\n457\t\t\t\tname:     \"different DNSNames\",\n458\t\t\t\tdesired:  &certmanagerv1.Certificate{Spec: certmanagerv1.CertificateSpec{DNSNames: []string{\"a.example.com\"}}},\n459\t\t\t\tfetched:  &certmanagerv1.Certificate{Spec: certmanagerv1.CertificateSpec{DNSNames: []string{\"b.example.com\"}}},\n460\t\t\t\twantTrue: true,\n461\t\t\t},\n462\t\t}\n463\t\tfor _, tt := range tests {\n464\t\t\tt.Run(tt.name, func(t *testing.T) {\n465\t\t\t\tgot := certificateSpecModified(tt.desired, tt.fetched)\n466\t\t\t\tif got != tt.wantTrue {\n467\t\t\t\t\tt.Errorf(\"certificateSpecModified() = %v, want %v\", got, tt.wantTrue)\n468\t\t\t\t}\n469\t\t\t})\n470\t\t}\n471\t}\n472\t\n473\tfunc TestConfigMapDataModified(t *testing.T) {\n474\t\ttests := []struct {\n475\t\t\tname     string\n476\t\t\tdesired  *corev1.ConfigMap\n477\t\t\tfetched  *corev1.ConfigMap\n478\t\t\twantTrue bool\n479\t\t}{\n480\t\t\t{\n481\t\t\t\tname:     \"identical\",\n482\t\t\t\tdesired:  &corev1.ConfigMap{Data: map[string]string{\"key\": \"v1\"}},\n483\t\t\t\tfetched:  &corev1.ConfigMap{Data: map[string]string{\"key\": \"v1\"}},\n484\t\t\t\twantTrue: false,\n485\t\t\t},\n486\t\t\t{\n487\t\t\t\tname:     \"different value\",\n488\t\t\t\tdesired:  &corev1.ConfigMap{Data: map[string]string{\"key\": \"v1\"}},\n489\t\t\t\tfetched:  &corev1.ConfigMap{Data: map[string]string{\"key\": \"v2\"}},\n490\t\t\t\twantTrue: true,\n491\t\t\t},\n492\t\t}\n493\t\tfor _, tt := range tests {\n494\t\t\tt.Run(tt.name, func(t *testing.T) {\n495\t\t\t\tgot := configMapDataModified(tt.desired, tt.fetched)\n496\t\t\t\tif got != tt.wantTrue {\n497\t\t\t\t\tt.Errorf(\"configMapDataModified() = %v, want %v\", got, tt.wantTrue)\n498\t\t\t\t}\n499\t\t\t})\n500\t\t}\n501\t}\n502\t\n503\tfunc TestNetworkPolicySpecModified(t *testing.T) {\n504\t\ttests := []struct {\n505\t\t\tname     string\n506\t\t\tdesired  *networkingv1.NetworkPolicy\n507\t\t\tfetched  *networkingv1.NetworkPolicy\n508\t\t\twantTrue bool\n509\t\t}{\n510\t\t\t{\n511\t\t\t\tname:     \"identical\",\n512\t\t\t\tdesired:  &networkingv1.NetworkPolicy{Spec: networkingv1.NetworkPolicySpec{PolicyTypes: []networkingv1.PolicyType{networkingv1.PolicyTypeIngress}}},\n513\t\t\t\tfetched:  &networkingv1.NetworkPolicy{Spec: networkingv1.NetworkPolicySpec{PolicyTypes: []networkingv1.PolicyType{networkingv1.PolicyTypeIngress}}},\n514\t\t\t\twantTrue: false,\n515\t\t\t},\n516\t\t\t{\n517\t\t\t\tname:     \"different PolicyTypes\",\n518\t\t\t\tdesired:  &networkingv1.NetworkPolicy{Spec: networkingv1.NetworkPolicySpec{PolicyTypes: []networkingv1.PolicyType{networkingv1.PolicyTypeIngress}}},\n519\t\t\t\tfetched:  &networkingv1.NetworkPolicy{Spec: networkingv1.NetworkPolicySpec{PolicyTypes: []networkingv1.PolicyType{networkingv1.PolicyTypeEgress}}},\n520\t\t\t\twantTrue: true,\n521\t\t\t},\n522\t\t}\n523\t\tfor _, tt := range tests {\n524\t\t\tt.Run(tt.name, func(t *testing.T) {\n525\t\t\t\tgot := networkPolicySpecModified(tt.desired, tt.fetched)\n526\t\t\t\tif got != tt.wantTrue {\n527\t\t\t\t\tt.Errorf(\"networkPolicySpecModified() = %v, want %v\", got, tt.wantTrue)\n528\t\t\t\t}\n529\t\t\t})\n530\t\t}\n531\t}\n532\t"}]},"parent_tool_use_id":null,"session_id":"e448ac16-8089-42df-8a5f-f54a209422fc","uuid":"2a1c4bf8-0539-4b8d-b6b4-2754f7946281","timestamp":"2026-07-20T17:20:44.764Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/controller/istiocsr/utils_test.go","content":"package istiocsr\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\t\"testing\"\n\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tnetworkingv1 \"k8s.io/api/networking/v1\"\n\trbacv1 \"k8s.io/api/rbac/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n)\n\n// baseDeployment returns a minimal deployment for spec comparison tests.\nfunc baseDeployment(replicas int32, image string) *appsv1.Deployment {\n\treturn &appsv1.Deployment{\n\t\tSpec: appsv1.DeploymentSpec{\n\t\t\tReplicas: &replicas,\n\t\t\tSelector: &metav1.LabelSelector{MatchLabels: map[string]string{\"app\": \"x\"}},\n\t\t\tTemplate: corev1.PodTemplateSpec{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"app\": \"x\"}},\n\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\tContainers: []corev1.Container{{\n\t\t\t\t\t\tName:  \"c\",\n\t\t\t\t\t\tImage: image,\n\t\t\t\t\t\tArgs:  []string{\"--arg\"},\n\t\t\t\t\t\tPorts: []corev1.ContainerPort{{ContainerPort: 8080}},\n\t\t\t\t\t\tReadinessProbe: &corev1.Probe{\n\t\t\t\t\t\t\tProbeHandler:        corev1.ProbeHandler{HTTPGet: &corev1.HTTPGetAction{Path: \"/ready\"}},\n\t\t\t\t\t\t\tInitialDelaySeconds: 0,\n\t\t\t\t\t\t\tPeriodSeconds:       1,\n\t\t\t\t\t\t},\n\t\t\t\t\t\tSecurityContext: &corev1.SecurityContext{},\n\t\t\t\t\t\tResources:       corev1.ResourceRequirements{},\n\t\t\t\t\t}},\n\t\t\t\t\tServiceAccountName: \"sa\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc TestHasObjectChanged(t *testing.T) {\n\ttests := []struct {\n\t\tname        string\n\t\tdesired     client.Object\n\t\tfetched     client.Object\n\t\twantPanic   bool\n\t\tpanicSubstr string\n\t\twantChanged bool\n\t}{\n\t\t{\n\t\t\tname:        \"different types panics\",\n\t\t\tdesired:     &rbacv1.ClusterRole{},\n\t\t\tfetched:     &rbacv1.ClusterRoleBinding{},\n\t\t\twantPanic:   true,\n\t\t\tpanicSubstr: \"same type\",\n\t\t},\n\t\t{\n\t\t\tname:        \"mismatched types (CR vs CRB) panics\",\n\t\t\tdesired:     &rbacv1.ClusterRole{},\n\t\t\tfetched:     &rbacv1.ClusterRoleBinding{},\n\t\t\twantPanic:   true,\n\t\t\tpanicSubstr: \"same type\",\n\t\t},\n\t\t{\n\t\t\tname: \"matching ClusterRole identical\",\n\t\t\tdesired: &rbacv1.ClusterRole{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tRules:      []rbacv1.PolicyRule{{Verbs: []string{\"get\"}}},\n\t\t\t},\n\t\t\tfetched: &rbacv1.ClusterRole{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tRules:      []rbacv1.PolicyRule{{Verbs: []string{\"get\"}}},\n\t\t\t},\n\t\t\twantChanged: false,\n\t\t},\n\t\t{\n\t\t\tname: \"ClusterRole rules different\",\n\t\t\tdesired: &rbacv1.ClusterRole{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tRules:      []rbacv1.PolicyRule{{Verbs: []string{\"get\"}, APIGroups: []string{\"\"}}},\n\t\t\t},\n\t\t\tfetched: &rbacv1.ClusterRole{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tRules:      []rbacv1.PolicyRule{{Verbs: []string{\"list\"}}},\n\t\t\t},\n\t\t\twantChanged: true,\n\t\t},\n\t\t{\n\t\t\tname: \"matching ClusterRoleBinding identical\",\n\t\t\tdesired: &rbacv1.ClusterRoleBinding{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tRoleRef:    rbacv1.RoleRef{APIGroup: \"rbac\", Kind: \"ClusterRole\", Name: \"x\"},\n\t\t\t\tSubjects:   []rbacv1.Subject{{Kind: \"ServiceAccount\", Name: \"y\", Namespace: \"z\"}},\n\t\t\t},\n\t\t\tfetched: &rbacv1.ClusterRoleBinding{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tRoleRef:    rbacv1.RoleRef{APIGroup: \"rbac\", Kind: \"ClusterRole\", Name: \"x\"},\n\t\t\t\tSubjects:   []rbacv1.Subject{{Kind: \"ServiceAccount\", Name: \"y\", Namespace: \"z\"}},\n\t\t\t},\n\t\t\twantChanged: false,\n\t\t},\n\t\t{\n\t\t\tname: \"Deployment labels different\",\n\t\t\tdesired: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Labels = map[string]string{\"a\": \"1\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\tfetched: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Labels = map[string]string{\"a\": \"2\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\twantChanged: true,\n\t\t},\n\t\t{\n\t\t\tname: \"ConfigMap identical\",\n\t\t\tdesired: &corev1.ConfigMap{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tData:       map[string]string{\"k\": \"v\"},\n\t\t\t},\n\t\t\tfetched: &corev1.ConfigMap{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tData:       map[string]string{\"k\": \"v\"},\n\t\t\t},\n\t\t\twantChanged: false,\n\t\t},\n\t\t{\n\t\t\tname: \"Service identical\",\n\t\t\tdesired: &corev1.Service{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tSpec: corev1.ServiceSpec{\n\t\t\t\t\tType:     corev1.ServiceTypeClusterIP,\n\t\t\t\t\tPorts:    []corev1.ServicePort{{Port: 443}},\n\t\t\t\t\tSelector: map[string]string{\"app\": \"x\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\tfetched: &corev1.Service{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"a\": \"1\"}},\n\t\t\t\tSpec: corev1.ServiceSpec{\n\t\t\t\t\tType:     corev1.ServiceTypeClusterIP,\n\t\t\t\t\tPorts:    []corev1.ServicePort{{Port: 443}},\n\t\t\t\t\tSelector: map[string]string{\"app\": \"x\"},\n\t\t\t\t},\n\t\t\t},\n\t\t\twantChanged: false,\n\t\t},\n\t\t{\n\t\t\tname:        \"unsupported type (Pod) panics\",\n\t\t\tdesired:     &corev1.Pod{ObjectMeta: metav1.ObjectMeta{Name: \"a\"}},\n\t\t\tfetched:     &corev1.Pod{ObjectMeta: metav1.ObjectMeta{Name: \"a\"}},\n\t\t\twantPanic:   true,\n\t\t\tpanicSubstr: \"unsupported\",\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tif tt.wantPanic {\n\t\t\t\tdefer func() {\n\t\t\t\t\tr := recover()\n\t\t\t\t\tif r == nil {\n\t\t\t\t\t\tt.Error(\"expected panic\")\n\t\t\t\t\t}\n\t\t\t\t\tif msg := fmt.Sprintf(\"%v\", r); tt.panicSubstr != \"\" && !strings.Contains(msg, tt.panicSubstr) {\n\t\t\t\t\t\tt.Errorf(\"panic message = %q, want substring %q\", msg, tt.panicSubstr)\n\t\t\t\t\t}\n\t\t\t\t}()\n\t\t\t}\n\t\t\tgot := hasObjectChanged(tt.desired, tt.fetched)\n\t\t\tif !tt.wantPanic && got != tt.wantChanged {\n\t\t\t\tt.Errorf(\"hasObjectChanged() = %v, want %v\", got, tt.wantChanged)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestDeploymentSpecModified(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tdesired  *appsv1.Deployment\n\t\tfetched  *appsv1.Deployment\n\t\twantTrue bool\n\t}{\n\t\t{\n\t\t\tname:     \"identical\",\n\t\t\tdesired:  baseDeployment(1, \"img\"),\n\t\t\tfetched:  baseDeployment(1, \"img\"),\n\t\t\twantTrue: false,\n\t\t},\n\t\t{\n\t\t\tname:     \"replicas different\",\n\t\t\tdesired:  baseDeployment(1, \"img\"),\n\t\t\tfetched:  baseDeployment(2, \"img\"),\n\t\t\twantTrue: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"image different\",\n\t\t\tdesired:  baseDeployment(1, \"img:v1\"),\n\t\t\tfetched:  baseDeployment(1, \"img:v2\"),\n\t\t\twantTrue: true,\n\t\t},\n\t\t{\n\t\t\tname: \"selector match labels different\",\n\t\t\tdesired: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Spec.Selector.MatchLabels = map[string]string{\"app\": \"x\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\tfetched: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Spec.Selector.MatchLabels = map[string]string{\"app\": \"y\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\twantTrue: true,\n\t\t},\n\t\t{\n\t\t\tname: \"template labels different\",\n\t\t\tdesired: func() *appsv1.Deployment {\n\t\t\t\td := base
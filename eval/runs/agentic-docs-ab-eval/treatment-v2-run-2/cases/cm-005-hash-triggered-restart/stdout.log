\nfunc TestComputeCAContentHash(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tcertData string\n\t}{\n\t\t{\n\t\t\tname:     \"deterministic hash\",\n\t\t\tcertData: \"-----BEGIN CERTIFICATE-----\\nMIIBtest\\n-----END CERTIFICATE-----\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"empty string\",\n\t\t\tcertData: \"\",\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\thash1 := computeCAContentHash(tt.certData)\n\t\t\thash2 := computeCAContentHash(tt.certData)\n\t\t\tif hash1 != hash2 {\n\t\t\t\tt.Errorf(\"expected deterministic hash, got %s != %s\", hash1, hash2)\n\t\t\t}\n\t\t\tif len(hash1) != 64 {\n\t\t\t\tt.Errorf(\"expected 64 char hex string, got %d chars: %s\", len(hash1), hash1)\n\t\t\t}\n\t\t\texpected := sha256.Sum256([]byte(tt.certData))\n\t\t\twant := hex.EncodeToString(expected[:])\n\t\t\tif hash1 != want {\n\t\t\t\tt.Errorf(\"computeCAContentHash() = %s, want %s\", hash1, want)\n\t\t\t}\n\t\t})\n\t}\n\n\tt.Run(\"different content produces different hash\", func(t *testing.T) {\n\t\thash1 := computeCAContentHash(\"cert-a\")\n\t\thash2 := computeCAContentHash(\"cert-b\")\n\t\tif hash1 == hash2 {\n\t\t\tt.Errorf(\"expected different hashes for different content, both are %s\", hash1)\n\t\t}\n\t})\n}\n\nfunc TestUpdateCAContentHashAnnotation(t *testing.T) {\n\tt.Run(\"sets annotation on nil annotations map\", func(t *testing.T) {\n\t\tdeployment := baseDeployment(1, \"img\")\n\t\tdeployment.Spec.Template.Annotations = nil\n\n\t\tupdateCAContentHashAnnotation(deployment, \"abc123\")\n\n\t\tgot, ok := deployment.Spec.Template.Annotations[caContentHashAnnotation]\n\t\tif !ok {\n\t\t\tt.Fatalf(\"expected annotation %q to be set\", caContentHashAnnotation)\n\t\t}\n\t\tif got != \"abc123\" {\n\t\t\tt.Errorf(\"annotation value = %q, want %q\", got, \"abc123\")\n\t\t}\n\t})\n\n\tt.Run(\"preserves existing annotations\", func(t *testing.T) {\n\t\tdeployment := baseDeployment(1, \"img\")\n\t\tdeployment.Spec.Templa
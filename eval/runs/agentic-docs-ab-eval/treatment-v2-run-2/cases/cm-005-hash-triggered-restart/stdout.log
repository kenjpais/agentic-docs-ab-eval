{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_015hvQ5AP1YrUkWycU77xm5J","type":"tool_result","content":"1\tpackage istiocsr\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"strings\"\n6\t\t\"testing\"\n7\t\n8\t\tappsv1 \"k8s.io/api/apps/v1\"\n9\t\tcorev1 \"k8s.io/api/core/v1\"\n10\t\tnetworkingv1 \"k8s.io/api/networking/v1\"\n11\t\trbacv1 \"k8s.io/api/rbac/v1\"\n12\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n13\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n14\t\n15\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n16\t)\n17\t\n18\t// baseDeployment returns a minimal deployment for spec comparison tests.\n19\tfunc baseDeployment(replicas int32, image string) *appsv1.Deployment {\n20\t\treturn &appsv1.Deployment{\n21\t\t\tSpec: appsv1.DeploymentSpec{\n22\t\t\t\tReplicas: &replicas,\n23\t\t\t\tSelector: &metav1.LabelSelector{MatchLabels: map[string]string{\"app\": \"x\"}},\n24\t\t\t\tTemplate: corev1.PodTemplateSpec{\n25\t\t\t\t\tObjectMeta: metav1.ObjectMeta{Labels: map[string]string{\"app\": \"x\"}},\n26\t\t\t\t\tSpec: corev1.PodSpec{\n27\t\t\t\t\t\tContainers: []corev1.Container{{\n28\t\t\t\t\t\t\tName:  \"c\",\n29\t\t\t\t\t\t\tImage: image,\n30\t\t\t\t\t\t\tArgs:  []string{\"--arg\"},\n31\t\t\t\t\t\t\tPorts: []corev1.ContainerPort{{ContainerPort: 8080}},\n32\t\t\t\t\t\t\tReadinessProbe: &corev1.Probe{\n33\t\t\t\t\t\t\t\tProbeHandler:        corev1.ProbeHandler{HTTPGet: &corev1.HTTPGetAction{Path: \"/ready\"}},\n34\t\t\t\t\t\t\t\tInitialDelaySeconds: 0,\n35\t\t\t\t\t\t\t\tPeriodSeconds:       1,\n36\t\t\t\t\t\t\t},\n37\t\t\t\t\t\t\tSecurityContext: &corev1.SecurityContext{},\n38\t\t\t\t\t\t\tResources:       corev1.ResourceRequirements{},\n39\t\t\t\t\t\t}},\n40\t\t\t\t\t\tServiceAccountName: \"sa\",\n41\t\t\t\t\t},\n42\t\t\t\t},\n43\t\t\t},\n44\t\t}\n45\t}\n46\t\n47\tfunc TestHasObjectChanged(t *testing.T) {\n48\t\ttests := []struct {\n49\t\t\tname        string\n50\t\t\tdesired     client.Object\n5
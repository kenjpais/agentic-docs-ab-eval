the controller already requeues every 30 seconds by default, it'll eventually catch any ConfigMap changes without explicit watch configuration.", "signature": ""}], "stop_reason": null, "stop_sequence": null, "stop_details": null, "usage": {"input_tokens": 1, "cache_creation_input_tokens": 9159, "cache_read_input_tokens": 107423, "cache_creation": {"ephemeral_5m_input_tokens": 9159, "ephemeral_1h_input_tokens": 0}, "output_tokens": 8}, "context_management": null}, "parent_tool_use_id": null, "session_id": "8fdfb16a-a511-4502-96e2-833b77f0955b", "uuid": "edca5119-7368-470d-beb1-1e7680a61438", "request_id": "req_vrtx_011Cd3ucqGMiHj97r2fNEGHD", "timestamp": "2026-07-15T13:18:09.705Z"}
{"type": "assistant", "message": {"model": "claude-opus-4-6", "id": "msg_vrtx_01TVid7Z4tezfVLsEJxpZkey", "type": "message", "role": "assistant", "content": [{"type": "text", "text": "I now have a complete picture. Here's the full implementation:\n\n---\n\n## Implementation: Content-Hash-Triggered Rolling Restart for IstioCSR\n\n### Overview\n\nThe implementation mirrors the trustmanager pattern:\n1. Read the CNO-injected CA bundle ConfigMap\n2. Compute SHA-256 hash of the PEM data\n3. Stamp the hash as a pod template annotation on the IstioCSR Deployment\n4. Compare pod template annotations in the drift detector so unchanged hashes skip the update\n\n---\n\n### File 1: NEW \u2014 `pkg/controller/istiocsr/configmaps.go`\n\n```go\npackage istiocsr\n\nimport (\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n)\n\n// readTrustedCABundle reads the CNO-injected CA bundle from the operator namespace.\n// Returns the PEM bundle and any error.\n// Returns (\"\", nil) when the ConfigMap does not exist or the expected key is absent.\nfunc (r *Reconciler) readTrustedCABundle() (string, error) {\n\tinjectionCM := &corev1.ConfigMap{}\n\tkey := client.ObjectKey{\n\t\tNamespace: common.OperatorNamespace,\n\t\tName:      common.TrustedCABundleConfigMapName,\n\t}\n\tif err := r.Get(r.ctx, key, injectionCM); err != nil {\n\t\tif errors.IsNotFound(err) {\n\t\t\tr.log.V(4).Info(\"CNO-injected CA bundle ConfigMap not found, skipping hash annotation\",\n\t\t\t\t\"name\", common.TrustedCABundleConfigMapName, \"namespace\", common.OperatorNamespace)\n\t\t\treturn \"\", nil\n\t\t}\n\t\treturn \"\", common.FromClientError(\n\t\t\terr,\n\t\t\t\"failed to read CA bundle ConfigMap %q in namespace %q\",\n\t\t\tcommon.TrustedCABundleConfigMapName, common.OperatorNamespace,\n\t\t)\n\t}\n\n\tcaBundle, ok := injectionCM.Data[common.TrustedCABundleKey]\n\tif !ok || caBundle == \"\" {\n\t\tr.log.V(4).Info(\"CNO-injected CA bundle ConfigMap does not contain expected key, skipping hash annotation\",\n\t\t\t\"name\", common.TrustedCABundleConfigMapName, \"key\", common.TrustedCABundleKey)\n\t\treturn \"\", nil\n\t}\n\n\treturn caBundle, nil\n}\n\n// computeCABundleHash returns the SHA-256 hash of the CA bundle PEM content.\n// The hash is used as a pod template annotation to trigger rolling restarts\n// only when the actual certificate content changes.\nfunc computeCABundleHash(caBundle string) string {\n\thash := sha256.Sum256([]byte(caBundle))\n\treturn hex.EncodeToString(hash[:])\n}\n\n// stampCABundleHash sets the CA bundle hash annotation on the deployment's\n// pod template spec. When the hash changes, the annotation change triggers\n// a rolling restart of the pods. No-op when caBundleHash is empty.\nfunc stampCABundleHash(deployment *appsv1.Deployment, caBundleHash string) {\n\tif caBundleHash == \"\" {\n\t\treturn\n\t}\n\tif deployment.Spec.Template.Annotations == nil {\n\t\tdeployment.Spec.Template.Annotations = make(map[string]string)\n\t}\n\tdeployment.Spec.Template.Annotations[caBundleHashAnnotation] = caBundleHash\n}\n```\n\n---\n\n### File 2: NEW \u2014 `pkg/controller/istiocsr/configmaps_test.go`\n\n```go\npackage istiocsr\n\nimport (\n\t\"context\"\n\t\"testing\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common/fakes\"\n)\n\nconst testCABundle = \"-----BEGIN CERTIFICATE-----\\nthisIsATestCABundle\\n-----END CERTIFICATE-----\"\n\nfunc TestComputeCABundleHash(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tbundle1  string\n\t\tbundle2  string\n\t\twantSame bool\n\t}{\n\t\t{\n\t\t\tname:     \"same bundle produces same hash\",\n\t\t\tbundle1:  testCABundle,\n\t\t\tbundle2:  testCABundle,\n\t\t\twantSame: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"different bundles produce different hashes\",\n\t\t\tbundle1:  testCABundle,\n\t\t\tbundle2:  \"-----BEGIN CERTIFICATE-----\\ndifferent\\n-----END CERTIFICATE-----\",\n\t\t\twantSame: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\thash1 := computeCABundleHash(tt.bundle1)\n\t\t\thash2 := computeCABundleHash(tt.bundle2)\n\n\t\t\tif hash1 == \"\" {\n\t\t\t\tt.Fatal(\"expected non-empty hash\")\n\t\t\t}\n\t\t\tif (hash1 == hash2) != tt.wantSame {\n\t\t\t\tt.Errorf(\"hash equality=%v, want %v (hash1=%s, hash2=%s)\", hash1 == hash2, tt.wantSame, hash1, hash2)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestStampCABundleHash(t *testing.T) {\n\ttests := []struct {\n\t\tname           string\n\t\thash           string\n\t\twantAnnotation bool\n\t}{\n\t\t{\n\t\t\tname:           \"stamps annotation when hash is non-empty\",\n\t\t\thash:           \"abc123\",\n\t\t\twantAnnotation: true,\n\t\t},\n\t\t{\n\t\t\tname:           \"no-op when hash is empty\",\n\t\t\thash:           \"\",\n\t\t\twantAnnotation: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdeployment := testDeployment()\n\t\t\tstampCABundleHash(deployment, tt.hash)\n\n\t\t\tann := deployment.Spec.Template.Annotations\n\t\t\tif tt.wantAnnotation {\n\t\t\t\tif ann == nil || ann[caBundleHashAnnotation] != tt.hash {\n\t\t\t\t\tt.Errorf(\"expected annotation %q=%q, got %v\", caBundleHashAnnotation, tt.hash, ann)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif ann != nil && ann[caBundleHashAnnotation] != \"\" {\n\t\t\t\t\tt.Errorf(\"expected no annotation, got %v\", ann)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestReadTrustedCABundle(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\tpreReq     func(*fakes.FakeCtrl
o` | **MODIFY** | Add `caBundleHashAnnotation` constant |\n| `pkg/controller/istiocsr/deployments.go` | **MODIFY** | Add `caBundleHash` param to `createOrApplyDeployments` and `getDeploymentObject`; call `stampCABundleHash` |\n| `pkg/controller/istiocsr/install_istiocsr.go` | **MODIFY** | Call `readTrustedCABundleHash()` before deployment reconciliation; pass hash downstream |\n| `pkg/controller/istiocsr/utils.go` | **MODIFY** | Add pod template annotation comparison to `deploymentSpecModified` (idempotency guard) |\n| `pkg/controller/istiocsr/deployments_test.go` | **MODIFY** | Update `createOrApplyDeployments` call to include `caBundleHash` parameter |\n\nThe idempotency guard works as follows: when the CA bundle content hasn't changed, `computeCABundleHash` produces the same hash, `stampCABundleHash` sets the same annotation value, and `deploymentSpecModified` (via the new `Annotations` comparison) returns `false`, causing `hasObjectChanged` to return `false` and skipping the `UpdateWithRetry` call."}], "stop_reason": null, "stop_sequence": null, "stop_details": null, "usage": {"input_tokens": 1, "cache_creation_input_tokens": 9159, "cache_read_input_tokens": 107423, "cache_creation": {"ephemeral_5m_input_tokens": 9159, "ephemeral_1h_input_tokens": 0}, "output_tokens": 8}, "context_management": null}, "parent_tool_use_id": null, "session_id": "8fdfb16a-a511-4502-96e2-833b77f0955b", "uuid": "9f2b7f73-3ce9-41ab-b204-cfe6e1665848", "request_id": "req_vrtx_011Cd3ucqGMiHj97r2fNEGHD", "timestamp": "2026-07-15T13:19:11.313Z"}
{"type": "result", "subtype": "success", "is_error": false, "api_error_status": null, "duration_ms": 260007, "duration_api_ms": 255221, "ttft_ms": 5243, "ttft_stream_ms": 4279, "time_to_request_ms": 20, "num_turns": 20, "result": "I now have a complete picture. Here's the full implementation:\n\n---\n\n## Implementation: Content-Hash-Triggered Rolling Restart for IstioCSR\n\n### Overview\n\nThe implementation mirrors the trustmanager pattern:\n1. Read the CNO-injected CA bundle ConfigMap\n2. Compute SHA-256 hash of the PEM data\n3. Stamp the hash as a pod template annotation on the IstioCSR Deployment\n4. Compare pod template annotations in the drift detector so unchanged hashes skip the update\n\n---\n\n### File 1: NEW \u2014 `pkg/controller/istiocsr/configmaps.go`\n\n```go\npackage istiocsr\n\nimport (\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n)\n\n// readTrustedCABundle reads the CNO-injected CA bundle from the operator namespace.\n// Returns the PEM bundle and any error.\n// Returns (\"\", nil) when the ConfigMap does not exist or the expected key is absent.\nfunc (r *Reconciler) readTrustedCABundle() (string, error) {\n\tinjectionCM := &corev1.ConfigMap{}\n\tkey := client.ObjectKey{\n\t\tNamespace: common.OperatorNamespace,\n\t\tName:      common.TrustedCABundleConfigMapName,\n\t}\n\tif err := r.Get(r.ctx, key, injectionCM); err != nil {\n\t\tif errors.IsNotFound(err) {\n\t\t\tr.log.V(4).Info(\"CNO-injected CA bundle ConfigMap not found, skipping hash annotation\",\n\t\t\t\t\"name\", common.TrustedCABundleConfigMapName, \"namespace\", common.OperatorNamespace)\n\t\t\treturn \"\", nil\n\t\t}\n\t\treturn \"\", common.FromClientError(\n\t\t\terr,\n\t\t\t\"failed to read CA bundle ConfigMap %q in namespace %q\",\n\t\t\tcommon.TrustedCABundleConfigMapName, common.OperatorNamespace,\n\t\t)\n\t}\n\n\tcaBundle, ok := injectionCM.Data[common.TrustedCABundleKey]\n\tif !ok || caBundle == \"\" {\n\t\tr.log.V(4).Info(\"CNO-injected CA bundle ConfigMap does not contain expected key, skipping hash annotation\",\n\t\t\t\"name\", common.TrustedCABundleConfigMapName, \"key\", common.TrustedCABundleKey)\n\t\treturn \"\", nil\n\t}\n\n\treturn caBundle, nil\n}\n\n// computeCABundleHash returns the SHA-256 hash of the CA bundle PEM content.\n// The hash is used as a pod template annotation to trigger rolling restarts\n// only when the actual certificate content changes.\nfunc computeCABundleHash(caBundle string) string {\n\thash := sha256.Sum256([]byte(caBundle))\n\treturn hex.EncodeToString(hash[:])\n}\n\n// stampCABundleHash sets the CA bundle hash annotation on the deployment's\n// pod template spec. When the hash changes, the annotation change triggers\n// a rolling restart of the pods. No-op when caBundleHash is empty.\nfunc stampCABundleHash(deployment *appsv1.Deployment, caBundleHash string) {\n\tif caBundleHash == \"\" {\n\t\treturn\n\t}\n\tif deployment.Spec.Template.Annotations == nil {\n\t\tdeployment.Spec.Template.Annotations = make(map[string]string)\n\t}\n\tdeployment.Spec.Template.Annotations[caBundleHashAnnotation] = caBundleHash\n}\n```\n\n---\n\n### File 2: NEW \u2014 `pkg/controller/istiocsr/configmaps_test.go`\n\n```go\npackage istiocsr\n\nimport (\n\t\"context\"\n\t\"testing\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common/fakes\"\n)\n\nconst testCABundle = \"-----BEGIN CERTIFICATE-----\\nthisIsATestCABundle\\n-----END CERTIFICATE-----\"\n\nfunc TestComputeCABundleHash(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tbundle1  string\n\t\tbundle2  string\n\t\twantSame bool\n\t}{\n\t\t{\n\t\t\tname:     \"same bundle produces same hash\",\n\t\t\tbundle1:  testCABundle,\n\t\t\tbundle2:  testCABundle,\n\t\t\twantSame: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"different bundles produce different hashes\",\n\t\t\tbundle1:  testCABundle,\n\t\t\tbundle2:  \"-----BEGIN CERTIFICATE-----\\ndifferent\\n-----END CERTIFICATE-----\",\n\t\t\twantSame: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\thash1 := computeCABundleHash(tt.bundle1)\n\t\t\thash2 := computeCABundleHash(tt.bundle2)\n\n\t\t\tif hash1 == \"\" {\n\t\t\t\tt.Fatal(\"expected non-empty hash\")\n\t\t\t}\n\t\t\tif (hash1 == hash2) != tt.wantSame {\n\t\t\t\tt.Errorf(\"hash equality=%v, want %v (hash1=%s, hash2=%s)\", hash1 == hash2, tt.wantSame, hash1, hash2)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestStampCABundleHash(t *testing.T) {\n\ttests := []struct {\n\t\tname           string\n\t\thash           string\n\t\twantAnnotation bool\n\t}{\n\t\t{\n\t\t\tname:           \"stamps annotation when hash is non-empty\",\n\t\t\thash:           \"abc123\",\n\t\t\twantAnnotation: true,\n\t\t},\n\t\t{\n\t\t\tname:           \"no-op when hash is empty\",\n\t\t\thash:           \"\",\n\t\t\twantAnnotation: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdeployment := testDeployment()\n\t\t\tstampCABundleHash(deployment, tt.hash)\n\n\t\t\tann := deployment.Spec.Template.Annotations\n\t\t\tif tt.wantAnnotation {\n\t\t\t\tif ann == nil || ann[caBundleHashAnnotation] != tt.hash {\n\t\t\t\t\tt.Errorf(\"expected annotation %q=%q, got %v\", caBundleHashAnnotation, tt.hash, ann)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif ann != nil && ann[caBundleHashAnnotation] != \"\" {\n\t\t\t\t\tt.Errorf(\"expected no annotation, got %v\", ann)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestReadTrustedCABundle(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\tpreReq     func(*fakes.FakeCtrlClient)\n\t\twantBundle string\n\t\twantErr    string\n\t}{\n\t\t{\n\t\t\tname: \"returns CA bundle when ConfigMap exists with expected key\",\n\t\t\tpreReq: func(m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tif key.Name == common.TrustedCABundleConfigMapName && key.Namespace == common.OperatorNamespace {\n\t\t\t\t\t\tcm := obj.(*corev1.ConfigMap)\n\t\t\t\t\t\tcm.Data = map[string]string{common.TrustedCABundleKey: testCABundle}\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantBundle: testCABundle,\n\t\t},\n\t\t{\n\t\t\tname: \"returns empty when ConfigMap is not found\",\n\t\t\tpreReq: func(m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tif key.Name == common.TrustedCABundleConfigMapName {\n\t\t\t\t\t\treturn apierrors.NewNotFound(schema.GroupResource{Resource: \"configmaps\"}, key.Name)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantBundle: \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"returns empty when key is missing from ConfigMap\",\n\t\t\tpreReq: func(m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tif key.Name == common.TrustedCABundleConfigMapName {\n\t\t\t\t\t\tcm := obj.(*corev1.ConfigMap)\n\t\t\t\t\t\tcm.Data = map[string]string{\"other-key\": \"data\"}\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantBundle: \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"returns empty when CA bundle value is empty\",\n\t\t\tpreReq: func(m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tif key.Name == common.TrustedCABundleConfigMapName {\n\t\t\t\t\t\tcm := obj.(*corev1.ConfigMap)\n\t\t\t\t\t\tcm.Data = map[string]string{common.TrustedCABundleKey: \"\"}\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantBundle: \"\",\n\t\t},\n\t\t{\n\t\t\tname: \"returns error on non-NotFound API error\",\n\t\t\tpreReq: func(m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tif key.Name == common.TrustedCABundleConfigMapName {\n\t\t\t\t\t\treturn errTestClient\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantErr: \"failed to read CA bundle ConfigMap\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tr := testReconciler(t)\n\t\t\tmock := &fakes.FakeCtrlClient{}\n\t\t\tif tt.preReq != nil {\n\t\t\t\ttt.preReq(mock)\n\t\t\t}\n\t\t\tr.CtrlClient = mock\n\n\t\t\tbundle, err := r.readTrustedCABundle()\n\n\t\t\tif tt.wantErr != \"\" {\n\t\t\t\tif err == nil || !containsSubstring(err.Error(), tt.wantErr) {\n\t\t\t\t\tt.Errorf(\"readTrustedCABundle() err = %v, want substring %q\", err, tt.wantErr)\n\t\t\t\t}\n\t\t\t\treturn\n\t\t\t}\n\t\t\tif err != nil {\n\t\t\t\tt.Fatalf(\"readTrustedCABundle() unexpected error: %v\", err)\n\t\t\t}\n\t\t\tif bundle != tt.wantBundle {\n\t\t\t\tt.Errorf(\"readTrustedCABundle() bundle = %q, want %q\", bundle, tt.wantBundle)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc containsSubstring(s, substr string) bool {\n\treturn len(s) >= len(substr) && (s == substr || len(s) > 0 && containsStr(s, substr))\n}\n\nfunc containsStr(s, substr string) bool {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n```\n\n---\n\n### File 3: MODIFY \u2014 `pkg/controller/istiocsr/constants.go`\n\nAdd the hash annotation constant. Insert after the `IstiocsrCAKeyName` constant (around line 89):\n\n```go\n// caBundleHashAnnotation is the pod template annotation that tracks the CNO-injected\n// CA bundle hash. Changes to this annotation trigger rolling restarts.\ncaBundleHashAnnotation = \"operator.openshift.io/ca-bundle-hash\"\n```\n\n**Exact diff** \u2014 in `constants.go`, change:\n\n```go\n\t// IstiocsrCAKeyName is the key name holding the CA certificate in the issuer secret or the controller\n\t// CA configmap.\n\tIstiocsrCAKeyName = \"ca.crt\"\n)\n```\n\nto:\n\n```go\n\t// IstiocsrCAKeyName is the key name holding the CA certificate in the issuer secret or the controller\n\t// CA configmap.\n\tIstiocsrCAKeyName = \"ca.crt\"\n\n\t// caBundleHashAnnotation is the pod template annotation that tracks the CNO-injected\n\t// CA bundle hash. Changes to this annotation trigger rolling restarts.\n\tcaBundleHashAnnotation = \"operator.openshift.io/ca-bundle-hash\"\n)\n```\n\n---\n\n### File 4: MODIFY \u2014 `pkg/controller/istiocsr/deployments.go`\n\n**Change 1** \u2014 `createOrApplyDeployments` signature and body (line 31):\n\n```go\nfunc (r *Reconciler) createOrApplyDeployments(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, istioCSRCreateRecon bool, caBundleHash string) error {\n\tdesired, err := r.getDeploymentObject(istiocsr, resourceLabels, caBundleHash)\n```\n\n(Add `caBundleHash string` parameter, and pass it to `getDeploymentObject`.)\n\n**Change 2** \u2014 `getDeploymentObject` signature and body (line 73):\n\n```go\nfunc (r *Reconciler) getDeploymentObject(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, caBundleHash string) (*appsv1.Deployment, error) {\n```\n\nAnd add `stampCABundleHash(deployment, caBundleHash)` after the `updateVolumes` call (after line 103, before `return deployment, nil`):\n\n```go\n\tif err := r.updateVolumes(deployment, istiocsr, resourceLabels); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to update volume %s/%s: %w\", istiocsr.GetNamespace(), istiocsr.GetName(), err)\n\t}\n\n\tstampCABundleHash(deployment, caBundleHash)\n\n\treturn deployment, nil\n}\n```\n\n---\n\n### File 5: MODIFY \u2014 `pkg/controller/istiocsr/install_istiocsr.go`\n\nAdd the CA bundle hash computation before the deployment reconciliation call. Change lines 48-51 from:\n\n```go\n\tif err := r.createOrApplyDeployments(istiocsr, resourceLabels, istioCSRCreateRecon); err != nil {\n\t\tr.log.Error(err, \"failed to reconcile deployment resource\")\n\t\treturn err\n\t}\n```\n\nto:\n\n```go\n\tcaBundleHash, err := r.readTrustedCABundleHash()\n\tif err != nil {\n\t\tr.log.Error(err, \"failed to read CNO-injected CA bundle for hash annotation\")\n\t\treturn err\n\t}\n\n\tif err := r.createOrApplyDeployments(istiocsr, resourceLabels, istioCSRCreateRecon, caBundleHash); err != nil {\n\t\tr.log.Error(err, \"failed to reconcile deployment resource\")\n\t\treturn err\n\t}\n```\n\nAnd add the helper method \u2014 this can go in `configmaps.go` or inline here. I'll add it to `configmaps.go`:\n\nAdd this method to the bottom of `pkg/controller/istiocsr/configmaps.go`:\n\n```go\n// readTrustedCABundleHash reads the CNO-injected CA bundle and returns its\n// SHA-256 hash. Returns (\"\", nil) when the bundle is absent.\nfunc (r *Reconciler) readTrustedCABundleHash() (string, error) {\n\tcaBundle, err := r.readTrustedCABundle()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\tif caBundle == \"\" {\n\t\treturn \"\", nil\n\t}\n\treturn computeCABundleHash(caBundle), nil\n}\n```\n\n---\n\n### File 6: MODIFY \u2014 `pkg/controller/istiocsr/utils.go`\n\nAdd pod template annotation comparison to `deploymentSpecModified`. Change lines 316-318 from:\n\n```go\n\tif !reflect.DeepEqual(desired.Spec.Template.Labels, fetched.Spec.Template.Labels) ||\n\t\tlen(desired.Spec.Template.Spec.Containers) != len(fetched.Spec.Template.Spec.Containers) {\n\t\treturn true\n\t}\n```\n\nto:\n\n```go\n\tif !reflect.DeepEqual(desired.Spec.Template.Labels, fetched.Spec.Template.Labels) ||\n\t\t!reflect.DeepEqual(desired.Spec.Template.Annotations, fetched.Spec.Template.Annotations) ||\n\t\tlen(desired.Spec.Template.Spec.Containers) != len(fetched.Spec.Template.Spec.Containers) {\n\t\treturn true\n\t}\n```\n\n---\n\n### File 7: MODIFY \u2014 `pkg/controller/istiocsr/deployments_test.go`\n\nUpdate all calls to `createOrApplyDeployments` to pass the new `caBundleHash` parameter. On line 1085, change:\n\n```go\nerr := r.createOrApplyDeployments(istiocsr, controllerDefaultResourceLabels, false)\n```\n\nto:\n\n```go\nerr := r.createOrApplyDeployments(istiocsr, controllerDefaultResourceLabels, false, \"\")\n```\n\n---\n\n### File 8: MODIFY \u2014 `pkg/controller/istiocsr/install_instiocsr_test.go`\n\nThe existing test cases use mocks that return `nil` for `Get` calls on unhandled types. Since `readTrustedCABundle` calls `r.Get` for a `*corev1.ConfigMap` and the mocks don't handle it, the ConfigMap will be empty (nil Data), so `readTrustedCABundle` returns `(\"\", nil)` \u2014 the hash is empty and the test behavior is unchanged. **No changes needed in this file** unless you want to explicitly test the hash flow.\n\nHowever, the first test case's `GetCalls` mock handles `*corev1.Secret` \u2014 we need to make sure `*corev1.ConfigMap` for the CNO bundle doesn't collide. Checking the mock: the switch doesn't handle `*corev1.ConfigMap`, so it falls through and returns nil \u2014 correct. The existing tests pass as-is.\n\n---\n\n### Commands to build and test\n\n```bash\ncd /Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-baseline\n\n# Verify compilation\ngo build ./pkg/controller/istiocsr/...\n\n# Run unit tests for the istiocsr package\ngo test ./pkg/controller/istiocsr/... -v -count=1\n\n# Run the trustmanager tests to ensure no regression\ngo test ./pkg/controller/trustmanager/... -v -count=1\n\n# Full project build\nmake build\n```\n\n---\n\n### Summary of all changes\n\n| File | Action | What |\n|------|--------|------|\n| `pkg/controller/istiocsr/configmaps.go` | **NEW** | `readTrustedCABundle()`, `readTrustedCABundleHash()`, `computeCABundleHash()`, `stampCABundleHash()` |\n| `pkg/controller/istiocsr/configmaps_test.go` | **NEW** | Tests for hash computation, stamping, and CA bundle reading |\n| `pkg/controller/istiocsr/constants.go` | **MODIFY** | Add `caBundleHashAnnotation` constant |\n| `pkg/controller/istiocsr/deployments.go` | **MODIFY** | Add `caBundleHash` param to `createOrApplyDeployments` and `getDeploymentObject`; call `stampCABundleHash` |\n| `pkg/controller/istiocsr/install_istiocsr.go` | **MODIFY** | Call `readTrustedCABundleHash()` before deployment reconciliation; pass hash downstream |\n| `pkg/controller/istiocsr/utils.go` | **MODIFY** | Add pod template annotation comparison to `deploymentSpecModified` (idempotency guard) |\n| `pkg/controller/istiocsr/deployments_test.go` | **MODIFY** | Update `createOrApplyDeployments` call to include `caBundleHash` parameter |\n\nThe idempotency guard works as follows: when the CA bundle content hasn't changed, `computeCABundleHash` produces the same hash, `stampCABundleHash` sets the same annotation value, and `deploymentSpecModified` (via the new `Annotations` comparison) returns `false`, causing `hasObjectChanged` to return `false` and skipping the `UpdateWithRetry` call.", "stop_reason": "end_turn", "session_id": "8fdfb16a-a511-4502-96e2-833b77f0955b", "total_cost_usd": 1.42572625, "usage": {"input_tokens": 20040, "cache_creation_input_tokens": 93875, "cache_read_input_tokens": 684765, "output_tokens": 15857, "server_tool_use": {"web_search_requests": 0, "web_fetch_requests": 0}, "service_tier": "standard", "cache_creation": {"ephemeral_1h_input_tokens": 0, "ephemeral_5m_input_tokens": 93875}, "inference_geo": "", "iterations": [], "speed": "standard"}, "modelUsage": {"claude-opus-4-6": {"inputTokens": 20040, "outputTokens": 15857, "cacheReadInputTokens": 684765, "cacheCreationInputTokens": 93875, "webSearchRequests": 0, "costUSD": 1.42572625, "contextWindow": 200000, "maxOutputTokens": 64000}}, "permission_denials": [], "terminal_reason": "completed", "fast_mode_state": "off", "uuid": "381d9705-2097-4aaf-a370-3ab9f3894672", "timestamp": "2026-07-15T13:19:11.335Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_015dNyaokoXd31AMuMMs6SFM","type":"tool_result","content":"1\tpackage podplacement\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"strconv\"\n6\t\t\"time\"\n7\t\n8\t\t\"k8s.io/apimachinery/pkg/util/sets\"\n9\t\n10\t\t. \"github.com/onsi/ginkgo/v2\"\n11\t\t. \"github.com/onsi/gomega\"\n12\t\n13\t\tcorev1 \"k8s.io/api/core/v1\"\n14\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n15\t\tcrclient \"sigs.k8s.io/controller-runtime/pkg/client\"\n16\t\n17\t\timgspecv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n18\t\n19\t\t\"github.com/openshift/multiarch-tuning-operator/api/common\"\n20\t\t\"github.com/openshift/multiarch-tuning-operator/api/v1beta1\"\n21\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/e2e\"\n22\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/informers/clusterpodplacementconfig\"\n23\t\t. \"github.com/openshift/multiarch-tuning-operator/pkg/testing/builder\"\n24\t\t. \"github.com/openshift/multiarch-tuning-operator/pkg/testing/framework\"\n25\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/testing/image/fake/registry\"\n26\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/utils\"\n27\t)\n28\t\n29\tvar _ = Describe(\"Internal/Controller/Podplacement/PodReconciler\", func() {\n30\t\tWhen(\"Handling Single-container Pods\", func() {\n31\t\t\tContext(\"with different image types\", func() {\n32\t\t\t\tDescribeTable(\"handles correctly\", func(imageType string, supportedArchitectures ...string) {\n33\t\t\t\t\tpod := NewPod().\n34\t\t\t\t\t\tWithContainersImages(fmt.Sprintf(\"%s/%s/%s:latest\", registryAddress,\n35\t\t\t\t\t\t\tregistry.PublicRepo, registry.ComputeNameByMediaType(imageType))).\n36\t\t\t\t\t\tWithGenerateName(\"test-pod-\").\n37\t\t\t\t\t\tWithNamespace(\"test-namespace\").\n38\t\t\t\t\t\tBuild()\n39\t\t\t\t\terr := k8sClient.Create(ctx, pod)\n40\t\t\t\t\tExpect(err).NotTo(HaveOccurred(), \"failed to create pod\", err)\n41\t\t\t\t\t// Test the removal of the scheduling gate. However, since the pod is mutated and the reconciler\n42\t\t\t\t\t// removes the scheduling gate concurrently, we cannot ensure that the scheduling gate is added\n43\t\t\t\t\t// and that the following Eventually works on a pod with the scheduling gate.\n44\t\t\t\t\t// Waiting for the pod to be mutated is not enough, as the pod could be mutated and the reconciler\n45\t\t\t\t\t// could have removed the scheduling gate before our check.\n46\t\t\t\t\tEventually(func(g Gomega) {\n47\t\t\t\t\t\t// Get pod from the API server\n48\t\t\t\t\t\terr := k8sClient.Get(ctx, crclient.ObjectKeyFromObject(pod), pod)\n49\t\t\t\t\t\tg.Expect(err).NotTo(HaveOccurred(), \"failed to get pod\", err)\n50\t\t\t\t\t\tg.Expect(pod.Spec.SchedulingGates).NotTo(ContainElement(corev1.PodSchedulingGate{\n51\t\t\t\t\t\t\tName: utils.SchedulingGateName,\n52\t\t\t\t\t\t}), \"scheduling gate not removed\")\n53\t\t\t\t\t\tg.Expect(pod.Labels).To(HaveKeyWithValue(utils.SchedulingGateLabel, utils.SchedulingGateLabelValueRemoved),\n54\t\t\t\t\t\t\t\"scheduling gate annotation not found\")\n55\t\t\t\t\t\tg.Expect(pod.Labels).To(HaveKeyWithValue(utils.PreferredNodeAffinityLabel, utils.NodeAffinityLabelValueSet),\n56\t\t\t\t\t\t\t\"preferred node affinity label not found\")\n57\t\t\t\t\t\tg.Expect(pod.Labels).To(HaveKeyWithValue(utils.NodeAffinityLabel, utils.NodeAffinityLabelValueSet),\n58\t\t\t\t\t\t\t\"node affinity label not found\")\n59\t\t\t\t\t}).Should(Succeed(), \"failed to remove scheduling gate from pod\")\n60\t\t\t\t\tEventually(func(g Gomega) {\n61\t\t\t\t\t\tg.Expect(*pod).To(HaveEquivalentNodeAffinity(\n62\t\t\t\t\t\t\t&corev1.NodeAffinity{\n63\t\t\t\t\t\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &corev1.NodeSelector{\n64\t\t\t\t\t\t\t\t\tNodeSelectorTerms: []corev1.NodeSelectorTerm{\n65\t\t\t\t\t\t\t\t\t\t{\n66\t\t\t\t\t\t\t\t\t\t\tMatchExpressions: []corev1.NodeSelectorRequirement{\n67\t\t\t\t\t\t\t\t\t\t\t\t{\n68\t\t\t\t\t\t\t\t\t\t\t\t\tKey:
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01Fzute1n86K24BYUxXhq5vs","type":"tool_result","content":"1\t/*\n2\tCopyright 2023 Red Hat, Inc.\n3\t\n4\tLicensed under the Apache License, Version 2.0 (the \"License\");\n5\tyou may not use this file except in compliance with the License.\n6\tYou may obtain a copy of the License at\n7\t\n8\t    http://www.apache.org/licenses/LICENSE-2.0\n9\t\n10\tUnless required by applicable law or agreed to in writing, software\n11\tdistributed under the License is distributed on an \"AS IS\" BASIS,\n12\tWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13\tSee the License for the specific language governing permissions and\n14\tlimitations under the License.\n15\t*/\n16\t\n17\tpackage v1beta1\n18\t\n19\timport (\n20\t\t\"fmt\"\n21\t\t\"strings\"\n22\t\n23\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n24\t\n25\t\t\"github.com/openshift/library-go/pkg/operator/v1helpers\"\n26\t\n27\t\t\"github.com/openshift/multiarch-tuning-operator/api/common\"\n28\t\t\"github.com/openshift/multiarch-tuning-operator/api/common/plugins\"\n29\t)\n30\t\n31\t// ClusterPodPlacementConfigSpec defines the desired state of ClusterPodPlacementConfig\n32\ttype ClusterPodPlacementConfigSpec struct {\n33\t\t// LogVerbosity is the log level for the pod placement components.\n34\t\t// Valid values are: \"Normal\", \"Debug\", \"Trace\", \"TraceAll\".\n35\t\t// Defaults to \"Normal\".\n36\t\t// +optional\n37\t\t// +kubebuilder:default=Normal\n38\t\tLogVerbosity common.LogVerbosityLevel `json:\"logVerbosity,omitempty\"`\n39\t\n40\t\t// NamespaceSelector selects the namespaces where the pod placement operand can process the nodeAffinity\n41\t\t// of the pods. If left empty, all the namespaces are considered.\n42\t\t// The default sample allows to exclude all the namespaces where the\n43\t\t// label \"multiarch.openshift.io/exclude-pod-placement\" exists.\n44\t\t// +optional\n45\t\tNamespaceSelector *metav1.LabelSelector `json:\"namespaceSelector,omitempty\"`\n46\t\n47\t\t// Plugins defines the configurable plugins for this component.\n48\t\t// This field is optional and will be omitted from the output if not set.\n49\t\t// +optional\n50\t\tPlugins *plugins.Plugins `json:\"plugins,omitempty\"`\n51\t\n52\t\t// FallbackArchitecture defines the architecture to use if the image inspector cannot determine the image's architecture.\n53\t\t// If configured, the PodPlacementController will set the node affinity of the pod to the fallback architecture\n54\t\t// if the image inspector cannot determine the image's architecture.\n55\t\t// +optional\n56\t\t// +kubebuilder:default=\"\"\n57\t\t// +kubebuilder:validation:Enum=arm64;amd64;ppc64le;s390x;\"\"\n58\t\tFallbackArchitecture string `json:\"fallbackArchitecture,omitempty\"`\n59\t}\n60\t\n61\t// ClusterPodPlacementConfigStatus defines the observed state of ClusterPodPlacementConfig\n62\ttype ClusterPodPlacementConfigStatus struct {\n63\t\t// Conditions represents the latest available observations of a ClusterPodPlacementConfig's current state.\n64\t\tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n65\t\n66\t\t// The following fields are used to derive the conditions. They are not exposed to the user.\n67\t\t//nolint:revive // controller-gen requires json tags on all fields, even unexported ones\n68\t\tavailable                                bool `json:\"-\"`\n69\t\tprogressing                              bool `json:\"-\"`\n70\t\tdegraded                                 bool `json:\"-\"`\n71\t\tdeprovisioning                           bool `json:\"-\"`\n72\t\tpodPlacementControllerNotReady           bool `json:\"-\"`\n73\t\tpodPlacementWebhookNotReady              bool `json:\"-\"`\n74\t\tmutatingWebhookConfigurationNotAvailable bool `json:\"-\"`\n75\t\tcanDeployMutatingWebhook                 bool `json:\"-\"`\n76\t}\n77\t\n78\tfunc (s *ClusterPodPlacementConfigStatus) IsReady() bool {\n79\t\treturn s.available\n80\t}\n81\t\n82\tfunc (s *ClusterPodPlacementConfigStatus) IsProgressing() bool {\n83\t\treturn s.progressing\n84\t}\n85\t\n86\tfunc (s *ClusterPodPlacementConfigStatus) IsDegraded() bool {\n87\t\treturn s.degraded\n88\t}\n89\t\n90\tfunc (s *ClusterPodPlacementConfigStatus) IsDeprovisioning() bool {\n91\t\treturn s.deprovisioning\n92\t}\n93\t\n94\tfunc (s *ClusterPodPlacementConfigStatus) IsPodPlacementControllerNotReady() bool {\n95\t\treturn s.podPlacementControllerNotReady\n96\t}\n97\t\n98\tfunc (s *ClusterPodPlacementConfigStatus) IsPodPlacementWebhookNotReady() bool {\n99\t\treturn s.podPlacementWebhookNotReady\n100\t}\n101\t\n102\tfunc (s *ClusterPodPlacementConfigStatus) IsMutatingWebhookConfigurationNotAvailable() bool {\n103\t\treturn s.mutatingWebhookConfigurationNotAvailable\n104\t}\n105\t\n106\tfunc (s *ClusterPodPlacementConfigStatus) CanDeployMutatingWebhook() bool {\n107\t\treturn s.canDeployMutatingWebhook\n108\t}\n109\t\n110\t// Build sets the conditions in the ClusterPodPlacementConfig object.\n111\t// The build Conditions are:\n112\t//   - Degraded: if some components are not available (no replicas) and the object is not deprovisioning\n113\t//   - Deprovisioning: if the object is being deleted\n114\t//   - MutatingWebhookConfigurationNotAvailable: if the mutating webhook configuration does not exist\n115\t//   - PodPlacementControllerNotReady: if the pod placement controller is not available or up-to-date\n116\t//   - PodPlacementWebhookNotReady: if the pod placement webhook is not available or up-to-date\n117\t//   - Progressing: if the object is not deprovisioning and some of the components are not up-to-date.\n118\t//   - Available: if all the components are available to serve the requests and reconcile node affinities (at least one replica).\n119\tfunc (s *ClusterPodPlacementConfigStatus) Build(\n120\t\tpodPlacementControllerAvailable, podPlacementWebhookAvailable,\n121\t\tpodPlacementControllerUpToDate, podPlacementWebhookUpToDate,\n122\t\
prometheus-operator/pkg/apis/monitoring/v1\"\n49\t\t\"go.uber.org/zap/zapcore\"\n50\t\n51\t\t\"github.com/openshift/multiarch-tuning-operator/api/common\"\n52\t\t\"github.com/openshift/multiarch-tuning-operator/api/common/plugins\"\n53\t\tmultiarchv1beta1 \"github.com/openshift/multiarch-tuning-operator/api/v1beta1\"\n54\t\tenoexechandler \"github.com/openshift/multiarch-tuning-operator/internal/controller/enoexecevent/handler\"\n55\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/testing/framework\"\n56\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/utils\"\n57\t)\n58\t\n59\t// ClusterPodPlacementConfigReconciler reconciles a ClusterPodPlacementConfig object\n60\ttype ClusterPodPlacementConfigReconciler struct {\n61\t\tclient.Client\n62\t\tDynamicClient *dynamic.DynamicClient\n63\t\tScheme        *runtime.Scheme\n64\t\tClientSet     *kubernetes.Clientset\n65\t\tRecorder      events.Recorder\n66\t}\n67\t\n68\tconst (\n69\t\toperandName       = \"pod-placement-controller\"\n70\t\tpriorityClassName = \"system-cluster-critical\"\n71\t)\n72\t\n73\ttype requeueAfterError struct {\n74\t\tduration time.Duration\n75\t\tmsg      string\n76\t}\n77\t\n78\tfunc (e *requeueAfterError) Error() string { return e.msg }\n79\t\n80\tfunc newRequeueAfterError(d time.Duration, msg string) error {\n81\t\treturn &requeueAfterError{duration: d, msg: msg}\n82\t}\n83\t\n84\tconst (\n85\t\twaitingForUngatingPodsError         = \"waiting for pods with the scheduling gate to be ungated\"\n86\t\twaitingForWebhookSInterruptionError = \"re-queueing to ensure the webhook objects deletion interrupt pods gating before checking the pods gating status\"\n87\t\tclusterPodPlacementConfigNotReady   = \"cluster pod placement config is not ready yet. re-queueing\"\n88\t\tRemainingPodPlacementConfig         = \"cannot delete: namespaced PodPlacementConfig resources still exist\"\n89\t)\n90\t\n91\t//+kubebuilder:rbac:groups=multiarch.openshift.io,resources=clusterpodplacementconfigs,verbs=get;list;watch;create;update;patch;delete\n92\t//+kubebuilder:rbac:groups=multiarch.openshift.io,resources=clusterpodplacementconfigs/status,verbs=get;update;patch\n93\t//+kubebuilder:rbac:groups=multiarch.openshift.io,resources=clusterpodplacementconfigs/finalizers,verbs=update\n94\t\n95\t// The operator creates ClusterRoles for operand components (buildClusterRoleController, etc.)\n96\t// that grant these permissions. Kubernetes RBAC escalation prevention requires the creating\n97\t// SA to hold every permission it grants, so these must also appear in the manager-role.\n98\t//+kubebuilder:rbac:groups=core,resources=configmaps,verbs=get;list;watch\n99\t//+kubebuilder:rbac:groups=core,resources=secrets,verbs=get;list;watch\n100\t//+kubebuilder:rbac:groups=security.openshift.io,resources=securitycontextconstraints,verbs=use\n101\t\n102\t// FIND-002: Scope MWC write to the single webhook the operator manages.\n103\t// create cannot be name-scoped in K8s, so it stays in the unscoped rule.\n104\t//+kubebuilder:rbac:groups=admissionregistration.k8s.io,resources=mutatingwebhookconfigurations,verbs=create;list;watch\n105\t//+kubebuilder:rbac:groups=admissionregistration.k8s.io,resources=mutatingwebhookconfigurations,resourceNames=pod-placement-mutating-webhook-configuration,verbs=get;update;patch;delete\n106\t//+kubebuilder:rbac:groups=admissionregistration.k8s.io,resources=mutatingwebhookconfigurations/status,verbs=get\n107\t\n108\t//+kubebuilder:rbac:groups=core,resources=namespaces,verbs=get;update\n109\t//+kubebuilder:rbac:groups=core,resources=pods,verbs=get;list;watch;update;patch\n110\t//+kubebuilder:rbac:groups=core,resources=pods/status,verbs=get;update\n111\t//+kubebuilder:rbac:groups=apps,resources=deployments,verbs=get;list;watch;update;patch;create;delete\n112\t//+kubebuilder:rbac:groups=apps,resources=deployments/status,verbs=get\n113\t//+kubebuilder:rbac:groups=apps,resources=deployments/finalizers,verbs=update\n114\t//+kubebuilder:rbac:groups=core,resources=services,verbs=get;list;watch;update;patch;create;delete\n115\t//+kubebuilder:rbac:groups=core,resources=services/status,verbs=get\n116\t//+kubebuilder:rbac:groups=core,resources=events,verbs=create;patch\n117\t//+kubebuilder:rbac:groups=apps,resources=daemonsets,verbs=get;list;watch;create;update;patch;delete\n118\t\n119\t//+kubebuilder:rbac:groups=core,resources=serviceaccounts,verbs=get;list;watch;update;patch;create;delete\n120\t//+kubebuilder:rbac:groups=core,resources=serviceaccounts/status,verbs=get\n121\t//+kubebuilder:rbac:groups=core,resources=serviceaccounts/finalizers,verbs=update\n122\t\n123\t// FIND-003: Scope RBAC write to the named operand resources.\n124\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterroles,verbs=create;list;watch\n125\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterroles,resourceNames=pod-placement-controller;pod-placement-web-hook;enoexec-event-handler-controller;enoexec-event-daemon,verbs=get;update;patch;delete\n126\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterroles/status,verbs=get\n127\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterroles/finalizers,verbs=update\n128\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterrolebindings,verbs=create;list;watch\n129\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterrolebindings,resourceNames=pod-placement-controller;pod-placement-web-hook;enoexec-event-handler-controller;enoexec-event-daemon,verbs=get;update;patch;delete\n130\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterrolebindings/status,verbs=get\n131\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterrolebindings/finalizers,verbs=update\n132\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=roles,verbs=create;list;watch\n133\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=roles,resourceNames=pod-placement-controller;enoexec-event-handler-controller;enoexec-event-daemon,verbs=get;update;patch;delete\n134\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=roles/status,verbs=get\n135\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=roles/finalizers,verbs=update\n136\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=rolebindings,verbs=create;list;watch\n137\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=rolebindings,resourceNames=pod-placement-controller;enoexec-event-handler-controller;enoexec-event-daemon,verbs=get;update;patch;delete\n138\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=rolebindings/status,verbs=get\n139\t//+kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=rolebindings/finalizers,verbs=update\n140\t\n141\t//+kubebuilder:rbac:groups=monitoring.coreos.com,resources=servicemonitors,verbs=get;list;watch;update;patch;create;delete\n142\t//+kubebuilder:rbac:groups=monitoring.coreos.com,resources=prometheusrules,verbs=get;list;watch;update;patch;create;delete\n143\t\n144\t// Reconcile reconciles the ClusterPodPlacementConfig object against the actual cluster state, and then\n145\t// perform operations to make the cluster state reflect the state specified by\n146\t// the user.\n147\tfunc (r *ClusterPodPlacementConfigReconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error) {\n148\t\tlog := ctrllog.FromContext(ctx)\n149\t\tlog.V(1).Info(\"+++++++++++++++++++ Reconciling ClusterPodPlacementConfig +++++++++++++++++++\")\n150\t\t// Lookup the ClusterPodPlacementConfig instance for this reconcile request\n151\t\tclusterPodPlacementConfig := &multiarchv1beta1.ClusterPodPlacementConfig{}\n152\t\tvar err error\n153\t\n154\t\tif err = r.Get(ctx, client.ObjectKey{\n155\t\t\tName: req.Name,\n156\t\t}, clusterPodPlacementConfig); err != nil {\n157\t\t\tlog.Error(err, \"Unable to fetch ClusterPodPlacementConfig\")\n158\t\t\treturn ctrl.Result{}, client.IgnoreNotFound(err)\n159\t\t}\n160\t\tlog.V(1).Info(\"ClusterPodPlacementConfig fetched...\", \"name\", clusterPodPlacementConfig.Name)\n161\t\tswitch {\n162\t\tcase !clusterPodPlacementConfig.DeletionTimestamp.IsZero() && !controllerutil.ContainsFinalizer(clusterPodPlacementConfig, utils.PodPlacementFinalizerName):\n163\t\t\tlog.V(2).Info(\"the ClusterPodPlacementConfig object is being deleted, and the finalizer has already been removed successfully.\")\n164\t\t\treturn ctrl.Result{}, nil\n165\t\tcase !clusterPodPlacementConfig.DeletionTimestamp.IsZero():\n166\t\t\t// Only execute deletion if the object is being deleted and the finalizer is present\n167\t\t\tif err := r.handleDelete(ctx, clusterPodPlacementConfig); err != nil {\n168\t\t\t\tvar requeueErr *requeueAfterError\n169\t\t\t\tif errors.As(err, &requeueErr) {\n170\t\t\t\t\tlog.V(1).Info(\"Requeuing after delay\", \"reason\", requeueErr.msg, \"after\", requeueErr.duration)\n171\t\t\t\t\treturn ctrl.Result{RequeueAfter: requeueErr.duration}, nil\n172\t\t\t\t}\n173\t\t\t\treturn ctrl.Result{}, err\n174\t\t\t}\n175\t\t\treturn ctrl.Result{}, nil\n176\t\t}\n177\t\t// Move the finalizer block before applying the corresponding resources\n178\t\t// to ensure that finalizers are properly added and can be cleaned up\n179\t\t// even if the clusterPodPlacementConfig CR is deleted shortly after creation.\n180\t\tif !controllerutil.ContainsFinalizer(clusterPodPlacementConfig, utils.PodPlacementFinalizerName) {\n181\t\t\t// Add the finalizer to the object\n182\t\t\tlog.V(1).Info(\"Adding finalizer to the ClusterPodPlacementConfig\")\n183\t\t\tcontrollerutil.AddFinalizer(clusterPodPlacementConfig, utils.PodPlacementFinalizerName)\n184\t\t\tif err := r.Update(ctx, clusterPodPlacementConfig); err != nil {\n185\t\t\t\tlog.Error(err, \"Unable to update finalizers in the ClusterPodPlacementConfig\")\n186\t\t\t\treturn ctrl.Result{}, err\n187\t\t\t}\n188\t\t\treturn ctrl.Result{RequeueAfter: 0}, nil\n189\t\t}\n190\t\n191\t\t// Handle the no-pod-placement-config finalizer\n192\t\tppcList := &multiarchv1beta1.PodPlacementConfigList{}\n193\t\tif err := r.List(ctx, ppcList); err != nil {\n194\t\t\tlog.Error(err, \"Unable to list PodPlacementConfigs\")\n195\t\t\treturn ctrl.Result{}, err\n196\t\t}\n197\t\tshouldHavePPCFinalizer := len(ppcList.Items) > 0\n198\t\thasPPCFinalizer := controllerutil.ContainsFinalizer(clusterPodPlacementConfig, utils.CPPCNoPPCObjectFinalizer)\n199\t\tif shouldHavePPCFinalizer != hasPPCFinalizer {\n200\t\t\tif shouldHavePPCFinalizer {\n201\t\t\t\tlog.V(1).Info(\"Adding no-pod-placement-config finalizer to the ClusterPodPlacementConfig\")\n202\t\t\t\tcontrollerutil.AddFinalizer(clusterPodPlacementConfig, utils.CPPCNoPPCObjectFinalizer)\n203\t\t\t} else {\n204\t\t\t\tlog.V(1).Info(\"Removing no-pod-placement-config finalizer from the ClusterPodPlacementConfig\")\n205\t\t\t\tcontrollerutil.RemoveFinalizer(clusterPodPlacementConfig, utils.CPPCNoPPCObjectFinalizer)\n206\t\t\t}\n207\t\t\tif err := r.Update(ctx, clusterPodPlacementConfig); err != nil {\n208\t\t\t\tlog.Error(err, \"Unable to update finalizers on the ClusterPodPlacementConfig\")\n209\t\t\t\treturn ctrl.Result{}, err\n210\t\t\t}\n211\t\t\treturn ctrl.Result{RequeueAfter: 0}, nil\n212\t\t}\n213\t\n214\t\tif clusterPodPlacementConfig.PluginsEnabled(common.ExecFormatErrorMonitorPluginName) {\n215\t\t\tif !controllerutil.ContainsFinalizer(clusterPodPlacementConfig, utils.ExecFormatErrorFinalizerName) {\n216\t\t\t\t// Add the finalizer to the object\n217\t\t\t\tlog.V(1).Info(\"Adding ENoExecEvent finalizer to the ClusterPodPlacementConfig\")\n218\t\t\t\tcontrollerutil.AddFinalizer(clusterPodPlacementConfig, utils.ExecFormatErrorFinalizerName)\n219\t\t\t\tif err := r.Update(ctx, clusterPodPlacementConfig); err != nil {\n220\t\t\t\t\tlog.Error(err, \"Unable to update finalizers in the ClusterPodPlacementConfig\")\n221\t\t\t\t\treturn ctrl.Result{}, err\n222\t\t\t\t}\n223\t\t\t\treturn ctrl.Result{RequeueAfter: 0}, nil\n224\t\t\t}\n225\t\n226\t\t\t// Attempt to fetch the ENoExecEvent Deployment.\n227\t\t\teNoExecEventDeployment := &appsv1.Deployment{}\n228\t\t\terr := r.Get(ctx, client.ObjectKey{\n229\t\t\t\tName:      utils.EnoexecControllerName,\n230\t\t\t\tNamespace: utils.Namespace(),\n231\t\t\t}, eNoExecEventDeployment)\n232\t\t\tif err != nil {\n233\t\t\t\t// If the deployment is not found, it may be created later.\n234\t\t\t\t// If any other error occurs, log it and requeue.\n235\t\t\t\tlog.Error(err, \"Unable to fetch EnoexecController Deployment\")\n236\t\t\t\tif client.IgnoreNotFound(err) != nil {\n237\t\t\t\t\treturn ctrl.Result{}, err\n238\t\t\t\t}\n239\t\t\t} else {\n240\t\t\t\tif !controllerutil.ContainsFinalizer(eNoExecEventDeployment, utils.ExecFormatErrorFinalizerName) {\n241\t\t\t\t\tlog.V(1).Info(\"Adding finalizers to the ENoExecEvent Deployment for the ENoExecEvents\")\n242\t\t\t\t\tcontrollerutil.AddFinalizer(eNoExecEventDeployment, utils.ExecFormatErrorFinalizerName)\n243\t\t\t\t\tif err := r.Update(ctx, eNoExecEventDeployment); err != nil {\n244\t\t\t\t\t\tlog.Error(err, \"Unable to update finalizers on the EnoexecController Deployment\")\n245\t\t\t\t\t\t// Requeue on conflict, as another process might have updated the object.\n246\t\t\t\t\t\treturn ctrl.Result{}, err\n247\t\t\t\t\t}\n248\t\t\t\t\t// After a successful update, requeue to ensure the next state is processed.\n249\t\t\t\t\treturn ctrl.Result{RequeueAfter: 0}, nil\n250\t\t\t\t}\n251\t\t\t}\n252\t\t}\n253\t\n254\t\terr = r.dependentsStatusToClusterPodPlacementConfig(ctx, clusterPodPlacementConfig)\n255\t\tif err != nil {\n256\t\t\tlog.Error(err, \"Unable to retrieve the status of the PodPlacementConfig dependencies\")\n257\t\t\treturn ctrl.Result{}, err\n258\t\t}\n259\t\n260\t\tif err := r.reconcile(ctx, clusterPodPlacementConfig); err != nil {\n261\t\t\tvar requeueErr *requeueAfterError\n262\t\t\tif errors.As(err, &requeueErr) {\n263\t\t\t\tlog.V(1).Info(\"Requeuing after delay\", \"reason\", requeueErr.msg, \"after\", requeueErr.duration)\n264\t\t\t\treturn ctrl.Result{RequeueAfter: requeueErr.duration}, nil\n265\t\t\t}\n266\t\t\treturn ctrl.Result{}, err\n267\t\t}\n268\t\treturn ctrl.Result{}, nil\n269\t}\n270\t\n271\tfunc (r *ClusterPodPlacementConfigReconciler) ensureNamespaceLabels(ctx context.Context) error {\n272\t\t// https://kubernetes.io/docs/concepts/security/pod-security-standards/\n273\t\t// https://kubernetes.io/docs/concepts/security/pod-security-admission/\n274\t\t// https://kubernetes.io/docs/tasks/configure-pod-container/enforce-standards-namespace-labels/\n275\t\tlog := ctrllog.FromContext(ctx)\n276\t\tlog.V(1).Info(\"Ensuring namespace labels\", \"namespace\", utils.Namespace())\n277\t\n278\t\tns, err := r.ClientSet.CoreV1().Namespaces().Get(ctx, utils.Namespace(), metav1.GetOptions{})\n279\t\tif err != nil {\n280\t\t\tlog.Error(err, \"Unable to get the namespace\")\n281\t\t\treturn err\n282\t\t}\n283\t\tif ns.Labels == nil {\n284\t\t\tns.Labels = make(map[string]string)\n285\t\t}\n286\t\tns.Labels[\"pod-security.kubernetes.io/audit\"] = \"privileged\"\n287\t\tns.Labels[\"pod-security.kubernetes.io/audit-version\"] = \"v1.29\"\n288\t\tns.Labels[\"pod-security.kubernetes.io/enforce\"] = \"privileged\"\n289\t\tns.Labels[\"pod-security.kubernetes.io/enforce-version\"] = \"v1.29\"\n290\t\tns.Labels[\"pod-security.kubernetes.io/warn\"] = \"privileged\"\n291\t\tns.Labels[\"pod-security.kubernetes.io/warn-version\"] = \"v1.29\"\n292\t\t// See https://github.com/openshift/enhancements/blob/c5b9aea25e/enhancements/workload-partitioning/management-workload-partitioning.md\n293\t\tns.Labels[\"workload.openshift.io/allowed\"] = \"management\"\n294\t\tlog.V(2).Info(\"Updating the namespace labels\", \"labels\", ns.Labels)\n295\t\t_, err = r.ClientSet.CoreV1().Namespaces().Update(ctx, ns, metav1.UpdateOptions{})\n296\t\treturn err\n297\t}\n298\t\n299\t// getCorrectHostmountAnyUIDSCC computes the SCC to use for the operator's wokrloads requiring hostPath mounts.\n300\t// OpenShift 4.19 introduced a new SCC `hostmount-anyuid-v2` with elevated privileges\n301\t// compared to `hostmount-anyuid`, allowing pods to mount specific hostPath volumes\n302\t// that may otherwise be restricted. For more details, see following bugs:\n303\t// https://issues.redhat.com/browse/OCPBUGS-55013\n304\t// https://issues.redhat.com/browse/MULTIARCH-5405\n305\tfunc (r *ClusterPodPlacementConfigReconciler) getCorrectHostmountAnyUIDSCC(ctx context.Context) (string, *corev1.SELinuxOptions, error) {\n306\t\tlog := ctrllog.FromContext(ctx)\n307\t\tlog.V(1).Info(\"Ensuring using the correct hostmount scc for podplacementconfig\")\n308\t\n309\t\tminor, err := framework.GetClusterMinorVersion(r.ClientSet)\n310\t\tif err != nil {\n311\t\t\treturn \"\", nil, err\n312\t\t}\n313\t\t// OpenShift version to Kubernetes version mapping assumption:\n314\t\t// - OpenShift 4.18 maps to Kubernetes 1.31.x\n315\t\t// - OpenShift 4.19 maps to Kubernetes 1.32.x and so on\n316\t\t// - Assume this mapping will remain stable after GA (Generally Available) release\n317\t\t// We use this check to decide which SCC (SecurityContextConstraint) to use\n318\t\tif minor < 30 {\n319\t\t\t// logic for Kubernetes < 1.30 (OpenShift < 4.17)\n320\t\t\treturn \"hostmount-anyuid\", nil, nil\n321\t\t}\n322\t\n323\t\t// Because this MCO PR https://github.com/openshift/machine-config-operator/pull/4933\n324\t\t// was backported to OCP 4.17 and 4.18, it is causing a regression for MTO in those versions.\n325\t\t// Adding a temporary workaround here to give the pod temporary privileged SCC access.\n326\t\tif minor == 30 || minor == 31 {\n327\t\t\treturn \"privileged\", &corev1.SELinuxOptions{\n328\t\t\t\tType: \"spc_t\",\n329\t\t\t}, nil\n330\t\t}\n331\t\n332\t\t// logic for default set for Kubernetes >= 1.32 (OpenShift >= 4.19)\n333\t\treturn \"hostmount-anyuid-v2\", &corev1.SELinuxOptions{\n334\t\t\tType: \"spc_t\",\n335\t\t}, nil\n336\t}\n337\t\n338\t// dependentsStatusToClusterPodPlacementConfig gathers the status of the dependents of the ClusterPodPlacementConfig object.\n339\t// The status is propagated to the ClusterPodPlacementConfig object.\n340\tfunc (r *ClusterPodPlacementConfigReconciler) dependentsStatusToClusterPodPlacementConfig(ctx context.Context, config *multiarchv1beta1.ClusterPodPlacementConfig) error {\n341\t\tlog := ctrllog.FromContext(ctx).WithValues(\"ClusterPodPlacementConfig\", config.Name,\n342\t\t\t\"function\", \"updateStatus\")\n343\t\tpodPlacementController, err := r.ClientSet.AppsV1().Deployments(utils.Namespace()).Get(ctx, utils.PodPlacementControllerName, metav1.GetOptions{})\n344\t\tif client.IgnoreNotFound(err) != nil {\n345\t\t\tlog.Error(err, \"Unable to get the PodPlacement controller deployment\")\n346\t\t\treturn err\n347\t\t}\n348\t\n349\t\tif config.DeletionTimestamp.IsZero() && !podPlacementController.DeletionTimestamp.IsZero() {\n350\t\t\t// remove the finalizer in case the pod placement controller is deleted and we should reconcile it\n351\t\t\tlog.Info(\"Removing the finalizer from the pod-placement-controller to allow reconciliation\")\n352\t\t\tif controllerutil.RemoveFinalizer(podPlacementController, utils.PodPlacementFinalizerName) {\n353\t\t\t\tif err = r.Update(ctx, podPlacementController); err != nil {\n354\t\t\t\t\tlog.Error(err, \"Unable to remove the finalizer from the pod-placement-controller\")\n355\t\t\t\t\treturn err\n356\t\t\t\t}\n357\t\t\t}\n358\t\t}\n359\t\n360\t\tpodPlacementWebhook, err := r.ClientSet.AppsV1().Deployments(utils.Namespace()).Get(ctx, utils.PodPlacementWebhookName, metav1.GetOptions{})\n361\t\tif client.IgnoreNotFound(err) != nil {\n362\t\t\tlog.Error(err, \"Unable to get the PodPlacement webhook deployment\")\n363\t\t\treturn err\n364\t\t}\n365\t\t_, err = r.ClientSet.AdmissionregistrationV1().MutatingWebhookConfigurations().Get(ctx, utils.PodMutatingWebhookConfigurationName, metav1.GetOptions{})\n366\t\tif client.IgnoreNotFound(err) != nil {\n367\t\t\tlog.Error(err, \"Unable to get the mutating webhook configuration\")\n368\t\t\treturn err\n369\t\t}\n370\t\tconfig.Status.Build(\n371\t\t\tisDeploymentAvailable(podPlacementController), isDeploymentAvailable(podPlacementWebhook),\n372\t\t\tisDeploymentUpToDate(podPlacementController), isDeploymentUpToDate(podPlacementWebhook),\n373\t\t\t// err == nil means the MutatingWebhookConfiguration is available\n374\t\t\terr == nil, !config.DeletionTimestamp.IsZero())\n375\t\treturn nil\n376\t}\n377\t\n378\t// handleDelete handles the deletion of the PodPlacement operand's resources.\n379\tfunc (r *ClusterPodPlacementConfigReconciler) handleDelete(ctx context.Context,\n380\t\tclusterPodPlacementConfig *multiarchv1beta1.ClusterPodPlacementConfig) error {\n381\t\t// The ClusterPodPlacementConfig is being deleted, cleanup the resources\n382\t\tlog := ctrllog.FromContext(ctx).WithValues(\"operation\", \"handleDelete\")\n383\t\n384\t\terr := r.handleEnoexecDelete(ctx, clusterPodPlacementConfig)\n385\t\tif err != nil {\n386\t\t\treturn err\n387\t\t}\n388\t\n389\t\t// The error by the updateStatus function, if any, is ignored, as the deletion should always proceed.\n390\t\t// We execute the update here because this function returns multiple times before the whole deletion process is completed.\n391\t\t// Executing it here ensures that the conditions are updated throughout the deletion process.\n392\t\t_ = r.updateStatus(ctx, clusterPodPlacementConfig)\n393\t\n394\t\t// Prevent deletion while PodPlacementConfig resources still exist\n395\t\t// Check this BEFORE tearing down webhook/operand resources to prevent orphaning PPCs\n396\t\tif controllerutil.ContainsFinalizer(clusterPodPlacementConfig, utils.CPPCNoPPCObjectFinalizer) {\n397\t\t\tlog.V(1).Info(\"Checking for existing PodPlacementConfig resources before deletion\")\n398\t\t\tppcList := &multiarchv1beta1.PodPlacementConfigList{}\n399\t\t\tif err := r.List(ctx, ppcList); err != nil {\n400\t\t\t\tlog.Error(err, \"Unable to list PodPlacementConfigs during deletion\")\n401\t\t\t\treturn err\n402\t\t\t}\n403\t\t\tif len(ppcList.Items) > 0 {\n404\t\t\t\t// Block deletion - PPCs still exist\n405\t\t\t\terr := errors.New(RemainingPodPlacementConfig)\n406\t\t\t\tlog.Error(err, \"Deletion blocked due to existing PodPlacementConfig resources\")\n407\t\t\t\treturn err\n408\t\t\t}\n409\t\t\t// All PPCs are gone, remove the finalizer\n410\t\t\tlog.V(1).Info(\"No PodPlacementConfig resources found, removing no-pod-placement-config finalizer\")\n411\t\t\tcontrollerutil.RemoveFinalizer(clusterPodPlacementConfig, utils.CPPCNoPPCObjectFinalizer)\n412\t\t\tif err := r.Update(ctx, clusterPodPlacementConfig); err != nil {\n413\t\t\t\tlog.Error(err, \"Unable to remove no-pod-placement-config finalizer from ClusterPodPlacementConfig\")\n414\t\t\t\treturn err\n415\t\t\t}\n416\t\t\treturn nil\n417\t\t}\n418\t\n419\t\tobjsToDelete := []utils.ToDeleteRef{\n420\t\t\t{\n421\t\t\t\tNamespacedTypedClient: r.ClientSet.AdmissionregistrationV1().MutatingWebhookConfigurations(),\n422\t\t\t\tObjName:               utils.PodMutatingWebhookConfigurationName,\n423\t\t\t},\n424\t\t\t{\n425\t\t\t\tNamespacedTypedClient: r.ClientSet.CoreV1().Services(utils.Namespace()),\n426\t\t\t\tObjName:               utils.PodPlacementWebhookName,\n427\t\t\t},\n428\t\t\t{\n429\t\t\t\tNamespacedTypedClient: r.ClientSet.AppsV1().Deployments(utils.Namespace()),\n430\t\t\t\tObjName:               utils.PodPlacementWebhookName,\n431\t\t\t},\n432\t\t\t{\n433\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().ClusterRoles(),\n434\t\t\t\tObjName:               utils.PodPlacementWebhookName,\n435\t\t\t},\n436\t\t\t{\n437\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().ClusterRoleBindings(),\n438\t\t\t\tObjName:               utils.PodPlacementWebhookName,\n439\t\t\t},\n440\t\t\t{\n441\t\t\t\tNamespacedTypedClient: r.ClientSet.CoreV1().ServiceAccounts(utils.Namespace()),\n442\t\t\t\tObjName:               utils.PodPlacementWebhookName,\n443\t\t\t},\n444\t\t}\n445\t\tlog.Info(\"Deleting the pod placement operand's resources\")\n446\t\t// NOTE: err aggregates non-nil errors, excluding NotFound errors\n447\t\tif err := utils.DeleteResources(ctx, objsToDelete); err != nil {\n448\t\t\tlog.Error(err, \"Unable to delete resources\")\n449\t\t\treturn err\n450\t\t}\n451\t\t_, err = r.ClientSet.CoreV1().Services(utils.Namespace()).Get(ctx, utils.PodPlacementWebhookName, metav1.GetOptions{})\n452\t\t// We look for the webhook service to ensure that the webhook has stopped communicating with the API server.\n453\t\t// If the error is nil, the service was found. If the error is not nil and the error is not NotFound, some other error occurred.\n454\t\t// In both the cases we return an error, to requeue the request and ensure no race conditions between the verification of the\n455\t\t// pods gating status and the webhook stopping to communicate with the API server.\n456\t\tif err == nil || client.IgnoreNotFound(err) != nil {\n457\t\t\treturn errors.New(waitingForWebhookSInterruptionError)\n458\t\t}\n459\t\n460\t\tlog.Info(\"Looking for pods with the scheduling gate\")\n461\t\t// get pending pods as we cannot query for the scheduling gate\n462\t\tpods, err := r.ClientSet.CoreV1().Pods(\"\").List(ctx, metav1.ListOptions{\n463\t\t\tFieldSelector: \"status.phase=Pending\",\n464\t\t})\n465\t\tif err != nil {\n466\t\t\tlog.Error(err, \"Unable to list pods\")\n467\t\t\treturn err\n468\t\t}\n469\t\tif len(pods.Items) != 0 {\n470\t\t\t// Check if any pods really have our scheduling gate\n471\t\t\tfound := false\n472\t\t\tfor _, pod := range pods.Items {\n473\t\t\t\tfor _, sg := range pod.Spec.SchedulingGates {\n474\t\t\t\t\tlog.V(2).Info(\"Pod has scheduling gate\", \"pod\", pod.Name, \"gate\", sg.Name)\n475\t\t\t\t\tif sg.Name == utils.SchedulingGateName {\n476\t\t\t\t\t\tlog.Info(\"Found pod with the pod placement scheduling gate\", \"pod\", pod.Name)\n477\t\t\t\t\t\tfound = true\n478\t\t\t\t\t}\n479\t\t\t\t}\n480\t\t\t}\n481\t\t\tif found {\n482\t\t\t\treturn errors.New(waitingForUngatingPodsError)\n483\t\t\t}\n484\t\t}\n485\t\n486\t\t// The pods have been ungated and no other errors occurred, so we can remove the finalizer\n487\t\tlog.Info(\"Pods have been ungated\")\n488\t\tlog = log.WithValues(\"finalizer\", utils.PodPlacementFinalizerName)\n489\t\tppcDeployment := &appsv1.Deployment{}\n490\t\terr = r.Get(ctx, client.ObjectKey{\n491\t\t\tName:      utils.PodPlacementControllerName,\n492\t\t\tNamespace: utils.Namespace(),\n493\t\t}, ppcDeployment)\n494\t\tif client.IgnoreNotFound(err) != nil {\n495\t\t\tlog.Error(err, \"Unable to fetch the deployment\")\n496\t\t\treturn err\n497\t\t}\n498\t\tif err == nil && controllerutil.RemoveFinalizer(ppcDeployment, utils.PodPlacementFinalizerName) {\n499\t\t\tlog.V(2).Info(\"Updating the deployment\")\n500\t\t\tif err = r.Update(ctx, ppcDeployment); err != nil {\n501\t\t\t\tlog.Error(err, \"Unable to remove the finalizer\")\n502\t\t\t\treturn err\n503\t\t\t}\n504\t\t}\n505\t\t// we can remove the finalizer in the ClusterPodPlacementConfig object now\n506\t\tlog.Info(\"Removing the finalizer from the ClusterPodPlacementConfig\")\n507\t\tif controllerutil.RemoveFinalizer(clusterPodPlacementConfig, utils.PodPlacementFinalizerName) {\n508\t\t\tif err = r.Update(ctx, clusterPodPlacementConfig); err != nil {\n509\t\t\t\tlog.Error(err, \"Unable to remove finalizers.\",\n510\t\t\t\t\tclusterPodPlacementConfig.Kind, clusterPodPlacementConfig.Name)\n511\t\t\t\treturn err\n512\t\t\t}\n513\t\t}\n514\t\tobjsToDelete = []utils.ToDeleteRef{\n515\t\t\t{\n516\t\t\t\tNamespacedTypedClient: r.ClientSet.CoreV1().Services(utils.Namespace()),\n517\t\t\t\tObjName:               utils.PodPlacementControllerName,\n518\t\t\t},\n519\t\t\t{\n520\t\t\t\tNamespacedTypedClient: r.ClientSet.AppsV1().Deployments(utils.Namespace()),\n521\t\t\t\tObjName:               utils.PodPlacementControllerName,\n522\t\t\t},\n523\t\t\t{\n524\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().ClusterRoles(),\n525\t\t\t\tObjName:               utils.PodPlacementControllerName,\n526\t\t\t},\n527\t\t\t{\n528\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().ClusterRoleBindings(),\n529\t\t\t\tObjName:               utils.PodPlacementControllerName,\n530\t\t\t},\n531\t\t\t{\n532\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().Roles(utils.Namespace()),\n533\t\t\t\tObjName:               utils.PodPlacementControllerName,\n534\t\t\t},\n535\t\t\t{\n536\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().RoleBindings(utils.Namespace()),\n537\t\t\t\tObjName:               utils.PodPlacementControllerName,\n538\t\t\t},\n539\t\t\t{\n540\t\t\t\tNamespacedTypedClient: r.ClientSet.CoreV1().ServiceAccounts(utils.Namespace()),\n541\t\t\t\tObjName:               utils.PodPlacementControllerName,\n542\t\t\t},\n543\t\t}\n544\t\n545\t\tif utils.IsResourceAvailable(ctx, r.DynamicClient, monitoringv1.SchemeGroupVersion.WithResource(\"servicemonitors\")) {\n546\t\t\tobjsToDelete = append(objsToDelete, utils.ToDeleteRef{\n547\t\t\t\tNamespacedTypedClient: utils.NewDynamicDeleter(r.DynamicClient.Resource(schema.GroupVersionResource{Group: \"monitoring.coreos.com\", Version: \"v1\", Resource: \"servicemonitors\"}).Namespace(utils.Namespace())),\n548\t\t\t\tObjName:               utils.PodPlacementWebhookName,\n549\t\t\t}, utils.ToDeleteRef{\n550\t\t\t\tNamespacedTypedClient: utils.NewDynamicDeleter(r.DynamicClient.Resource(schema.GroupVersionResource{Group: \"monitoring.coreos.com\", Version: \"v1\", Resource: \"servicemonitors\"}).Namespace(utils.Namespace())),\n551\t\t\t\tObjName:               utils.PodPlacementControllerName,\n552\t\t\t}, utils.ToDeleteRef{\n553\t\t\t\tNamespacedTypedClient: utils.NewDynamicDeleter(r.DynamicClient.Resource(schema.GroupVersionResource{Group: \"monitoring.coreos.com\", Version: \"v1\", Resource: \"prometheusrules\"}).Namespace(utils.Namespace())),\n554\t\t\t\tObjName:               utils.OperatorName,\n555\t\t\t})\n556\t\t}\n557\t\n558\t\tlog.Info(\"Deleting the remaining resources after cleanup\")\n559\t\t// NOTE: err aggregates non-nil errors, excluding NotFound errors\n560\t\tif err := utils.DeleteResources(ctx, objsToDelete); err != nil {\n561\t\t\tlog.Error(err, \"Unable to delete resources\")\n562\t\t\treturn err\n563\t\t}\n564\t\treturn err\n565\t}\n566\t\n567\tfunc (r *ClusterPodPlacementConfigReconciler) handleEnoexecDelete(ctx context.Context, clusterPodPlacementConfig *multiarchv1beta1.ClusterPodPlacementConfig) error {\n568\t\tvar err error\n569\t\tlog := ctrllog.FromContext(ctx, \"operation\", \"handleEnoexecDelete\")\n570\t\t// If the ENoExecEvent finalizer was never added, skip the entire cleanup process.\n571\t\t// This prevents attempting to list ENoExecEvent resources when the plugin was never enabled,\n572\t\t// which would cause the informer to be created and fail to sync in time.\n573\t\tif !controllerutil.ContainsFinalizer(clusterPodPlacementConfig, utils.ExecFormatErrorFinalizerName) {\n574\t\t\tlog.V(1).Info(\"ENoExecEvent finalizer not present, skipping ENoExecEvent cleanup\")\n575\t\t\treturn nil\n576\t\t}\n577\t\tdaemonSetRelatedObjsToDelete := []utils.ToDeleteRef{\n578\t\t\t{\n579\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().ClusterRoles(),\n580\t\t\t\tObjName:               utils.EnoexecDaemonSet,\n581\t\t\t},\n582\t\t\t{\n583\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().ClusterRoleBindings(),\n584\t\t\t\tObjName:               utils.EnoexecDaemonSet,\n585\t\t\t},\n586\t\t\t{\n587\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().Roles(utils.Namespace()),\n588\t\t\t\tObjName:               utils.EnoexecDaemonSet,\n589\t\t\t},\n590\t\t\t{\n591\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().RoleBindings(utils.Namespace()),\n592\t\t\t\tObjName:               utils.EnoexecDaemonSet,\n593\t\t\t},\n594\t\t\t{\n595\t\t\t\tNamespacedTypedClient: r.ClientSet.CoreV1().ServiceAccounts(utils.Namespace()),\n596\t\t\t\tObjName:               utils.EnoexecDaemonSet,\n597\t\t\t},\n598\t\t\t{\n599\t\t\t\tNamespacedTypedClient: r.ClientSet.AppsV1().DaemonSets(utils.Namespace()),\n600\t\t\t\tObjName:               utils.EnoexecDaemonSet,\n601\t\t\t},\n602\t\t}\n603\t\tlog.Info(\"Deleting the DaemonSet ENoExecEvent resources\")\n604\t\tif err := utils.DeleteResources(ctx, daemonSetRelatedObjsToDelete); err != nil {\n605\t\t\tlog.Error(err, \"Unable to delete DaemonSet resources\")\n606\t\t\treturn err\n607\t\t}\n608\t\tds := &appsv1.DaemonSet{}\n609\t\terr = r.Get(ctx, client.ObjectKey{\n610\t\t\tName:      utils.EnoexecDaemonSet,\n611\t\t\tNamespace: utils.Namespace(),\n612\t\t}, ds)\n613\t\tif err == nil {\n614\t\t\tlog.Info(\"Waiting for the eNoExecEvent DaemonSet to be fully deleted...\")\n615\t\t\t// Return an error to force requeue. This is a common pattern for waiting.\n616\t\t\treturn newRequeueAfterError(5*time.Second, \"enoexec DaemonSet is still terminating\")\n617\t\t}\n618\t\tif client.IgnoreNotFound(err) != nil {\n619\t\t\tlog.Error(err, \"Failed to check for the eNoExecEvent DaemonSet status\")\n620\t\t\treturn err\n621\t\t}\n622\t\tlog.Info(\"eNoExecEvent DaemonSet has been deleted. Proceeding with eNoExecEvent controller cleanup.\")\n623\t\tenoexecEventList := &multiarchv1beta1.ENoExecEventList{}\n624\t\terr = r.List(ctx, enoexecEventList, client.InNamespace(utils.Namespace()))\n625\t\tif err != nil {\n626\t\t\tlog.Error(err, \"Failed to list ENoExecEvent resources\")\n627\t\t\treturn err\n628\t\t}\n629\t\n630\t\t// Delete errored ENoExecEvent resources and count remaining non-errored ones\n631\t\tnonErroredCount, _ := r.deleteErroredENoExecEvents(ctx, enoexecEventList)\n632\t\n633\t\t// Only block cleanup if there are non-errored ENoExecEvent resources.\n634\t\t// The enoexec-controller deployment is still running at this point so it can\n635\t\t// process the remaining events before we proceed.\n636\t\tif nonErroredCount > 0 {\n637\t\t\tlog.Info(\"Found existing non-errored ENoExecEvent resources, waiting for reconciliation\", \"nonErroredCount\", nonErroredCount)\n638\t\t\treturn newRequeueAfterError(5*time.Second, \"found existing ENoExecEvent resources that need reconciliation\")\n639\t\t}\n640\t\n641\t\tlog.Info(\"No non-errored ENoExecEvent resources found in the cluster. Removing the ExecEvent finalizer from the ENoExec Deployment\")\n642\t\tdeployment := &appsv1.Deployment{}\n643\t\terr = r.Get(ctx, client.ObjectKey{\n644\t\t\tName:      utils.EnoexecControllerName,\n645\t\t\tNamespace: utils.Namespace(),\n646\t\t}, deployment)\n647\t\tif client.IgnoreNotFound(err) != nil {\n648\t\t\tlog.Error(err, \"Could not fetch ENoExecEvent Deployment\")\n649\t\t\treturn err\n650\t\t}\n651\t\tif err == nil && controllerutil.RemoveFinalizer(deployment, utils.ExecFormatErrorFinalizerName) {\n652\t\t\tif err = r.Update(ctx, deployment); err != nil {\n653\t\t\t\tlog.Error(err, \"Unable to remove finalizers.\",\n654\t\t\t\t\tdeployment.Kind, deployment.Name)\n655\t\t\t\treturn err\n656\t\t\t}\n657\t\t}\n658\t\n659\t\tdeploymentRelatedObjsToDelete := []utils.ToDeleteRef{\n660\t\t\t{\n661\t\t\t\tNamespacedTypedClient: r.ClientSet.AppsV1().Deployments(utils.Namespace()),\n662\t\t\t\tObjName:               utils.EnoexecControllerName,\n663\t\t\t},\n664\t\t\t{\n665\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().Roles(utils.Namespace()),\n666\t\t\t\tObjName:               utils.EnoexecControllerName,\n667\t\t\t},\n668\t\t\t{\n669\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().RoleBindings(utils.Namespace()),\n670\t\t\t\tObjName:               utils.EnoexecControllerName,\n671\t\t\t},\n672\t\t\t{\n673\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().ClusterRoles(),\n674\t\t\t\tObjName:               utils.EnoexecControllerName,\n675\t\t\t},\n676\t\t\t{\n677\t\t\t\tNamespacedTypedClient: r.ClientSet.RbacV1().ClusterRoleBindings(),\n678\t\t\t\tObjName:               utils.EnoexecControllerName,\n679\t\t\t},\n680\t\t\t{\n681\t\t\t\tNamespacedTypedClient: r.ClientSet.CoreV1().ServiceAccounts(utils.Namespace()),\n682\t\t\t\tObjName:               utils.EnoexecControllerName,\n683\t\t\t},\n684\t\t\t{\n685\t\t\t\tNamespacedTypedClient: r.ClientSet.CoreV1().ServiceAccounts(utils.Namespace()),\n686\t\t\t\tObjName:               utils.EnoexecDaemonSet,\n687\t\t\t},\n688\t\t\t{\n689\t\t\t\tNamespacedTypedClient: r.ClientSet.CoreV1().Services(utils.Namespace()),\n690\t\t\t\tObjName:               utils.EnoexecControllerName,\n691\t\t\t},\n692\t\t}\n693\t\n694\t\tif utils.IsResourceAvailable(ctx, r.DynamicClient, monitoringv1.SchemeGroupVersion.WithResource(\"servicemonitors\")) {\n695\t\t\tdeploymentRelatedObjsToDelete = append(deploymentRelatedObjsToDelete, utils.ToDeleteRef{\n696\t\t\t\tNamespacedTypedClient: utils.NewDynamicDeleter(r.DynamicClient.Resource(schema.GroupVersionResource{Group: \"monitoring.coreos.com\", Version: \"v1\", Resource: \"servicemonitors\"}).Namespace(utils.Namespace())),\n697\t\t\t\tObjName:               utils.EnoexecControllerName,\n698\t\t\t}, utils.ToDeleteRef{\n699\t\t\t\tNamespacedTypedClient: utils.NewDynamicDeleter(r.DynamicClient.Resource(schema.GroupVersionResource{Group: \"monitoring.coreos.com\", Version: \"v1\", Resource: \"prometheusrules\"}).Namespace(utils.Namespace())),\n700\t\t\t\tObjName:               plugins.ExecFormatErrorMonitorPluginName,\n701\t\t\t}, utils.ToDeleteRef{\n702\t\t\t\tNamespacedTypedClient: utils.NewDynamicDeleter(r.DynamicClient.Resource(schema.GroupVersionResource{Group: \"monitoring.coreos.com\", Version: \"v1\", Resource: \"prometheusrules\"}).Namespace(utils.Namespace())),\n703\t\t\t\tObjName:               utils.ExecFormatErrorsDetected,\n704\t\t\t})\n705\t\t}\n706\t\n707\t\tlog.Info(\"Deleting the ENoExecEvent Deployment resources\")\n708\t\tif err = utils.DeleteResources(ctx, deploymentRelatedObjsToDelete); err != nil {\n709\t\t\tlog.Error(err, \"Unable to delete deployment resources\")\n710\t\t\treturn err\n711\t\t}\n712\t\tlog.Info(\"Removing the ENoExecEvent finalizer from the ClusterPodPlacementConfig\")\n713\t\tif controllerutil.RemoveFinalizer(clusterPodPlacementConfig, utils.ExecFormatErrorFinalizerName) {\n714\t\t\tif err = r.Update(ctx, clusterPodPlacementConfig); err != nil {\n715\t\t\t\tlog.Error(err, \"Unable to remove finalizers.\",\n716\t\t\t\t\tclusterPodPlacementConfig.Kind, clusterPodPlacementConfig.Name)\n717\t\t\t\treturn err\n718\t\t\t}\n719\t\t}\n720\t\treturn nil\n721\t}\n722\t\n723\t// reconcile reconciles the ClusterPodPlacementConfig operand's resources.\n724\tfunc (r *ClusterPodPlacementConfigReconciler) reconcile(ctx context.Context, clusterPodPlacementConfig *multiarchv1beta1.ClusterPodPlacementConfig) error {\n725\t\tlog := ctrllog.FromContext(ctx)\n726\t\tdesiredLogLevel := int8(-clusterPodPlacementConfig.Spec.LogVerbosity.ToZapLevelInt()) // #nosec G115 -- LogVerbosity values are constrained to 0-3 by enum\n727\t\tif int8(utils.AtomicLevel.Level()) != desiredLogLevel {\n728\t\t\tlog.Info(\"Setting log level\", \"level\", desiredLogLevel)\n729\t\t\tutils.AtomicLevel.SetLevel(zapcore.Level(desiredLogLevel))\n730\t\t}\n731\t\tif err := r.ensureNamespaceLabels(ctx); err != nil {\n732\t\t\tlog.Error(err, \"Unable to ensure namespace labels\")\n733\t\t\treturn errorutils.NewAggregate([]error{err, r.updateStatus(ctx, clusterPodPlacementConfig)})\n734\t\t}\n735\t\tclusterPodPlacementConfigObjects, err := r.buildPodPlacementConfigObjects(clusterPodPlacementConfig, ctx)\n736\t\tif err != nil {\n737\t\t\treturn err\n738\t\t}\n739\t\n740\t\texecFormatErrorObjects := []client.Object{}\n741\t\tif clusterPodPlacementConfig.PluginsEnabled(common.ExecFormatErrorMonitorPluginName) {\n742\t\t\texecFormatErrorObjects, err = r.buildENoExecEventObjects(ctx, clusterPodPlacementConfig)\n743\t\t\tif err != nil {\n744\t\t\t\treturn err\n745\t\t\t}\n746\t\t} else {\n747\t\t\terr := r.handleEnoexecDelete(ctx, clusterPodPlacementConfig)\n748\t\t\tif err != nil {\n749\t\t\t\treturn err\n750\t\t\t}\n751\t\t}\n752\t\n753\t\tobjects := append(clusterPodPlacementConfigObjects, execFormatErrorObjects...)\n754\t\n755\t\t// We ensure the MutatingWebHookConfiguration is created and present only if the operand is ready to serve the admission request and add/remove the scheduling gate.\n756\t\tshouldEnsureMWC := clusterPodPlacementConfig.Status.CanDeployMutatingWebhook()\n757\t\tshouldDeleteMWC := !shouldEnsureMWC && !clusterPodPlacementConfig.Status.IsMutatingWebhookConfigurationNotAvailable()\n758\t\tif shouldEnsureMWC {\n759\t\t\tobjects = append(objects, buildMutatingWebhookConfiguration(clusterPodPlacementConfig))\n760\t\t}\n761\t\tif shouldDeleteMWC {\n762\t\t\tlog.Info(\"Deleting the mutating webhook configuration as the operand is not ready to serve the admission request or remove the scheduling gate\")\n763\t\t\t_ = r.ClientSet.AdmissionregistrationV1().MutatingWebhookConfigurations().Delete(ctx, utils.PodMutatingWebhookConfigurationName, metav1.DeleteOptions{})\n764\t\t}\n765\t\n766\t\t// If the servicemonitors.monitoring.coreos.com CRD is available, we create the ServiceMonitor objects\n767\t\tif utils.IsResourceAvailable(ctx, r.DynamicClient, monitoringv1.SchemeGroupVersion.WithResource(\"servicemonitors\")) {\n768\t\t\tlog.V(1).Info(\"Creating ServiceMonitors\")\n769\t\t\tobjects = append(objects,\n770\t\t\t\tbuildServiceMonitor(utils.PodPlacementControllerName),\n771\t\t\t\tbuildServiceMonitor(utils.PodPlacementWebhookName),\n772\t\t\t\tbuildCPPCAvailabilityAlertRule(),\n773\t\t\t)\n774\t\t} else {\n775\t\t\tlog.V(1).Info(\"servicemonitoring.monitoring.coreos.com is not available. Skipping the creation of the ServiceMonitors\")\n776\t\t}\n777\t\terrs := make([]error, 0)\n778\t\tfor _, o := range objects {\n779\t\t\tif err := ctrl.SetControllerReference(clusterPodPlacementConfig, o, r.Scheme); err != nil {\n780\t\t\t\tlog.Error(err, \"Unable to set controller reference\", \"name\", o.GetName())\n781\t\t\t\terrs = append(errs, err)\n782\t\t\t}\n783\t\t}\n784\t\n785\t\tif len(errs) > 0 {\n786\t\t\treturn errorutils.NewAggregate(append(errs, r.updateStatus(ctx, clusterPodPlacementConfig)))\n787\t\t}\n788\t\n789\t\tif err := utils.ApplyResources(ctx, r.ClientSet, r.DynamicClient, r.Recorder, objects); err != nil {\n790\t\t\tlog.Error(err, \"Unable to apply resources\")\n791\t\t\treturn errorutils.NewAggregate([]error{err, r.updateStatus(ctx, clusterPodPlacementConfig)})\n792\t\t}\n793\t\n794\t\treturn r.updateStatus(ctx, clusterPodPlacementConfig)\n795\t}\n796\t\n797\t// updateStatus updates the status of the ClusterPodPlacementConfig object.\n798\t// It returns an error if the object is progressing or the status update fails. Otherwise, it returns nil.\n799\t// When it returns an error, the caller should requeue the request, unless the Reconciler is handling the deletion of the object.\n800\tfunc (r *ClusterPodPlacementConfigReconciler) updateStatus(ctx context.Context, config *multiarchv1beta1.ClusterPodPlacementConfig) error {\n801\t\tlog := ctrllog.FromContext(ctx).WithValues(\"ClusterPodPlacementConfig\", config.Name,\n802\t\t\t\"function\", \"updateStatus\")\n803\t\tlog.V(2).Info(\"----------------- ClusterPodPlacementConfig status report ------------------\",\n804\t\t\t\"ready\", config.Status.IsReady(),\n805\t\t\t\"progressing\", config.Status.IsProgressing(),\n806\t\t\t\"degraded\", config.Status.IsDegraded(),\n807\t\t\t\"deprovisioning\", config.Status.IsDeprovisioning(),\n808\t\t\t\"podPlacementControllerNotReady\", config.Status.IsPodPlacementControllerNotReady(),\n809\t\t\t\"podPlacementWebhookNotReady\", config.Status.IsPodPlacementWebhookNotReady(),\n810\t\t\t\"mutatingWebhookConfigurationNotAvailable\", config.Status.IsMutatingWebhookConfigurationNotAvailable())\n811\t\n812\t\tprogressing := config.Status.IsProgressing()\n813\t\tif err := r.Status().Update(ctx, config); err != nil {\n814\t\t\tlog.Error(err, \"Unable to update conditions in the ClusterPodPlacementConfig\")\n815\t\t\treturn err\n816\t\t}\n817\t\tvar err error = nil\n818\t\tif progressing {\n819\t\t\terr = errors.New(clusterPodPlacementConfigNotReady)\n820\t\t}\n821\t\treturn err\n822\t}\n823\t\n824\tfunc (r *ClusterPodPlacementConfigReconciler) buildPodPlacementConfigObjects(clusterPodPlacementConfig *multiarchv1beta1.ClusterPodPlacementConfig, ctx context.Context) ([]client.Object, error) {\n825\t\tlog := ctrllog.FromContext(ctx)\n826\t\n827\t\trequiredSCCHostmountAnyUID, seLinuxOptionsType, err := r.getCorrectHostmountAnyUIDSCC(ctx)\n828\t\tif err != nil {\n829\t\t\tlog.Error(err, \"Unable to set correct hostmount SCC\", \"requiredSCCHostmoundAnyUID\", requiredSCCHostmountAnyUID)\n830\t\t\treturn []client.Object{}, errorutils.NewAggregate([]error{err, r.updateStatus(ctx, clusterPodPlacementConfig)})\n831\t\t}\n832\t\tobjects := []client.Object{\n833\t\t\t// The finalizer will not affect the reconciliation of ReplicaSets and Pods\n834\t\t\t// when updates to the ClusterPodPlacementConfig are made.\n835\t\t\tbuildService(utils.PodPlacementControllerName),\n836\t\t\tbuildService(utils.PodPlacementWebhookName),\n837\t\t\tbuildClusterRoleController(), buildClusterRoleWebhook(), buildRoleController(),\n838\t\t\tbuildServiceAccount(utils.PodPlacementWebhookName), buildServiceAccount(utils.PodPlacementControllerName),\n839\t\t\tbuildClusterRoleBinding(utils.PodPlacementControllerName, rbacv1.RoleRef{\n840\t\t\t\tAPIGroup: rbacv1.GroupName,\n841\t\t\t\tKind:     clusterRoleKind,\n842\t\t\t\tName:     utils.PodPlacementControllerName,\n843\t\t\t}, []rbacv1.Subject{\n844\t\t\t\t{\n845\t\t\t\t\tKind:      serviceAccountKind,\n846\t\t\t\t\tName:      utils.PodPlacementControllerName,\n847\t\t\t\t\tNamespace: utils.Namespace(),\n848\t\t\t\t},\n849\t\t\t}),\n850\t\t\tbuildRoleBinding(utils.PodPlacementControllerName, rbacv1.RoleRef{\n851\t\t\t\tAPIGroup: rbacv1.GroupName,\n852\t\t\t\tKind:     roleKind,\n853\t\t\t\tName:     utils.PodPlacementControllerName,\n854\t\t\t}, []rbacv1.Subject{\n855\t\t\t\t{\n856\t\t\t\t\tKind: serviceAccountKind,\n857\t\t\t\t\tName: utils.PodPlacementControllerName,\n858\t\t\t\t},\n859\t\t\t}),\n860\t\t\tbuildClusterRoleBinding(utils.PodPlacementWebhookName, rbacv1.RoleRef{\n861\t\t\t\tAPIGroup: rbacv1.GroupName,\n862\t\t\t\tKind:     clusterRoleKind,\n863\t\t\t\tName:     utils.PodPlacementWebhookName,\n864\t\t\t}, []rbacv1.Subject{\n865\t\t\t\t{\n866\t\t\t\t\tKind:      serviceAccountKind,\n867\t\t\t\t\tName:      utils.PodPlacementWebhookName,\n868\t\t\t\t\tNamespace: utils.Namespace(),\n869\t\t\t\t},\n870\t\t\t}),\n871\t\t\tbuildControllerDeployment(clusterPodPlacementConfig, requiredSCCHostmountAnyUID, seLinuxOptionsType),\n872\t\t\tbuildWebhookDeployment(clusterPodPlacementConfig),\n873\t\t}\n874\t\treturn objects, nil\n875\t}\n876\t\n877\t// buildENoExecEventObjects if the ExecFormatErrorMonitor plugin is enabled create the deployment to start the controller\n878\t// if it does not already exist\n879\tfunc (r *ClusterPodPlacementConfigReconciler) buildENoExecEventObjects(ctx context.Context, clusterPodPlacementConfig *multiarchv1beta1.ClusterPodPlacementConfig) ([]client.Object, error) {\n880\t\tlog := ctrllog.FromContext(ctx)\n881\t\tlogVerbosityLevel := clusterPodPlacementConfig.Spec.LogVerbosity.ToZapLevelInt()\n882\t\n883\t\tlog.Info(\"Starting ENoExecEvent Controller\")\n884\t\tobjects := []client.Object{\n885\t\t\tbuildService(utils.EnoexecControllerName),\n886\t\t\tbuildServiceAccount(utils.EnoexecControllerName),\n887\t\t\tbuildServiceAccount(utils.EnoexecDaemonSet),\n888\t\n889\t\t\t// Then Roles and ClusterRoles\n890\t\t\tbuildClusterRoleENoExecEventsController(),\n891\t\t\tbuildRoleENoExecEventController(),\n892\t\t\tbuildClusterRoleENoExecEventsDaemonSet(),\n893\t\t\tbuildRoleENoExecEventDaemonSet(),\n894\t\n895\t\t\tbuildClusterRoleBinding(\n896\t\t\t\tutils.EnoexecControllerName,\n897\t\t\t\trbacv1.RoleRef{\n898\t\t\t\t\tAPIGroup: rbacv1.GroupName,\n899\t\t\t\t\tKind:     clusterRoleKind,\n900\t\t\t\t\tName:     utils.EnoexecControllerName,\n901\t\t\t\t},\n902\t\t\t\t[]rbacv1.Subject{\n903\t\t\t\t\t{\n904\t\t\t\t\t\tKind:      serviceAccountKind,\n905\t\t\t\t\t\tName:      utils.EnoexecControllerName,\n906\t\t\t\t\t\tNamespace: utils.Namespace(),\n907\t\t\t\t\t},\n908\t\t\t\t},\n909\t\t\t),\n910\t\t\tbuildRoleBinding(\n911\t\t\t\tutils.EnoexecControllerName,\n912\t\t\t\trbacv1.RoleRef{\n913\t\t\t\t\tAPIGroup: rbacv1.GroupName,\n914\t\t\t\t\tKind:     roleKind,\n915\t\t\t\t\tName:     utils.EnoexecControllerName,\n916\t\t\t\t},\n917\t\t\t\t[]rbacv1.Subject{\n918\t\t\t\t\t{\n919\t\t\t\t\t\tKind:      serviceAccountKind,\n920\t\t\t\t\t\tName:      utils.EnoexecControllerName,\n921\t\t\t\t\t\tNamespace: utils.Namespace(),\n922\t\t\t\t\t},\n923\t\t\t\t},\n924\t\t\t),\n925\t\t\tbuildClusterRoleBinding(\n926\t\t\t\tutils.EnoexecDaemonSet,\n927\t\t\t\trbacv1.RoleRef{\n928\t\t\t\t\tAPIGroup: rbacv1.GroupName,\n929\t\t\t\t\tKind:     clusterRoleKind,\n930\t\t\t\t\tName:     utils.EnoexecDaemonSet,\n931\t\t\t\t},\n932\t\t\t\t[]rbacv1.Subject{\n933\t\t\t\t\t{\n934\t\t\t\t\t\tKind:      serviceAccountKind,\n935\t\t\t\t\t\tName:      utils.EnoexecDaemonSet,\n936\t\t\t\t\t\tNamespace: utils.Namespace(),\n937\t\t\t\t\t},\n938\t\t\t\t},\n939\t\t\t),\n940\t\t\tbuildRoleBinding(\n941\t\t\t\tutils.EnoexecDaemonSet,\n942\t\t\t\trbacv1.RoleRef{\n943\t\t\t\t\tAPIGroup: rbacv1.GroupName,\n944\t\t\t\t\tKind:     roleKind,\n945\t\t\t\t\tName:     utils.EnoexecDaemonSet,\n946\t\t\t\t},\n947\t\t\t\t[]rbacv1.Subject{\n948\t\t\t\t\t{\n949\t\t\t\t\t\tKind:      serviceAccountKind,\n950\t\t\t\t\t\tName:      utils.EnoexecDaemonSet,\n951\t\t\t\t\t\tNamespace: utils.Namespace(),\n952\t\t\t\t\t},\n953\t\t\t\t},\n954\t\t\t),\n955\t\t\tbuildDeploymentENoExecEventHandler(logVerbosityLevel),\n956\t\t\tbuildDaemonSetENoExecEvent(utils.EnoexecDaemonSet, utils.EnoexecDaemonSet, logVerbosityLevel),\n957\t\t}\n958\t\t// If the servicemonitors.monitoring.coreos.com CRD is available, we create the ServiceMonitor objects\n959\t\tif utils.IsResourceAvailable(ctx, r.DynamicClient, monitoringv1.SchemeGroupVersion.WithResource(\"servicemonitors\")) {\n960\t\t\tlog.V(1).Info(\"Creating ServiceMonitors\")\n961\t\t\tobjects = append(objects,\n962\t\t\t\tbuildServiceMonitor(utils.EnoexecControllerName),\n963\t\t\t\tbuildExecFormatErrorAvailabilityAlertRule(),\n964\t\t\t\tbuildExecFormatErrorsDetectedAlertRule(),\n965\t\t\t)\n966\t\t} else {\n967\t\t\tlog.V(1).Info(\"servicemonitoring.monitoring.coreos.com is not available. Skipping the creation of the ServiceMonitors\")\n968\t\t}\n969\t\treturn objects, nil\n970\t}\n971\t\n972\tfunc isDeploymentAvailable(deployment *appsv1.Deployment) bool {\n973\t\tif deployment == nil {\n974\t\t\treturn false\n975\t\t}\n976\t\treturn deployment.Status.AvailableReplicas > 0\n977\t}\n978\t\n979\tfunc isDeploymentUpToDate(deployment *appsv1.Deployment) bool {\n980\t\tif deployment == nil {\n981\t\t\treturn false\n982\t\t}\n983\t\texpectedReplicas := int32(-1)\n984\t\tif deployment.Spec.Replicas != nil {\n985\t\t\texpectedReplicas = *deployment.Spec.Replicas\n986\t\t}\n987\t\treturn deployment.Status.UpdatedReplicas == expectedReplicas &&\n988\t\t\tdeployment.Status.Replicas == expectedReplicas &&\n989\t\t\tdeployment.Status.AvailableReplicas == expectedReplicas &&\n990\t\t\tdeployment.Status.ReadyReplicas == expectedReplicas &&\n991\t\t\tdeployment.Status.UnavailableReplicas == 0 &&\n992\t\t\tdeployment.Status.ObservedGeneration == deployment.Generation\n993\t}\n994\t\n995\t// deleteErroredENoExecEvents deletes ENoExecEvent resources that are marked with an error label.\n996\t// Returns the count of non-errored and errored events found.\n997\tfunc (r *ClusterPodPlacementConfigReconciler) deleteErroredENoExecEvents(ctx context.Context, enoexecEventList *multiarchv1beta1.ENoExecEventList) (nonErroredCount, erroredCount int) {\n998\t\tlog := ctrllog.FromContext(ctx)\n999\t\tfor i := range enoexecEventList.Items {\n1000\t\t\tenoexecEvent := &enoexecEventList.Items[i]\n1001\t\t\t// Check if this ENoExecEvent is marked as errored\n1002\t\t\tif enoexecEvent.Labels == nil {\n1003\t\t\t\tnonErroredCount++\n1004\t\t\t\tcontinue\n1005\t\t\t}\n1006\t\t\tif _, hasError := enoexecEvent.Labels[enoexechandler.ENoExecEventErrorLabel]; !hasError {\n1007\t\t\t\tnonErroredCount++\n1008\t\t\t\tcontinue\n1009\t\t\t}\n1010\t\t\t// Delete errored ENoExecEvents to prevent accumulation of stale resources\n1011\t\t\terroredCount++\n1012\t\t\tdeleteErr := r.Delete(ctx, enoexecEvent)\n1013\t\t\tif deleteErr == nil {\n1014\t\t\t\tlog.V(1).Info(\"Deleted errored ENoExecEvent\", \"name\", enoexecEvent.Name)\n1015\t\t\t} else if client.IgnoreNotFound(deleteErr) == nil {\n1016\t\t\t\tlog.V(1).Info(\"Errored ENoExecEvent already deleted\", \"name\", enoexecEvent.Name)\n1017\t\t\t} else {\n1018\t\t\t\tlog.Error(deleteErr, \"Failed to delete errored ENoExecEvent\", \"name\", enoexecEvent.Name)\n1019\t\t\t}\n1020\t\t}\n1021\t\n1022\t\tif erroredCount > 0 {\n1023\t\t\tlog.Info(\"Deleted errored ENoExecEvent resources during cleanup\", \"erroredCount\", erroredCount)\n1024\t\t}\n1025\t\treturn nonErroredCount, erroredCount\n1026\t}\n1027\t\n1028\t// SetupWithManager sets up the controller with the Manager.\n1029\tfunc (r *ClusterPodPlacementConfigReconciler) SetupWithManager(mgr ctrl.Manager) error {\n1030\t\tc := ctrl.NewControllerManagedBy(mgr).\n1031\t\t\tFor(&multiarchv1beta1.ClusterPodPlacementConfig{}).\n1032\t\t\t// Watch PodPlacementConfig to reconcile ClusterPodPlacementConfig only on create/delete events.\n1033\t\t\t// Updates to PodPlacementConfig are intentionally ignored.\n1034\t\t\tWatches(\n1035\t\t\t\t&multiarchv1beta1.PodPlacementConfig{},\n1036\t\t\t\thandler.EnqueueRequestsFromMapFunc(func(ctx context.Context, obj client.Object) []reconcile.Request {\n1037\t\t\t\t\treturn []reconcile.Request{\n1038\t\t\t\t\t\t{\n1039\t\t\t\t\t\t\tNamespacedName: types.NamespacedName{\n1040\t\t\t\t\t\t\t\tName: common.SingletonResourceObjectName,\n1041\t\t\t\t\t\t\t},\n1042\t\t\t\t\t\t},\n1043\t\t\t\t\t}\n1044\t\t\t\t}),\n1045\t\t\t\tbuilder.WithPredicates(predi
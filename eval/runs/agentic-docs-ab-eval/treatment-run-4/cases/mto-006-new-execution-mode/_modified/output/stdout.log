ersion().String(),\n234\t\t\t\t},\n235\t\t\t\tclock.RealClock{},\n236\t\t\t),\n237\t\t}).SetupWithManager(mgr), unableToCreateController, controllerKey, \"ClusterPodPlacementConfig\")\n238\t\tmust((&multiarchv1beta1.ClusterPodPlacementConfig{}).SetupWebhookWithManager(mgr), unableToCreateController,\n239\t\t\tcontrollerKey, \"ClusterPodPlacementConfigConversionWebhook\")\n240\t}\n241\t\n242\tfunc RunClusterPodPlacementConfigOperandControllers(mgr ctrl.Manager) {\n243\t\tconfig := ctrl.GetConfigOrDie()\n244\t\tclientset := kubernetes.NewForConfigOrDie(config)\n245\t\n246\t\tmust((&podplacement.PodReconciler{\n247\t\t\tClient:    mgr.GetClient(),\n248\t\t\tAPIReader: mgr.GetAPIReader(),\n249\t\t\tScheme:    mgr.GetScheme(),\n250\t\t\tClientSet: clientset,\n251\t\t\tRecorder:  mgr.GetEventRecorderFor(utils.OperatorName), //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n252\t\t}).SetupWithManager(mgr),\n253\t\t\tunableToCreateController, controllerKey, \"PodReconciler\")\n254\t\n255\t\tmust(mgr.Add(podplacement.NewGlobalPullSecretSyncer(clientset, globalPullSecretNamespace, globalPullSecretName)),\n256\t\t\tunableToAddRunnable, runnableKey, \"GlobalPullSecretSyncer\")\n257\t}\n258\t\n259\tfunc RunClusterPodPlacementConfigOperandWebHook(mgr ctrl.Manager) {\n260\t\tconfig := ctrl.GetConfigOrDie()\n261\t\tclientset := kubernetes.NewForConfigOrDie(config)\n262\t\tpool, err := ants.NewMultiPool(16, 16, ants.LeastTasks,\n263\t\t\tants.WithPreAlloc(true))\n264\t\tmust(err, \"unable to create multi pool for the webhook's event messages\")\n265\t\tpostFuncs = append(postFuncs, func() {\n266\t\t\terr = pool.ReleaseTimeout(30 * time.Second)\n267\t\t\tif err != nil {\n268\t\t\t\tsetupLog.Error(err, \"failed to release the worker pool\")\n269\t\t\t}\n270\t\t\tants.Release()\n271\t\t})\n272\t\thandler := podplacement.NewPodSchedulingGateMutatingWebHook(mgr.GetClient(), clientset, mgr.GetScheme(),\n273\t\t\tmgr.GetEventRecorderFor(utils.OperatorName), pool) //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n274\t\tmgr.GetWebhookServer().Register(\"/add-pod-scheduling-gate\", &webhook.Admission{Handler: handler})\n275\t}\n276\t\n277\tfunc RunPodPlacementConfigWebHook(mgr ctrl.Manager) {\n278\t\tmgr.GetWebhookServer().Register(\"/validate-multiarch-openshift-io-v1beta1-podplacementconfig\",\n279\t\t\t&webhook.Admission{Handler: podplacementconfig.NewPodPlacementConfigWebhook(mgr.GetAPIReader(), mgr.GetScheme())})\n280\t}\n281\t\n282\tfunc RunENoExecEventControllers(mgr ctrl.Manager) {\n283\t\tconfig := ctrl.GetConfigOrDie()\n284\t\tclientset := kubernetes.NewForConfigOrDie(config)\n285\t\tmust(enoexeceventhandler.NewReconciler(\n286\t\t\tmgr.GetClient(),\n287\t\t\tclientset,\n288\t\t\tmgr.GetScheme(),\n289\t\t\tmgr.GetEventRecorderFor(utils.EnoexecControllerName), //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n290\t\t).SetupWithManager(mgr), unableToCreateController, controllerKey, \"ENoExecEventController\")\n291\t}\n292\t\n293\tfunc validateFlags() error {\n294\t\tif !enableOperator && !enableClusterPodPlacementConfigOperandControllers && !enableClusterPodPlacementConfigOperandWebHook && !enableENoExecEventControllers {\n295\t\t\treturn errors.New(\"at least one of the following flags must be set: --enable-operator, --enable-ppc-controllers, --enable-ppc-webhook, --enable-enoexec-event-controllers\")\n296\t\t}\n297\t\t// no more than one of the flags can be set\n298\t\tif btoi(enableOperator)+btoi(enableClusterPodPlacementConfigOperandControllers)+btoi(enableClusterPodPlacementConfigOperandWebHook)+btoi(enableENoExecEventControllers) > 1 {\n299\t\t\treturn errors.New(\"only one of the following flags can be set: --enable-operator, --enable-ppc-controllers, --enable-ppc-webhook, --enable-enoexec-event-controllers\")\n300\t\t}\n301\t\treturn nil\n302\t}\n303\t\n304\tfunc bindFlags() {\n305\t\tflag.StringVar(&metricsAddr, \"metrics-bind-address\", \":808
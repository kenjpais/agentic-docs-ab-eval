der) *Reconciler {\n49\t\treturn &Reconciler{\n50\t\t\tClient:    client,\n51\t\t\tclientSet: clientSet,\n52\t\t\tScheme:    scheme,\n53\t\t\trecorder:  recorder,\n54\t\t}\n55\t}\n56\t\n57\t//+kubebuilder:rbac:groups=multiarch.openshift.io,resources=enoexecevents,verbs=get;list;watch;create;update;patch;delete\n58\t//+kubebuilder:rbac:groups=multiarch.openshift.io,resources=enoexecevents/status,verbs=get;update;patch\n59\t//+kubebuilder:rbac:groups=multiarch.openshift.io,resources=enoexecevents/finalizers,verbs=update\n60\t//+kubebuilder:rbac:groups=\"\",resources=pods,verbs=get;list;update\n61\t//+kubebuilder:rbac:groups=\"\",resources=nodes,verbs=get;list\n62\t\n63\t// Reconcile will reconcile the ENoExecEvent resource.\n64\t// It will fetch the ENoExecEvent instance, retrieve the pod and node information,\n65\t// label the pod with the ENoExecEvent label, update the metrics, and publish an event.\n66\t// Finally, it will delete the ENoExecEvent resource if the reconciliation was successful or if the pod was not found.\n67\tfunc (r *Reconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error) {\n68\t\tlogger := log.FromContext(ctx)\n69\t\tmetrics.InitMetrics()\n70\t\t// Fetch the ENoExecEvent instance\n71\t\tenoExecEventObj := &multiarchv1beta1.ENoExecEvent{}\n72\t\tif err := r.Get(ctx, req.NamespacedName, enoExecEventObj); err != nil {\n73\t\t\t// If the resource is not found, we simply return. This is not an error.\n74\t\t\treturn ctrl.Result{}, client.IgnoreNotFound(err)\n75\t\t}\n76\t\n77\t\teNoExecEvent := NewENoExecEvent(enoExecEventObj, ctx, r.recorder)\n78\t\n79\t\tif eNoExecEvent.Namespace != utils.Namespace() {\n80\t\t\tlogger.Info(\"ENoExecEvent is not in the operator namespace, skipping reconciliation\", \"name\", eNoExecEvent.Name, \"namespace\", eNoExecEvent.Namespace)\n81\t\t\tr.markAsError(ctx, eNoExecEvent, ErrorReasonWrongNamespace)\n82\t\t\t// Return nil to avoid requeuing - this event will be cleaned up by deleteErroredENoE
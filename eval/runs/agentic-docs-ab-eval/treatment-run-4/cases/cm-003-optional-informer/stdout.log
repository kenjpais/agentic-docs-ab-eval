{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_014uVkxmzmoej7avmowJqH89","type":"tool_result","content":"1\t// Package utils provides small shared helpers for the cert-manager operator,\n2\t// including optional API discovery (whether a GroupVersionResource is served)\n3\t// and shared informer wiring that runs only when that API exists.\n4\tpackage utils\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\n9\t\t\"k8s.io/apimachinery/pkg/api/errors\"\n10\t\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n11\t\t\"k8s.io/client-go/discovery\"\n12\t)\n13\t\n14\t// ResourceDiscoverer reports whether a GroupVersionResource is served by the\n15\t// cluster API server (via discovery). Implementations include the value returned\n16\t// from NewResourceDiscoverer.\n17\ttype ResourceDiscoverer interface {\n18\t\tDiscover() (bool, error)\n19\t}\n20\t\n21\t// apiResourceDiscoverer implements ResourceDiscoverer using the discovery API.\n22\ttype apiResourceDiscoverer struct {\n23\t\tgvr             schema.GroupVersionResource\n24\t\tdiscoveryClient discovery.DiscoveryInterface\n25\t}\n26\t\n27\t// OptionalInformer holds a typed informer factory only when the target API\n28\t// resource exists on the cluster. Populated by InitInformerIfAvailable when\n29\t// discovery reports the resource is served.\n30\ttype OptionalInformer[GroupInformer any] struct {\n31\t\tInformerFactory *GroupInformer\n32\t}\n33\t\n34\t// NewResourceDiscoverer returns a ResourceDiscoverer for the given GVR and\n35\t// discovery client. Discover is not called until Discover or\n36\t// InitInformerIfAvailable runs.\n37\tfunc NewResourceDiscoverer(gvr schema.GroupVersionResource, discoveryClient discovery.DiscoveryInterface) ResourceDiscoverer {\n38\t\treturn &apiResourceDiscoverer{\n39\t\t\tgvr:             gvr,\n40\t\t\tdiscoveryClient: discoveryClient,\n41\t\t}\n42\t}\n43\t\n44\t// Discover reports whether the API server lists a.gvr.Resource in the\n45\t// APIResources for the group/version in a.gvr. A NotFound error from discovery is\n46\t// treated as not present (false, nil); other errors are returned.\n47\tfunc (a *apiResourceDiscoverer) Discover() (bool, error) {\n48\t\tresources, err := a.discoveryClient.ServerResourcesForGroupVersion(a.gvr.GroupVersion().String())\n49\t\tif err != nil {\n50\t\t\tif errors.IsNotFound(err) {\n51\t\t\t\treturn false, nil\n52\t\t\t}\n53\t\t\treturn false, fmt.Errorf(\"failed to discover resources: %w\", err)\n54\t\t}\n55\t\n56\t\tfor _, res := range resources.APIResources {\n57\t\t\tif res.Name == a.gvr.Resource {\n58\t\t\t\treturn true, nil\n59\t\t\t}\n60\t\t}\n61\t\n62\t\treturn false, nil\n63\t}\n64\t\n65\t// InitInformerIfAvailable calls d.Discover(), and if the resource is served it\n66\t// calls informerInitFunc and stores the result in InformerFactory; otherwise\n67\t// InformerFactory remains nil and no error is returned (the API is treated as\n68\t// unavailable).\n69\tfunc InitInformerIfAvailable[groupInformer any](\n70\t\td ResourceDiscoverer,\n71\t\tinformerInitFunc func() groupInformer,\n72\t) (*OptionalInformer[groupInformer], error) {\n73\t\to := new(OptionalInformer[groupInformer])\n74\t\n75\t\tdiscovered, err := d.Discover()\n76\t\tif err != nil {\n77\t\t\treturn nil, err\n78\t\t}\n79\t\n80\t\tif discovered {\n81\t\t\tinformer := informerInitFunc()\n82\t\t\to.InformerFactory = &informer\n83\t\t}\n84\t\n85\t\treturn o, nil\n86\t}\n87\t\n88\t// Applicable reports whether an informer factory was set (the API was present).\n89\tfunc (o *OptionalInformer[GroupInformer]) Applicable() bool {\n90\t\treturn o.InformerFactory != nil\n91\t}\n92\t"}]},"parent_tool_use_id":null,"session_id":"a36c7296-0784-4af5-b840-7c5df961bda9","uuid":"5956c812-a0e2-4e81-98aa-d935a7b97a22","timestamp":"2026-07-20T14:05:44.306Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/operator/utils/apidiscovery.go","content":"// Package utils provides small shared helpers for the cert-manager operator,\n// including optional API discovery (whether a GroupVersionResource is served)\n// and shared informer wiring that runs only when that API exists.\npackage utils\n\nimport (\n\t\"fmt\"\n\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/discovery\"\n)\n\n// ResourceDiscoverer reports whether a GroupVersionResource is served by the\n// cluster API server (via discovery). Implementations include the value returned\n// from NewResourceDiscoverer.\ntype ResourceDiscoverer interface {\n\tDiscover() (bool, error)\n}\n\n// apiResourceDiscoverer implements ResourceDiscoverer using the discovery API.\ntype apiResourceDiscoverer struct {\n\tgvr             schema.GroupVersionResource\n\tdiscoveryClient discovery.DiscoveryInterface\n}\n\n// OptionalInformer holds a typed informer factory only when the target API\n// resource exists on the cluster. Populated by InitInformerIfAvailable when\n// discovery reports the resource is served.\ntype OptionalInformer[GroupInformer any] struct {\n\tInformerFactory *GroupInformer\n}\n\n// NewResourceDiscoverer returns a ResourceDiscoverer for the given GVR and\n// discovery client. Discover is not called until Discover or\n// InitInformerIfAvailable runs.\nfunc NewResourceDiscoverer(gvr schema.GroupVersionResource, discoveryClient discovery.DiscoveryInterface) ResourceDiscoverer {\n\treturn &apiResourceDiscoverer{\n\t\tgvr:             gvr,\n\t\tdiscoveryClient: discoveryClient,\n\t}\n}\n\n// Discover reports whether the API server lists a.gvr.Resource in the\n// APIResources for the group/version in a.gvr. A NotFound error from discovery is\n// treated as not present (false, nil); other errors are returned.\nfunc (a *apiResourceDiscoverer) Discover() (bool, error) {\n\tresources, err := a.discoveryClient.ServerResourcesForGroupVersion(a.gvr.GroupVersion().String())\n\tif err != nil {\n\t\tif errors.IsNotFound(err) {\n\t\t\treturn false, nil\n\t\t}\n\t\treturn false, fmt.Errorf(\"failed to discover resources: %w\", err)\n\t}\n\n\tfor _, res := range resources.APIResources {\n\t\tif res.Name == a.gvr.Resource {\n\t\t\treturn true, nil\n\t\t}\n\t}\n\n\treturn false, nil\n}\n\n// InitInformerIfAvailable calls d.Discover(), and if the resource is served it\n// calls informerInitFunc and stores the result in InformerFactory; otherwise\n// InformerFactory remains nil and no error is returned (the API is treated as\n// unavailable).\nfunc InitInformerIfAvailable[groupInformer any](\n\td ResourceDiscoverer,\n\tinformerInitFunc func() groupInformer,\n) (*OptionalInformer[groupInformer], error) {\n\to := new(OptionalInformer[groupInformer])\n\n\tdiscovered, err := d.Discover()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif discovered {\n\t\tinformer := informerInitFunc()\n\t\to.InformerFactory = &informer\n\t}\n\n\treturn o, nil\n}\n\n// Applicable reports whether an informer factory was set (the API was present).\nfunc (o *OptionalInformer[GroupInformer]) Applicable() bool {\n\treturn o.InformerFactory != nil\n}\n","numLines":92,"startLine":1,"totalLines":92}}}

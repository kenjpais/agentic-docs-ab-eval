merIfAvailable(\n\t\tutils.NewResourceDiscoverer(infraGVR, configClient.Discovery()),\n\t\tfunc() configinformers.SharedInformerFactory {\n\t\t\treturn configinformers.NewSharedInformerFactory(configClient, resyncInterval)\n\t\t},\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to discover Infrastructure presence: %w\", err)\n\t}\n\n\tproxyGVR := configv1.GroupVersion.WithResource(\"proxies\")\n\toptProxyInformer, err := utils.InitInformerIfAvailable(\n\t\tutils.NewResourceDiscoverer(proxyGVR, configClient.Discovery()),\n\t\tfunc() configinformers.SharedInformerFactory {\n\t\t\treturn configinformers.NewSharedInformerFactory(configClient, resyncInterval)\n\t\t},\n\t)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to discover Proxy presence: %w\", err)\n\t}\n\n\t// ... existing certManagerControllerSet, etc. ...\n\n\t// only start the informer if Infrastructure is found applicable\n\tif optInfraInformer.Applicable() {\n\t\t(*optInfraInformer.InformerFactory).Start(ctx.Done())\n\t}\n\n\tif optProxyInformer.Applicable() {\n\t\t(*optProxyInformer.InformerFactory).Start(ctx.Done())\n\t}\n```\n\n**Pass `optProxyInformer` into `NewControllerManager`**: We need to thread it through `ControllerConfig` → `setupTrustManagerController` → `trustmanager.New`.\n\n### File 3: `pkg/operator/setup_manager.go` — thread proxy informer\n\n**Add import** (already has `configv1 \"github.com/openshift/api/config/v1\"`):\n\n```go\n\tconfiginformers \"github.com/openshift/client-go/config/informers/externalversions\"\n\t\"github.com/openshift/cert-manager-operator/pkg/operator/utils\"\n```\n\n**Modify `ControllerConfig`** (line 115-118):\n\n```go\ntype ControllerConfig struct {\n\tEnableIstioCSR     bool\n\tEnableTrustManager bool\n\tProxyInformer      *utils.OptionalInformer[configinformers.SharedInformerFactory]\n}\n```\n\n**Modify `setupTrustManagerController`** (line 170-180):\n\n```go\nfunc setupTrustManagerController(mgr ctrl.Manager, proxyInformer *utils.OptionalInformer[configinformers.SharedInformerFactory]) error {\n\tsetupLog.Info(\"setting up controller\", \"name\", trustmanager.ControllerName)\n\tr, err := trustmanager.New(mgr, proxyInformer)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to create %s reconciler object: %w\", trustmanager.ControllerName, err)\n\t}\n\tif err := r.SetupWithManager(mgr); err != nil {\n\t\treturn fmt.Errorf(\"failed to create %s controller: %w\", trustmanager.ControllerName, err)\n\t}\n\treturn nil\n}\n```\n\n**Update the call site** in `NewControllerManager` (line 145-149):\n\n```go\n\tif config.EnableTrustManager {\n\t\tif err := setupTrustManagerController(mgr, config.ProxyInformer); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n```\n\n### File 4: `pkg/operator/starter.go` — pass ProxyInformer to ControllerConfig\n\n**Modify the `NewControllerManager` call** (around line 150):\n\n```go\n\t\tmanager, err := NewControllerManager(ControllerConfig{\n\t\t\tEnableIstioCSR:     istioCSREnabled,\n\t\t\tEnableTrustManager: trustManagerEnabled,\n\t\t\tProxyInformer:      optProxyInformer,\n\t\t})\n```\n\n### File 5: `pkg/controller/trustmanager/controller.go` — accept and use proxy informer\n\n**Add imports**:\n\n```go\n\tconfigv1 \"github.com/openshift/api/config/v1\"\n\tconfiginformers \"github.com/openshift/client-go/config/informers/externalversions\"\n\n\t\"github.com/openshift/cert-manager-operator/pkg/operator/utils\"\n```\n\n**Add field to `Reconciler`** (after line 44):\n\n```go\ntype Reconciler struct {\n\tcommon.CtrlClient\n\n\tctx            context.Context\n\teventRecorder  record.EventRecorder\n\tlog            logr.Logger\n\tscheme         *runtime.Scheme\n\tproxyInformer  *utils.OptionalInformer[configinformers.SharedInformerFactory]\n}\n```\n\n**Update `New` constructor** (line 64-76):\n\n```go\nfunc New(mgr ctrl.Manager, proxyInformer *utils.OptionalInformer[configinformers.SharedInformerFactory]) (*Reconciler, error) {\n\tc, err := common.NewClient(mgr)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn &Reconciler{\n\t\tCtrlClient:    c,\n\t\tctx:           context.Background(),\n\t\teventRecorder: mgr.GetEventRecorderFor(ControllerName),\n\t\tlog:           ctrl.Log.WithName(ControllerName),\n\t\tscheme:        mgr.GetScheme(),\n\t\tproxyInformer: proxyInformer,\n\t}, nil\n}\n```\n\n**Add proxy reading method and reconcile-time guard**: Add a new method to the Reconciler that reads proxy settings when available. Insert this in `controller.go` after the `cleanUp` method (after line 219):\n\n```go\n// clusterProxySettings returns the cluster-wide proxy configuration from\n// config.openshift.io/v1 Proxy \"cluster\" when the API is available. Returns\n// empty strings on non-OpenShift clusters or when no proxy is configured.\nfunc (r *Reconciler) clusterProxySettings() (httpProxy, httpsProxy, noProxy string) {\n\tif r.proxyInformer == nil || !r.proxyInformer.Applicable() {\n\t\treturn \"\", \"\", \"\"\n\t}\n\n\tproxyLister := (*r.proxyInformer.InformerFactory).Config().V1().Proxies().Lister()\n\tproxy, err := proxyLister.Get(\"cluster\")\n\tif err != nil {\n\t\tr.log.V(2).Info(\"unable to read cluster proxy config\", \"error\", err)\n\t\treturn \"\", \"\", \"\"\n\t}\n\n\treturn proxy.Status.HTTPProxy, proxy.Status.HTTPSProxy, proxy.Status.NoProxy\n}\n```\n\n**Add the reconcile-time guard** in `processReconcileRequest`. Modify `processReconcileRequest` (line 195-210):\n\n```go\nfunc (r *Reconciler) processReconcileRequest(trustManager *v1alpha1.TrustManager, req types.NamespacedName) (ctrl.Result, error) {\n\thttpProxy, httpsProxy, noProxy := r.clusterProxySettings()\n\tif httpProxy != \"\" || httpsProxy != \"\" || noProxy != \"\" {\n\t\tr.log.V(2).Info(\"cluster proxy settings detected\",\n\t\t\t\"httpProxy\", httpProxy, \"httpsProxy\", httpsProxy, \"noProxy\", noProxy)\n\t}\n\n\treconcileErr := r.reconcileTrustManagerDeployment(trustManager)\n\tif reconcileErr != nil {\n\t\tr.log.Error(reconcileErr, \"failed to reconcile TrustManager deployment\", \"request\", req)\n\t}\n\n\treturn common.HandleReconcileResult(\n\t\t&trustManager.Status.ConditionalStatus,\n\t\treconcileErr,\n\t\tr.log.WithValues(\"name\", trustManager.GetName()),\n\t\tfunc(prependErr error) error {\n\t\t\treturn r.updateCondition(trustManager, prependErr)\n\t\t},\n\t\tdefaultRequeueTime,\n\t)\n}\n```\n\n### File 6: `pkg/operator/utils/apidiscovery.go` — final complete file\n\nHere is the complete file with the new function:\n\n```go\n// Package utils provides small shared helpers for the cert-manager operator,\n// including optional API discovery (whether a GroupVersionResource is served)\n// and shared informer wiring that runs only when that API exists.\npackage utils\n\nimport (\n\t\"fmt\"\n\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/discovery\"\n)\n\n// ResourceDiscoverer reports whether a GroupVersionResource is served by the\n// cluster API server (via discovery). Implementations include the value returned\n// from NewResourceDiscoverer.\ntype ResourceDiscoverer interface {\n\tDiscover() (bool, error)\n}\n\n// apiResourceDiscoverer implements ResourceDiscoverer using the discovery API.\ntype apiResourceDiscoverer struct {\n\tgvr             schema.GroupVersionResource\n\tdiscoveryClient discovery.DiscoveryInterface\n}\n\n// OptionalInformer holds a typed informer factory only when the target API\n// resource exists on the cluster. Populated by InitInformerIfAvailable when\n// discovery reports the resource is served.\ntype OptionalInformer[GroupInformer any] struct {\n\tInformerFactory *GroupInformer\n}\n\n// NewResourceDiscoverer returns a ResourceDiscoverer for the given GVR and\n// discovery client. Discover is not called until Discover or\n// InitInformerIfAvailable runs.\nfunc NewResourceDiscoverer(gvr schema.GroupVersionResource, discoveryClient discovery.DiscoveryInterface) ResourceDiscoverer {\n\treturn &apiResourceDiscoverer{\n\t\tgvr:             gvr,\n\t\tdiscoveryClient: discoveryClient,\n\t}\n}\n\n// Discover reports whether the API server lists a.gvr.Resource in the\n// APIResources for the group/version in a.gvr. A NotFound error from discovery is\n// treated as not present (false, nil); other errors are returned.\nfunc (a *apiResourceDiscoverer) Discover() (bool, error) {\n\tresources, err := a.discoveryClient.ServerResourcesForGroupVersion(a.gvr.GroupVersion().String())\n\tif err != nil {\n\t\tif errors.IsNotFound(err) {\n\t\t\treturn false, nil\n\t\t}\n\t\treturn false, fmt.Errorf(\"failed to discover resources: %w\", err)\n\t}\n\n\tfor _, res := range resources.APIResources {\n\t\tif res.Name == a.gvr.Resource {\n\t\t\treturn true, nil\n\t\t}\n\t}\n\n\treturn false, nil\n}\n\n// InitInformerIfAvailable calls d.Discover(), and if the resource is served it\n// calls informerInitFunc and stores the result in InformerFactory; otherwise\n// InformerFactory remains nil and no error is returned (the API is treated as\n// unavailable).\nfunc InitInformerIfAvailable[groupInformer any](\n\td ResourceDiscoverer,\n\tinformerInitFunc func() groupInformer,\n) (*OptionalInformer[groupInformer], error) {\n\to := new(OptionalInformer[groupInformer])\n\n\tdiscovered, err := d.Discover()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif discovered {\n\t\tinformer := informerInitFunc()\n\t\to.InformerFactory = &informer\n\t}\n\n\treturn o, nil\n}\n\n// Applicable reports whether an informer factory was set (the API was present).\nfunc (o *OptionalInformer[GroupInformer]) Applicable() bool {\n\treturn o.InformerFactory != nil\n}\n\n// NewProxyInformerIfAvailable discovers whether config.openshift.io/v1 proxies\n// is served by the cluster and, if so, calls informerInitFunc to create an\n// informer factory. Returns an OptionalInformer whose Applicable() method\n// reports whether the Proxy API was found.\nfunc NewProxyInformerIfAvailable[F any](\n\tdiscoveryClient discovery.DiscoveryInterface,\n\tinformerInitFunc func() F,\n) (*OptionalInformer[F], error) {\n\tproxyGVR := schema.GroupVersionResource{\n\t\tGroup:    \"config.openshift.io\",\n\t\tVersion:  \"v1\",\n\t\tResource: \"proxies\",\n\t}\n\treturn InitInformerIfAvailable(\n\t\tNewResourceDiscoverer(proxyGVR, discoveryClient),\n\t\tinformerInitFunc,\n\t)\n}\n```\n\n---\n\n## Summary of all changed files\n\n### 1. `pkg/operator/utils/apidiscovery.go`\nAdd `NewProxyInformerIfAvailable` generic function after `Applicable()` (shown above).\n\n### 2. `pkg/operator/starter.go`\n- After `optInfraInformer` creation (line 98), add proxy informer creation using `NewProxyInformerIfAvailable` (or equivalently `InitInformerIfAvailable` with the proxy GVR directly).\n- After infra informer `.Start()` (line 135), add proxy informer `.Start()`.\n- Pass `ProxyInformer: optProxyInformer` in the `ControllerConfig` struct.\n\n**Diff for `starter.go`:**\n\n```diff\n@@ -97,6 +97,16 @@\n \tif err != nil {\n \t\treturn fmt.Errorf(\"failed to discover Infrastructure presence: %w\", err)\n \t}\n+\n+\toptProxyInformer, err := utils.NewProxyInformerIfAvailable(\n+\t\tconfigClient.Discovery(),\n+\t\tfunc() configinformers.SharedInformerFactory {\n+\t\t\treturn configinformers.NewSharedInformerFactory(configClient, resyncInterval)\n+\t\t},\n+\t)\n+\tif err != nil {\n+\t\treturn fmt.Errorf(\"failed to discover Proxy presence: %w\", err)\n+\t}\n \n \tcertManagerControllerSet := certmanager.NewCertManagerControllerSet(\n@@ -133,6 +143,10 @@\n \tif optInfraInformer.Applicable() {\n \t\t(*optInfraInformer.InformerFactory).Start(ctx.Done())\n \t}\n+\n+\tif optProxyInformer.Applicable() {\n+\t\t(*optProxyInformer.InformerFactory).Start(ctx.Done())\n+\t}\n \n \tfor _, controller := range controllersToStart {\n@@ -149,6 +163,7 @@\n \t\tmanager, err := NewControllerManager(ControllerConfig{\n \t\t\tEnableIstioCSR:     istioCSREnabled,\n \t\t\tEnableTrustManager: trustManagerEnabled,\n+\t\t\tProxyInformer:      optProxyInformer,\n \t\t})\n```\n\n### 3. `pkg/operat
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01SWYLbhehGVHCMWkadMLyuh","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\n7\t\tadmissionregistrationv1 \"k8s.io/api/admissionregistration/v1\"\n8\t\tappsv1 \"k8s.io/api/apps/v1\"\n9\t\tcorev1 \"k8s.io/api/core/v1\"\n10\t\trbacv1 \"k8s.io/api/rbac/v1\"\n11\t\t\"k8s.io/apimachinery/pkg/api/errors\"\n12\t\t\"k8s.io/apimachinery/pkg/runtime\"\n13\t\t\"k8s.io/apimachinery/pkg/types\"\n14\t\t\"k8s.io/client-go/tools/record\"\n15\t\n16\t\tctrl \"sigs.k8s.io/controller-runtime\"\n17\t\t\"sigs.k8s.io/controller-runtime/pkg/builder\"\n18\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n19\t\t\"sigs.k8s.io/controller-runtime/pkg/event\"\n20\t\t\"sigs.k8s.io/controller-runtime/pkg/handler\"\n21\t\t\"sigs.k8s.io/controller-runtime/pkg/predicate\"\n22\t\t\"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n23\t\n24\t\t\"github.com/go-logr/logr\"\n25\t\n26\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n27\t\n28\t\tv1alpha1 \"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n29\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n30\t)\n31\t\n32\t// RequestEnqueueLabelValue is the label value used for filtering reconcile\n33\t// events to include only the resources created by the TrustManager controller.\n34\t// The label key is common.ManagedResourceLabelKey.\n35\tconst RequestEnqueueLabelValue = \"cert-manager-trust-manager\"\n36\t\n37\t// Reconciler reconciles a TrustManager object.\n38\ttype Reconciler struct {\n39\t\tcommon.CtrlClient\n40\t\n41\t\tctx           context.Context\n42\t\teventRecorder record.EventRecorder\n43\t\tlog           logr.Logger\n44\t\tscheme        *runtime.Scheme\n45\t}\n46\t\n47\t// +kubebuilder:rbac:groups=operator.openshift.io,resources=trustmanagers,verbs=get;list;watch;update;patch\n48\t// +kubebuilder:rbac:groups=operator.openshift.io,re
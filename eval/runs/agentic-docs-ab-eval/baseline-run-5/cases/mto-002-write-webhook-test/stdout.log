thout PPC filtering - fail open\n89\t\t\tppcList.Items = []multiarchv1beta1.PodPlacementConfig{}\n90\t\t}\n91\t\n92\t\t// Filter to only PPCs that match this pod's labels - do this once for efficiency\n93\t\tmatchingPPCs := pod.filterMatchingPPCs(ppcList)\n94\t\n95\t\t// Set label to indicate if preferred affinity will be set by CPPC or any matching PPC\n96\t\tif (cppc != nil && cppc.PluginsEnabled(common.NodeAffinityScoringPluginName)) ||\n97\t\t\tpod.hasMatchingPPCWithPlugin(matchingPPCs) {\n98\t\t\tpod.EnsureLabel(utils.PreferredNodeAffinityLabel, utils.LabelValueNotSet)\n99\t\t}\n100\t\tpod.EnsureLabel(utils.NodeAffinityLabel, utils.LabelValueNotSet)\n101\t\tpod.EnsureLabel(utils.SchedulingGateLabel, utils.LabelValueNotSet)\n102\t\n103\t\tif pod.shouldIgnorePod(cppc, matchingPPCs) {\n104\t\t\tlog.V(3).Info(\"Ignoring the pod\")\n105\t\t\treturn a.patchedPodResponse(pod.PodObject(), req)\n106\t\t}\n107\t\n108\t\tpod.ensureSchedulingGate()\n109\t\t// We also add a label to the pod to indicate that the scheduling gate was added\n110\t\t// and this pod expects processing by the operator. That's useful for testing and debugging, but also gives the user\n111\t\t// an indication that the pod is waiting for processing and can support kubectl queries to find out which pods are\n112\t\t// waiting for processing, for example when the operator is being uninstalled.\n113\t\tpod.Labels[utils.SchedulingGateLabel] = utils.SchedulingGateLabelValueGated\n114\t\t// we don't care about this goroutine, it's informational,\n115\t\t// we know it will finish eventually by design, and we don't need to block the response as we\n116\t\t// are right in the admission pipeline, before the pod is persisted.\n117\t\tlog.V(3).Info(\"Scheduling gate added to the pod, launching the event creation goroutine\")\n118\t\ta.delayedSchedulingGatedEvent(ctx, pod.DeepCopy())\n119\t\tmetrics.GatedPods.Inc()\n120\t\tmetrics.GatedPodsGauge.Inc()\n121\t\tlog.V(2).Info(\"Accepting pod\")\n122\t\treturn a.patchedPodResponse(pod.PodObject(), req)\n123\t}\n124\t\n125\tfunc (a *PodSchedulingGateMutatingWebHook) delayedSchedulingGatedEvent(ctx context.Context, pod *corev1.Pod) {\n126\t\terr := a.workerPool.Submit(func() {\n127\t\t\tctx, cancel := context.WithTimeout(context.Background(), 2*time.Minute)\n128\t\t\tdefer cancel()\n129\t\t\tlog := ctrllog.FromContext(ctx).WithValues(\"namespace\", pod.Namespace, \"name\", pod.Name,\n130\t\t\t\t\"function\", \"delayedSchedulingGatedEvent\")\n131\t\t\t// We try to get the pod from the API with exponential backoff until we find it or a timeout is reached\n132\t\t\terr := wait.ExponentialBackoff(wait.Backoff{\n133\t\t\t\t// The maximum time, excluding the time for the execution of the request,\n134\t\t\t\t// is the sum of a geometric series with factor != 1.\n135\t\t\t\t// maxTime = duration * (factor^steps - 1) / (factor - 1)\n136\t\t\t\t// maxTime = 2e-3s * (2^15 - 1) = 65.534s\n137\t\t\t\tDuration: 2 * time.Millisecond,\n138\t\t\t\tFactor:   2,\n139\t\t\t\tSteps:    15,\n140\t\t\t}, func() (bool, error) {\n141\t\t\t\tcreatedPod, err := a.clientSet.CoreV1().Pods(pod.Namespace).Get(ctx, pod.Name, metav1.GetOptions{})\n142\t\t\t\tif err == nil {\n143\t\t\t\t\tlog.V(2).Info(\"Pod was found\", \"namespace\", pod.Namespace, \"name\", pod.Name)\n144\t\t\t\t\ta.recorder.Event(createdPod, corev1.EventTypeNormal, ArchitectureAwareSchedulingGateAdded, SchedulingGateAddedMsg)\n145\t\t\t\t\t// Pod was found, return true to stop retrying\n146\t\t\t\t\treturn true, nil\n147\t\t\t\t}\n148\t\t\t\tif apierrors.IsNotFound(err) {\n149\t\t\t\t\tlog.V(3).Info(\"Pod not found yet\", \"namespace\", pod.Namespace, \"name\", pod.Name)\n150\t\t\t\t\t// Pod not found yet, continue retrying\n151\t\t\t\t\treturn false, nil\n152\t\t\t\t}\n153\t\t\t\t// Stop retrying\n154\t\t\t\tlog.V(3).Info(\"Failed to get pod\", \"error\", err)\n155\t\t\t\treturn false, err\n156\t\t\t})\n157\t\t\tif err != nil {\n158\t\t\t\tlog.V(2).Info(\"Failed to get a scheduling gated Po
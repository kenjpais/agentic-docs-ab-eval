io/controller-runtime/pkg/metrics/server\"\n51\t\t\"sigs.k8s.io/controller-runtime/pkg/webhook\"\n52\t\n53\t\t//+kubebuilder:scaffold:imports\n54\t\n55\t\t\"github.com/openshift/library-go/pkg/operator/events\"\n56\t\n57\t\t\"github.com/panjf2000/ants/v2\"\n58\t\tzapuber \"go.uber.org/zap\"\n59\t\t\"go.uber.org/zap/zapcore\"\n60\t\n61\t\tmonitoringv1 \"github.com/prometheus-operator/prometheus-operator/pkg/apis/monitoring/v1\"\n62\t\n63\t\tmultiarchv1alpha1 \"github.com/openshift/multiarch-tuning-operator/api/v1alpha1\"\n64\t\tmultiarchv1beta1 \"github.com/openshift/multiarch-tuning-operator/api/v1beta1\"\n65\t\n66\t\t\"github.com/openshift/multiarch-tuning-operator/api/common\"\n67\t\tenoexeceventhandler \"github.com/openshift/multiarch-tuning-operator/internal/controller/enoexecevent/handler\"\n68\t\t\"github.com/openshift/multiarch-tuning-operator/internal/controller/operator\"\n69\t\t\"github.com/openshift/multiarch-tuning-operator/internal/controller/podplacement\"\n70\t\t\"github.com/openshift/multiarch-tuning-operator/internal/controller/podplacementconfig\"\n71\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/informers/clusterpodplacementconfig\"\n72\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/utils\"\n73\t)\n74\t\n75\tconst (\n76\t\tunableToCreateController = \"unable to create controller\"\n77\t\tunableToAddRunnable      = \"unable to add runnable\"\n78\t\tcontrollerKey            = \"controller\"\n79\t\trunnableKey              = \"runnable\"\n80\t)\n81\t\n82\tvar (\n83\t\tscheme   = runtime.NewScheme()\n84\t\tsetupLog = ctrl.Log.WithName(\"setup\")\n85\t\tmetricsAddr,\n86\t\tprobeAddr,\n87\t\tcertDir,\n88\t\tglobalPullSecretNamespace,\n89\t\tglobalPullSecretName,\n90\t\tregistryCertificatesConfigMapName string\n91\t\tenableLeaderElection,\n92\t\tenableClusterPodPlacementConfigOperandWebHook,\n93\t\tenableClusterPodPlacementConfigOperandControllers,\n94\t\tenableENoExecEventControllers bool\n95\t\tenableCPPCInformer bool\n96\t\tenableOperator     bool\n97\t\tinitialLogLevel    int\n98\t\tpostFuncs          []func()\n99\t)\n100\t\n101\tfunc init() {\n102\t\tutilruntime.Must(clientgoscheme.AddToScheme(scheme))\n103\t\tutilruntime.Must(multiarchv1alpha1.AddToScheme(scheme))\n104\t\tutilruntime.Must(multiarchv1beta1.AddToScheme(scheme))\n105\t\tutilruntime.Must(monitoringv1.AddToScheme(scheme))\n106\t}\n107\t\n108\tfunc main() {\n109\t\tbindFlags()\n110\t\tmust(validateFlags(), \"invalid flags\")\n111\t\tcacheOpts := cache.Options{\n112\t\t\tDefaultTransform: cache.TransformStripManagedFields(),\n113\t\t}\n114\t\n115\t\t// Build the leader election ID deterministically and based on the flags\n116\t\tleaderID := \"208d7abd.multiarch.openshift.io\"\n117\t\tif enableOperator {\n118\t\t\tleaderID = fmt.Sprintf(\"operator-%s\", leaderID)\n119\t\t}\n120\t\tif enableClusterPodPlacementConfigOperandControllers {\n121\t\t\tleaderID = fmt.Sprintf(\"ppc-controllers-%s\", leaderID)\n122\t\t\t// We need to watch the pods with the status.phase equal to Pending to be able to update the nodeAffinity.\n123\t\t\t// We can discard the other pods because they are already scheduled.\n124\t\t\tcacheOpts.ByObject = map[client.Object]cache.ByObject{\n125\t\t\t\t&corev1.Pod{}: {\n126\t\t\t\t\tField: fields.OneTermEqualSelector(\"status.phase\", \"Pending\"),\n127\t\t\t\t},\n128\t\t\t}\n129\t\t}\n130\t\tif enableENoExecEventControllers {\n131\t\t\tleaderID = fmt.Sprintf(\"enoexecevent-controllers-%s\", leaderID)\n132\t\t\tcacheOpts.DefaultNamespaces = map[string]cache.Config{\n133\t\t\t\tutils.Namespace(): {},\n134\t\t\t}\n135\t\t}\n136\t\n137\t\t// Rapid Reset CVEs. For more information see:\n138\t\t// - https://github.com/advisories/GHSA-qppj-fm5r-hxr3\n139\t\t// - https://github.com/advisories/GHSA-4374-p667-p6c8\n140\t\t// - https://github.com/kubernetes-sigs/kubebuilder/blob/33a2f3dc556a9e49e06e6f19e0ae737d82d402db/testdata/project-v4/cmd/main.go#L78-L89\n141\t\tvar tlsOpts []func(*tls.Config)\n142\t\tdisableHTTP2 := func(c *tls.Config) {\n143\t\t\tsetupLog.Info(\"disabling http/2\")\n144\t\t\tc.NextProtos = []string{\"http/1.1\"}\n145\t\t}\n146\t\ttlsOpts = append(tlsOpts, disableHTTP2)\n147\t\n148\t\twebhookServer := webhook.NewServer(webhook.Options{\n149\t\t\tPort:    9443,\n150\t\t\tCertDir: certDir,\n151\t\t\tTLSOpts: tlsOpts,\n152\t\t})\n153\t\tmgr, err := ctrl.NewManager(ctrl.GetConfigOrDie(), ctrl.Options{\n154\t\t\tScheme: scheme,\n155\t\t\tMetrics: metricsserver.Options{\n156\t\t\t\tBindAddress:    metricsAddr,\n157\t\t\t\tCertDir:        certDir,\n158\t\t\t\tFilterProvider: filters.WithAuthenticationAndAuthorization,\n159\t\t\t\tSecureServing:  true,\n160\t\t\t},\n161\t\t\tWebhookServer:          webhookServer,\n162\t\t\tHealthProbeBindAddress: probeAddr,\n163\t\t\tLeaderElection:         enableLeaderElection,\n164\t\t\tLeaderElectionID:       leaderID,\n165\t\t\tCache:                  cacheOpts,\n166\t\t\tLogger:                 ctrllog.FromContext(context.Background()).WithName(\"manager\"),\n167\t\t\t// LeaderElectionReleaseOnCancel defines if the leader should step down voluntarily\n168\t\t\t// when the Manager ends. This requires the binary to immediately end when the\n169\t\t\t// Manager is stopped, otherwise, this setting is unsafe. Setting this significantly\n170\t\t\t// speeds up voluntary leader transitions as the new leader don't have to wait\n171\t\t\t// LeaseDuration time first.\n172\t\t\t//\n173\t\t\t// In the default scaffold provided, the program ends immediately after\n174\t\t\t// the manager stops, so would be fine to enable this option. However,\n175\t\t\t// if you are doing or is intended to do any operation such as perform cleanups\n176\t\t\t// after the manager stops then its usage might be unsafe.\n177\t\t\t// LeaderElectionReleaseOnCancel: true,\n178\t\t})\n179\t\tmust(err, \"unable to create manager\")\n180\t\n181\t\t//+kubebuilder:scaffold:builder\n182\t\tmust(mgr.AddHealthzCheck(\"healthz\", healthz.Ping), \"unable to set up health check\")\n183\t\tmust(mgr.AddReadyzCheck(\"readyz\", healthz.Ping), \"unable to set up ready check\")\n184\t\n185\t\tif enableCPPCInformer {\n186\t\t\tmust(mgr.Add(clusterpodplacementconfig.NewCPPCSyncer(mgr)), \"unable to instantiate CPPCSyncer\")\n187\t\t}\n188\t\n189\t\tif enableOperator {\n190\t\t\tRunOperator(mgr)\n191\t\t\tRunPodPlacementConfigWebHook(mgr)\n192\t\t}\n193\t\tif enableClusterPodPlacementConfigOperandControllers {\n194\t\t\tRunClusterPodPlacementConfigOperandControllers(mgr)\n195\t\t}\n196\t\tif enableClusterPodPlacementConfigOperandWebHook {\n197\t\t\tRunClusterPodPlacementConfigOperandWebHook(mgr)\n198\t\t}\n199\t\tif enableENoExecEventControllers {\n200\t\t\tRunENoExecEventControllers(mgr)\n201\t\t}\n202\t\n203\t\tsetupLog.Info(\"starting manager\")\n204\t\tmust(mgr.Start(ctrl.SetupSignalHandler()), \"unable to start the manager\")\n205\t\tsetupLog.Info(\"the manager has stopped\")\n206\t\tsetupLog.Info(\"running post functions\")\n207\t\tfor _, f := range postFuncs {\n208\t\t\tf()\n209\t\t}\n210\t\tsetupLog.Info(\"exiting\")\n211\t}\n212\t\n213\tfunc RunOperator(mgr ctrl.Manager) {\n214\t\tconfig := ctrl.GetConfigOrDie()\n215\t\tclientset := kubernetes.NewForConfigOrDie(config)\n216\t\n217\t\t// Get GVK for ClusterPodPlacementConfig\n218\t\tgvk, _ := apiutil.GVKForObject(&multiarchv1beta1.ClusterPodPlacementConfig{}, mgr.GetScheme())\n219\t\n220\t\t// Set up the reconciler\n221\t\tmust((&operator.ClusterPodPlacementConfigReconciler{\n222\t\t\tClient:        mgr.GetClient(),\n223\t\t\tScheme:        mgr.GetScheme(),\n224\t\t\tClientSet:     clientset,\n225\t\t\tDynamicClient: dynamic.NewForConfigOrDie(config),\n226\t\t\tRecorder: events.NewKubeRecorder(\n227\t\t\t\tclientset.CoreV1().Events(utils.Namespace()),\n228\t\t\t\tutils.OperatorName,\n229\t\t\t\t&corev1.ObjectReference{\n230\t\t\t\t\tKind:       gvk.Kind,\n231\t\t\t\t\tName:       common.SingletonResourceObjectName,\n232\t\t\t\t\tNamespace:  utils.Namespace(),\n233\t\t\t\t\tAPIVersion: gvk.GroupVersion().String(),\n234\t\t\t\t},\n235\t\t\t\tclock.RealClock{},\n236\t\t\t),\n237\t\t}).SetupWithManager(mgr), unableToCreateController, controllerKey, \"ClusterPodPlacementConfig\")\n238\t\tmust((&multiarchv1beta1.ClusterPodPlacementConfig{}).SetupWebhookWithManager(mgr), unableToCreateController,\n239\t\t\tcontrollerKey, \"ClusterPodPlacementConfigConversionWebhook\")\n240\t}\n241\t\n242\tfunc RunClusterPodPlacementConfigOperandControllers(mgr ctrl.Manager) {\n243\t\tconfig := ctrl.GetConfigOrDie()\n244\t\tclientset := kubernetes.NewForConfigOrDie(config)\n245\t\n246\t\tmust((&podplacement.PodReconciler{\n247\t\t\tClient:    mgr.GetClient(),\n248\t\t\tAPIReader: mgr.GetAPIReader(),\n249\t\t\tScheme:    mgr.GetScheme(),\n250\t\t\tClientSet: clientset,\n251\t\t\tRecorder:  mgr.GetEventRecorderFor(utils.OperatorName), //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n252\t\t}).SetupWithManager(mgr),\n253\t\t\tunableToCreateController, controllerKey, \"PodReconciler\")\n254\t\n255\t\tmust(mgr.Add(podplacement.NewGlobalPullSecretSyncer(clientset, globalPullSecretNamespace, globalPullSecretName)),\n256\t\t\tunableToAddRunnable, runnableKey, \"GlobalPullSecretSyncer\")\n257\t}\n258\t\n259\tfunc RunClusterPodPlacementConfigOperandWebHook(mgr ctrl.Manager) {\n260\t\tconfig := ctrl.GetConfigOrDie()\n261\t\tclientset := kubernetes.NewForConfigOrDie(config)\n262\t\tpool, err := ants.NewMultiPool(16, 16, ants.LeastTasks,\n263\t\t\tants.WithPreAlloc(true))\n264\t\tmust(err, \"unable to create multi pool for the webhook's event messages\")\n265\t\tpostFuncs = append(postFuncs, func() {\n266\t\t\terr = pool.ReleaseTimeout(30 * time.Second)\n267\t\t\tif err != nil {\n268\t\t\t\tsetupLog.Error(err, \"failed to release the worker pool\")\n269\t\t\t}\n270\t\t\tants.Release()\n271\t\t})\n272\t\thandler := podplacement.NewPodSchedulingGateMutatingWebHook(mgr.GetClient(), clientset, mgr.GetScheme(),\n273\t\t\tmgr.GetEventRecorderFor(utils.OperatorName), pool) //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n274\t\tmgr.GetWebhookServer().Register(\"/add-pod-scheduling-gate\", &webhook.Admission{Handler: handler})\n275\t}\n276\t\n277\tfunc RunPodPlacementConfigWebHook(mgr ctrl.Manager) {\n278\t\tmgr.GetWebhookServer().Register(\"/validate-multiarch-openshift-io-v1beta1-podplacementconfig\",\n279\t\t\t&webhook.Admission{Handler: podplacementconfig.NewPodPlacementConfigWebhook(mgr.GetAPIReader(), mgr.GetScheme())})\n280\t}\n281\t\n282\tfunc RunENoExecEventControllers(mgr ctrl.Manager) {\n283\t\tconfig := ctrl.GetConfigOrDie()\n284\t\tclientset := kubernetes.NewForConfigOrDie(config)\n285\t\tmust(enoexeceventhandler.NewReconciler(\n286\t\t\tmgr.GetClient(),\n287\t\t\tclientset,\n288\t\t\tmgr.GetScheme(),\n289\t\t\tmgr.GetEventRecorderFor(utils.EnoexecControllerName), //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n290\t\t).SetupWithManager(mgr), unableToCreateController, controllerKey, \"ENoExecEventController\")\n291\t}\n292\t\n293\tfunc validateFlags() error {\n294\t\tif !enableOperator && !enableClusterPodPlacementConfigOperandControllers && !enableClusterPodPlacementConfigOperandWebHook && !enableENoExecEventControllers {\n295\t\t\treturn errors.New(\"at least one of the following flags must be set: --enable-operator, --enable-ppc-controllers, --enable-ppc-webhook, --enable-enoexec-event-controllers\")\n296\t\t}\n297\t\t// no more than one of the flags can be set\n298\t\tif btoi(enableOperator)+btoi(enableClusterPodPlacementConfigOperandControllers)+btoi(enableClusterPodPlacementConfigOperandWebHook)+btoi(enableENoExecEventControllers) > 1 {\n299\t\t\treturn errors.New(\"only one of the following flags can be set: --enable-operator, --enable-ppc-controllers, --enable-ppc-webhook, --enable-enoexec-event-controllers\")\n300\t\t}\n301\t\treturn nil\n302\t}\n303\t\n304\tfunc bindFlags() {\n305\t\tflag.StringVar(&metricsAddr, \"metrics-bind-address\", \":8080\", \"The address the metric endpoint binds to.\")\n306\t\tflag.StringVar(&probeAddr, \"health-probe-bind-address\", \":8081\", \"The address the probe endpoint binds to.\")\n307\t\tflag.BoolVar(&enableLeaderElection, \"leader-elect\", false,\n308\t\t\t\"Enable leader election for controller manager. \"+\n309\t\t\t\t\"Enabling this will ensure there is only one active controller manager.\")\n310\t\tflag.StringVar(&certDir, \"cert-dir\", \"/var/run/manager/tls\", \"The directory where the TLS certs are stored\")\n311\t\t// TODO: Change the defaults to match a local secret; the OCP specific settings will be provided by the operator\n312\t\tflag.StringVar(&globalPullSecretNamespace, \"global-pull-secret-namespace\", \"openshift-config\", \"The namespace where the global pull secret is stored\")\n313\t\tflag.StringVar(&globalPullSecretName, \"global-pull-secret-name\", \"pull-secret\", \"The name of the global pull secret\")\n314\t\tflag.StringVar(&registryCertificatesConfigMapName, \"registry-certificates-configmap-name\", \"image-registry-certificates\", \"The name of the configmap that contains the registry certificates\")\n315\t\tflag.BoolVar(&enableClusterPodPlacementConfigOperandWebHook, \"enable-ppc-webhook\", false, \"Enable the pod placement config operand webhook\")\n316\t\tflag.BoolVar(&enableClusterPodPlacementConfigOperandControllers, \"enable-ppc-controllers\", false, \"Enable the pod placement config operand controllers\")\n317\t\tflag.BoolVar(&enableOperator, \"enable-operator\", false, \"Enable the operator\")\n318\t\tflag.BoolVar(&enableCPPCInformer, \"enable-cppc-informer\", false, \"Enable informer for ClusterPodPlacementConfig\")\n319\t\tflag.BoolVar(&enableENoExecEventControllers, \"enable-enoexec-event-controllers\", false, \"Enable the ENoExecEvent controllers\")\n320\t\t// This may be deprecated in the future. It is used to support the current way of setting the log level for operands\n321\t\t// If operands will start to support a controller that watches the ClusterPodPlacementConfig, this flag may be removed\n322\t\t// and the log level will be set in the ClusterPodPlacementConfig at runtime (with no need for reconciliation)\n323\t\tflag.IntVar(&initialLogLevel, \"initial-log-level\", common.LogVerbosityLevelNormal.ToZapLevelInt(), \"Initial log level. Converted to zap\")\n324\t\tklog.InitFlags(nil)\n325\t\tflag.Parse()\n326\t\t// Set the Log Level as AtomicLevel to allow runtime changes\n327\t\tutils.AtomicLevel = zapuber.NewAtomicLevelAt(zapcore.Level(int8(-initialLogLevel))) // #nosec G115 -- initialLogLevel is constrained to 0-3 range\n328\t\tzapLogger := zap.New(zap.Level(utils.AtomicLevel), zap.UseDevMode(false))\n329\t\tklog.SetLogger(zapLogger)\n330\t\tctrllog.SetLogger(zapLogger)\n331\t}\n332\t\n333\tfunc must(err error, msg string, keysAndValues ...interface{}) {\n334\t\tif err != nil {\n335\t\t\tsetupLog.Error(err, msg, keysAndValues...)\n336\t\t\tos.Exit(1)\n337\t\t}\n338\t}\n339\t\n340\tfunc btoi(b bool) int {\n341\t\tif b {\n342\t\t\treturn 1\n343\t\t}\n344\t\treturn 0\n345\t}\n346\t"}]},"parent_tool_use_id":null,"session_id":"c4dd21f2-9f54-4036-9aae-401594712b4d","uuid":"0584390e-4a7a-4b35-87a6-46c38f7ae5fe","timestamp":"2026-07-20T18:31:29.150Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/multiarch-tuning-operator-treatment/cmd/main.go","content":"/*\nCopyright 2023 Red Hat, Inc.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage main\n\nim
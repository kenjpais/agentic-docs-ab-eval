{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01FXBMPjxKqG9c4cuJXL2WgN","type":"tool_result","content":"1\t/*\n2\tCopyright 2025 Red Hat, Inc.\n3\t\n4\tLicensed under the Apache License, Version 2.0 (the \"License\");\n5\tyou may not use this file except in compliance with the License.\n6\tYou may obtain a copy of the License at\n7\t\n8\t    http://www.apache.org/licenses/LICENSE-2.0\n9\t\n10\tUnless required by applicable law or agreed to in writing, software\n11\tdistributed under the License is distributed on an \"AS IS\" BASIS,\n12\tWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13\tSee the License for the specific language governing permissions and\n14\tlimitations under the License.\n15\t*/\n16\t\n17\tpackage v1beta1\n18\t\n19\timport (\n20\t\t\"context\"\n21\t\t\"errors\"\n22\t\t\"fmt\"\n23\t\n24\t\tctrl \"sigs.k8s.io/controller-runtime\"\n25\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n26\t\t\"sigs.k8s.io/controller-runtime/pkg/webhook/admission\"\n27\t)\n28\t\n29\t// +kubebuilder:webhook:path=/validate-multiarch-openshift-io-v1beta1-clusterpodplacementconfig,mutating=false,failurePolicy=fail,sideEffects=None,groups=multiarch.openshift.io,resources=clusterpodplacementconfigs,verbs=create;update;delete,versions=v1beta1,name=validate-clusterpodplacementconfig.multiarch.openshift.io,admissionReviewVersions=v1\n30\t\n31\tfunc (c *ClusterPodPlacementConfig) SetupWebhookWithManager(mgr ctrl.Manager) error {\n32\t\treturn ctrl.NewWebhookManagedBy(mgr, &ClusterPodPlacementConfig{}).\n33\t\t\tWithValidator(&ClusterPodPlacementConfigValidator{\n34\t\t\t\tClient: mgr.GetClient(),\n35\t\t\t}).\n36\t\t\tComplete()\n37\t}\n38\t\n39\t// ClusterPodPlacementConfigValidator validates ClusterPodPlacementConfig resources\n40\t// +kubebuilder:object:generate=false\n41\ttype ClusterPodPlacementConfigValidator struct {\n42\t\tClient client.Client\n43\t}\n44\t\n45\tfunc (v *ClusterPodPlacementConfigValidator) ValidateCreate(ctx context.Context, obj *ClusterPodPlacementConfig) (warnings admission.Warnings, err error) {\n46\t\treturn v.validate(obj)\n47\t}\n48\t\n49\tfunc (v *ClusterPodPlacementConfigValidator) ValidateUpdate(ctx context.Context, oldObj, newObj *ClusterPodPlacementConfig) (warnings admission.Warnings, err error) {\n50\t\treturn v.validate(newObj)\n51\t}\n52\t\n53\tfunc (v *ClusterPodPlacementConfigValidator) ValidateDelete(ctx context.Context, obj *ClusterPodPlacementConfig) (warnings admission.Warnings, err error) {\n54\t\t// Check if any local PodPlacementConfig exists. If exists, deny deletion of ClusterPodPlacementConfig.\n55\t\texistingPPCs := &PodPlacementConfigList{}\n56\t\tif err := v.Client.List(ctx, existingPPCs); err != nil {\n57\t\t\treturn nil, fmt.Errorf(\"failed to list existing PodPlacementConfigs: %w\", err)\n58\t\t}\n59\t\tif len(existingPPCs.Items) != 0 {\n60\t\t\treturn nil, fmt.Errorf(\"cannot delete ClusterPodPlacementConfig while local PodPlacementConfigs still exist\")\n61\t\t}\n62\t\treturn nil, nil\n63\t}\n64\t\n65\tfunc (v *ClusterPodPlacementConfigValidator) validate(cppc *ClusterPodPlacementConfig) (warnings admission.Warnings, err error) {\n66\t\tif cppc.Spec.Plugins == nil || cppc.Spec.Plugins.NodeAffinityScoring == nil {\n67\t\t\treturn nil, nil\n68\t\t}\n69\t\t// Verify unique Architecture terms\n70\t\tplatforms := make(map[string]struct{})\n71\t\tfor _, term := range cppc.Spec.Plugins.NodeAffinityScoring.Platforms {\n72\t\t\tif _, ok := platforms[term.Architecture]; ok {\n73\t\t\t\treturn nil, errors.New(\"duplicate architecture in the .spec.plugins.nodeAffinityScoring.platforms list\")\n74\t\t\t}\n75\t\t\tplatforms[term.Architecture] = struct{}{}\n76\t\t}\n77\t\treturn nil, nil\n78\t}\n79\t"}]},"parent_tool_use_id":null,"session_id":"8c647edd-43ca-48b5-9dd4-7a080ea5c4aa","uuid":"26904f13-4b68-4b08-935d-66a0e6937ea7","timestamp":"2026-07-20T18:28:47.255Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-works
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01BFpEz13oQ6ZYN4Eua9Erxx","type":"tool_result","content":"1\tpackage istiocsr\n2\t\n3\timport (\n4\t\t\"os\"\n5\t\t\"strings\"\n6\t\t\"time\"\n7\t\n8\t\tcertmanagerapi \"github.com/cert-manager/cert-manager/pkg/apis/certmanager\"\n9\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n10\t)\n11\t\n12\tconst (\n13\t\t// istiocsrCommonName is the name commonly used for naming resources.\n14\t\tistiocsrCommonName = \"cert-manager-istio-csr\"\n15\t\n16\t\t// ControllerName is the name of the controller used in logs and events.\n17\t\tControllerName = istiocsrCommonName + \"-controller\"\n18\t\n19\t\t// controllerProcessedAnnotation is the annotation added to istiocsr resource once after\n20\t\t// successful reconciliation by the controller.\n21\t\tcontrollerProcessedAnnotation = \"operator.openshift.io/istio-csr-processed\"\n22\t\n23\t\t// controllerProcessingRejectedAnnotation is the annotation added to istiocsr resource when multiple\n24\t\t// instances of istiocsr resource is created.\n25\t\tcontrollerProcessingRejectedAnnotation = \"operator.openshift.io/istio-csr-reject-multiple-instance\"\n26\t\n27\t\t// finalizer name for istiocsr.openshift.operator.io resource.\n28\t\tfinalizer = \"istiocsr.openshift.operator.io/\" + ControllerName\n29\t\n30\t\t// defaultRequeueTime is the default reconcile requeue time.\n31\t\tdefaultRequeueTime = time.Second * 30\n32\t\n33\t\t// istiocsrObjectName is the name of the istio-csr resource created by user.\n34\t\t// istio-csr CRD enforces name to be `default`.\n35\t\tistiocsrObjectName = \"default\"\n36\t\n37\t\t// istiocsrContainerName is the name of the container created for istiocsr.\n38\t\tistiocsrContainerName = istiocsrCommonName\n39\t\n40\t\t// istiocsrImageNameEnvVarName is the environment variable key name\n41\t\t// containing the image name of the istiocsr as value.\n42\t\tistiocsrImageNameEnvVarName = \"RELATED_IMA
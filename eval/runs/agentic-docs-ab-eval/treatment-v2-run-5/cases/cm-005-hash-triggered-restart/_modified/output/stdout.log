ue,\n\t\t},\n\t\t{\n\t\t\tname:      \"different content produces different hash\",\n\t\t\tbundle1:   \"-----BEGIN CERTIFICATE-----\\nAAAA\\n-----END CERTIFICATE-----\\n\",\n\t\t\tbundle2:   \"-----BEGIN CERTIFICATE-----\\nBBBB\\n-----END CERTIFICATE-----\\n\",\n\t\t\twantEqual: false,\n\t\t},\n\t\t{\n\t\t\tname:      \"empty vs non-empty produces different hash\",\n\t\t\tbundle1:   \"\",\n\t\t\tbundle2:   \"data\",\n\t\t\twantEqual: false,\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\thash1 := computeCABundleHash(tt.bundle1)\n\t\t\thash2 := computeCABundleHash(tt.bundle2)\n\t\t\tif (hash1 == hash2) != tt.wantEqual {\n\t\t\t\tt.Errorf(\"computeCABundleHash equality = %v, want %v (h1=%s, h2=%s)\",\n\t\t\t\t\thash1 == hash2, tt.wantEqual, hash1, hash2)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestComputeCABundleHash_Deterministic(t *testing.T) {\n\tbundle := \"-----BEGIN CERTIFICATE-----\\ntest\\n-----END CERTIFICATE-----\\n\"\n\th1 := computeCABundleHash(bundle)\n\th2 := computeCABundleHash(bundle)\n\tif h1 != h2 {\n\t\tt.Errorf(\"hash not deterministic: %s != %s\", h1, h2)\n\t}\n\tif len(h1) != 64 {\n\t\tt.Errorf(\"expected 64-char hex SHA-256 hash, got length %d\", len(h1))\n\t}\n}\n\nfunc TestUpdateCABundleHashAnnotation(t *testing.T) {\n\ttests := []struct {\n\t\tname                string\n\t\texistingAnnotations map[string]string\n\t\thash                string\n\t\twantAnnotations     map[string]string\n\t}{\n\t\t{\n\t\t\tname:                \"nil annotations\",\n\t\t\texistingAnnotations: nil,\n\t\t\thash:                \"abc123\",\n\t\t\twantAnnotations:     map[string]string{caBundleHashAnnotation: \"abc123\"},\n\t\t},\n\t\t{\n\t\t\tname:                \"empty annotations\",\n\t\t\texistingAnnotations: map[string]string{},\n\t\t\thash:                \"def456\",\n\t\t\twantAnnotations:     map[string]string{caBundleHashAnnotation: \"def456\"},\n\t\t},\n\t\t{\n\t\t\tname:                \"preserves existing annotations\",\n\t\t\texistingAnnotations: map[string]string{\"other\": \"value\"},\n\t\t\thash:                \"ghi789\",\n\t\t\twantAnnotations:     map[string]string{\"other\": \"value\", caBundleHashAnnotation: \"ghi789\"},\n\t\t},\n\t\t{\n\t\t\tname:                \"overwrites stale hash\",\n\t\t\texistingAnnotations: map[string]string{caBundleHashAnnotation: \"old-hash\"},\n\t\t\thash:                \"new-hash\",\n\t\t\twantAnnotations:     map[string]string{caBundleHashAnnotation: \"new-hash\"},\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdep := &appsv1.Deployment{\n\t\t\t\tSpec: appsv1.DeploymentSpec{\n\t\t\t\t\tTemplate: corev1.PodTemplateSpec{\n\t\t\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\t\t\tAnnotations: tt.existingAnnotations,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\t\t\tupdateCABundleHashAnnotation(dep, tt.hash)\n\t\t\tgot := dep.Spec.Template.Annotations\n\t\t\tif len(got) != len(tt.wantAnnotations) {\n\t\t\t\tt.Fatalf(\"annotation count = %d, want %d\", len(got), len(tt.wantAnnotations))\n\t\t\t}\n\t\t\tfor k, v := range tt.wantAnnotations {\n\t\t\t\tif got[k] != v {\n\t\t\t\t\tt.Errorf(\"annotation[%q] = %q, want %q\", k, got[k], v)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestDeploymentSpecModified_TemplateAnnotations(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tdesired  *appsv1.Deployment\n\t\tfetched  *appsv1.Deployment\n\t\twantTrue bool\n\t}{\n\t\t{\n\t\t\tname: \"both nil annotations\",\n\t\t\tdesired: func() *appsv1.Deployment {\n\t\t\t\treturn baseDeployment(1, \"img\")\n\t\t\t}(),\n\t\t\tfetched: func() *appsv1.Deployment {\n\t\t\t\treturn baseDeployment(1, \"img\")\n\t\t\t}(),\n\t\t\twantTrue: false,\n\t\t},\n\t\t{\n\t\t\tname: \"desired has hash annotation, fetched has none\",\n\t\t\tdesired: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Spec.Template.Annotations = map[string]string{caBundleHashAnnotation: \"abc123\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\tfetched:  baseDeployment(1, \"img\"),\n\t\t\twantTrue: true,\n\t\t},\n\t\t{\n\t\t\tname: \"hash annotation changed\",\n\t\t\tdesired: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Spec.Template.Annotations = map[string]string{caBundleHashAnnotation: \"new-hash\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\tfetched: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Spec.Template.Annotations = map[string]string{caBundleHashAnnotation: \"old-hash\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\twantTrue: true,\n\t\t},\n\t\t{\n\t\t\tname: \"same hash annotation\",\n\t\t\tdesired: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Spec.Template.Annotations = map[string]string{caBundleHashAnnotation: \"same-hash\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\tfetched: func() *appsv1.Deployment {\n\t\t\t\td := baseDeployment(1, \"img\")\n\t\t\t\td.Spec.Template.Annotations = map[string]string{caBundleHashAnnotation: \"same-hash\"}\n\t\t\t\treturn d\n\t\t\t}(),\n\t\t\twantTrue: false,\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tgot := deploymentSpecModified(tt.desired, tt.fetched)\n\t\t\tif got != tt.wantTrue {\n\t\t\t\tt.Errorf(\"deploymentSpecModified() = %v, want %v\", got, tt.wantTrue)\n\t\t\t}\n\t\t})\n\t}\n}\n```\n\n---\n\n### Commands to run\n\n```bash\n# From the repository root:\n\n# 1. Run unit tests to verify the changes compile and pass\nmake test\n\n# Or just the unit tests for the istiocsr package:\ngo test ./pkg/controller/istiocsr/...\n\n# 2. Run vet\nmake vet\n\n# 3. Full verify\nmake verify\n```\n\n---\n\n### Summary of the idempotency guard\n\nThe idempotency works at two levels:\n\n1. **ConfigMap level**: `createOrUpdateCAConfigMap` checks `hasObjectChanged(desired, fetched)` \u2014 if the ConfigMap data hasn't changed, it skips the update. Since the hash is computed from the same `certData`, an unchanged ConfigMap means an unchanged hash.\n\n2. **Deployment level**: `createOrApplyDeployments` checks `hasObjectChanged(desired, fetched)` which calls `deploymentSpecModified`. The updated `deploymentSpecModified` now compares `Spec.Template.Annotations` (including the hash annotation). When the hash is the same, `deploymentSpecModified` returns false, and the `UpdateWithRetry` call is skipped entirely. Only when the CA PEM content changes does the hash change, causing the annotation to differ, triggering the deployment update and thus a rolling restart.", "stop_reason": "end_turn", "session_id": "70c02473-b6cc-430a-bbaf-9126673321a3", "total_cost_usd": 1.5626595, "usage": {"input_tokens": 10887, "cache_creation_input_tokens": 94558, "cache_read_input_tokens": 671824, "output_tokens": 23253, "server_tool_use": {"web_search_requests": 0, "web_fetch_requests": 0}, "service_tier": "standard", "cache_creation": {"ephemeral_1h_input_tokens": 0, "ephemeral_5m_input_tokens": 94558}, "inference_geo": "", "iterations": [], "speed": "standard"}, "modelUsage": {"claude-opus-4-6": {"inputTokens": 10887, "outputTokens": 23253, "cacheReadInputTokens": 671824, "cacheCreationInputTokens": 94558, "webSearchRequests": 0, "costUSD": 1.5626595, "contextWindow": 200000, "maxOutputTokens": 64000}}, "permission_denials": [], "terminal_reason": "completed", "fast_mode_state": "off", "uuid": "4aca4ebe-0efb-4fe1-90c6-b0eafd5ff23a", "timestamp": "2026-07-20T18:26:42.708Z"}
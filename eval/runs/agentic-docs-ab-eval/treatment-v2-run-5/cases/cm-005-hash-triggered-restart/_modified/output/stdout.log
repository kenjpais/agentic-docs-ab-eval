rrorf(\"serviceSpecModified() = %v, want %v\", got, tt.wantTrue)\n438\t\t\t\t}\n439\t\t\t})\n440\t\t}\n441\t}\n442\t\n443\tfunc TestCertificateSpecModified(t *testing.T) {\n444\t\ttests := []struct {\n445\t\t\tname     string\n446\t\t\tdesired  *certmanagerv1.Certificate\n447\t\t\tfetched  *certmanagerv1.Certificate\n448\t\t\twantTrue bool\n449\t\t}{\n450\t\t\t{\n451\t\t\t\tname:     \"identical\",\n452\t\t\t\tdesired:  &certmanagerv1.Certificate{Spec: certmanagerv1.CertificateSpec{DNSNames: []string{\"a.example.com\"}}},\n453\t\t\t\tfetched:  &certmanagerv1.Certificate{Spec: certmanagerv1.CertificateSpec{DNSNames: []string{\"a.example.com\"}}},\n454\t\t\t\twantTrue: false,\n455\t\t\t},\n456\t\t\t{\n457\t\t\t\tname:     \"different DNSNames\",\n458\t\t\t\tdesired:  &certmanagerv1.Certificate{Spec: certmanagerv1.CertificateSpec{DNSNames: []string{\"a.example.com\"}}},\n459\t\t\t\tfetched:  &certmanagerv1.Certificate{Spec: certmanagerv1.CertificateSpec{DNSNames: []string{\"b.example.com\"}}},\n460\t\t\t\twantTrue: true,\n461\t\t\t},\n462\t\t}\n463\t\tfor _, tt := range tests {\n464\t\t\tt.Run(tt.name, func(t *testing.T) {\n465\t\t\t\tgot := certificateSpecModified(tt.desired, tt.fetched)\n466\t\t\t\tif got != tt.wantTrue {\n467\t\t\t\t\tt.Errorf(\"certificateSpecModified() = %v, want %v\", got, tt.wantTrue)\n468\t\t\t\t}\n469\t\t\t})\n470\t\t}\n471\t}\n472\t\n473\tfunc TestConfigMapDataModified(t *testing.T) {\n474\t\ttests := []struct {\n475\t\t\tname     string\n476\t\t\tdesired  *corev1.ConfigMap\n477\t\t\tfetched  *corev1.ConfigMap\n478\t\t\twantTrue bool\n479\t\t}{\n480\t\t\t{\n481\t\t\t\tname:     \"identical\",\n482\t\t\t\tdesired:  &corev1.ConfigMap{Data: map[string]string{\"key\": \"v1\"}},\n483\t\t\t\tfetched:  &corev1.ConfigMap{Data: map[string]string{\"key\": \"v1\"}},\n484\t\t\t\twantTrue: false,\n485\t\t\t},\n486\t\t\t{\n487\t\t\t\tname:     \"different value\",\n488\t\t\t\tdesired:  &corev1.ConfigMap{Data: map[string]string{\"key\": \"v1\"}},\n489\t\t\t
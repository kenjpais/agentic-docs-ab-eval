l on CA certificate ConfigMap istiocsr-test-ns/watch-label-fail-test: failed to update watch-label-fail-test resource with watch label: no access to update watch label`,\n1003\t\t\t},\n1004\t\n1005\t\t\t{\n1006\t\t\t\tname: \"deployment reconciliation fails with non-CA certificate in ConfigMap\",\n1007\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n1008\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, ns types.NamespacedName, obj client.Object) (bool, error) {\n1009\t\t\t\t\t\tswitch o := obj.(type) {\n1010\t\t\t\t\t\tcase *appsv1.Deployment:\n1011\t\t\t\t\t\t\tdeployment := testDeployment()\n1012\t\t\t\t\t\t\tdeployment.DeepCopyInto(o)\n1013\t\t\t\t\t\t}\n1014\t\t\t\t\t\treturn true, nil\n1015\t\t\t\t\t})\n1016\t\t\t\t\tm.GetCalls(func(ctx context.Context, ns types.NamespacedName, obj client.Object) error {\n1017\t\t\t\t\t\tswitch o := obj.(type) {\n1018\t\t\t\t\t\tcase *corev1.ConfigMap:\n1019\t\t\t\t\t\t\tif ns.Name == \"non-ca-cert-test\" {\n1020\t\t\t\t\t\t\t\tconfigMap := testNonCACertificateConfigMap()\n1021\t\t\t\t\t\t\t\tconfigMap.DeepCopyInto(o)\n1022\t\t\t\t\t\t\t}\n1023\t\t\t\t\t\t}\n1024\t\t\t\t\t\treturn nil\n1025\t\t\t\t\t})\n1026\t\t\t\t},\n1027\t\t\t\tupdateIstioCSR: func(i *v1alpha1.IstioCSR) {\n1028\t\t\t\t\ti.Status.IstioCSRImage = image\n1029\t\t\t\t\ti.Spec.IstioCSRConfig.CertManager.IstioCACertificate = &v1alpha1.ConfigMapReference{\n1030\t\t\t\t\t\tName: \"non-ca-cert-test\",\n1031\t\t\t\t\t\tKey:  \"ca-cert.pem\",\n1032\t\t\t\t\t}\n1033\t\t\t\t},\n1034\t\t\t\twantErr: `failed to generate deployment resource for creation in istiocsr-test-ns: failed to update volume istiocsr-test-ns/istiocsr-test-resource: failed to validate and mount CA certificate ConfigMap: invalid PEM data in CA certificate ConfigMap istiocsr-test-ns/non-ca-cert-test key \"ca-cert.pem\": certificate is not a CA certificate`,\n1035\t\t\t},\n1036\t\n1037\t\t\t{\n1038\t\t\t\tname: \"deployment reconciliation fails with certificate missing KeyUsageCertSign in ConfigMap\",\n1039\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n1040\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, ns types.NamespacedName, obj client.Object) (bool, error) {\n1041\t\t\t\t\t\tswitch o := obj.(type) {\n1042\t\t\t\t\t\tcase *appsv1.Deployment:\n1043\t\t\t\t\t\t\tdeployment := testDeployment()\n1044\t\t\t\t\t\t\tdeployment.DeepCopyInto(o)\n1045\t\t\t\t\t\t}\n1046\t\t\t\t\t\treturn true, nil\n1047\t\t\t\t\t})\n1048\t\t\t\t\tm.GetCalls(func(ctx context.Context, ns types.NamespacedName, obj client.Object) error {\n1049\t\t\t\t\t\tswitch o := obj.(type) {\n1050\t\t\t\t\t\tcase *corev1.ConfigMap:\n1051\t\t\t\t\t\t\tif ns.Name == \"ca-without-certsign-test\" {\n1052\t\t\t\t\t\t\t\tconfigMap := testCertificateWithoutCertSignConfigMap()\n1053\t\t\t\t\t\t\t\tconfigMap.DeepCopyInto(o)\n1054\t\t\t\t\t\t\t}\n1055\t\t\t\t\t\t}\n1056\t\t\t\t\t\treturn nil\n1057\t\t\t\t\t})\n1058\t\t\t\t},\n1059\t\t\t\tupdateIstioCSR: func(i *v1alpha1.IstioCSR) {\n1060\t\t\t\t\ti.Status.IstioCSRImage = image\n1061\t\t\t\t\ti.Spec.IstioCSRConfig.CertManager.IstioCACertificate = &v1alpha1.ConfigMapReference{\n1062\t\t\t\t\t\tName: \"ca-without-certsign-test\",\n1063\t\t\t\t\t\tKey:  \"ca-cert.pem\",\n1064\t\t\t\t\t}\n1065\t\t\t\t},\n1066\t\t\t\twantErr: `failed to generate deployment resource for creation in istiocsr-test-ns: failed to update volume istiocsr-test-ns/istiocsr-test-resource: failed to validate and mount CA certificate ConfigMap: invalid PEM data in CA certificate ConfigMap istiocsr-test-ns/ca-without-certsign-test key \"ca-cert.pem\": certificate does not have Certificate Sign key usage`,\n1067\t\t\t},\n1068\t\t}\n1069\t\n1070\t\tfor _, tt := range tests {\n1071\t\t\tt.Run(tt.name, func(t *testing.T) {\n1072\t\t\t\tr := testReconciler(t)\n1073\t\t\t\tmock := &fakes.FakeCtrlClient{}\n1074\t\t\t\tif tt.preReq != nil {\n1075\t\t\t\t\ttt.preReq(r, mock)\n1076\t\t\t\t}\n1077\t\t\t\tr.CtrlClient = mock\n1078\t\t\t\tistiocsr := testIstioCSR()\n1079\t\t\t\tif tt.updateIstioCSR != nil {\n1080\t\t\t\t\ttt.updateIstioCSR(istiocsr)\n1081\t\t\t\t}\n1082\t\t\t\tif !tt.skipEnvVar {\n1083\t\t\t\t\tt.Setenv(\"RELATED_IMAGE_CERT_MANAGER_ISTIOCSR\", image)\n1084\t\t\t\t}\n1085\t\t\t\terr := r.createOrApplyDeployments(istiocsr, controllerDefaultResourceLabels, false)\n1086\t\t\t\tif tt.wantErrSubstring {\n1087\t\t\t\t\tif err == nil || !strings.Contains(err.Error(), tt.wantErr) {\n1088\t\t\t\t\t\tt.Errorf(\"createOrApplyDeployments() err: %v, want substring: %q\", err, tt.wantErr)\n1089\t\t\t\t\t}\n1090\t\t\t\t} else if (tt.wantErr != \"\" || err != nil) && (err == nil || err.Error() != tt.wantErr) {\n1091\t\t\t\t\tt.Errorf(\"createOrApplyDeployments() err: %v, wantErr: %v\", err, tt.wantErr)\n1092\t\t\t\t}\n1093\t\t\t\tif tt.wantErr == \"\" {\n1094\t\t\t\t\tif istiocsr.Status.IstioCSRImage != image {\n1095\t\t\t\t\t\tt.Errorf(\"createOrApplyDeployments() got: %v, want: %v\", istiocsr.Status.IstioCSRImage, image)\n1096\t\t\t\t\t}\n1097\t\t\t\t}\n1098\t\t\t})\n1099\t\t}\n1100\t}\n1101\t\n1102\tfunc TestUpdateArgList(t *testing.T) {\n1103\t\ttests := []struct {\n1104\t\t\tname            string\n1105\t\t\tupdateIstioCSR  func(*v1alpha1.IstioCSR)\n1106\t\t\texpectedArgs    map[string]string // key is arg name (without --), value is expected value\n1107\t\t\tnotExpectedArgs []string          // arg names (without --) that should NOT be present\n1108\t\t}{\n1109\t\t\t{\n1110\t\t\t\tname: \"clusterID not provided should default to Kubernetes\",\n1111\t\t\t\tupdateIstioCSR: func(istiocsr *v1alpha1.IstioCSR) {\n1112\t\t\t\t\t// Server config is nil, so clusterID should default\n1113\t\t\t\t},\n1114\t\t\t\texpectedArgs: map[string]string{\n1115\t\t\t\t\t\"cluster-id\": defaultClusterID,\n1116\t\t\t\t},\n1117\t\t\t},\n1118\t\t\t{\n1119\t\t\t\tname: \"clusterID empty string should default to Kubernetes\",\n1120\t\t\t\tupdateIstioCSR: func(istiocsr *v1alpha1.IstioCSR) {\n1121\t\t\t\t\tistiocsr.Spec.IstioCSRConfig.Server = &v1alpha1.ServerConfig{\n1122\t\t\t\t\t\tClusterID: \"\",\n1123\t\t\t\t\t}\n1124\t\t\t\t},\n1125\t\t\t\texpectedArgs: map[string]string{\n1126\t\t\t\t\t\"cluster-id\": defaultClusterID,\n1127\t\t\t\t},\n1128\t\t\t},\n1129\t\t\t{\n1130\t\t\t\tname: \"clusterID provided should use custom value\",\n1131\t\t\t\tupdateIstioCSR: func(istiocsr *v1alpha1.IstioCSR) {\n1132\t\t\t\t\tistiocsr.Spec.IstioCSRConfig.Server = &v1alpha1.ServerConfig{\n1133\t\t\t\t\t\tClusterID: \"cluster-123_dev.local\",\n1134\t\t\t\t\t}\n1135\t\t\t\t},\n1136\t\t\t\texpectedArgs: map[string]string{\n1137\t\t\t\t\t\"cluster-id\": \"cluster-123_dev.local\",\n1138\t\t\t\t},\n1139\t\t\t},\n1140\t\t\t{\n1141\t\t\t\tname: \"istioDataPlaneNamespaceSelector not provided should not include argument\",\n1142\t\t\t\tnotExpectedArgs: []string{\n1143\t\t\t\t\t\"configmap-namespace-selector\",\n1144\t\t\t\t},\n1145\t\t\t},\n1146\t\t\t{\n1147\t\t\t\tname: \"istioDataPlaneNamespaceSelector provided should include argument\",\n1148\t\t\t\tupdateIstioCSR: func(istiocsr *v1alpha1.IstioCSR) {\n1149\t\t\t\t\tistiocsr.Spec.IstioCSRConfig.IstioDataPlaneNamespaceSelector = \"cert-manager.io/test-ca-injection=enabled\"\n1150\t\t\t\t},\n1151\t\t\t\texpectedArgs: map[string]string{\n1152\t\t\t\t\t\"configmap-namespace-selector\": \"cert-manager.io/test-ca-injection=enabled\",\n1153\t\t\t\t},\n1154\t\t\t},\n1155\t\t}\n1156\t\n1157\t\tfor _, tt := range tests {\n1158\t\t\tt.Run(tt.name, func(t *testing.T) {\n1159\t\t\t\tdeployment := testDeployment()\n1160\t\t\t\tistiocsr := testIstioCSR()\n1161\t\t\t\tif tt.updateIstioCSR != nil {\n1162\t\t\t\t\ttt.updateIstioCSR(istiocsr)\n1163\t\t\t\t}\n1164\t\n1165\t\t\t\tupdateArgList(deployment, istiocsr)\n1166\t\n1167\t\t\t\t// Find the istio-csr container and check its arguments\n1168\t\t\t\tvar containerArgs []string\n1169\t\t\t\tfor _, container := range deployment.Spec.Template.Spec.Containers {\n1170\t\t\t\t\tif container.Name == istiocsrContainerName {\n1171\t\t\t\t\t\tcontainerArgs = container.Args\n1
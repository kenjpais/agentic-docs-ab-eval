{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01BdfqyyzoZobcX2iNb8D3m6","type":"tool_result","content":"1\tpackage v1alpha1\n2\t\n3\timport (\n4\t\tcorev1 \"k8s.io/api/core/v1\"\n5\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n6\t)\n7\t\n8\tfunc init() {\n9\t\tSchemeBuilder.Register(&TrustManager{}, &TrustManagerList{})\n10\t}\n11\t\n12\t// TrustManagerList contains a list of TrustManager resources.\n13\t//\n14\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n15\t// +kubebuilder:object:root=true\n16\ttype TrustManagerList struct {\n17\t\tmetav1.TypeMeta `json:\",inline\"`\n18\t\n19\t\t// metadata is the standard list's metadata.\n20\t\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n21\t\tmetav1.ListMeta `json:\"metadata\"`\n22\t\tItems           []TrustManager `json:\"items\"`\n23\t}\n24\t\n25\t// TrustManager describes the configuration and information about the managed trust-manager deployment.\n26\t// The name must be `cluster` to make TrustManager a singleton, allowing only one instance per cluster.\n27\t// When a TrustManager CR is created, trust-manager operand is deployed in the cert-manager namespace.\n28\t//\n29\t// +genclient\n30\t// +genclient:nonNamespaced\n31\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n32\t// +kubebuilder:object:root=true\n33\t// +kubebuilder:subresource:status\n34\t// +kubebuilder:resource:path=trustmanagers,scope=Cluster,categories={cert-manager-operator, trust-manager},shortName=trustmanager;tm\n35\t// +kubebuilder:printcolumn:name=\"Ready\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].status\"\n36\t// +kubebuilder:printcolumn:name=\"Message\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].message\"\n37\t// +kubebuilder:printcolumn:name=\"AGE\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n38\t// +kubebuilder:metadata:labels={\"app.kubernetes.io/name=trustmanager\", \"app.kubernetes.io/part-of=cert-manager-operator\"}\n39\t// +kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'cluster'\",message=\"TrustManager is a singleton, .metadata.name must be 'cluster'\"\n40\t// +operator-sdk:csv:customresourcedefinitions:displayName=\"TrustManager\"\n41\ttype TrustManager struct {\n42\t\tmetav1.TypeMeta `json:\",inline\"`\n43\t\n44\t\t// metadata is the standard object's metadata.\n45\t\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n46\t\t// +required\n47\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n48\t\n49\t\t// spec is the specification of the desired behavior of the TrustManager.\n50\t\t// +kubebuilder:validation:Required\n51\t\t// +required\n52\t\tSpec TrustManagerSpec `json:\"spec\"`\n53\t\n54\t\t// status is the most recently observed status of the TrustManager.\n55\t\t// +kubebuilder:validation:Optional\n56\t\t// +optional\n57\t\tStatus TrustManagerStatus `json:\"status,omitempty\"`\n58\t}\n59\t\n60\t// TrustManagerSpec defines the desired state of TrustManager.\n61\t// Note: trust-manager operand is always deployed in the cert-manager namespace.\n62\ttype TrustManagerSpec struct {\n63\t\t// trustManagerConfig configures the trust-manager operand's behavior.\n64\t\t// +kubebuilder:validation:Required\n65\t\t// +required\n66\t\tTrustManagerConfig TrustManagerConfig `json:\"trustManagerConfig\"`\n67\t\n68\t\t// controllerConfig configures the operator's behavior for resource creation.\n69\t\t// +kubebuilder:validation:Optional\n70\t\t// +optional\n71\t\tControllerConfig TrustManagerControllerConfig `json:\"controllerConfig,omitempty\"`\n72\t}\n73\t\n74\t// TrustManagerConfig configures the trust-manager operand's behavior.\n75\ttype TrustManagerConfig struct {\n76\t\t// logLevel configures the verbosity of trust-manager logging.\n77\t\t// Follows [Kubernetes logging guidelines](https://github.com/kubernetes/community/blob/master/contributors/devel/sig-instrumentation/logging.md#what-method-to-use).\n78\t\t// +kubebuilder:default:=1\n79\t\t// +kubebuilder:validation:Minimum:=1\n80\t\t// +kubebuilder:validation:Maximum:=5\n81\t\t// +kubebuilder:validation:Optional\n82\t\t// +optional\n83\t\tLogLevel int32 `json:\"logLevel,omitempty\"`\n84\t\n85\t\t// logFormat specifies the output format for trust-manager logging.\n86\t\t// Supported formats are \"text\" and \"json\".\n87\t\t// +kubebuilder:validation:Enum:=\"text\";\"json\"\n88\t\t// +kubebuilder:default:=\"text\"\n89\t\t// +kubebuilder:validation:Optional\n90\t\t// +optional\n91\t\tLogFormat string `json:\"logFormat,omitempty\"`\n92\t\n93\t\t// trustNamespace is the namespace where trust-manager looks for trust sources\n94\t\t// (ConfigMaps and Secrets containing CA certificates).\n95\t\t// Defaults to \"cert-manager\" if not specified.\n96\t\t// This field is immutable once set.\n97\t\t// This field can have a maximum of 63 characters.\n98\t\t// +kubebuilder:default:=\"cert-manager\"\n99\t\t// +kubebuilder:validation:MinLength:=1\n100\t\t// +kubebuilder:validation:MaxLength:=63\n101\t\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"trustNamespace is immutable once set\"\n102\t\t// +kubebuilder:validation:Optional\n103\t\t// +optional\n104\t\tTrustNamespace string `json:\"trustNamespace,omitempty\"`\n105\t\n106\t\t// secretTargets configures whether trust-manager can write trust bundles to Secrets.\n107\t\t// +kubebuilder:validation:Optional\n108\t\t// +optional\n109\t\tSecretTargets SecretTargetsConfig `json:\"secretTargets,omitempty\"`\n110\t\n111\t\t// filterExpiredCertificates controls whether trust-manager filters out\n112\t\t// expired certificates from trust bundles before distributing them.\n113\t\t// When set to \"Enabled\", expired certificates are removed from bundles.\n114\t\t// When set to \"Disabled\", expired certificates are included (default behavior).\n115\t\t// +kubebuilder:default:=\"Disabled\"\n116\t\t// +kubebuilder:validation:Enum:=Enabled;Disabled\n117\t\t// +kubebuilder:validation:Optional\n118\t\t// +optional\n119\t\tFilterExpiredCertificates FilterExpiredCertificatesPolicy `json:\"filterExpiredCertificates,omitempty\"`\n120\t\n121\t\t// defaultCAPackage configures the default CA package for trust-manager.\n122\t\t// When enabled, the operator will use OpenShift's trusted CA bundle injection mechanism.\n123\t\t// +kubebuilder:validation:Optional\n124\t\t// +optional\n125\t\tDefaultCAPackage DefaultCAPackageConfig `json:\"defaultCAPackage,omitempty\"`\n126\t\n127\t\t// resources defines the compute resource requirements for the trust-manager pod.\n128\t\t// ref: https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/\n129\t\t// +kubebuilder:validation:Optional\n130\t\t// +optional\n131\t\tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n132\t\n133\t\t// affinity defines scheduling constraints for the trust-manager pod.\n134\t\t// ref: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/\n135\t\t// +kubebuilder:validation:Optional\n136\t\t// +optional\n137\t\tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n138\t\n139\t\t// tolerations allows the trust-manager pod to be scheduled on tainted nodes.\n140\t\t// ref: https://kubernetes.io/docs/concepts/scheduling-eviction/taint-and-toleration/\n141\t\t// +listType=atomic\n142\t\t// +kubebuilder:validation:MinItems:=0\n143\t\t// +kubebuilder:validation:MaxItems:=50\n144\t\t// +kubebuilder:validation:Optional\n145\t\t// +optional\n146\t\tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n147\t\n148\t\t// nodeSelector restricts which nodes the trust-manager pod can be scheduled on.\n149\t\t// ref: https://kubernetes.io/docs/concepts/configuration/assign-pod-node/\n150\t\t// +mapType=atomic\n151\t\t// +kubebuilder:validation:MinProperties:=0\n152\t\t// +kubebuilder:validation:MaxProperties:=50\n153\t\t// +kubebuilder:validation:Optional\n154\t\t// +optional\n155\t\tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n156\t}\n157\t\n158\t// SecretTargetsConfig configures whether and how trust-manager can write\n159\t// trust bundles to Secrets.\n160\t//\n161\t// +kubebuilder:validation:XValidation:rule=\"self.policy != 'Custom' || (has(self.authorizedSecrets) && size(self.authorizedSecrets) > 0)\",message=\"authorizedSecrets must not be empty when policy is Custom\"\n162\t// +kubebuilder:validation:XValidation:rule=\"self.policy == 'Custom' || !has(self.authorizedSecrets) || size(self.authorizedSecrets) == 0\",message=\"authorizedSecrets must be empty when policy is not Custom\"\n163\ttype SecretTargetsConfig struct {\n164\t\t// policy controls whether and how trust-manager can write trust bundles to Secrets.\n165\t\t// Allowed values are \"Disabled\" or \"Custom\".\n166\t\t// \"Disabled\" means trust-manager cannot write trust bundles to Secrets (default behavior).\n167\t\t// \"Custom\" grants trust-manager read access  to all secrets cluster-wide,\n168\t\t// and write access only to the secrets listed in authorizedSecrets.\n169\t\t// +kubebuilder:default:=\"Disabled\"\n170\t\t// +kubebuilder:validation:Enum:=Disabled;Custom\n171\t\t// +kubebuilder:validation:Optional\n172\t\t// +optional\n173\t\tPolicy SecretTargetsPolicy `json:\"policy,omitempty\"`\n174\t\n175\t\t// authorizedSecrets is a list of specific secret names that trust-manager\n176\t\t// is authorized to create and update. This field is only valid when policy is \"Custom\".\n177\t\t// +listType=set\n178\t\t// +kubebuilder:validation:MinItems:=0\n179\t\t// +kubebuilder:validation:items:MinLength:=1\n180\t\t// +kubebuilder:validation:Optional\n181\t\t// +optional\n182\t\tAuthorizedSecrets []string `json:\"authorizedSecrets,omitempty\"`\n183\t}\n184\t\n185\t// DefaultCAPackageConfig configures the default CA package feature for trust-manager.\n186\ttype DefaultCAPackageConfig struct {\n187\t\t// policy controls whether the default CA package feature is enabled.\n188\t\t// When set to \"Enabled\", the operator will inject OpenShift's trusted CA bundle\n189\t\t// into trust-manager, enabling the \"useDefaultCAs: true\" source in Bundle resources.\n190\t\t// When set to \"Disabled\", no default CA package is configured and Bundles cannot use useDefaultCAs (default behavior).\n191\t\t// +kubebuilder:default:=\"Disabled\"\n192\t\t// +kubebuilder:validation:Enum:=Enabled;Disabled\n193\t\t// +kubebuilder:validation:Optional\n194\t\t// +optional\n195\t\tPolicy DefaultCAPackagePolicy `json:\"policy,omitempty\"`\n196\t}\n197\t\n198\t// TrustManagerControllerConfig configures the operator's behavior for\n199\t// creating trust-manager resources.\n200\ttype TrustManagerControllerConfig struct {\n201\t\t// labels to apply to all resources created for the trust-manager deployment.\n202\t\t// +mapType=granular\n203\t\t// +kubebuilder:validation:MinProperties:=0\n204\t\t// +kubebuilder:validation:MaxProperties:=25\n205\t\t// +kubebuilder:validation:Optional\n206\t\t// +optional\n207\t\tLabels map[string]string `json:\"labels,omitempty\"`\n208\t\n209\t\t// annotations to apply to all resources created for the trust-manager deployment.\n210\t\t// +mapType=granular\n211\t\t// +kubebuilder:validation:MinProperties:=0\n212\t\t// +kubebuilder:validation:MaxProperties:=25\n213\t\t// +kubebuilder:validation:Optional\n214\t\t// +optional\n215\t\tAnnotations map[string]string `json:\"annotations,omitempty\"`\n216\t}\n217\t\n218\t// FilterExpiredCertificatesPolicy defines the policy for filtering expired certificates.\n219\ttype FilterExpiredCertificatesPolicy string\n220\t\n221\tconst (\n222\t\t// FilterExpiredCertificatesPolicyEnabled filters out expired certificates from bundles.\n223\t\tFilterExpiredCertificatesPolicyEnabled FilterExpiredCertificatesPolicy = \"Enabled\"\n224\t\t// FilterExpiredCertificatesPolicyDisabled includes expired certificates in bundles.\n225\t\tFilterExpiredCertificatesPolicyDisabled FilterExpiredCertificatesPolicy = \"Disabled\"\n226\t)\n227\t\n228\t// SecretTargetsPolicy defines the policy for writing trust bundles to Secrets.\n229\ttype SecretTargetsPolicy string\n230\t\n231\tconst (\n232\t\t// SecretTargetsPolicyDisabled means trust-manager cannot write trust bundles to Secrets.\n233\t\tSecretTargetsPolicyDisabled SecretTargetsPolicy = \"Disabled\"\n234\t\t// SecretTargetsPolicyCustom grants trust-manager read access to all cluster secrets\n235\t\t// and write access to only the secrets listed in authorizedSecrets.\n236\t\tSecretTargetsPolicyCustom SecretTargetsPolicy = \"Custom\"\n237\t)\n238\t\n239\t// DefaultCAPackagePolicy defines the policy for the default CA package feature.\n240\ttype DefaultCAPackagePolicy string\n241\t\n242\tconst (\n243\t\t// DefaultCAPackagePolicyEnabled enables the default CA package feature.\n244\t\tDefaultCAPackagePolicyEnabled DefaultCAPackagePolicy = \"Enabled\"\n245\t\t// DefaultCAPackagePolicyDisabled disables the default CA package feature.\n246\t\tDefaultCAPackagePolicyDisabled DefaultCAPackagePolicy = \"Disabled\"\n247\t)\n248\t\n249\t// TrustManagerStatus defines the observed state of TrustManager.\n250\ttype TrustManagerStatus struct {\n251\t\t// conditions holds information about the current state of the trust-manager deployment.\n252\t\tConditionalStatus `json:\",inline,omitempty\"`\n253\t\n254\t\t// trustManagerImage is the container image (name:tag) used for trust-manager.\n255\t\tTrustManagerImage string `json:\"trustManagerImage,omitempty\"`\n256\t\n257\t\t// trustNamespace is the namespace where trust-manager looks for trust sources.\n258\t\tTrustNamespace string `json:\"trustNamespace,omitempty\"`\n259\t\n260\t\t// secretTargetsPolicy indicates the current secret targets policy.\n261\t\t// +kubebuilder:validation:Enum:=Disabled;Custom\n262\t\tSecretTargetsPolicy SecretTargetsPolicy `json:\"secretTargetsPolicy,omitempty\"`\n263\t\n264\t\t// defaultCAPackagePolicy indicates the current default CA package policy.\n265\t\t// +kubebuilder:validation:Enum:=Enabled;Disabled\n266\t\tDefaultCAPackagePolicy DefaultCAPackagePolicy `json:\"defaultCAPackagePolicy,omitempty\"`\n267\t\n268\t\t// filterExpiredCertificatesPolicy indicates the current policy for filtering expired certificates.\n269\t\t// +kubebuilder:validation:Enum:=Enabled;Disabled\n270\t\tFilterExpiredCertificatesPolicy FilterExpiredCertificatesPolicy `json:\"filterExpiredCertificatesPolicy,omitempty\"`\n271\t}\n272\t"}]},"parent_tool_use_id":null,"session_id":"c62453c8-e16c-4cb8-ac40-4226525deac5","uuid":"8b9fada5-3bf2-4308-9d8c-0a04edf491ea","timestamp":"2026-07-20T18:16:34.640Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/api/operator/v1alpha1/trustmanager_types.go","content":"package v1alpha1\n\nimport (\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n)\n\nfunc init() {\n\tSchemeBuilder.Register(&TrustManager{}, &TrustManagerList{})\n}\n\n// TrustManagerList contains a list of TrustManager resources.\n//\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\ntype TrustManagerList struct {\n\tmetav1.TypeMeta `json:\",inline\"`\n\n\t// metadata is the standard list's metadata.\n\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n\tmetav1.ListMeta `json:\"metadata\"`\n\tItems           []TrustManager `json:\"items\"`\n}\n\n// TrustManager describes the configuration and information about the managed trust-manager deployment.\n// The name must be `cluster` to make TrustManager a singleton, allowing only one instance per cluster.\n// When a TrustManager CR is created, trust-manager operand is deployed in the cert-manager namespace.\n//\n// +genclient\n// +genclient:nonNamespaced\n// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n// +kubebuilder:object:root=true\n// +kubebuilder:subresource:status\n// +kubebuilder:resource:path=trustmanagers,scope=Cluster,categories={cert-manager-operator, trust-manager},shortName=trustmanager;tm\n// +kubebuilder:printcolumn:name=\"Ready\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].status\"\n// +kubebuilder:printcolumn:name=\"Message\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].message\"\n// +kubebuilder:printcolumn:name=\"AGE\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n// +kubebuilder:metadata:labels={\"app.kubernetes.io/name=trustmanager\", \"app.kubernetes.io/part-of=cert-manager-operator\"}\n// +kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'cluster'\",message=\"TrustManager is a singleton, .metadata.name must be 'cluster'\"\n// +operator-sdk:csv:customresourcedefinitions:displayName=\"TrustManager\"\ntype TrustManager struct {\n\tmetav1.TypeMeta `json:\",inline\"`\n\n\t// metadata is the standard object's metadata.\n\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n\t// +required\n\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n\n\t// spec is the specification of the desired behavior of the TrustManager.\n\t// +kubebuilder:validation:Required\n\t// +required\n\tSpec TrustManagerSpec `json:\"spec\"`\n\n\t// status is the most recently observed status of the TrustManager.\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tStatus TrustManagerStatus `json:\"status,omitempty\"`\n}\n\n// TrustManagerSpec defines the desired state of TrustManager.\n// Note: trust-manager operand is always deployed in the cert-manager namespace.\ntype TrustManagerSpec struct {\n\t// trustManagerConfig configures the trust-manager operand's behavior.\n\t// +kubebuilder:validation:Required\n\t// +required\n\tTrustManagerConfig TrustManagerConfig `json:\"trustManagerConfig\"`\n\n\t// controllerConfig configures the operator's behavior for resource creation.\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tControllerConfig TrustManagerControllerConfig `json:\"controllerConfig,omitempty\"`\n}\n\n// TrustManagerConfig configures the trust-manager operand's behavior.\ntype TrustManagerConfig struct {\n\t// logLevel configures the verbosity of trust-manager logging.\n\t// Follows [Kubernetes logging guidelines](https://github.com/kubernetes/community/blob/master/contributors/devel/sig-instrumentation/logging.md#what-method-to-use).\n\t// +kubebuilder:default:=1\n\t// +kubebuilder:validation:Minimum:=1\n\t// +kubebuilder:validation:Maximum:=5\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tLogLevel int32 `json:\"logLevel,omitempty\"`\n\n\t// logFormat specifies the output format for trust-manager logging.\n\t// Supported formats are \"text\" and \"json\".\n\t// +kubebuilder:validation:Enum:=\"text\";\"json\"\n\t// +kubebuilder:default:=\"text\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tLogFormat string `json:\"logFormat,omitempty\"`\n\n\t// trustNamespace is the namespace where trust-manager looks for trust sources\n\t// (ConfigMaps and Secrets containing CA certificates).\n\t// Defaults to \"cert-manager\" if not specified.\n\t// This field is immutable once set.\n\t// This field can have a maximum of 63 characters.\n\t// +kubebuilder:default:=\"cert-manager\"\n\t// +kubebuilder:validation:MinLength:=1\n\t// +kubebuilder:validation:MaxLength:=63\n\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"trustNamespace is immutable once set\"\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tTrustNamespace string `json:\"trustNamespace,omitempty\"`\n\n\t// secretTargets configures whether trust-manager can write trust bundles to Secrets.\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tSecretTargets SecretTargetsConfig `json:\"secretTargets,omitempty\"`\n\n\t// filterExpiredCertificates controls whether trust-manager filters out\n\t// expired certificates from trust bundles before distributing them.\n\t// When set to \"Enabled\", expired certificates are removed from bundles.\n\t// When set to \"Disabled\", expired certificates are included (default behavior).\n\t// +kubebuilder:default:=\"Disabled\"\n\t// +kubebuilder:validation:Enum:=Enabled;Disabled\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tFilterExpiredCertificates FilterExpiredCertificatesPolicy `json:\"filterExpiredCertificates,omitempty\"`\n\n\t// defaultCAPackage configures the default CA package for trust-manager.\n\t// When enabled, the operator will use OpenShift's trusted CA bundle injection mechanism.\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tDefaultCAPackage DefaultCAPackageConfig `json:\"defaultCAPackage,omitempty\"`\n\n\t// resources defines the compute resource requirements for the trust-manager pod.\n\t// ref: https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tResources corev1.ResourceRequirements `json:\"resources,omitempty\"`\n\n\t// affinity defines scheduling constraints for the trust-manager pod.\n\t// ref: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tAffinity *corev1.Affinity `json:\"affinity,omitempty\"`\n\n\t// tolerations allows the trust-manager pod to be scheduled on tainted nodes.\n\t// ref: https://kubernetes.io/docs/concepts/scheduling-eviction/taint-and-toleration/\n\t// +listType=atomic\n\t// +kubebuilder:validation:MinItems:=0\n\t// +kubebuilder:validation:MaxItems:=50\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tTolerations []corev1.Toleration `json:\"tolerations,omitempty\"`\n\n\t// nodeSelector restricts which nodes the trust-manager pod can be scheduled on.\n\t// ref: https://kubernetes.io/docs/concepts/configuration/assign-pod-node/\n\t// +mapType=atomic\n\t// +kubebuilder:validation:MinProperties:=0\n\t// +kubebuilder:validation:MaxProperties:=50\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tNodeSelector map[string]string `json:\"nodeSelector,omitempty\"`\n}\n\n// SecretTargetsConfig configures whether and how trust-manager can write\n// trust bundles to Secrets.\n//\n// +kubebuilder:validation:XValidation:rule=\"self.policy != 'Custom' || (has(self.authorizedSecrets) && size(self.authorizedSecrets) > 0)\",message=\"authorizedSecrets must not be empty when policy is Custom\"\n// +kubebuilder:validation:XValidation:rule=\"self.policy == 'Custom' || !has(self.authorizedSecrets) || size(self.authorizedSecrets) == 0\",message=\"authorizedSecrets must be empty when policy is not Custom\"\ntype SecretTargetsConfig struct {\n\t// policy controls whether and how trust-manager can write trust bundles to Secrets.\n\t// Allowed values are \"Disabled\" or \"Custom\".\n\t// \"Disabled\" means trust-manager cannot write trust bundles to Secrets (default behavior).\n\t// \"Custom\" grants trust-manager read access  to all secrets cluster-wide,\n\t// and write access only to the secrets listed in authorizedSecrets.\n\t// +kubebuilder:default:=\"Disabled\"\n\t// +kubebuilder:validation:Enum:=Disabled;Custom\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tPolicy SecretTargetsPolicy `json:\"policy,omitempty\"`\n\n\t// authorizedSecrets is a list of specific secret names that trust-manager\n\t// is authorized to create and update. This field is only valid when policy is \"Custom\".\n\t// +listType=set\n\t// +kubebuilder:validation:MinItems:=0\n\t// +kubebuilder:validation:items:MinLength:=1\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tAuthorizedSecrets []string `json:\"authorizedSecrets,omitempty\"`\n}\n\n// DefaultCAPackageConfig configures the default CA package feature for trust-manager.\ntype DefaultCAPackageConfig struct {\n\t// policy controls whether the default CA package feature is enabled.\n\t// When set to \"Enabled\", the operator will inject OpenShift's trusted CA bundle\n\t// into trust-manager, enabling the \"useDefaultCAs: true\" source in Bundle resources.\n\t// When set to \"Disabled\", no default CA package is configured and Bundles cannot use useDefaultCAs (default behavior).\n\t// +kubebuilder:default:=\"Disabled\"\n\t// +kubebuilder:validation:Enum:=Enabled;Disabled\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tPolicy DefaultCAPackagePolicy `json:\"policy,omitempty\"`\n}\n\n// TrustManagerControllerConfig configures the operator's behavior for\n// creating trust-manager resources.\ntype TrustManagerControllerConfig struct {\n\t// labels to apply to all resources created for the trust-manager deployment.\n\t// +mapType=granular\n\t// +kubebuilder:validation:MinProperties:=0\n\t// +kubebuilder:validation:MaxProperties:=25\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tLabels map[string]string `json:\"labels,omitempty\"`\n\n\t// annotations to apply to all resources created for the trust-manager deployment.\n\t// +mapType=granular\n\t// +kubebuilder:validation:MinProperties:=0\n\t// +kubebuilder:validation:MaxProperties:=25\n\t// +kubebuilder:validation:Optional\n\t// +optional\n\tAnnotations map[string]string `json:\"annotations,omitempty\"`\n}\n\n// FilterExpiredCertificatesPolicy defines the policy for filtering expired certificates.\ntype FilterExpiredCertificatesPolicy string\n\nconst (\n\t// FilterExpiredCertificatesPolicyEnabled filters out expired certificates from bundles.\n\tFilterExpiredCertificatesPolicyEnabled FilterExpiredCertificatesPolicy = \"Enabled\"\n\t// FilterExpiredCertificatesPolicyDisabled includes expired certificates in bundles.\n\tFilterExpiredCertificatesPolicyDisabled FilterExpiredCertificatesPolicy = \"Disabled\"\n)\n\n// SecretTargetsPolicy defines the policy for writing trust bundles to Secrets.\ntype SecretTargetsPolicy string\n\nconst (\n\t// SecretTargetsPolicyDisabled means trust-manager cannot write trust bundles to Secrets.\n\tSecretTargetsPolicyDisabled SecretTargetsPolicy = \"Disabled\"\n\t// SecretTargetsPolicyCustom grants trust-manager read access to all cluster secrets\n\t// and write access to only the secrets listed in authorizedSecrets.\n\tSecretTargetsPolicyCustom SecretTargetsPolicy = \"Custom\"\n)\n\n// DefaultCAPackagePolicy defines the policy for the default CA package feature.\ntype DefaultCAPackagePolicy string\n\nconst (\n\t// DefaultCAPackagePolicyEnabled enables the default CA package feature.\n\tDefaultCAPackagePolicyEnabled DefaultCAPackagePolicy = \"Enabled\"\n\t// DefaultCAPackagePolicyDisabled disables the default CA package feature.\n\tDefaultCAPackagePolicyDisabled DefaultCAPackagePolicy = \"Disabled\"\n)\n\n// TrustManagerStatus defines the observed state of TrustManager.\ntype TrustManagerStatus struct {\n\t// conditions holds information about the current state of the trust-manager deployment.\n\tConditionalStatus `json:\",inline,omitempty\"`\n\n\t// trustManagerImage is the container image (name:tag) used for trust-manager.\n\tTrustManagerImage string `json:\"trustManagerImage,omitempty\"`\n\n\t// trustNamespace is the namespace where trust-manager looks for trust sources.\n\tTrustNamespace string `json:\"trustNamespace,omitempty\"`\n\n\t// secretTargetsPolicy indicates the current secret targets policy.\n\t// +kubebuilder:validation:Enum:=Disabled;Custom\n\tSecretTargetsPolicy SecretTargetsPolicy `json:\"secretTargetsPolicy,omitempty\"`\n\n\t// defaultCAPackagePolicy indicates the current default CA package policy.\n\t// +kubebuilder:validation:Enum:=Enabled;Disabled\n\tDefaultCAPackagePolicy DefaultCAPackagePolicy `json:\"defaultCAPackagePolicy,omitempty\"`\n\n\t// filterExpiredCertificatesPolicy indicates the current policy for filtering expired certificates.\n\t// +kubebuilder:validation:Enum:=Enabled;Disabled\n\tFilterExpiredCertificatesPolicy FilterExpiredCertificatesPolicy `json:\"filterExpiredCertificatesPolicy,omitempty\"`\n}\n","numLines":272,"startLine":1,"totalLines":272}}}

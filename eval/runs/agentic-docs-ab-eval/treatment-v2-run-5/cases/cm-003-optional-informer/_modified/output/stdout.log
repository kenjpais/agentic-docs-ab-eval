ler) cleanUp(trustManager *v1alpha1.TrustManager) (bool, error) {\n214\t\t// TODO: For GA, handle cleaning up of resources created for installing trust-manager operand.\n215\t\t// As per Non-Goals in the enhancement, removing the TrustManager CR will not remove the\n216\t\t// trust-manager deployment or its associated resources.\n217\t\tr.eventRecorder.Eventf(trustManager, corev1.EventTypeWarning, \"RemoveDeployment\", \"%s trustmanager marked for deletion, remove all resources created for trustmanager deployment manually\", trustManager.GetName())\n218\t\treturn false, nil\n219\t}\n220\t"}]},"parent_tool_use_id":null,"session_id":"4e719bef-a1d9-4ac0-976e-27b5e577da14","uuid":"acec0739-a892-4787-bcfa-372e7983b685","timestamp":"2026-07-20T18:17:47.849Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/controller/trustmanager/controller.go","content":"package trustmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\n\tadmissionregistrationv1 \"k8s.io/api/admissionregistration/v1\"\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\trbacv1 \"k8s.io/api/rbac/v1\"\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/client-go/tools/record\"\n\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/builder\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/event\"\n\t\"sigs.k8s.io/controller-runtime/pkg/handler\"\n\t\"sigs.k8s.io/controller-runtime/pkg/predicate\"\n\t\"sigs.k8s.io/controller-runtime/pkg/reconcile\"\n\n\t\"github.com/go-logr/logr\"\n\n\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n\n\tv1alpha1 \"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n)\n\n// RequestEnqueueLabelValue is the label value used for filtering reconcile\n// events to include only the resources created by the TrustManager controller.\n// The label key is common.ManagedResourceLabelKey.\nconst RequestEnqueueLabelValue = \"cert-manager-trust-manager\"\n\n// Reconciler reconciles a TrustManager object.\ntype Reconciler struct {\n\tcommon.CtrlClient\n\n\tctx           context.Context\n\teventRecorder record.EventRecorder\n\tlog           logr.Logger\n\tscheme        *runtime.Scheme\n}\n\n// +kubebuilder:rbac:groups=operator.openshift.io,resources=trustmanagers,verbs=get;list;watch;update;patch\n// +kubebuilder:rbac:groups=operator.openshift.io,resources=trustmanagers/status,verbs=get;update;patch\n// +kubebuilder:rbac:groups=operator.openshift.io,resources=trustmanagers/finalizers,verbs=update\n// +kubebuilder:rbac:groups=\"\",resources=namespaces,verbs=get;list;watch\n// +kubebuilder:rbac:groups=\"\",resources=configmaps,verbs=get;list;watch;create;update;patch\n// +kubebuilder:rbac:groups=\"\",resources=serviceaccounts,verbs=get;list;watch;create;update;patch\n// +kubebuilder:rbac:groups=\"\",resources=services,verbs=get;list;watch;create;update;patch\n// +kubebuilder:rbac:groups=apps,resources=deployments,verbs=get;list;watch;create;update;patch\n// +kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=clusterroles;clusterrolebindings,verbs=get;list;watch;create;update;patch\n// +kubebuilder:rbac:groups=rbac.authorization.k8s.io,resources=roles;rolebindings,verbs=get;list;watch;create;update;patch\n// +kubebuilder:rbac:groups=cert-manager.io,resources=certificates;issuers,verbs=get;list;watch;create;update;patch\n// +kubebuilder:rbac:groups=admissionregistration.k8s.io,resources=validatingwebhookconfigurations,verbs=get;list;watch;create;update;patch\n// +kubebuilder:rbac:groups=trust.cert-manager.io,resources=bundles,verbs=get;list;watch\n// +kubebuilder:rbac:groups=trust.cert-manager.io,resources=bundles/finalizers,verbs=update\n// +kubebuilder:rbac:groups=trust.cert-manager.io,resources=bundles/status,verbs=patch\n\n// New returns a new Reconciler instance.\nfunc New(mgr ctrl.Manager) (*Reconciler, error) {\n\tc, err := common.NewClient(mgr)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\treturn &Reconciler{\n\t\tCtrlClient:    c,\n\t\tctx:           context.Background(),\n\t\teventRecorder: mgr.GetEventRecorderFor(ControllerName),\n\t\tlog:           ctrl.Log.WithName(ControllerName),\n\t\tscheme:        mgr.GetScheme(),\n\t}, nil\n}\n\n// SetupWithManager sets up the controller with the Manager.\nfunc (r *Reconciler) SetupWithManager(mgr ctrl.Manager) error {\n\t// mapFunc unconditionally enqueues the singleton TrustManager CR.\n\t// Filtering is handled by predicates attached to each Watch.\n\tmapFunc := func(ctx context.Context, obj client.Object) []reconcile.Request {\n\t\tr.log.V(4).Info(\"received reconcile event\", \"object\", fmt.Sprintf(\"%T\", obj), \"name\", obj.GetName(), \"namespace\", obj.GetNamespace())\n\t\treturn []reconcile.Request{{NamespacedName: types.NamespacedName{Name: trustManagerObjectName}}}\n\t}\n\n\tisManagedResource := func(object client.Object) bool {\n\t\tlabels := object.GetLabels()\n\t\tmatches := labels != nil && labels[common.ManagedResourceLabelKey] == RequestEnqueueLabelValue\n\t\tr.log.V(4).Info(\"predicate evaluation\", \"object\", fmt.Sprintf(\"%T\", object), \"name\", object.GetName(), \"namespace\", object.GetNamespace(), \"labels\", labels, \"matches\", matches)\n\t\treturn matches\n\t}\n\n\t// Predicate to filter events for resources managed by this controller.\n\t// On updates, checks both old and new objects so that events where the\n\t// managed label is removed still trigger reconciliation.\n\tcontrollerManagedResources := predicate.Funcs{\n\t\tCreateFunc: func(e event.CreateEvent) bool {\n\t\t\treturn isManagedResource(e.Object)\n\t\t},\n\t\tUpdateFunc: func(e event.UpdateEvent) bool {\n\t\t\treturn isManagedResource(e.ObjectOld) || isManagedResource(e.ObjectNew)\n\t\t},\n\t\tDeleteFunc: func(e event.DeleteEvent) bool {\n\t\t\treturn isManagedResource(e.Object)\n\t\t},\n\t\tGenericFunc: func(e event.GenericEvent) bool {\n\t\t\treturn isManagedResource(e.Object)\n\t\t},\n\t}\n\n\tcontrollerManagedResourcePredicates := builder.WithPredicates(controllerManagedResources)\n\n\t// withIgnoreStatusUpdatePredicates filters out status-only updates while still\n\t// detecting spec changes (generation bump) and metadata drift (label/annotation edits).\n\twithIgnoreStatusUpdatePredicates := builder.WithPredicates(\n\t\tpredicate.Or(\n\t\t\tpredicate.GenerationChangedPredicate{},\n\t\t\tpredicate.LabelChangedPredicate{},\n\t\t\tpredicate.AnnotationChangedPredicate{},\n\t\t),\n\t\tcontrollerManagedResources,\n\t)\n\n\t// Predicate that matches the CNO-injected CA bundle ConfigMap in the operator namespace.\n\t// This ConfigMap is NOT managed by trust-manager-controller (no managed label) but we need to detect\n\t// when CNO updates the trusted CA bundle so we can reformat and propagate it.\n\tinjectedCABundleConfigMapPredicate := predicate.NewPredicateFuncs(func(object client.Object) bool {\n\t\treturn object.GetNamespace() == common.OperatorNamespace &&\n\t\t\tobject.GetName() == common.TrustedCABundleConfigMapName\n\t})\n\n\treturn ctrl.NewControllerManagedBy(mgr).\n\t\tFor(&v1alpha1.TrustManager{}, builder.WithPredicates(predicate.GenerationChangedPredicate{})).\n\t\tNamed(ControllerName).\n\t\tWatches(&corev1.ServiceAccount{}, handler.EnqueueRequestsFromMapFunc(mapFunc), controllerManagedResourcePredicates).\n\t\tWatches(&appsv1.Deployment{}, handler.EnqueueRequestsFromMapFunc(mapFunc), withIgnoreStatusUpdatePredicates).\n\t\tWatches(&corev1.Service{}, handler.EnqueueRequestsFromMapFunc(mapFunc), controllerManagedResourcePredicates).\n\t\tWatches(&corev1.ConfigMap{}, handler.EnqueueRequestsFromMapFunc(mapFunc), controllerManagedResourcePredicates).\n\t\tWatches(&corev1.ConfigMap{}, handler.EnqueueRequestsFromMapFunc(mapFunc), builder.WithPredicates(injectedCABundleConfigMapPredicate)).\n\t\tWatches(&rbacv1.ClusterRole{}, handler.EnqueueRequestsFromMapFunc(mapFunc), controllerManagedResourcePredicates).\n\t\tWatches(&rbacv1.ClusterRoleBinding{}, handler.EnqueueRequestsFromMapFunc(mapFunc), controllerManagedResourcePredicates).\n\t\tWatches(&rbacv1.Role{}, handler.EnqueueRequestsFromMapFunc(mapFunc), controllerManagedResourcePredicates).\n\t\tWatches(&rbacv1.RoleBinding{}, handler.EnqueueRequestsFromMapFunc(mapFunc), controllerManagedResourcePredicates).\n\t\tWatches(&certmanagerv1.Certificate{}, handler.EnqueueRequestsFromMapFunc(mapFunc), withIgnoreStatusUpdatePredicates).\n\t\tWatches(&certmanagerv1.Issuer{}, handler.EnqueueRequestsFromMapFunc(mapFunc), withIgnoreStatusUpdatePredicates).\n\t\tWatches(&admissionregistrationv1.ValidatingWebhookConfiguration{}, handler.EnqueueRequestsFromMapFunc(mapFunc), controllerManagedResourcePredicates).\n\t\tComplete(r)\n}\n\n// Reconcile function to compare the state specified by the TrustManager object against the actual cluster state,\n// and to make the cluster state reflect the state specified by the user.\nfunc (r *Reconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error) {\n\tr.log.V(1).Info(\"reconciling\", \"request\", req)\n\n\t// Fetch the trustmanager.openshift.operator.io CR\n\ttrustManager := &v1alpha1.TrustManager{}\n\t// Note: No namespace because TrustManager is cluster-scoped\n\tif err := r.Get(ctx, types.NamespacedName{Name: req.Name}, trustManager); err != nil {\n\t\tif errors.IsNotFound(err) {\n\t\t\t// NotFound errors, since they can't be fixed by an immediate\n\t\t\t// requeue (have to wait for a new notification), and can be processed\n\t\t\t// on deleted requests.\n\t\t\tr.log.V(1).Info(\"trustmanager.openshift.operator.io object not found, skipping reconciliation\", \"request\", req)\n\t\t\treturn ctrl.Result{}, nil\n\t\t}\n\t\treturn ctrl.Result{}, fmt.Errorf(\"failed to fetch trustmanager.openshift.operator.io %q during reconciliation: %w\", req.NamespacedName, err)\n\t}\n\n\tif !trustManager.DeletionTimestamp.IsZero() {\n\t\tr.log.V(1).Info(\"trustmanager.openshift.operator.io is marked for deletion\", \"name\", req.NamespacedName)\n\n\t\tif requeue, err := r.cleanUp(trustManager); err != nil {\n\t\t\treturn ctrl.Result{}, fmt.Errorf(\"clean up failed for %q trustmanager.openshift.operator.io instance deletion: %w\", req.NamespacedName, err)\n\t\t} else if requeue {\n\t\t\treturn ctrl.Result{RequeueAfter: defaultRequeueTime}, nil\n\t\t}\n\n\t\tif err := r.removeFinalizer(ctx, trustManager, finalizer); err != nil {\n\t\t\treturn ctrl.Result{}, err\n\t\t}\n\n\t\tr.log.V(1).Info(\"removed finalizer, cleanup complete\", \"request\", req.NamespacedName)\n\t\treturn ctrl.Result{}, nil\n\t}\n\n\t// Set finalizers on the trustmanager.openshift.operator.io resource\n\tif err := r.addFinalizer(ctx, trustManager); err != nil {\n\t\treturn ctrl.Result{}, fmt.Errorf(\"failed to update %q trustmanager.openshift.operator.io with finalizers: %w\", req.NamespacedName, err)\n\t}\n\n\treturn r.processReconcileRequest(trustManager, req.NamespacedName)\n}\n\nfunc (r *Reconciler) processReconcileRequest(trustManager *v1alpha1.TrustManager, req types.NamespacedName) (ctrl.Result, error) {\n\treconcileErr := r.reconcileTrustManagerDeployment(trustManager)\n\tif reconcileErr != nil {\n\t\tr.log.Error(reconcileErr, \"failed to reconcile TrustManager deployment\", \"request\", req)\n\t}\n\n\treturn common.HandleReconcileResult(\n\t\t&trustManager.Status.ConditionalStatus,\n\t\treconcileErr,\n\t\tr.log.WithValues(\"name\", trustManager.GetName()),\n\t\tfunc(prependErr error) error {\n\t\t\treturn r.updateCondition(trustManager, prependErr)\n\t\t},\n\t\tdefaultRequeueTime,\n\t)\n}\n\n// cleanUp handles deletion of trustmanager.openshift.operator.io gracefully.\nfunc (r *Reconciler) cleanUp(trustManager *v1alpha1.TrustManager) (bool, error) {\n\t// TODO: For GA, handle cleaning up of resources created for installing trust-manager operand.\n\t// As per Non-Goals in the enhancement, removing the TrustManager CR will not remove the\n\t// trust-manager deployment or its associated resources.\n\tr.eventRecorder.Eventf(trustManager, corev1.EventTypeWarning, \"RemoveDeployment\", \"%s trustmanager marked for deletion, remove all resources created for trustmanager deployment manually\", trustManager.GetName())\n\treturn false, nil\n}\n","numLines":220,"startLine":1,"totalLines":220}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01UQDQGtz7S3gapbNuDG7wGC","type":"tool_result","content":"1\t// Package utils provides small shared helpers for the cert-manager operator,\n2\t// including optional API discovery (whether a GroupVersionResource is served)\n3\t// and shared informer wiring that runs only when that API exists.\n4\tpackage utils\n5\t\n6\timport (\n7\t\t\"fmt\"\n8\t\n9\t\t\"k8s.io/apimachinery/pkg/api/errors\"\n10\t\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n11\t\t\"k8s.io/client-go/discovery\"\n12\t)\n13\t\n14\t// ResourceDiscoverer reports whether a GroupVersionResource is served by the\n15\t// cluster API server (via discovery). Implementations include the value returned\n16\t// from NewResourceDiscoverer.\n17\ttype ResourceDiscoverer interface {\n18\t\tDiscover() (bool, error)\n19\t}\n20\t\n21\t// apiResourceDiscoverer implements ResourceDiscoverer using the discovery API.\n22\ttype apiResourceDiscoverer struct {\n23\t\tgvr             schema.GroupVersionResource\n24\t\tdiscoveryClient discovery.DiscoveryInterface\n25\t}\n26\t\n27\t// OptionalInformer holds a typed informer factory only when the target API\n28\t// resource exists on the cluster. Populated by InitInformerIfAvailable when\n29\t// discovery reports the resource is served.\n30\ttype OptionalInformer[GroupInformer any] struct {\n31\t\tInformerFactory *GroupInformer\n32\t}\n33\t\n34\t// NewResourceDiscoverer returns a ResourceDiscoverer for the given GVR and\n35\t// discovery client. Discover is not called until Discover or\n36\t// InitInformerIfAvailable runs.\n37\tfunc NewResourceDiscoverer(gvr schema.GroupVersionResource, discoveryClient discovery.DiscoveryInterface) ResourceDiscoverer {\n38\t\treturn &apiResourceDiscoverer{\n39\t\t\tgvr:             gvr,\n40\t\t\tdiscoveryClient: discoveryClient,\n41\t\t}\n42\t}\n43\t\n44\t// Discover reports whether the API server lists a.gvr.Resource in the\n45\t// APIResources for the group/version in a.gvr. A NotFound error from discovery is\n46\t// treated as not present (false, nil); other errors are returned.\n47\tfunc (a *apiResourceDiscoverer) Discover() (bool, error) {\n48\t\tresources, err := a.discoveryClient.ServerResourcesForGroupVersion(a.gvr.GroupVersion().String())\n49\t\tif err != nil {\n50\t\t\tif errors.IsNotFound(err) {\n51\t\t\t\treturn false, nil\n52\t\t\t}\n53\t\t\treturn false, fmt.Errorf(\"failed to discover resources: %w\", err)\n54\t\t}\n55\t\n56\t\tfor _, res := range resources.APIResources {\n57\t\t\tif res.Name == a.gvr.Resource {\n58\t\t\t\treturn true, nil\n59\t\t\t}\n60\t\t}\n61\t\n62\t\treturn false, nil\n63\t}\n64\t\n65\t// InitInformerIfAvailable calls d.Discover(), and if the resource is served it\n66\t// calls informerInitFunc and stores the result in InformerFactory; otherwise\n67\t// InformerFactory remains nil and no error is returned (the API is treated as\n68\t// unavailable).\n69\tfunc InitInformerIfAvailable[groupInformer any](\n70\t\td ResourceDiscoverer,\n71\t\tinformerInitFunc func() groupInformer,\n72\t) (*OptionalInformer[groupInformer], error) {\n73\t\to := new(OptionalInformer[groupInformer])\n74\t\n75\t\tdiscovered, err := d.Discover()\n76\t\tif err != nil {\n77\t\t\treturn nil, err\n78\t\t}\n79\t\n80\t\tif discovered {\n81\t\t\tinformer := informerInitFunc()\n82\t\t\to.InformerFactory = &informer\n83\t\t}\n84\t\n85\t\treturn o, nil\n86\t}\n87\t\n88\t// Applicable reports whether an informer factory was set (the API was present).\n89\tfunc (o *OptionalInformer[GroupInformer]) Applicable() bool {\n90\t\treturn o.InformerFactory != nil\n91\t}\n92\t"}]},"parent_tool_use_id":null,"session_id":"4e719bef-a1d9-4ac0-976e-27b5e577da14","uuid":"641a6702-ed8a-4bb9-832f-6e5e20a08ed7","timestamp":"2026-07-20T18:17:47.849Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/operator/utils/apidiscovery.go","content":"// Package utils provides small shared helpers for the cert-manager operator,\n// including optional API discovery (whether a GroupVersionResource is served)\n// and shared informer wiring that runs only when that API exists.\npackage utils\n\nimport (\n\t\"fmt\"\n\n\t\"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/runtime/schema\"\n\t\"k8s.io/client-go/discovery\"\n)\n\n// ResourceDiscoverer reports whether a GroupVersionResource is served by the\n// cluster API server (via discovery). Implementations include the value returned\n// from NewResourceDiscoverer.\ntype ResourceDiscoverer interface {\n\tDiscover() (bool, error)\n}\n\n// apiResourceDiscoverer implements ResourceDiscoverer using the discovery API.\ntype apiResourceDiscoverer struct {\n\tgvr             schema.GroupVersionResource\n\tdiscoveryClient discovery.DiscoveryInterface\n}\n\n// OptionalInformer holds a typed informer factory only when the target API\n// resource exists on the cluster. Populated by InitInformerIfAvailable when\n// discovery reports the resource is served.\ntype OptionalInformer[GroupInformer any] struct {\n\tInformerFactory *GroupInformer\n}\n\n// NewResourceDiscoverer returns a ResourceDiscoverer for the given GVR and\n// discovery client. Discover is not called until Discover or\n// InitInformerIfAvailable runs.\nfunc NewResourceDiscoverer(gvr schema.GroupVersionResource, discoveryClient discovery.DiscoveryInterface) ResourceDiscoverer {\n\treturn &apiResourceDiscoverer{\n\t\tgvr:             gvr,\n\t\tdiscoveryClient: discoveryClient,\n\t}\n}\n\n// Discover reports whether the API server lists a.gvr.Resource in the\n// APIResources for the group/version in a.gvr. A NotFound error from discovery is\n// treated as not present (false, nil); other errors are returned.\nfunc (a *apiResourceDiscoverer) Discover() (bool, error) {\n\tresources, err := a.discoveryClient.ServerResourcesForGroupVersion(a.gvr.GroupVersion().String())\n\tif err != nil {\n\t\tif errors.IsNotFound(err) {\n\t\t\treturn false, nil\n\t\t}\n\t\treturn false, fmt.Errorf(\"failed to discover resources: %w\", err)\n\t}\n\n\tfor _, res := range resources.APIResources {\n\t\tif res.Name == a.gvr.Resource {\n\t\t\treturn true, nil\n\t\t}\n\t}\n\n\treturn false, nil\n}\n\n// InitInformerIfAvailable calls d.Discover(), and if the resource is served it\n// calls informerInitFunc and stores the result in InformerFactory; otherwise\n// InformerFactory remains nil and no error is returned (the API is treated as\n// unavailable).\nfunc InitInformerIfAvailable[groupInformer any](\n\td ResourceDiscoverer,\n\tinformerInitFunc func() groupInformer,\n) (*OptionalInformer[groupInformer], error) {\n\to := new(OptionalInformer[groupInformer])\n\n\tdiscovered, err := d.Discover()\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif discovered {\n\t\tinformer := informerInitFunc()\n\t\to.InformerFactory = &informer\n\t}\n\n\treturn o, nil\n}\n\n// Applicable reports whether an informer factory was set (the API was present).\nfunc (o *OptionalInformer[GroupInformer]) Applicable() bool {\n\treturn o.InformerFactory != nil\n}\n","numLines":92,"startLine":1,"totalLines":92}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01AxpETz45gjN1YwyW4NpkpZ","type":"tool_result","content":"1\t# OptionalInformer / API Discovery\n2\t\n3\tSource: `pkg/operator/utils/apidiscovery.go`\n4\t\n5\t## Purpose\n6\t\n7\tThe cert-manager operator targets both full OpenShift clusters and stripped-down variants\n8\t(e.g., MicroShift) that do not serve every OpenShift API. `OptionalInformer` allows the\n9\toperator to start an informer factory for a given API group only when that API is actually\n10\tpresent on the cluster, with no special-casing scattered through startup code.\n11\t\n12\t## Core types\n13\t\n14\t### ResourceDiscoverer interface\n15\t\n16\t```go\n17\ttype ResourceDiscoverer interface {\n18\t    Discover() (bool, error)\n19\t}\n20\t```\n21\t\n22\tThe only implementation is `apiResourceDiscoverer`, constructed by `NewResourceDiscoverer`.\n23\tConstruction is cheap: no API call is made until `Discover()` is invoked. `Discover()` calls\n24\t`discovery.DiscoveryInterface.ServerResourcesForGroupVersion` for the GVR's group/version,\n25\tthen scans the returned resource list for the resource name.\n26\t\n27\t### OptionalInformer[T]\n28\t\n29\t```go\n30\ttype OptionalInformer[GroupInformer any] struct {\n31\t    InformerFactory *GroupInformer\n32\t}\n33\t```\n34\t\n35\tA typed wrapper that holds a pointer to an informer factory, or nil if the API was absent.\n36\tThe type parameter `T` is the concrete group informer factory type (e.g.,\n37\t`configinformers.SharedInformerFactory`).\n38\t\n39\t### InitInformerIfAvailable[T]\n40\t\n41\t```go\n42\tfunc InitInformerIfAvailable[groupInformer any](\n43\t    d ResourceDiscoverer,\n44\t    informerInitFunc func() groupInformer,\n45\t) (*OptionalInformer[groupInformer], error)\n46\t```\n47\t\n48\tThis is the entry point for callers. It:\n49\t1. Calls `d.Discover()`.\n50\t2. If discovery returns an error **other than NotFound**, propagates it — the operator cannot\n51\t   start safely without knowing whether the API is present.\n52\t3. If the API is **not found** (Discover returns false, nil), returns an `OptionalInformer`\n53\t   with `InformerFactory == nil`. No informer is started. The operator continues normally.\n54\t4. If the API is **found**, calls `informerInitFunc()`, stores the result in\n55\t   `InformerFactory`, and returns it.\n56\t\n57\tDiscovery NotFound errors are silently treated as absent — this covers MicroShift or any\n58\tcluster that simply hasn't installed a given API group.\n59\t\n60\t### Applicable() guard\n61\t\n62\t```go\n63\tfunc (o *OptionalInformer[GroupInformer]) Applicable() bool {\n64\t    return o.InformerFactory != nil\n65\t}\n66\t```\n67\t\n68\tCallers check `Applicable()` before accessing the factory. If false, the feature that\n69\tdepends on the optional API is silently skipped for the lifetime of the operator process\n70\t(there is no periodic re-check; the operator must restart to pick up a newly installed API).\n71\t\n72\t## Currently optional APIs\n73\t\n74\t| API | GVR | Used by |\n75\t|---|---|---|\n76\t| OpenShift Infrastructure | `config.openshift.io/v1 / infrastructures` | certmanager controller; passes proxy/infra topology to Deployment controllers |\n77\t| OpenShift FeatureGate | `config.openshift.io/v1 / featuregates` | `pkg/features`; gates preview features (e.g., TrustManager, IstioCSR) |\n78\t\n79\tThe FeatureGate case uses `ResourceDiscoverer` directly (calling `Discover()` and branching\n80\tmanually) rather than wrapping in `OptionalInformer`, because it only needs a one-time read\n81\trather than a live-watching informer factory.\n82\t"}]},"parent_tool_use_id":null,"session_id":"4e719bef-a1d9-4ac0-976e-27b5e577da14","uuid":"835f2096-d45f-49c1-8de4-21de096da208","timestamp":"2026-07-20T18:17:47.850Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/agentic/design-docs/components/optional-informer.md","content":"# OptionalInformer / API Discovery\n\nSource: `pkg/operator/utils/apidiscovery.go`\n\n## Purpose\n\nThe cert-manager operator targets both full OpenShift clusters and stripped-down variants\n(e.g., MicroShift) that do not serve every OpenShift API. `OptionalInformer` allows the\noperator to start an informer factory for a given API group only when that API is actually\npresent on the cluster, with no special-casing scattered through startup code.\n\n## Core types\n\n### ResourceDiscoverer interface\n\n```go\ntype ResourceDiscoverer interface {\n    Discover() (bool, error)\n}\n```\n\nThe only implementation is `apiResourceDiscoverer`, constructed by `NewResourceDiscoverer`.\nConstruction is cheap: no API call is made until `Discover()` is invoked. `Discover()` calls\n`discovery.DiscoveryInterface.ServerResourcesForGroupVersion` for the GVR's group/version,\nthen scans the returned resource list for the resource name.\n\n### OptionalInformer[T]\n\n```go\ntype OptionalInformer[GroupInformer any] struct {\n    InformerFactory *GroupInformer\n}\n```\n\nA typed wrapper that holds a pointer to an informer factory, or nil if the API was absent.\nThe type parameter `T` is the concrete group informer factory type (e.g.,\n`configinformers.SharedInformerFactory`).\n\n### InitInformerIfAvailable[T]\n\n```go\nfunc InitInformerIfAvailable[groupInformer any](\n    d ResourceDiscoverer,\n    informerInitFunc func() groupInformer,\n) (*OptionalInformer[groupInformer], error)\n```\n\nThis is the entry point for callers. It:\n1. Calls `d.Discover()`.\n2. If discovery returns an error **other than NotFound**, propagates it — the operator cannot\n   start safely without knowing whether the API is present.\n3. If the API is **not found** (Discover returns false, nil), returns an `OptionalInformer`\n   with `InformerFactory == nil`. No informer is started. The operator continues normally.\n4. If the API is **found**, calls `informerInitFunc()`, stores the result in\n   `InformerFactory`, and returns it.\n\nDiscovery NotFound errors are silently treated as absent — this covers MicroShift or any\ncluster that simply hasn't installed a given API group.\n\n### Applicable() guard\n\n```go\nfunc (o *OptionalInformer[GroupInformer]) Applicable() bool {\n    return o.InformerFactory != nil\n}\n```\n\nCallers check `Applicable()` before accessing the factory. If false, the feature that\ndepends on the optional API is silently skipped for the lifetime of the operator process\n(there is no periodic re-check; the operator must restart to pick up a newly installed API).\n\n## Currently optional APIs\n\n| API | GVR | Used by |\n|---|---|---|\n| OpenShift Infrastructure | `config.openshift.io/v1 / infrastructures` | certmanager controller; passes proxy/infra topology to Deployment controllers |\n| OpenShift FeatureGate | `config.openshift.io/v1 / featuregates` | `pkg/features`; gates preview features (e.g., TrustManager, IstioCSR) |\n\nThe FeatureGate case uses `ResourceDiscoverer` directly (calling `Discover()` and branching\nmanually) rather than wrapping in `OptionalInformer`, because it only needs a one-time read\nrather than a live-watching informer factory.\n","numLines":82,"startLine":1,"totalLines":82}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_017Gnb7T51QdstnZjRsaq8TA","type":"tool_result","content":"1\t# TrustManager Controller\n2\t\n3\t## What it reconciles\n4\t\n5\tThe TrustManager controller owns the `TrustManager` cluster-scoped singleton CRD\n6\t(`operator.openshift.io/v1alpha1`). When a `TrustManager` CR named `cluster` exists,\n7\tthe controller ensures that the trust-manager operand Deployment and its full supporting\n8\tresource set are present and match the declared spec.\n9\t\n10\t## Resource watch surface (13+ types)\n11\t\n12\t`SetupWithManager` registers watches for:\n13\t\n14\t| Watch target | Predicate |\n15\t|---|---|\n16\t| `TrustManager` (For) | GenerationChangedPredicate |\n17\t| `ServiceAccount` | managed-label predicate |\n18\t| `Deployment` | managed-label + ignore-status-update |\n19\t| `Service` | managed-label |\n20\t| `ConfigMap` (controller-owned) | managed-label |\n21\t| `ConfigMap` (CNO CA bundle) | namespace==operator-ns AND name==trusted-ca-bundle |\n22\t| `ClusterRole`, `ClusterRoleBinding` | managed-label |\n23\t| `Role`, `RoleBinding` | managed-label |\n24\t| `Certificate`, `Issuer` | managed-label + ignore-status-update |\n25\t| `ValidatingWebhookConfiguration` | managed-label |\n26\t\n27\tThe \"managed-label predicate\" matches `cert-manager.io/managed-by: cert-manager-trust-manager`.\n28\tOn Update events it checks both old and new objects, so removing the label still triggers\n29\treconciliation. The CNO CA bundle ConfigMap is watched unconditionally by name/namespace\n30\tbecause CNO owns it (it carries no managed label).\n31\t\n32\t## Mutation pipeline\n33\t\n34\t`reconcileTrustManagerDeployment` calls `getDeploymentObject`, which applies a sequential\n35\tchain of named mutate functions to a freshly decoded bindata Deployment:\n36\t\n37\t1. `validateDeploymentManifest` — asserts the expected container name and TLS secret volume\n38\t   are present; returns an `IrrecoverableError` if not, preventing further apply.\n39\t2. `common.UpdateName / UpdateNamespace / UpdateResourceLabels` — sets stable identity fields.\n40\t3. `updateResourceAnnotations`, `updatePodTemplateLabels` — propagates user-provided labels\n41\t   and annotations from `spec.controllerConfig`.\n42\t4. `updateDeploymentArgs` — rebuilds the container arg list from spec fields (logLevel,\n43\t   logFormat, trustNamespace, secretTargets, filterExpiredCertificates, defaultCAPackage).\n44\t5. `updateServiceAccountName`, `updateTLSSecretVolume` — wires up the operator-managed SA\n45\t   and the webhook TLS Secret volume.\n46\t6. `updateDefaultCAPackageVolume` — when `DefaultCAPackage.Policy == Enabled`, adds the\n47\t   CNO-injected ConfigMap volume/mount and stamps the pod template with a hash annotation.\n48\t7. `updateImage`, `updateResourceRequirements`, `updateAffinityRules`, `updatePodTolerations`,\n49\t   `updateNodeSelector` — apply user overrides, each validating before mutating.\n50\t\n51\tOnce built, `createOrApplyDeployment` compares against the live object with `deploymentModified`\n52\t(a field-by-field comparison that deliberately excludes API-server-defaulted probe scalars),\n53\tand skips the apply if nothing changed. Writes use Server-Side Apply via\n54\t`client.Patch(..., client.Apply, client.FieldOwner(fieldOwner), client.ForceOwnership)`.\n55\t\n56\t## ConfigMap hash restart\n57\t\n58\t`updateDefaultCAPackageVolume` hashes the content of the CNO CA bundle ConfigMap and sets it\n59\tas a pod template annotation (`cert-manager.io/ca-bundle-hash`). When CNO rotates the bundle,\n60\tthe predicate on the CNO ConfigMap watch fires, reconciliation runs, the hash changes, and\n61\tKubernetes performs a rolling restart of the Deployment — no manual intervention required.\n62\t\n63\t## OptionalInformer wiring\n64\t\n65\tThe TrustManager controller itself uses direct predicate-based watches rather than\n66\t`OptionalInformer`, because trust-manager is deployed exclusively on OpenShift where the\n67\tCNO-managed CA bundle ConfigMap always exists. The `OptionalInformer` pattern (see\n68\t`optional-informer.md`) is used by the sibling certmanager controller for the OpenShift\n69\tInfrastructure API, which is absent on MicroShift. TrustManager avoids the same complexity\n70\tbecause its only OpenShift-specific dependency (the CA bundle ConfigMap) is filtered by a\n71\tplain name/namespace predicate rather than by API discovery.\n72\t"}]},"parent_tool_use_id":null,"session_id":"4e719bef-a1d9-4ac0-976e-27b5e577da14","uuid":"27787142-f7d3-4b37-97cc-8fa2977fee35","timestamp":"2026-07-20T18:17:47.851Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/agentic/design-docs/components/trustmanager-controller.md","content":"# TrustManager Controller\n\n## What it reconciles\n\nThe TrustManager controller owns the `TrustManager` cluster-scoped singleton CRD\n(`operator.openshift.io/v1alpha1`). When a `TrustManager` CR named `cluster` exists,\nthe controller ensures that the trust-manager operand Deployment and its full supporting\nresource set are present and match the declared spec.\n\n## Resource watch surface (13+ types)\n\n`SetupWithManager` registers watches for:\n\n| Watch target | Predicate |\n|---|---|\n| `TrustManager` (For) | GenerationChangedPredicate |\n| `ServiceAccount` | managed-label predicate |\n| `Deployment` | managed-label + ignore-status-update |\n| `Service` | managed-label |\n| `ConfigMap` (controller-owned) | managed-label |\n| `ConfigMap` (CNO CA bundle) | namespace==operator-ns AND name==trusted-ca-bundle |\n| `ClusterRole`, `ClusterRoleBinding` | managed-label |\n| `Role`, `RoleBinding` | managed-label |\n| `Certificate`, `Issuer` | managed-label + ignore-status-update |\n| `ValidatingWebhookConfiguration` | managed-label |\n\nThe \"managed-label predicate\" matches `cert-manager.io/managed-by: cert-manager-trust-manager`.\nOn Update events it checks both old and new objects, so removing the label still triggers\nreconciliation. The CNO CA bundle ConfigMap is watched unconditionally by name/namespace\nbecause CNO owns it (it carries no managed label).\n\n## Mutation pipeline\n\n`reconcileTrustManagerDeployment` calls `getDeploymentObject`, which applies a sequential\nchain of named mutate functions to a freshly decoded bindata Deployment:\n\n1. `validateDeploymentManifest` — asserts the expected container name and TLS secret volume\n   are present; returns an `IrrecoverableError` if not, preventing further apply.\n2. `common.UpdateName / UpdateNamespace / UpdateResourceLabels` — sets stable identity fields.\n3. `updateResourceAnnotations`, `updatePodTemplateLabels` — propagates user-provided labels\n   and annotations from `spec.controllerConfig`.\n4. `updateDeploymentArgs` — rebuilds the container arg list from spec fields (logLevel,\n   logFormat, trustNamespace, secretTargets, filterExpiredCertificates, defaultCAPackage).\n5. `updateServiceAccountName`, `updateTLSSecretVolume` — wires up the operator-managed SA\n   and the webhook TLS Secret volume.\n6. `updateDefaultCAPackageVolume` — when `DefaultCAPackage.Policy == Enabled`, adds the\n   CNO-injected ConfigMap volume/mount and stamps the pod template with a hash annotation.\n7. `updateImage`, `updateResourceRequirements`, `updateAffinityRules`, `updatePodTolerations`,\n   `updateNodeSelector` — apply user overrides, each validating before mutating.\n\nOnce built, `createOrApplyDeployment` compares against the live object with `deploymentModified`\n(a field-by-field comparison that deliberately excludes API-server-defaulted probe scalars),\nand skips the apply if nothing changed. Writes use Server-Side Apply via\n`client.Patch(..., client.Apply, client.FieldOwner(fieldOwner), client.ForceOwnership)`.\n\n## ConfigMap hash restart\n\n`updateDefaultCAPackageVolume` hashes the content of the CNO CA bundle ConfigMap and sets it\nas a pod template annotation (`cert-manager.io/ca-bundle-hash`). When CNO rotates the bundle,\nthe predicate on the CNO ConfigMap watch fires, reconciliation runs, the hash changes, and\nKubernetes performs a rolling restart of the Deployment — no manual intervention required.\n\n## OptionalInformer wiring\n\nThe TrustManager controller itself uses direct predicate-based watches rather than\n`OptionalInformer`, because trust-manager is deployed exclusively on OpenShift where the\nCNO-managed CA bundle ConfigMap always exists. The `OptionalInformer` pattern (see\n`optional-informer.md`) is used by the sibling certmanager controller for the OpenShift\nInfrastructure API, which is absent on MicroShift. TrustManager avoids the same complexity\nbecause its only OpenShift-specific dependency (the CA bundle ConfigMap) is filtered by a\nplain name/namespace predicate rather than by API discovery.\n","numLines":72,"startLine":1,"totalLines":72}}}

{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01TKzL5hyRaXbSm88GVTFJY3","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\n7\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n8\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n9\t)\n10\t\n11\tfunc (r *Reconciler) reconcileTrustManagerDeployment(trustManager *v1alpha1.TrustManager) error {\n12\t\tif err := validateTrustManagerConfig(trustManager); err != nil {\n13\t\t\treturn common.NewIrrecoverableError(err, \"%s configuration validation failed\", trustManager.GetName())\n14\t\t}\n15\t\n16\t\tresourceLabels := getResourceLabels(trustManager)\n17\t\tresourceAnnotations := getResourceAnnotations(trustManager)\n18\t\n19\t\ttrustNamespace := getTrustNamespace(trustManager)\n20\t\tif err := r.validateTrustNamespace(trustNamespace); err != nil {\n21\t\t\treturn common.NewIrrecoverableError(err, \"trust namespace %q validation failed\", trustNamespace)\n22\t\t}\n23\t\n24\t\tcaBundleHash, err := r.createOrApplyDefaultCAPackageConfigMap(trustManager, resourceLabels, resourceAnnotations)\n25\t\tif err != nil {\n26\t\t\tr.log.Error(err, \"failed to reconcile default CA package ConfigMap\")\n27\t\t\treturn err\n28\t\t}\n29\t\n30\t\tif err := r.createOrApplyServiceAccounts(trustManager, resourceLabels, resourceAnnotations); err != nil {\n31\t\t\tr.log.Error(err, \"failed to reconcile serviceaccount resource\")\n32\t\t\treturn err\n33\t\t}\n34\t\n35\t\tif err := r.createOrApplyRBACResources(trustManager, resourceLabels, resourceAnnotations, trustNamespace); err != nil {\n36\t\t\tr.log.Error(err, \"failed to reconcile RBAC resources\")\n37\t\t\treturn err\n38\t\t}\n39\t\n40\t\tif err := r.createOrApplyServices(trustManager, resourceLabels, resourceAnnotations); err != nil {\n41\t\t\tr.log.Error(err, \"failed to reconcile service resources\")\n42\t\t\treturn err\n43\t\t}\n44\t\n45\t\tif err := r.createOrApplyIssuer(trustManager, resourceLabels, resourceAnnotations); err != nil {\n46\t\t\tr.log.Error(err, \"failed to reconcile issuer resource\")\n47\t\t\treturn err\n48\t\t}\n49\t\n50\t\tif err := r.createOrApplyCertificate(trustManager, resourceLabels, resourceAnnotations); err != nil {\n51\t\t\tr.log.Error(err, \"failed to reconcile certificate resource\")\n52\t\t\treturn err\n53\t\t}\n54\t\n55\t\tif err := r.createOrApplyDeployment(trustManager, resourceLabels, resourceAnnotations, caBundleHash); err != nil {\n56\t\t\tr.log.Error(err, \"failed to reconcile deployment resource\")\n57\t\t\treturn err\n58\t\t}\n59\t\n60\t\tif err := r.createOrApplyValidatingWebhookConfiguration(trustManager, resourceLabels, resourceAnnotations); err != nil {\n61\t\t\tr.log.Error(err, \"failed to reconcile validatingwebhookconfiguration resource\")\n62\t\t\treturn err\n63\t\t}\n64\t\n65\t\tif err := r.updateStatusObservedState(trustManager); err != nil {\n66\t\t\treturn common.FromClientError(err, \"failed to update status observed state\")\n67\t\t}\n68\t\n69\t\tr.log.V(4).Info(\"finished reconciliation of trustmanager\", \"name\", trustManager.GetName())\n70\t\treturn nil\n71\t}\n72\t\n73\t// validateTrustNamespace validates that the trust namespace exists.\n74\tfunc (r *Reconciler) validateTrustNamespace(namespace string) error {\n75\t\texists, err := r.namespaceExists(namespace)\n76\t\tif err != nil {\n77\t\t\treturn fmt.Errorf(\"failed to check if namespace %q exists: %w\", namespace, err)\n78\t\t}\n79\t\tif !exists {\n80\t\t\treturn fmt.Errorf(\"trust namespace %q does not exist, create the namespace before creating TrustManager CR\", namespace)\n81\t\t}\n82\t\treturn nil\n83\t}\n84\t\n85\t// updateStatusObservedState populates and persists the TrustManager status with the observed state.\n86\t// Returns nil if no changes were needed, otherwise returns an error if the update fails.\n87\tfunc (r *Reconciler) updateStatusObservedState(trustManager *v1alpha1.TrustManager) error 
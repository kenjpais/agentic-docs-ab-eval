HTTPSProxy})\n\t}\n\tif proxyConfig.Status.NoProxy != \"\" {\n\t\tenvVars = append(envVars, corev1.EnvVar{Name: \"NO_PROXY\", Value: proxyConfig.Status.NoProxy})\n\t}\n\n\tif len(envVars) == 0 {\n\t\treturn\n\t}\n\n\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == trustManagerContainerName {\n\t\t\texisting := make(map[string]int, len(container.Env))\n\t\t\tfor j, e := range container.Env {\n\t\t\t\texisting[e.Name] = j\n\t\t\t}\n\t\t\tfor _, ev := range envVars {\n\t\t\t\tif j, ok := existing[ev.Name]; ok {\n\t\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].Env[j] = ev\n\t\t\t\t} else {\n\t\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].Env = append(deployment.Spec.Template.Spec.Containers[i].Env, ev)\n\t\t\t\t}\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n}\n```\n\n**Add `Env` comparison to `containerModified` (line 346-349):**\n\nChange:\n```go\n\tif !slices.Equal(desired.Args, existing.Args) ||\n\t\t!reflect.DeepEqual(desired.Resources, existing.Resources) ||\n\t\t!reflect.DeepEqual(desired.SecurityContext, existing.SecurityContext) ||\n\t\t!reflect.DeepEqual(desired.VolumeMounts, existing.VolumeMounts) {\n\t\treturn true\n\t}\n```\n\nTo:\n```go\n\tif !slices.Equal(desired.Args, existing.Args) ||\n\t\t!reflect.DeepEqual(desired.Env, existing.Env) ||\n\t\t!reflect.DeepEqual(desired.Resources, existing.Resources) ||\n\t\t!reflect.DeepEqual(desired.SecurityContext, existing.SecurityContext) ||\n\t\t!reflect.DeepEqual(desired.VolumeMounts, existing.VolumeMounts) {\n\t\treturn true\n\t}\n```\n\n---\n\n## Summary of all changes\n\n| File | Change |\n|---|---|\n| `pkg/operator/utils/apidiscovery.go` | Add `NewProxyInformerIfAvailable` generic helper |\n| `pkg/operator/starter.go` | Create proxy `OptionalInformer`, start its factory, pass it to `ControllerConfig` |\n| `pkg/operator/setup_manager.go` | Add `ProxyInformer` field to `ControllerConfig`, thread to `setupTrustManagerController`, add imports |\n| `pkg/controller/tru
rableError(err, \"invalid istio-csr deployment manifest\")\n\t}\n\n\tcommon.UpdateNamespace(deployment, istiocsr.GetNamespace())\n```\n\n### Full diff for `pkg/controller/istiocsr/deployments.go`:\n\n```diff\n--- a/pkg/controller/istiocsr/deployments.go\n+++ b/pkg/controller/istiocsr/deployments.go\n@@ -76,6 +76,10 @@ func (r *Reconciler) getDeploymentObject(istiocsr *v1alpha1.IstioCSR, resourceLa\n \n \tdeployment := decodeDeploymentObjBytes(assets.MustAsset(deploymentAssetName))\n \n+\tif err := validateDeploymentManifest(deployment); err != nil {\n+\t\treturn nil, common.NewIrrecoverableError(err, \"invalid istio-csr deployment manifest\")\n+\t}\n+\n \tcommon.UpdateNamespace(deployment, istiocsr.GetNamespace())\n \tcommon.UpdateResourceLabels(deployment, resourceLabels)\n \tupdatePodTemplateLabels(deployment, resourceLabels)\n@@ -631,6 +635,22 @@ func (r *Reconciler) updateWatchLabel(obj client.Object, istiocsr *v1alpha1.Isti\n \treturn nil\n }\n \n+// validateDeploymentManifest checks that the bindata deployment contains the\n+// expected container name. Without it, the update helpers silently no-op and\n+// the operator would apply a deployment with stale defaults.\n+func validateDeploymentManifest(deployment *appsv1.Deployment) error {\n+\thasContainer := false\n+\tfor _, c := range deployment.Spec.Template.Spec.Containers {\n+\t\tif c.Name == istiocsrContainerName {\n+\t\t\thasContainer = true\n+\t\t\tbreak\n+\t\t}\n+\t}\n+\tif !hasContainer {\n+\t\treturn fmt.Errorf(\"deployment manifest missing required container %q\", istiocsrContainerName)\n+\t}\n+\n+\treturn nil\n+}\n```\n\n---\n\n## File 2: `pkg/controller/istiocsr/deployments_test.go` — Add table-driven test\n\nAppend the following test at the end of the file (before the closing of the file):\n\n```go\nfunc TestValidateDeploymentManifest(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\tdeployment *appsv1.Deployment\n\t\twantErr    string\n\t}{\n\t\t{\n\t\t\tname:       \"valid manifest from bindata\",\n\t\t\tdeployment: testDeployment(),\n\t\t},\n\t\t{\n\t\t\tname: \"missing required container\",\n\t\t\tdeployment: &appsv1.Deployment{\n\t\t\t\tSpec: appsv1.DeploymentSpec{\n\t\t\t\t\tTemplate: corev1.PodTemplateSpec{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t\t{Name: \"wrong-container\"},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\twantErr: fmt.Sprintf(\"deployment manifest missing required container %q\", istiocsrContainerName),\n\t\t},\n\t\t{\n\t\t\tname: \"empty containers list\",\n\t\t\tdeployment: &appsv1.Deployment{\n\t\t\t\tSpec: appsv1.DeploymentSpec{\n\t\t\t\t\tTemplate: corev1.PodTemplateSpec{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t\twantErr: fmt.Sprintf(\"deployment manifest missing required container %q\", istiocsrContainerName),\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\terr := validateDeploymentManifest(tt.deployment)\n\t\t\tif tt.wantErr != \"\" {\n\t\t\t\tif err == nil {\n\t\t\t\t\tt.Fatalf(\"expected error %q, got nil\", tt.wantErr)\n\t\t\t\t}\n\t\t\t\tif err.Error() != tt.wantErr {\n\t\t\t\t\tt.Errorf(\"error mismatch:\\ngot:  %q\\nwant: %q\", err.Error(), tt.wantErr)\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif err != nil {\n\t\t\t\t\tt.Errorf(\"unexpected error: %v\", err)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n```\n\n---\n\n## Commands to run\n\n```bash\ncd /Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment\n\n# Verify it compiles\ngo build ./pkg/controller/istiocsr/...\n\n# Run the new test\ngo test ./pkg/controller/istiocsr/ -run TestValidateDeploymentManifest -v -count=1\n\n# Run all existing istiocsr tests to confirm no regressions\ngo test ./pkg/controller/istiocsr/ -count=1\n```\n\n---\n\n## Summary\n\nTwo changes:\n\n1. **`pkg/controller/istiocsr/deployments.go`**: 
onfigMap\",\n1039\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n1040\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, ns types.NamespacedName, obj client.Object) (bool, error) {\n1041\t\t\t\t\t\tswitch o := obj.(type) {\n1042\t\t\t\t\t\tcase *appsv1.Deployment:\n1043\t\t\t\t\t\t\tdeployment := testDeployment()\n1044\t\t\t\t\t\t\tdeployment.DeepCopyInto(o)\n1045\t\t\t\t\t\t}\n1046\t\t\t\t\t\treturn true, nil\n1047\t\t\t\t\t})\n1048\t\t\t\t\tm.GetCalls(func(ctx context.Context, ns types.NamespacedName, obj client.Object) error {\n1049\t\t\t\t\t\tswitch o := obj.(type) {\n1050\t\t\t\t\t\tcase *corev1.ConfigMap:\n1051\t\t\t\t\t\t\tif ns.Name == \"ca-without-certsign-test\" {\n1052\t\t\t\t\t\t\t\tconfigMap := testCertificateWithoutCertSignConfigMap()\n1053\t\t\t\t\t\t\t\tconfigMap.DeepCopyInto(o)\n1054\t\t\t\t\t\t\t}\n1055\t\t\t\t\t\t}\n1056\t\t\t\t\t\treturn nil\n1057\t\t\t\t\t})\n1058\t\t\t\t},\n1059\t\t\t\tupdateIstioCSR: func(i *v1alpha1.IstioCSR) {\n1060\t\t\t\t\ti.Status.IstioCSRImage = image\n1061\t\t\t\t\ti.Spec.IstioCSRConfig.CertManager.IstioCACertificate = &v1alpha1.ConfigMapReference{\n1062\t\t\t\t\t\tName: \"ca-without-certsign-test\",\n1063\t\t\t\t\t\tKey:  \"ca-cert.pem\",\n1064\t\t\t\t\t}\n1065\t\t\t\t},\n1066\t\t\t\twantErr: `failed to generate deployment resource for creation in istiocsr-test-ns: failed to update volume istiocsr-test-ns/istiocsr-test-resource: failed to validate and mount CA certificate ConfigMap: invalid PEM data in CA certificate ConfigMap istiocsr-test-ns/ca-without-certsign-test key \"ca-cert.pem\": certificate does not have Certificate Sign key usage`,\n1067\t\t\t},\n1068\t\t}\n1069\t\n1070\t\tfor _, tt := range tests {\n1071\t\t\tt.Run(tt.name, func(t *testing.T) {\n1072\t\t\t\tr := testReconciler(t)\n1073\t\t\t\tmock := &fakes.FakeCtrlClient{}\n1074\t\t\t\tif tt.preReq != nil {\n1075\t\t\t\t\ttt.preReq(r, mock)\n1076\t\t\t\t}\n1077\t\t\t\tr.CtrlClient = mock\n1078\t\t\t\tistiocsr := testIstioCSR()\n1079\t\t\t\tif tt.updateIstioCSR != nil {\n1080\t\t\t\t\ttt.updateIstioCSR(istiocsr)\n1081\t\t\t\t}\n1082\t\t\t\tif !tt.skipEnvVar {\n1083\t\t\t\t\tt.Setenv(\"RELATED_IMAGE_CERT_MANAGER_ISTIOCSR\", image)\n1084\t\t\t\t}\n1085\t\t\t\terr := r.createOrApplyDeployments(istiocsr, controllerDefaultResourceLabels, false)\n1086\t\t\t\tif tt.wantErrSubstring {\n1087\t\t\t\t\tif err == nil || !strings.Contains(err.Error(), tt.wantErr) {\n1088\t\t\t\t\t\tt.Errorf(\"createOrApplyDeployments() err: %v, want substring: %q\", err, tt.wantErr)\n1089\t\t\t\t\t}\n1090\t\t\t\t} else if (tt.wantErr != \"\" || err != nil) && (err == nil || err.Error() != tt.wantErr) {\n1091\t\t\t\t\tt.Errorf(\"createOrApplyDeployments() err: %v, wantErr: %v\", err, tt.wantErr)\n1092\t\t\t\t}\n1093\t\t\t\tif tt.wantErr == \"\" {\n1094\t\t\t\t\tif istiocsr.Status.IstioCSRImage != image {\n1095\t\t\t\t\t\tt.Errorf(\"createOrApplyDeployments() got: %v, want: %v\", istiocsr.Status.IstioCSRImage, image)\n1096\t\t\t\t\t}\n1097\t\t\t\t}\n1098\t\t\t})\n1099\t\t}\n1100\t}\n1101\t\n1102\tfunc TestUpdateArgList(t *testing.T) {\n1103\t\ttests := []struct {\n1104\t\t\tname            string\n1105\t\t\tupdateIstioCSR  func(*v1alpha1.IstioCSR)\n1106\t\t\texpectedArgs    map[string]string // key is arg name (without --), value is expected value\n1107\t\t\tnotExpectedArgs []string          // arg names (without --) that should NOT be present\n1108\t\t}{\n1109\t\t\t{\n1110\t\t\t\tname: \"clusterID not provided should default to Kubernetes\",\n1111\t\t\t\tupdateIstioCSR: func(istiocsr *v1alpha1.IstioCSR) {\n1112\t\t\t\t\t// Server config is nil, so clusterID should default\n1113\t\t\t\t},\n1114\t\t\t\texpectedArgs: map[string]string{\n1115\t\t\t\t\t\"cluster-id\": defaultClusterID,\n1116\t\t\t\t},\n1117\t\t\t},\n1118\t\t\t{\n1119\t\t\t\tname: \"clusterID empty string should default to Kubernetes\",\n1120\t\t\t\tupdateIstioCSR: func(istiocsr *v1alpha1.IstioCSR) {\n1121\t\t\t\t\tistiocsr.Spec.IstioCSRConfig.Server = &v1alpha1.ServerConfig{\n1122\t\t\t\t\t\tClusterID: \"\",\n1123\t\t\t\t\t}\n1124\t\t\t\t},\n1125\t\t\t\texpectedArgs: map[string]string{\n1126\t\t\t\t\t\"cluster-id\": defaultClusterID,\n1127\t\t\t\t},\n1128\t\t\t},\n1129\t\t\t{\n1130\t\t\t\tname: \"clusterID provided should use custom value\",\n1131\t\t\t\tupdateIstioCSR: func(istiocsr *v1alpha1.IstioCSR) {\n1132\t\t\t\t\tistiocsr.Spec.IstioCSRConfig.Server = &v1alpha1.ServerConfig{\n1133\t\t\t\t\t\tClusterID: \"cluster-123_dev.local\",\n1134\t\t\t\t\t}\n1135\t\t\t\t},\n1136\t\t\t\texpectedArgs: map[string]string{\n1137\t\t\t\t\t\"cluster-id\": \"cluster-123_dev.local\",\n1138\t\t\t\t},\n1139\t\t\t},\n1140\t\t\t{\n1141\t\t\t\tname: \"istioDataPlaneNamespaceSelector not provided should not include argument\",\n1142\t\t\t\tnotExpectedArgs: []string{\n1143\t\t\t\t\t\"configmap-namespace-selector\",\n1144\t\t\t\t},\n1145\t\t\t},\n1146\t\t\t{\n1147\t\t\t\tname: \"istioDataPlaneNamespaceSelector provided should include argument\",\n1148\t\t\t\tupdateIstioCSR: func(istiocsr *v1alpha1.IstioCSR) {\n1149\t\t\t\t\tistiocsr.Spec.IstioCSRConfig.IstioDataPlaneNamespaceSelector = \"cert-manager.io/test-ca-injection=enabled\"\n1150\t\t\t\t},\n1151\t\t\t\texpectedArgs: map[string]string{\n1152\t\t\t\t\t\"configmap-namespace-selector\": \"cert-manager.io/test-ca-injection=enabled\",\n1153\t\t\t\t},\n1154\t\t\t},\n1155\t\t}\n1156\t\n1157\t\tfor _, tt := range tests {\n1158\t\t\tt.Run(tt.name, func(t *testing.T) {\n1159\t\t\t\tdeployment := testDeployment()\n1160\t\t\t\tistiocsr := testIstioCSR()\n1161\t\t\t\tif tt.updateIstioCSR != nil {\n1162\t\t\t\t\ttt.updateIstioCSR(istiocsr)\n1163\t\t\t\t}\n1164\t\n1165\t\t\t\tupdateArgList(deployment, istiocsr)\n1166\t\n1167\t\t\t\t// Find the istio-csr container and check its arguments\n1168\t\t\t\tvar containerArgs []string\n1169\t\t\t\tfor _, container := range deployment.Spec.Template.Spec.Containers {\n1170\t\t\t\t\tif container.Name == istiocsrContainerName {\n1171\t\t\t\t\t\tcontainerArgs = container.Args\n1172\t\t\t\t\t\tbreak\n1173\t\t\t\t\t}\n1174\t\t\t\t}\n1175\t\n1176\t\t\t\tif len(containerArgs) == 0 {\n1177\t\t\t\t\tt.Fatalf(\"Expected container args to be set, but got empty args\")\n1178\t\t\t\t}\n1179\t\n1180\t\t\t\t// Verify each expected argument\n1181\t\t\t\tfor argName, expectedValue := range tt.expectedArgs {\n1182\t\t\t\t\texpectedArg := fmt.Sprintf(\"--%s=%s\", argName, expectedValue)\n1183\t\t\t\t\tif !containsArg(containerArgs, expectedArg) {\n1184\t\t\t\t\t\tt.Errorf(\"Expected to find argument %q in container args, but it was not found. Args: %v\", expectedArg, containerArgs)\n1185\t\t\t\t\t}\n1186\t\t\t\t}\n1187\t\n1188\t\t\t\t// Verify arguments that should NOT be present\n1189\t\t\t\tfor _, argName := range tt.notExpectedArgs {\n1190\t\t\t\t\tfor _, arg := range containerArgs {\n1191\t\t\t\t\t\tif strings.HasPrefix(arg, fmt.Sprintf(\"--%s=\", argName)) {\n1192\t\t\t\t\t\t\tt.Errorf(\"Expected NOT to find argument %q in container args. Args: %v\", arg, containerArgs)\n1193\t\t\t\t\t\t\tbreak\n1194\t\t\t\t\t\t}\n1195\t\t\t\t\t}\n1196\t\t\t\t}\n1197\t\t\t})\n1198\t\t}\n1199\t}\n1200\t\n1201\t// containsArg checks if the given argument is present in the args list.\n1202\tfunc containsArg(args []string, targetArg string) bool {\n1203\t\treturn slices.Contains(args, targetArg)\n1204\t}\n1205\t\n1206\tfunc TestUpdateVolumeWithIssuerCA(t *testing.T) {\n1207\t\tdefaultMode := int32(420)\n1208\t\texpectedCAVolume := corev1.Volume{\n1209\t\t\tName: \"root-ca\",\n1210\t\t\tVolumeSource: corev1.VolumeSource{\n1211\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n1212\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n1213\t\t\t\t\t\tName: \"cert-manager-istio-csr-issuer-ca-copy\",\n1214\t\t\t\t\t},\n1215\t\t\t\t\tItems: []corev1.KeyToPath{\n1216\t\t\t\t\t\t{\n1217\t\t\t\t\t\t\tKey:  \"ca.crt\",\n1218\t\t\t\t\t\t\tPath: \"ca.crt\",\n1219\t\t\t\t\t\t\tMode: &defaultMode,\n1220\t\t\t\t\t\t},\n1221\t\t\t\t\t},\n1222\t\t\t\t\tDefaultMode: &defaultMode,\
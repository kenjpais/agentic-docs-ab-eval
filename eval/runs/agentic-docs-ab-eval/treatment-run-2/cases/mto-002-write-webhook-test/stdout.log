{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01B1qjqRvrrM4WeQS3ybtcGp","type":"tool_result","content":"130\t\t}\n131\t}\n132\t\n133\t// HasControlPlaneNodeSelector returns true if the pod has a node selector that matches the control plane nodes.\n134\tfunc (pod *Pod) HasControlPlaneNodeSelector() bool {\n135\t\tif pod.Spec.NodeSelector == nil {\n136\t\t\treturn false\n137\t\t}\n138\t\trequiredSelectors := []string{utils.MasterNodeSelectorLabel, utils.ControlPlaneNodeSelectorLabel}\n139\t\tfor _, value := range requiredSelectors {\n140\t\t\tif _, ok := pod.Spec.NodeSelector[value]; ok {\n141\t\t\t\treturn true\n142\t\t\t}\n143\t\t}\n144\t\treturn false\n145\t}\n146\t\n147\t// IsFromDaemonSet returns true if the pod is from a daemonSet.\n148\tfunc (pod *Pod) IsFromDaemonSet() bool {\n149\t\t// Check all ownerRef\n150\t\tfor _, ownerRef := range pod.OwnerReferences {\n151\t\t\tif ownerRef.Kind == \"DaemonSet\" && ownerRef.Controller != nil && *ownerRef.Controller {\n152\t\t\t\treturn true\n153\t\t\t}\n154\t\t}\n155\t\treturn false\n156\t}\n157\t\n158\tfunc (pod *Pod) ContainerNameFor(containerID string) (string, error) {\n159\t\t// The containerID is in the format: \"runtime://<64-hex-chars>\"\n160\t\tmatched, err := regexp.MatchString(`^.+://[a-f0-9]{64}$`, containerID)\n161\t\tif err != nil || !matched {\n162\t\t\treturn \"\", fmt.Errorf(\"invalid container ID format: %s\", containerID)\n163\t\t}\n164\t\tfor _, container := range pod.PodObject().Status.ContainerStatuses {\n165\t\t\tif container.ContainerID == containerID {\n166\t\t\t\treturn container.Name, nil\n167\t\t\t}\n168\t\t}\n169\t\treturn \"\", fmt.Errorf(\"container with ID %s not found in pod %s\", containerID, pod.Name)"}]},"parent_tool_use_id":null,"session_id":"08825ee3-2822-4cb7-9a97-2ce6ebb55753","uuid":"c89edca5-23cc-42a2-a261-8a92b72d6757","timestamp":"2026-07-20T13:33:14.384Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/multiarch-tuning-operator-treatment/pkg/models/pod.go","content":"\t}\n}\n\n// HasControlPlaneNodeSelector returns true if the pod has a node selector that matches the control plane nodes.\nfunc (pod *Pod) HasControlPlaneNodeSelector() bool {\n\tif pod.Spec.NodeSelector == nil {\n\t\treturn false\n\t}\n\trequiredSelectors := []string{utils.MasterNodeSelectorLabel, utils.ControlPlaneNodeSelectorLabel}\n\tfor _, value := range requiredSelectors {\n\t\tif _, ok := pod.Spec.NodeSelector[value]; ok {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// IsFromDaemonSet returns true if the pod is from a daemonSet.\nfunc (pod *Pod) IsFromDaemonSet() bool {\n\t// Check all ownerRef\n\tfor _, ownerRef := range pod.OwnerReferences {\n\t\tif ownerRef.Kind == \"DaemonSet\" && ownerRef.Controller != nil && *ownerRef.Controller {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nfunc (pod *Pod) ContainerNameFor(containerID string) (string, error) {\n\t// The containerID is in the format: \"runtime://<64-hex-chars>\"\n\tmatched, err := regexp.MatchString(`^.+://[a-f0-9]{64}$`, containerID)\n\tif err != nil || !matched {\n\t\treturn \"\", fmt.Errorf(\"invalid container ID format: %s\", containerID)\n\t}\n\tfor _, container := range pod.PodObject().Status.ContainerStatuses {\n\t\tif container.ContainerID == containerID {\n\t\t\treturn container.Name, nil\n\t\t}\n\t}\n\treturn \"\", fmt.Errorf(\"container with ID %s not found in pod %s\", containerID, pod.Name)","numLines":40,"startLine":130,"totalLines":171}}}

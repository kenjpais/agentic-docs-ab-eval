t-kube-apiserver` namespace exists. I can either create it in the test or check if it needs to be created in BeforeSuite. Let me check the existing approach for the `test-namespace` namespace.\n\nThe `seedK8S` function creates `openshift-config` and `test-namespace` namespaces in BeforeSuite. I'll create the `openshift-kube-apiserver` namespace in my test Context.\n\nNow let me write the complete implementation.\n\nHere is the complete implementation:\n\n---\n\n## File to modify\n\n**`internal/controller/podplacement/scheduling_gate_mutating_webhook_test.go`**\n\nReplace the entire file content with:\n\n```go\npackage podplacement\n\nimport (\n\t\"fmt\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\n\timgspecv1 \"github.com/opencontainers/image-spec/specs-go/v1\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\tcrclient \"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/testing/builder\"\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/testing/image/fake/registry\"\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/utils\"\n)\n\nvar _ = Describe(\"Internal/Controller/PodPlacement/scheduling_gate_mutating_webhook\", func() {\n\tWhen(\"The scheduling gat mutating webhook\", func() {\n\t\tContext(\"is handling the mutation of pods\", func() {\n\t\t\tIt(\"should ignore pods with a non-empty nodeName\", func() {\n\t\t\t\tpod := builder.NewPod().\n\t\t\t\t\tWithContainersImages(fmt.Sprintf(\"%s/%s/%s:latest\", registryAddress,\n\t\t\t\t\t\tregistry.PublicRepo, registry.ComputeNameByMediaType(imgspecv1.MediaTypeImageIndex))).\n\t\t\t\t\tWithGenerateName(\"test-pod-\").\n\t\t\t\t\tWithNamespace(\"test-namespace\").\n\t\t\t\t\tWithNodeName(\"test-node-name\").\n\t\t\t\t\tBuild()\n\t\t\t\terr := k8sClient.Create(ctx, pod)\n\t\t\t\tExpect(err).NotTo(HaveOccurred(), \"failed to create the pod\", err)\n\t\t\t})\n\t\t})\n\t\tContext(\"a pod is created in the openshift-kube-apiserver namespace\", func() {\n\t\t\tBeforeEach(func() {\n\t\t\t\tns := &corev1.Namespace{\n\t\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\t\tName: \"openshift-kube-apiserver\",\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t\terr := k8sClient.Create(ctx, ns)\n\t\t\t\tif err != nil {\n\t\t\t\t\tExpect(crclient.IgnoreAlreadyExists(err)).NotTo(HaveOccurred())\n\t\t\t\t}\n\t\t\t})\n\t\t\tIt(\"should not add the scheduling gate even when the CPPC namespaceSelector matches all namespaces\", func() {\n\t\t\t\tpod := builder.NewPod().\n\t\t\t\t\tWithContainersImages(fmt.Sprintf(\"%s/%s/%s:latest\", registryAddress,\n\t\t\t\t\t\tregistry.PublicRepo, registry.ComputeNameByMediaType(imgspecv1.MediaTypeImageIndex))).\n\t\t\t\t\tWithGenerateName(\"test-pod-\").\n\t\t\t\t\tWithNamespace(\"openshift-kube-apiserver\").\n\t\t\t\t\tWithNodeName(\"control-plane-node\").\n\t\t\t\t\tBuild()\n\t\t\t\terr := k8sClient.Create(ctx, pod)\n\t\t\t\tExpect(err).NotTo(HaveOccurred(), \"failed to create the pod\", err)\n\t\t\t\tEventually(func(g Gomega) {\n\t\t\t\t\terr := k8sClient.Get(ctx, crclient.ObjectKeyFromObject(pod), pod)\n\t\t\t\t\tg.Expect(err).NotTo(HaveOccurred(), \"failed to get pod\", err)\n\t\t\t\t\tg.Expect(pod.Spec.SchedulingGates).NotTo(ContainElement(corev1.PodSchedulingGate{\n\t\t\t\t\t\tName: utils.SchedulingGateName,\n\t\t\t\t\t}), \"scheduling gate should not be added for pods in openshift-kube-apiserver\")\n\t\t\t\t\tg.Expect(pod.Labels).NotTo(HaveKeyWithValue(utils.SchedulingGateLabel, utils.SchedulingGateLabelValueGated),\n\t\t\t\t\t\t\"scheduling gate label should not be set to gated\")\n\t\t\t\t}).Should(Succeed(), \"pod in openshift-kube-apiserver should not have the scheduling gate\")\n\t\t\t})\n\t\t})\n\t})\n})\n```\n\n---\n\n## Explanation of changes\n\n**What changed:** Added a new `Context` block inside the existing `When(\"The scheduling gat mutating webhook\"` block. The new context:\n\n1. **`BeforeEach`** — Creates the `openshift-kube-apiserver`
LabelSelector `json:\"namespaceSelector,omitempty\"`\n46\t\n47\t\t// Plugins defines the configurable plugins for this component.\n48\t\t// This field is optional and will be omitted from the output if not set.\n49\t\t// +optional\n50\t\tPlugins *plugins.Plugins `json:\"plugins,omitempty\"`\n51\t\n52\t\t// FallbackArchitecture defines the architecture to use if the image inspector cannot determine the image's architecture.\n53\t\t// If configured, the PodPlacementController will set the node affinity of the pod to the fallback architecture\n54\t\t// if the image inspector cannot determine the image's architecture.\n55\t\t// +optional\n56\t\t// +kubebuilder:default=\"\"\n57\t\t// +kubebuilder:validation:Enum=arm64;amd64;ppc64le;s390x;\"\"\n58\t\tFallbackArchitecture string `json:\"fallbackArchitecture,omitempty\"`\n59\t}\n60\t\n61\t// ClusterPodPlacementConfigStatus defines the observed state of ClusterPodPlacementConfig\n62\ttype ClusterPodPlacementConfigStatus struct {\n63\t\t// Conditions represents the latest available observations of a ClusterPodPlacementConfig's current state.\n64\t\tConditions []metav1.Condition `json:\"conditions,omitempty\"`\n65\t\n66\t\t// The following fields are used to derive the conditions. They are not exposed to the user.\n67\t\t//nolint:revive // controller-gen requires json tags on all fields, even unexported ones\n68\t\tavailable                                bool `json:\"-\"`\n69\t\tprogressing                              bool `json:\"-\"`\n70\t\tdegraded                                 bool `json:\"-\"`\n71\t\tdeprovisioning                           bool `json:\"-\"`\n72\t\tpodPlacementControllerNotReady           bool `json:\"-\"`\n73\t\tpodPlacementWebhookNotReady              bool `json:\"-\"`\n74\t\tmutatingWebhookConfigurationNotAvailable bool `json:\"-\"`\n75\t\tcanDeployMutatingWebhook                 bool `json:\"-\"`\n76\t}\n77\t\n78\tfunc (s *ClusterPodPlacementConfigStatus) IsReady() bool {\n79\t\treturn s.available
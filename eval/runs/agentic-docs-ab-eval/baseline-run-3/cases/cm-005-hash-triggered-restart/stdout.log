eed without the hash annotation.\nfunc (r *Reconciler) computeTrustedCABundleHash() (string, error) {\n\tcaBundle, err := r.readTrustedCABundle()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn computeCABundleHash(caBundle), nil\n}\n```\n\nSo the complete `configmaps.go` file is:\n\n```go\npackage istiocsr\n\nimport (\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"fmt\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n)\n\n// computeTrustedCABundleHash reads the CNO-injected CA bundle and returns its\n// SHA-256 content hash.\nfunc (r *Reconciler) computeTrustedCABundleHash() (string, error) {\n\tcaBundle, err := r.readTrustedCABundle()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn computeCABundleHash(caBundle), nil\n}\n\n// readTrustedCABundle reads the CNO-injected CA bundle from the operator namespace.\n// Returns the PEM bundle and any error.\nfunc (r *Reconciler) readTrustedCABundle() (string, error) {\n\tinjectionCM := &corev1.ConfigMap{}\n\tkey := client.ObjectKey{\n\t\tNamespace: common.OperatorNamespace,\n\t\tName:      common.TrustedCABundleConfigMapName,\n\t}\n\tif err := r.Get(r.ctx, key, injectionCM); err != nil {\n\t\treturn \"\", common.FromClientError(\n\t\t\terr,\n\t\t\t\"failed to read CA bundle ConfigMap %q in namespace %q\",\n\t\t\tcommon.TrustedCABundleConfigMapName, common.OperatorNamespace,\n\t\t)\n\t}\n\n\tcaBundle, ok := injectionCM.Data[common.TrustedCABundleKey]\n\tif !ok || caBundle == \"\" {\n\t\treturn \"\", common.FromClientError(\n\t\t\tfmt.Errorf(\"CA bundle ConfigMap %q does not contain key %q\",\n\t\t\t\tcommon.TrustedCABundleConfigMapName, common.TrustedCABundleKey),\n\t\t\t\"missing key %q in ConfigMap %q\",\n\t\t\tcommon.TrustedCABundleKey, common.TrustedCABundleConfigMapName,\n\t\t)\n\t}\n\n\treturn caBundle, nil\n}\n\n// computeCABundleHash returns the SHA-256 hash of the CA bundle PEM content.\n// The hash is used as the pod template annotation to trigger rolling restarts\n// only when the actual certificate content changes.\nfunc computeCABundleHash(caBundle string) string {\n\thash := sha256.Sum256([]byte(caBundle))\n\treturn hex.EncodeToString(hash[:])\n}\n```\n\n---\n\n### 4. Modified: `pkg/controller/istiocsr/deployments.go`\n\n**Change 1** — `createOrApplyDeployments` signature gains `caBundleHash string`:\n\n```diff\n-func (r *Reconciler) createOrApplyDeployments(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, istioCSRCreateRecon bool) error {\n-\tdesired, err := r.getDeploymentObject(istiocsr, resourceLabels)\n+func (r *Reconciler) createOrApplyDeployments(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, istioCSRCreateRecon bool, caBundleHash string) error {\n+\tdesired, err := r.getDeploymentObject(istiocsr, resourceLabels, caBundleHash)\n```\n\n**Change 2** — `getDeploymentObject` signature gains `caBundleHash string`, and stamps it after building the deployment:\n\n```diff\n-func (r *Reconciler) getDeploymentObject(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) (*appsv1.Deployment, error) {\n+func (r *Reconciler) getDeploymentObject(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, caBundleHash string) (*appsv1.Deployment, error) {\n```\n\nAdd the following call at the end of `getDeploymentObject`, just before the `return deployment, nil` (after `updateVolumes`):\n\n```diff\n \tif err := r.updateVolumes(deployment, istiocsr, resourceLabels); err != nil {\n \t\treturn nil, fmt.Errorf(\"failed to update volume %s/%s: %w\", istiocsr.GetNamespace(), istiocsr.GetName(), err)\n \t}\n \n+\tstampCABundleHash(deployment, caBundleHash)\n+\n \treturn deployment, nil\n }\n```\n\n**Change 3** — Add the `stampCABundleHash` function at the end of `deployments.go`:\n\n```go\n// stampCABundleHash sets the CA bundle content hash as a pod template annotation\n// on the deployment. Changing this annotation value triggers a rolling restart\n// because Kubernetes treats it as a pod template spec change.\nfunc stampCABundleHash(deployment *appsv1.Deployment, caBundleHash string) {\n\tif caBundleHash == \"\" {\n\t\treturn\n\t}\n\tif deployment.Spec.Template.Annotations == nil {\n\t\tdeployment.Spec.Template.Annotations = make(map[string]string)\n\t}\n\tdeployment.Spec.Template.Annotations[caBundleHashAnnotation] = caBundleHash\n}\n```\n\n---\n\n### 5. Modified: `pkg/controller/istiocsr/utils.go`\n\nAdd the pod template annotation comparison to `deploymentSpecModified`. This is the **idempotency guard**: when the hash hasn't changed, the annotation is the same, so the deployment is not considered modified and the update is skipped.\n\nIn `deploymentSpecModified`, after the pod template labels check (line 316) add the annotations check:\n\n```diff\n \tif !reflect.DeepEqual(desired.Spec.Template.Labels, fetched.Spec.Template.Labels) ||\n \t\tlen(desired.Spec.Template.Spec.Containers) != len(fetched.Spec.Template.Spec.Containers) {\n \t\treturn true\n \t}\n \n+\tif podTemplateAnnotationChanged(desired, fetched, caBundleHashAnnotation) {\n+\t\treturn true\n+\t}\n+\n```\n\nAdd the helper function (e.g., after `deploymentSpecModified`):\n\n```go\n// podTemplateAnnotationChanged checks whether a specific annotation on the pod\n// template differs between the desired and fetched deployments.\nfunc podTemplateAnnotationChanged(desired, fetched *appsv1.Deployment, key string) bool {\n\tdesiredVal := desired.Spec.Template.Annotations[key]\n\tfetchedVal := fetched.Spec.Template.Annotations[key]\n\treturn desiredVal != fetchedVal\n}\n```\n\n---\n\n### 6. Modified: `pkg/controller/istiocsr/controller.go`\n\nAdd a watch for the CNO-injected CA bundle ConfigMap so changes to it trigger reconciliation.\n\n**Change 1** — Add a `caBundleMapFunc` and predicate inside `SetupWithManager`, before the `return ctrl.NewControllerManagedBy(mgr).`:\n\n```go\n\t// mapFunc for CNO-injected CA bundle ConfigMap
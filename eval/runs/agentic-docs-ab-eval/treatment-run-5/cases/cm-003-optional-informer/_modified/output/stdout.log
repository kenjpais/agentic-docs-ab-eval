inalizers`,\n98\t\t\t},\n99\t\t\t{\n100\t\t\t\tname: \"status update failure\",\n101\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n102\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n103\t\t\t\t\t\tswitch o := obj.(type) {\n104\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n105\t\t\t\t\t\t\ttm := testTrustManager().Build()\n106\t\t\t\t\t\t\ttm.Spec.TrustManagerConfig = v1alpha1.TrustManagerConfig{}\n107\t\t\t\t\t\t\ttm.Finalizers = []string{finalizer}\n108\t\t\t\t\t\t\ttm.DeepCopyInto(o)\n109\t\t\t\t\t\t}\n110\t\t\t\t\t\treturn nil\n111\t\t\t\t\t})\n112\t\t\t\t\tm.StatusUpdateCalls(func(ctx context.Context, obj client.Object, opts ...client.SubResourceUpdateOption) error {\n113\t\t\t\t\t\treturn apierrors.NewBadRequest(\"test error\")\n114\t\t\t\t\t})\n115\t\t\t\t},\n116\t\t\t\twantErr: \"failed to update cluster status\",\n117\t\t\t},\n118\t\t}\n119\t\n120\t\tfor _, tt := range tests {\n121\t\t\tt.Run(tt.name, func(t *testing.T) {\n122\t\t\t\tr := testReconciler(t)\n123\t\t\t\tmock := &fakes.FakeCtrlClient{}\n124\t\t\t\tif tt.preReq != nil {\n125\t\t\t\t\ttt.preReq(r, mock)\n126\t\t\t\t}\n127\t\t\t\tr.CtrlClient = mock\n128\t\n129\t\t\t\t_, err := r.Reconcile(context.Background(),\n130\t\t\t\t\tctrl.Request{\n131\t\t\t\t\t\tNamespacedName: types.NamespacedName{Name: trustManagerObjectName},\n132\t\t\t\t\t},\n133\t\t\t\t)\n134\t\t\t\tassertError(t, err, tt.wantErr)\n135\t\t\t})\n136\t\t}\n137\t}\n138\t\n139\tfunc TestProcessReconcileRequest(t *testing.T) {\n140\t\tt.Setenv(trustManagerImageNameEnvVarName, testImage)\n141\t\n142\t\ttests := []struct {\n143\t\t\tname            string\n144\t\t\tgetTrustManager func() *v1alpha1.TrustManager\n145\t\t\tpreReq          func(*Reconciler, *fakes.FakeCtrlClient)\n146\t\t\twantConditions  []metav1.Condition\n147\t\t\twantErr         string\n148\t\t}{\n149\t\t\t{\n150\t\t\t\tname: \"successful reconciliation sets ready true\",\n151\t\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n152\t\t\t\t\treturn testTrustManager().Build()\n153\t\t\t\t},\n154\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n155\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n156\t\t\t\t\t\tswitch o := obj.(type) {\n157\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n158\t\t\t\t\t\t\ttestTrustManager().Build().DeepCopyInto(o)\n159\t\t\t\t\t\t}\n160\t\t\t\t\t\treturn nil\n161\t\t\t\t\t})\n162\t\t\t\t\t// Namespace exists; all other resources return not-found so they\n163\t\t\t\t\t// are created via SSA Patch (which succeeds by default).\n164\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n165\t\t\t\t\t\tswitch obj.(type) {\n166\t\t\t\t\t\tcase *corev1.Namespace:\n167\t\t\t\t\t\t\treturn true, nil\n168\t\t\t\t\t\t}\n169\t\t\t\t\t\treturn false, nil\n170\t\t\t\t\t})\n171\t\t\t\t},\n172\t\t\t\twantConditions: []metav1.Condition{\n173\t\t\t\t\t{\n174\t\t\t\t\t\tType:   v1alpha1.Degraded,\n175\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n176\t\t\t\t\t\tReason: v1alpha1.ReasonReady,\n177\t\t\t\t\t},\n178\t\t\t\t\t{\n179\t\t\t\t\t\tType:    v1alpha1.Ready,\n180\t\t\t\t\t\tStatus:  metav1.ConditionTrue,\n181\t\t\t\t\t\tReason:  v1alpha1.ReasonReady,\n182\t\t\t\t\t\tMessage: \"reconciliation successful\",\n183\t\t\t\t\t},\n184\t\t\t\t},\n185\t\t\t},\n186\t\t\t{\n187\t\t\t\tname: \"irrecoverable error sets degraded true\",\n188\t\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n189\t\t\t\t\t// Empty TrustManagerConfig triggers validateTrustManagerConfig failure,\n190\t\t\t\t\t// which is wrapped as an irrecoverable error in reconcileTrustManagerDeployment.\n191\t\t\t\t\ttm := testTrustManager().Build()\n192\t\t\t\t\ttm.Spec.TrustManagerConfig = v1alpha1.TrustManagerConfig{}\n193\t\t\t\t\treturn tm\n194\t\t\t\t},\n195\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n196\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n197\t\t\t\t\t\tswitch o := obj.(type) {\n198\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n199\t\t\t\t\t\t\ttm := testTrustManager().Build()\n200\t\t\t\t\t\t\ttm.Spec.TrustManagerConfig = v1alpha1.TrustManagerConfig{}\n201\t\t\t\t\t\t\ttm.DeepCopyInto(o)\n202\t\t\t\t\t\t}\n203\t\t\t\t\t\treturn nil\n204\t\t\t\t\t})\n205\t\t\t\t},\n206\t\t\t\twantConditions: []metav1.Condition{\n207\t\t\t\t\t{\n208\t\t\t\t\t\tType:   v1alpha1.Degraded,\n209\t\t\t\t\t\tStatus: metav1.ConditionTrue,\n210\t\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n211\t\t\t\t\t},\n212\t\t\t\t\t{\n213\t\t\t\t\t\tType:   v1alpha1.Ready,\n214\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n215\t\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n216\t\t\t\t\t},\n217\t\t\t\t},\n218\t\t\t},\n219\t\t\t{\n220\t\t\t\tname: \"recoverable error sets in progress\",\n221\t\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n222\t\t\t\t\treturn testTrustManager().Build()\n223\t\t\t\t},\n224\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n225\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n226\t\t\t\t\t\tswitch o := obj.(type) {\n227\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n228\t\t\t\t\t\t\ttestTrustManager().Build().DeepCopyInto(o)\n229\t\t\t\t\t\t}\n230\t\t\t\t\t\treturn nil\n231\t\t\t\t\t})\n232\t\t\t\t\t// Namespace Exists succeeds (passes validateTrustNamespace), but\n233\t\t\t\t\t// ServiceAccount Exists returns a FromClientError\n234\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n235\t\t\t\t\t\tswitch obj.(type) {\n236\t\t\t\t\t\tcase *corev1.Namespace:\n237\t\t\t\t\t\t\treturn true, nil\n238\t\t\t\t\t\t}\n239\t\t\t\t\t\treturn false, errTestClient\n240\t\t\t\t\t})\n241\t\t\t\t},\n242\t\t\t\twantConditions: []metav1.Condition{\n243\t\t\t\t\t{\n244\t\t\t\t\t\tType:   v1alpha1.Degraded,\n245\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n246\t\t\t\t\t\tReason: v1alpha1.ReasonReady,\n247\t\t\t\t\t},\n248\t\t\t\t\t{\n249\t\t\t\t\t\tType:   v1alpha1.Ready,\n250\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n251\t\t\t\t\t\tReason: v1alpha1.ReasonInProgress,\n252\t\t\t\t\t},\n253\t\t\t\t},\n254\t\t\t\twantErr: \"failed to check if serviceaccount\",\n255\t\t\t},\n256\t\t\t{\n257\t\t\t\tname: \"trust namespace does not exist sets degraded true\",\n258\t\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n259\t\t\t\t\treturn testTrustManager().Build()\n260\t\t\t\t},\n261\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n262\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n263\t\t\t\t\t\tswitch o := obj.(type) {\n264\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n265\t\t\t\t\t\t\ttestTrustManager().Build().DeepCopyInto(o)\n266\t\t\t\t\t\t}\n267\t\t\t\t\t\treturn nil\n268\t\t\t\t\t})\n269\t\t\t\t\t// Namespace does not exist - validateTrustNamespace will fail\n270\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n271\t\t\t\t\t\tswitch obj.(type) {\n272\t\t\t\t\t\tcase *corev1.Namespace:\n273\t\t\t\t\t\t\treturn false, nil\n274\t\t\t\t\t\t}\n275\t\t\t\t\t\treturn false, nil\n276\t\t\t\t\t})\n277\t\t\t\t},\n278\t\t\t\twantConditions: []metav1.Condition{\n279\t\t\t\t\t{\n280\t\t\t\t\t\tType:   v1alpha1.Degraded,\n281\t\t\t\t\t\tStatus: metav1.ConditionTrue,\n282\t\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n283\t\t\t\t\t\tMessage: fmt.Sprintf(\n284\t\t\t\t\t\t\t\"reconciliation failed with irrecoverable error not retrying: trust namespace %q validation failed: trust namespace %q does not exist, create the namespace before creating TrustManager CR\",\n285\t\t\t\t\t\t\tdefaultTrustNamespace,\n286\t\t\t\t\t\t\tdefaultTrustNamespace,\n287\t\t\t\t\t\t),\n288\t\t\t\t\t},\n289\t\t\t\t\t{\n290\t\t\t\t\t\tType:   v1alpha1.Ready,\n291\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n292\t\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n293\t\t\t\t\t},\n294\t\t\t\t},\n295\t\t\t},\n296\t\t\t{\n297\t\t\t\tname: \"custom trust namespace configures resources correctly\",\n298\t\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n299\t\t\t\t\ttm := testTrustManager().Build()\n300\t\t\t\t\ttm.Spec.TrustManagerConfig.TrustNamespace = \"custom-trust-ns\"\n301\t\t\t\t\treturn tm\n302\t\t\t\t},\n303\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n304\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n305\t\t\t\t\t\tswitch o := obj.(type) {\n306\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n307\t\t\t\t\t\t\ttm := testTrustManager().Build()\n308\t\t\t\t\t\t\ttm.Spec.TrustManagerConfig.TrustNamespace = \"custom-trust-ns\"\n309\t\t\t\t\t\t\ttm.DeepCopyInto(o)\n310\t\t\t\t\t\t}\n311\t\t\t\t\t\treturn nil\n312\t\t\t\t\t})\n313\t\t\t\t\t// Custom namespace exists; so SSA Patch will create or update all resources successfully.\n314\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n315\t\t\t\t\t\tswitch obj.(type) {\n316\t\t\t\t\t\tcase *corev1.Namespace:\n317\t\t\t\t\t\t\treturn true, nil\n318\t\t\t\t\t\t}\n319\t\t\t\t\t\treturn false, nil\n320\t\t\t\t\t})\n321\t\t\t\t},\n322\t\t\t\twantConditions: []metav1.Condition{\n323\t\t\t\t\t{\n324\t\t\t\t\t\tType:   v1alpha1.Degraded,\n325\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n326\t\t\t\t\t\tReason: v1alpha1.ReasonReady,\n327\t\t\t\t\t},\n328\t\t\t\t\t{\n329\t\t\t\t\t\tType:    v1alpha1.Ready,\n330\t\t\t\t\t\tStatus:  metav1.ConditionTrue,\n331\t\t\t\t\t\tReason:  v1alpha1.ReasonReady,\n332\t\t\t\t\t\tMessage: \"reconciliation successful\",\n333\t\t\t\t\t},\n334\t\t\t\t},\n335\t\t\t},\n336\t\t}\n337\t\n338\t\tfor _, tt := range tests {\n339\t\t\tt.Run(tt.name, func(t *testing.T) {\n340\t\t\t\tr := testReconciler(t)\n341\t\t\t\tmock := &fakes.FakeCtrlClient{}\n342\t\t\t\tif tt.preReq != nil {\n343\t\t\t\t\ttt.preReq(r, mock)\n344\t\t\t\t}\n345\t\t\t\tr.CtrlClient = mock\n346\t\n347\t\t\t\ttm := tt.getTrustManager()\n348\t\t\t\t_, err := r.processReconcileRequest(tm, types.NamespacedName{Name: tm.GetName()})\n349\t\t\t\tassertError(t, err, tt.wantErr)\n350\t\n351\t\t\t\tfor _, want := range tt.wantConditions {\n352\t\t\t\t\tfound := false\n353\t\t\t\t\tfor _, got := range tm.Status.Conditions {\n354\t\t\t\t\t\tif got.Type == want.Type {\n355\t\t\t\t\t\t\tfound = true\n356\t\t\t\t\t\t\tif got.Status != want.Status {\n357\t\t\t\t\t\t\t\tt.Errorf(\"condition %s: expected status %s, got %s\", want.Type, want.Status, got.Status)\n358\t\t\t\t\t\t\t}\n359\t\t\t\t\t\t\tif got.Reason != want.Reason {\n360\t\t\t\t\t\t\t\tt.Errorf(\"condition %s: expected reason %s, got %s\", want.Type, want.Reason, got.Reason)\n361\t\t\t\t\t\t\t}\n362\t\t\t\t\t\t\tif want.Message != \"\" && got.Message != want.Message {\n363\t\t\t\t\t\t\t\tt.Errorf(\"condition %s: expected message %q, got %q\", want.Type, want.Message, got.Message)\n364\t\t\t\t\t\t\t}\n365\t\t\t\t\t\t}\n366\t\t\t\t\t}\n367\t\t\t\t\tif !found {\n368\t\t\t\t\t\tt.Errorf(\"expected condition %s not found in status conditions %v\", want.Type, tm.Status.Conditions)\n369\t\t\t\t\t}\n370\t\t\t\t}\n371\t\t\t})\n372\t\t}\n373\t}\n374\t\n375\tfunc TestCleanUp(t *testing.T) {\n376\t\ttests := []struct {\n377\t\t\tname         string\n378\t\t\ttrustManager *v1alpha1.TrustManager\n379\t\t\twantRequeue  bool\n380\t\t\twantErr      bool\n381\t\t}{\n382\t\t\t{\n383\t\t\t\tname: \"returns false and nil\",\n384\t\t\t\ttrustManager: &v1alpha1.TrustManager{\n385\t\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"cluster\"},\n386\t\t\t\t},\n387\t\t\t\twantRequeue: false,\n388\t\t\t\twantErr:     false,\n389\t\t\t},\n390\t\t}\n391\t\tfor _, tt := range tests {\n392\t\t\tt.Run(tt.name, func(t *testing.T) {\n393\t\t\t\tr := &Reconciler{eventRecorder: record.NewFakeRecorder(10)}\n394\t\t\t\trequeue, err := r.cleanUp(tt.trustManager)\n395\t\t\t\tif (err != nil) != tt.wantErr {\n396\t\t\t\t\tt.Errorf(\"cleanUp() error = %v, wantErr %v\", err, tt.wantErr)\n397\t\t\t\t}\n398\t\t\t\tif requeue != tt.wantRequeue {\n399\t\t\t\t\tt.Errorf(\"cleanUp() requeue = %v, want %v\", requeue, tt.wantRequeue)\n400\t\t\t\t}\n401\t\t\t})\n402\t\t}\n403\t}\n404\t"}]},"parent_tool_use_id":null,"session_id":"be09c20f-030f-46ce-a4a8-0ca2be3d5af4","uuid":"f8b672ac-b9e7-49b7-8020-4cf40422d302","timestamp":"2026-07-20T14:45:01.288Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/controller/trustmanager/controller_test.go","content":"package trustmanager\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"testing\"\n\t\"time\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"k8s.io/client-go/tools/record\"\n\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common/fakes\"\n)\n\nfunc TestReconcile(t *testing.T) {\n\ttests := []struct {\n\t\tname    string\n\t\tpreReq  func(*Reconciler, *fakes.FakeCtrlClient)\n\t\twantErr string\n\t}{\n\t\t{\n\t\t\tname: \"resource not found returns no error\",\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\treturn apierrors.NewNotFound(v1alpha1.Resource(\"trustmanager\"), trustManagerObjectName)\n\t\t\t\t})\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"failed to fetch resource propagates error\",\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\treturn apierrors.NewBadRequest(\"test error\")\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantErr: \"failed to fetch trustmanager.openshift.operator.io\",\n\t\t},\n\t\t{\n\t\t\tname: \"resource marked for deletion without finalizer\",\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttm := testTrustManager().Build()\n\t\t\t\t\t\ttm.DeletionTimestamp = &metav1.Time{Time: time.Now()}\n\t\t\t\t\t\ttm.DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"remove finalizer fails on deletion\",\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttm := testTrustManager().Build()\n\t\t\t\t\t\ttm.DeletionTimestamp = &metav1.Time{Time: time.Now()}\n\t\t\t\t\t\ttm.Finalizers = []string{finalizer}\n\t\t\t\t\t\ttm.DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t\tm.UpdateWithRetryCalls(func(ctx context.Context, obj client.Object, opts ...client.UpdateOption) error {\n\t\t\t\t\treturn errTestClient\n\t\t\t\t})\n\t\t\t},\n\t\t\twantErr: \"failed to remove finalizers\",\n\t\t},\n\t\t{\n\t\t\tname: \"adding finalizer fails\",\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttm := testTrustManager().Build()\n\t\t\t\t\t\ttm.DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t\tm.UpdateWithRetryCalls(func(ctx context.Context, obj client.Object, opts ...client.UpdateOption) error {\n\t\t\t\t\treturn errTestClient\n\t\t\t\t})\n\t\t\t},\n\t\t\twantErr: `failed to update \"/cluster\" trustmanager.openshift.operator.io with finalizers`,\n\t\t},\n\t\t{\n\t\t\tname: \"status update failure\",\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttm := testTrustManager().Build()\n\t\t\t\t\t\ttm.Spec.TrustManagerConfig = v1alpha1.TrustManagerConfig{}\n\t\t\t\t\t\ttm.Finalizers = []string{finalizer}\n\t\t\t\t\t\ttm.DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t\tm.StatusUpdateCalls(func(ctx context.Context, obj client.Object, opts ...client.SubResourceUpdateOption) error {\n\t\t\t\t\treturn apierrors.NewBadRequest(\"test error\")\n\t\t\t\t})\n\t\t\t},\n\t\t\twantErr: \"failed to update cluster status\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tr := testReconciler(t)\n\t\t\tmock := &fakes.FakeCtrlClient{}\n\t\t\tif tt.preReq != nil {\n\t\t\t\ttt.preReq(r, mock)\n\t\t\t}\n\t\t\tr.CtrlClient = mock\n\n\t\t\t_, err := r.Reconcile(context.Background(),\n\t\t\t\tctrl.Request{\n\t\t\t\t\tNamespacedName: types.NamespacedName{Name: trustManagerObjectName},\n\t\t\t\t},\n\t\t\t)\n\t\t\tassertError(t, err, tt.wantErr)\n\t\t})\n\t}\n}\n\nfunc TestProcessReconcileRequest(t *testing.T) {\n\tt.Setenv(trustManagerImageNameEnvVarName, testImage)\n\n\ttests := []struct {\n\t\tname            string\n\t\tgetTrustManager func() *v1alpha1.TrustManager\n\t\tpreReq          func(*Reconciler, *fakes.FakeCtrlClient)\n\t\twantConditions  []metav1.Condition\n\t\twantErr         string\n\t}{\n\t\t{\n\t\t\tname: \"successful reconciliation sets ready true\",\n\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n\t\t\t\treturn testTrustManager().Build()\n\t\t\t},\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttestTrustManager().Build().DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t\t// Namespace exists; all other resources return not-found so they\n\t\t\t\t// are created via SSA Patch (which succeeds by default).\n\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n\t\t\t\t\tswitch obj.(type) {\n\t\t\t\t\tcase *corev1.Namespace:\n\t\t\t\t\t\treturn true, nil\n\t\t\t\t\t}\n\t\t\t\t\treturn false, nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:   v1alpha1.Degraded,\n\t\t\t\t\tStatus: metav1.ConditionFalse,\n\t\t\t\t\tReason: v1alpha1.ReasonReady,\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tType:    v1alpha1.Ready,\n\t\t\t\t\tStatus:  metav1.ConditionTrue,\n\t\t\t\t\tReason:  v1alpha1.ReasonReady,\n\t\t\t\t\tMessage: \"reconciliation successful\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"irrecoverable error sets degraded true\",\n\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n\t\t\t\t// Empty TrustManagerConfig triggers validateTrustManagerConfig failure,\n\t\t\t\t// which is wrapped as an irrecoverable error in reconcileTrustManagerDeployment.\n\t\t\t\ttm := testTrustManager().Build()\n\t\t\t\ttm.Spec.TrustManagerConfig = v1alpha1.TrustManagerConfig{}\n\t\t\t\treturn tm\n\t\t\t},\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttm := testTrustManager().Build()\n\t\t\t\t\t\ttm.Spec.TrustManagerConfig = v1alpha1.TrustManagerConfig{}\n\t\t\t\t\t\ttm.DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:   v1alpha1.Degraded,\n\t\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tType:   v1alpha1.Ready,\n\t\t\t\t\tStatus: metav1.ConditionFalse,\n\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"recoverable error sets in progress\",\n\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n\t\t\t\treturn testTrustManager().Build()\n\t\t\t},\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttestTrustManager().Build().DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t\t// Namespace Exists succeeds (passes validateTrustNamespace), but\n\t\t\t\t// ServiceAccount Exists returns a FromClientError\n\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n\t\t\t\t\tswitch obj.(type) {\n\t\t\t\t\tcase *corev1.Namespace:\n\t\t\t\t\t\treturn true, nil\n\t\t\t\t\t}\n\t\t\t\t\treturn false, errTestClient\n\t\t\t\t})\n\t\t\t},\n\t\t\twantConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:   v1alpha1.Degraded,\n\t\t\t\t\tStatus: metav1.ConditionFalse,\n\t\t\t\t\tReason: v1alpha1.ReasonReady,\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tType:   v1alpha1.Ready,\n\t\t\t\t\tStatus: metav1.ConditionFalse,\n\t\t\t\t\tReason: v1alpha1.ReasonInProgress,\n\t\t\t\t},\n\t\t\t},\n\t\t\twantErr: \"failed to check if serviceaccount\",\n\t\t},\n\t\t{\n\t\t\tname: \"trust namespace does not exist sets degraded true\",\n\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n\t\t\t\treturn testTrustManager().Build()\n\t\t\t},\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttestTrustManager().Build().DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t\t// Namespace does not exist - validateTrustNamespace will fail\n\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n\t\t\t\t\tswitch obj.(type) {\n\t\t\t\t\tcase *corev1.Namespace:\n\t\t\t\t\t\treturn false, nil\n\t\t\t\t\t}\n\t\t\t\t\treturn false, nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:   v1alpha1.Degraded,\n\t\t\t\t\tStatus: metav1.ConditionTrue,\n\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n\t\t\t\t\tMessage: fmt.Sprintf(\n\t\t\t\t\t\t\"reconciliation failed with irrecoverable error not retrying: trust namespace %q validation failed: trust namespace %q does not exist, create the namespace before creating TrustManager CR\",\n\t\t\t\t\t\tdefaultTrustNamespace,\n\t\t\t\t\t\tdefaultTrustNamespace,\n\t\t\t\t\t),\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tType:   v1alpha1.Ready,\n\t\t\t\t\tStatus: metav1.ConditionFalse,\n\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"custom trust namespace configures resources correctly\",\n\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n\t\t\t\ttm := testTrustManager().Build()\n\t\t\t\ttm.Spec.TrustManagerConfig.TrustNamespace = \"custom-trust-ns\"\n\t\t\t\treturn tm\n\t\t\t},\n\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n\t\t\t\t\tswitch o := obj.(type) {\n\t\t\t\t\tcase *v1alpha1.TrustManager:\n\t\t\t\t\t\ttm := testTrustManager().Build()\n\t\t\t\t\t\ttm.Spec.TrustManagerConfig.TrustNamespace = \"custom-trust-ns\"\n\t\t\t\t\t\ttm.DeepCopyInto(o)\n\t\t\t\t\t}\n\t\t\t\t\treturn nil\n\t\t\t\t})\n\t\t\t\t// Custom namespace exists; so SSA Patch will create or update all resources successfully.\n\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n\t\t\t\t\tswitch obj.(type) {\n\t\t\t\t\tcase *corev1.Namespace:\n\t\t\t\t\t\treturn true, nil\n\t\t\t\t\t}\n\t\t\t\t\treturn false, nil\n\t\t\t\t})\n\t\t\t},\n\t\t\twantConditions: []metav1.Condition{\n\t\t\t\t{\n\t\t\t\t\tType:   v1alpha1.Degraded,\n\t\t\t\t\tStatus: metav1.ConditionFalse,\n\t\t\t\t\tReason: v1alpha1.ReasonReady,\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tType:    v1alpha1.Ready,\n\t\t\t\t\tStatus:  metav1.ConditionTrue,\n\t\t\t\t\tReason:  v1alpha1.ReasonReady,\n\t\t\t\t\tMessage: \"reconciliation successful\",\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tr := testReconciler(t)\n\t\t\tmock := &fakes.FakeCtrlClient{}\n\t\t\tif tt.preReq != nil {\n\t\t\t\ttt.preReq(r, mock)\n\t\t\t}\n\t\t\tr.CtrlClient = mock\n\n\t\t\ttm := tt.getTrustManager()\n\t\t\t_, err := r.processReconcileRequest(tm, types.NamespacedName{Name: tm.GetName()})\n\t\t\tassertError(t, err, tt.wantErr)\n\n\t\t\tfor _, want := range tt.wantConditions {\n\t\t\t\tfound := false\n\t\t\t\tfor _, got := range tm.Status.Conditions {\n\t\t\t\t\tif got.Type == want.Type {\n\t\t\t\t\t\tfound = true\n\t\t\t\t\t\tif got.Status != want.Status {\n\t\t\t\t\t\t\tt.Errorf(\"condition %s: expected status %s, got %s\", want.Type, want.Status, got.Status)\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif got.Reason != want.Reason {\n\t\t\t\t\t\t\tt.Errorf(\"condition %s: expected reason %s, got %s\", want.Type, want.Reason, got.Reason)\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif want.Message != \"\" && got.Message != want.Message {\n\t\t\t\t\t\t\tt.Errorf(\"condition %s: expected message %q, got %q\", want.Type, want.Message, got.Message)\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tif !found {\n\t\t\t\t\tt.Errorf(\"expected condition %s not found in status conditions %v\", want.Type, tm.Status.Conditions)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestCleanUp(t *testing.T) {\n\ttests := []struct {\n\t\tname         string\n\t\ttrustManager *v1alpha1.TrustManager\n\t\twantRequeue  bool\n\t\twantErr      bool\n\t}{\n\t\t{\n\t\t\tname: \"returns false and nil\",\n\t\t\ttrustManager: &v1alpha1.TrustManager{\n\t\t\t\tObjectMeta: metav1.ObjectMeta{Name: \"cluster\"},\n\t\t\t},\n\t\t\twantRequeue: false,\n\t\t\twantErr:     false,\n\t\t},\n\t}\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tr := &Reconciler{eventRecorder: record.NewFakeRecorder(10)}\n\t\t\trequeue, err := r.cleanUp(tt.trustManager)\n\t\t\tif (err != nil) != tt.wantErr {\n\t\t\t\tt.Errorf(\"cleanUp() error = %v, wantErr %v\", err, tt.wantErr)\n\t\t\t}\n\t\t\tif requeue != tt.wantRequeue {\n\t\t\t\tt.Errorf(\"cleanUp() requeue = %v, want %v\", requeue, tt.wantRequeue)\n\t\t\t}\n\t\t})\n\t}\n}\n","numLines":404,"startLine":1,"totalLines":404}}}

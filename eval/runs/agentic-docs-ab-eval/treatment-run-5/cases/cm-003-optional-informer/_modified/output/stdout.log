{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_019gzQKfMnEhjJgf7CXfLBEU","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"os\"\n6\t\n7\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n8\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n9\t)\n10\t\n11\tfunc (r *Reconciler) reconcileTrustManagerDeployment(trustManager *v1alpha1.TrustManager) error {\n12\t\tif err := validateTrustManagerConfig(trustManager); err != nil {\n13\t\t\treturn common.NewIrrecoverableError(err, \"%s configuration validation failed\", trustManager.GetName())\n14\t\t}\n15\t\n16\t\tresourceLabels := getResourceLabels(trustManager)\n17\t\tresourceAnnotations := getResourceAnnotations(trustManager)\n18\t\n19\t\ttrustNamespace := getTrustNamespace(trustManager)\n20\t\tif err := r.validateTrustNamespace(trustNamespace); err != nil {\n21\t\t\treturn common.NewIrrecoverableError(err, \"trust namespace %q validation failed\", trustNamespace)\n22\t\t}\n23\t\n24\t\tcaBundleHash, err := r.createOrApplyDefaultCAPackageConfigMap(trustManager, resourceLabels, resourceAnnotations)\n25\t\tif err != nil {\n26\t\t\tr.log.Error(err, \"failed to reconcile default CA package ConfigMap\")\n27\t\t\treturn err\n28\t\t}\n29\t\n30\t\tif err := r.createOrApplyServiceAccounts(trustManager, resourceLabels, resourceAnnotations); err != nil {\n31\t\t\tr.log.Error(err, \"failed to reconcile serviceaccount resource\")\n32\t\t\treturn err\n33\t\t}\n34\t\n35\t\tif err := r.createOrApplyRBACResources(trustManager, resourceLabels, resourceAnnotations, trustNamespace); err != nil {\n36\t\t\tr.log.Error(err, \"failed to reconcile RBAC resources\")\n37\t\t\treturn err\n38\t\t}\n39\t\n40\t\tif err := r.createOrApplyServices(trustManager, resourceLabels, resourceAnnotations); err != nil {\n41\t\t\tr.log.Error(err, \"failed to reconcile service resources\")\n42\t\t\treturn err\n43\t\t}\n44\t\n45\t\tif err := r.crea
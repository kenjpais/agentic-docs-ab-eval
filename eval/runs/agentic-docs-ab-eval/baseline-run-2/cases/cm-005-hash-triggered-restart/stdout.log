dleHash(caBundle string) string {\n\thash := sha256.Sum256([]byte(caBundle))\n\treturn hex.EncodeToString(hash[:])\n}\n```\n\n---\n\n## New file: `pkg/controller/istiocsr/configmaps_test.go`\n\n```go\npackage istiocsr\n\nimport (\n\t\"testing\"\n)\n\nconst testCABundlePEM = \"-----BEGIN CERTIFICATE-----\\nthisIsATestCABundle\\n-----END CERTIFICATE-----\"\n\nfunc TestComputeCABundleHash(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tbundle1  string\n\t\tbundle2  string\n\t\twantSame bool\n\t}{\n\t\t{\n\t\t\tname:     \"same bundle produces same hash\",\n\t\t\tbundle1:  testCABundlePEM,\n\t\t\tbundle2:  testCABundlePEM,\n\t\t\twantSame: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"different bundles produce different hashes\",\n\t\t\tbundle1:  testCABundlePEM,\n\t\t\tbundle2:  \"-----BEGIN CERTIFICATE-----\\ndifferentBundle\\n-----END CERTIFICATE-----\",\n\t\t\twantSame: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\thash1 := computeCABundleHash(tt.bundle1)\n\t\t\thash2 := computeCABundleHash(tt.bundle2)\n\n\t\t\tif hash1 == \"\" {\n\t\t\t\tt.Fatal(\"expected non-empty hash\")\n\t\t\t}\n\t\t\tif (hash1 == hash2) != tt.wantSame {\n\t\t\t\tt.Errorf(\"hash equality=%v, want %v (hash1=%s, hash2=%s)\", hash1 == hash2, tt.wantSame, hash1, hash2)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestStampCABundleHashAnnotation(t *testing.T) {\n\tt.Run(\"empty hash is a no-op\", func(t *testing.T) {\n\t\tdep := testDeployment()\n\t\tstampCABundleHashAnnotation(dep, \"\")\n\t\tif dep.Spec.Template.Annotations != nil {\n\t\t\tif _, exists := dep.Spec.Template.Annotations[caBundleHashAnnotation]; exists {\n\t\t\t\tt.Error(\"expected no annotation when hash is empty\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"stamps annotation on nil annotations map\", func(t *testing.T) {\n\t\tdep := testDeployment()\n\t\tdep.Spec.Template.Annotations = nil\n\t\tstampCABundleHashAnnotation(dep, \"abc123hash\")\n\t\tgot, exists := dep.Spec.Template.Annotations[caBundleHashAnnotation]\n\t\tif !exists {\n\t\t\tt.Fatalf(\"expected pod template annotation %q to be set\", caBundleHashAnnotation)\n\t\t}\n\t\tif got != \"abc123hash\" {\n\t\t\tt.Errorf(\"expected hash annotation %q, got %q\", \"abc123hash\", got)\n\t\t}\n\t})\n\n\tt.Run(\"stamps annotation on existing annotations map\", func(t *testing.T) {\n\t\tdep := testDeployment()\n\t\tdep.Spec.Template.Annotations = map[string]string{\"existing\": \"value\"}\n\t\tstampCABundleHashAnnotation(dep, \"def456hash\")\n\t\tgot, exists := dep.Spec.Template.Annotations[caBundleHashAnnotation]\n\t\tif !exists {\n\t\t\tt.Fatalf(\"expected pod template annotation %q to be set\", caBundleHashAnnotation)\n\t\t}\n\t\tif got != \"def456hash\" {\n\t\t\tt.Errorf(\"expected hash annotation %q, got %q\", \"def456hash\", got)\n\t\t}\n\t\tif dep.Spec.Template.Annotations[\"existing\"] != \"value\" {\n\t\t\tt.Error(\"expected existing annotation to be preserved\")\n\t\t}\n\t})\n}\n```\n\n---\n\n## Modify: `pkg/controller/istiocsr/constants.go`\n\nAdd after line 89 (`IstiocsrCAKeyName = \"ca.crt\"`):\n\n```go\n\t// caBundleHashAnnotation is the pod template annotation that tracks the\n\t// SHA-256 hash of the CNO-injected CA bundle PEM content. When the hash\n\t// changes, Kubernetes triggers a rolling restart of the pods.\n\tcaBundleHashAnnotation = \"operator.openshift.io/ca-bundle-hash\"\n```\n\n---\n\n## Modify: `pkg/controller/istiocsr/deployments.go`\n\n**Change 1** \u2014 Line 31, update `createOrApplyDeployments` signature:\n\n```\nOLD: func (r *Reconciler) createOrApplyDeployments(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, istioCSRCreateRecon bool) error {\nNEW: func (r *Reconciler) createOrApplyDeployments(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string, istioCSRCreateRecon bool, caBundleHash string) error {\n```\n\n**Change 2** \u2014 Line 32, pass `caBundleHash` to `getDeploymentObject`:\n\n```\nOLD: desired, err := r.getDeploymentObject(istiocsr
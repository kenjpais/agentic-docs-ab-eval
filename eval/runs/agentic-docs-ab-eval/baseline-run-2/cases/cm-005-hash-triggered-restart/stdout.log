te(caBundle))\n\treturn hex.EncodeToString(hash[:])\n}\n```\n\n---\n\n## New file: `pkg/controller/istiocsr/configmaps_test.go`\n\n```go\npackage istiocsr\n\nimport (\n\t\"testing\"\n)\n\nconst testCABundlePEM = \"-----BEGIN CERTIFICATE-----\\nthisIsATestCABundle\\n-----END CERTIFICATE-----\"\n\nfunc TestComputeCABundleHash(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tbundle1  string\n\t\tbundle2  string\n\t\twantSame bool\n\t}{\n\t\t{\n\t\t\tname:     \"same bundle produces same hash\",\n\t\t\tbundle1:  testCABundlePEM,\n\t\t\tbundle2:  testCABundlePEM,\n\t\t\twantSame: true,\n\t\t},\n\t\t{\n\t\t\tname:     \"different bundles produce different hashes\",\n\t\t\tbundle1:  testCABundlePEM,\n\t\t\tbundle2:  \"-----BEGIN CERTIFICATE-----\\ndifferentBundle\\n-----END CERTIFICATE-----\",\n\t\t\twantSame: false,\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\thash1 := computeCABundleHash(tt.bundle1)\n\t\t\thash2 := computeCABundleHash(tt.bundle2)\n\n\t\t\tif hash1 == \"\" {\n\t\t\t\tt.Fatal(\"expected non-empty hash\")\n\t\t\t}\n\t\t\tif (hash1 == hash2) != tt.wantSame {\n\t\t\t\tt.Errorf(\"hash equality=%v, want %v (hash1=%s, hash2=%s)\", hash1 == hash2, tt.wantSame, hash1, hash2)\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestStampCABundleHashAnnotation(t *testing.T) {\n\tt.Run(\"empty hash is a no-op\", func(t *testing.T) {\n\t\tdep := testDeployment()\n\t\tstampCABundleHashAnnotation(dep, \"\")\n\t\tif dep.Spec.Template.Annotations != nil {\n\t\t\tif _, exists := dep.Spec.Template.Annotations[caBundleHashAnnotation]; exists {\n\t\t\t\tt.Error(\"expected no annotation when hash is empty\")\n\t\t\t}\n\t\t}\n\t})\n\n\tt.Run(\"stamps annotation on nil annotations map\", func(t *testing.T) {\n\t\tdep := testDeployment()\n\t\tdep.Spec.Template.Annotations = nil\n\t\tstampCABundleHashAnnotation(dep, \"abc123hash\")\n\t\tgot, exists := dep.Spec.Template.Annotations[caBundleHashAnnotation]\n\t\tif !exists {\n\t\t\tt.Fatalf
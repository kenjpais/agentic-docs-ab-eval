{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01AmSex4LHC5LbenZhc7Rw2W","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"encoding/json\"\n6\t\t\"testing\"\n7\t\n8\t\tcorev1 \"k8s.io/api/core/v1\"\n9\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n10\t\n11\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n12\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n13\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common/fakes\"\n14\t)\n15\t\n16\tconst testCABundle = \"-----BEGIN CERTIFICATE-----\\nthisIsATestCABundle\\n-----END CERTIFICATE-----\"\n17\t\n18\tfunc TestFormatCAPackage(t *testing.T) {\n19\t\tpkgJSON, err := formatCAPackage(testCABundle, \"12345\")\n20\t\tif err != nil {\n21\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n22\t\t}\n23\t\n24\t\tvar pkg caPackage\n25\t\tif err := json.Unmarshal(pkgJSON, &pkg); err != nil {\n26\t\t\tt.Fatalf(\"failed to unmarshal package JSON: %v\", err)\n27\t\t}\n28\t\tif pkg.Name != defaultCAPackageName {\n29\t\t\tt.Errorf(\"expected package name %q, got %q\", defaultCAPackageName, pkg.Name)\n30\t\t}\n31\t\tif pkg.Version != \"12345\" {\n32\t\t\tt.Errorf(\"expected package version %q, got %q\", \"12345\", pkg.Version)\n33\t\t}\n34\t\tif pkg.Bundle != testCABundle {\n35\t\t\tt.Errorf(\"expected bundle to match input, got different content\")\n36\t\t}\n37\t}\n38\t\n39\tfunc TestComputeCABundleHash(t *testing.T) {\n40\t\ttests := []struct {\n41\t\t\tname     string\n42\t\t\tbundle1  string\n43\t\t\tbundle2  string\n44\t\t\twantSame bool\n45\t\t}{\n46\t\t\t{\n47\t\t\t\tname:     \"same bundle produces same hash\",\n48\t\t\t\tbundle1:  testCABundle,\n49\t\t\t\tbundle2:  testCABundle,\n50\t\t\t\twantSame: true,\n51\t\t\t},\n52\t\t\t{\n53\t\t\t\tname:     \"different bundles produce different hashes\",\n54\t\t\t\tbundle1:  testCABundle,\n55\t\t\t\tbundle2:  \"-----BEGIN CERTIFICATE-----\\ndiffer
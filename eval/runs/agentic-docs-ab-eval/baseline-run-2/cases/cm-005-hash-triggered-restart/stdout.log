e(), \"namespace\", obj.GetNamespace())\n\t\t// List all IstioCSR instances to trigger reconciliation\n\t\tistiocsrList := &v1alpha1.IstioCSRList{}\n\t\tif err := r.List(ctx, istiocsrList); err != nil {\n\t\t\tr.log.Error(err, \"failed to list IstioCSR instances for CA bundle ConfigMap event\")\n\t\t\treturn nil\n\t\t}\n\t\tvar requests []reconcile.Request\n\t\tfor _, item := range istiocsrList.Items {\n\t\t\trequests = append(requests, reconcile.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{\n\t\t\t\t\tName:      istiocsrObjectName,\n\t\t\t\t\tNamespace: item.GetNamespace(),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t\treturn requests\n\t}\n```\n\nActually, looking more carefully at the trustmanager pattern — the trustmanager object is cluster-scoped and has a known singleton name, so the mapFunc there just returns the fixed name. For istiocsr, the object is namespace-scoped, so we need to discover the active instance.\n\nBut the `disallowMultipleIstioCSRInstances` code makes it clear there should be at most one active instance. We can list them. Or we can just enqueue the singleton name in all namespaces where IstioCSR exists.\n\nActually, looking again, the simplest approach is to list IstioCSR instances, but that requires the `List` method. Let me check if the Reconciler has access to `List`:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":276,"cache_read_input_tokens":87364,"cache_creation":{"ephemeral_5m_input_tokens":276,"ephemeral_1h_input_tokens":0},"output_tokens":1},"context_management":null},"parent_tool_use_id":null,"session_id":"d492c772-c168-4a0f-b3ec-8f3787d54983","uuid":"aa95e520-a480-40fe-998b-95cf7756e8e8","timestamp":"2026-07-16T13:13:54.308Z","request_id":"req_vrtx_011Cd5o5Dq61S9a56kRpZGqN"}

mpCABundleHashAnnotation(dep, \"abc123hash\")\n\t\tgot, exists := dep.Spec.Template.Annotations[caBundleHashAnnotation]\n\t\tif !exists {\n\t\t\tt.Fatalf(\"expected pod template annotation %q to be set\", caBundleHashAnnotation)\n\t\t}\n\t\tif got != \"abc123hash\" {\n\t\t\tt.Errorf(\"expected hash annotation %q, got %q\", \"abc123hash\", got)\n\t\t}\n\t})\n\n\tt.Run(\"stamps annotation on existing annotations map\", func(t *testing.T) {\n\t\tdep := testDeployment()\n\t\tdep.Spec.Template.Annotations = map[string]string{\"existing\": \"value\"}\n\t\tstampCABundleHashAnnotation(dep, \"def456hash\")\n\t\tgot, exists := dep.Spec.Template.Annotations[caBundleHashAnnotation]\n\t\tif !exists {\n\t\t\tt.Fatalf(\"expected pod template annotation %q to be set\", caBundleHashAnnotation)\n\t\t}\n\t\tif got != \"def456hash\" {\n\t\t\tt.Errorf(\"expected hash annotation %q, got %q\", \"def456hash\", got)\n\t\t}\n\t\tif dep.Spec.Template.Annotations[\"existing\"] != \"value\" {\n\t\t\tt.Error(\"expected existing annotation to be preserved\")\n\t\t}\n\t})\n}\n```\n\n---\n\n## File 8: Update test files that call the modified functions\n\nThe deployment tests call `createOrApplyDeployments` and `getDeploymentObject` — those signatures changed. Let me check:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3825,"cache_read_input_tokens":87640,"cache_creation":{"ephemeral_5m_input_tokens":3825,"ephemeral_1h_input_tokens":0},"output_tokens":1},"context_management":null},"parent_tool_use_id":null,"session_id":"d492c772-c168-4a0f-b3ec-8f3787d54983","uuid":"f8820177-e65a-4256-95ad-418c91a63175","timestamp":"2026-07-16T13:14:59.289Z","request_id":"req_vrtx_011Cd5o9EgYQRN4UrBQMQCqu"}

bject.GetNamespace() == common.OperatorNamespace &&\n\t\t\t\te.Object.GetName() == common.TrustedCABundleConfigMapName\n\t\t},\n\t}\n\n\t// Map function for the CNO-injected CA bundle ConfigMap. Since this ConfigMap\n\t// lacks the managed labels used by the main mapFunc, it uses a dedicated mapper\n\t// that enqueues reconcile requests for all existing IstioCSR instances.\n\tcaConfigMapMapFunc := func(ctx context.Context, obj client.Object) []reconcile.Request {\n\t\tr.log.V(4).Info(\"received CA bundle ConfigMap event\",\n\t\t\t\"name\", obj.GetName(), \"namespace\", obj.GetNamespace())\n\t\tistiocsrList := &v1alpha1.IstioCSRList{}\n\t\tif err := r.List(ctx, istiocsrList); err != nil {\n\t\t\tr.log.Error(err, \"failed to list IstioCSR instances for CA bundle ConfigMap event\")\n\t\t\treturn nil\n\t\t}\n\t\tvar requests []reconcile.Request\n\t\tfor _, item := range istiocsrList.Items {\n\t\t\trequests = append(requests, reconcile.Request{\n\t\t\t\tNamespacedName: types.NamespacedName{\n\t\t\t\t\tName:      item.GetName(),\n\t\t\t\t\tNamespace: item.GetNamespace(),\n\t\t\t\t},\n\t\t\t})\n\t\t}\n\t\treturn requests\n\t}\n```\n\n**5c.** Add the Watch line in the builder chain. After line 152 (the existing ConfigMap watch), add:\n\n```go\n\t\tWatches(&corev1.ConfigMap{}, handler.EnqueueRequestsFromMapFunc(caConfigMapMapFunc), builder.WithPredicates(injectedCABundleConfigMapPredicate)).\n```\n\nThe `List` method is already available via `common.CtrlClient`.\n\n---\n\n## File 6: Modify `pkg/controller/istiocsr/utils.go` — `deploymentSpecModified`\n\nAdd pod template annotation comparison in the `deploymentSpecModified` function. After line 316 (the `Template.Labels` comparison):\n\nOld (lines 316-317):\n```go\n\tif !reflect.DeepEqual(desired.Spec.Template.Labels, fetched.Spec.Template.Labels) ||\n\t\tlen(desired.Spec.Template.Spec.Containers) != len(fetched.Spec.Template.Spec.Containers) {\n```\n\nNew:\n```go\n\tif !reflect.DeepEqual(desired.Spec.Template.Labels, fetched
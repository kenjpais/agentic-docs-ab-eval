ha1.TrustManager {\n152\t\t\t\t\treturn testTrustManager().Build()\n153\t\t\t\t},\n154\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n155\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n156\t\t\t\t\t\tswitch o := obj.(type) {\n157\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n158\t\t\t\t\t\t\ttestTrustManager().Build().DeepCopyInto(o)\n159\t\t\t\t\t\t}\n160\t\t\t\t\t\treturn nil\n161\t\t\t\t\t})\n162\t\t\t\t\t// Namespace exists; all other resources return not-found so they\n163\t\t\t\t\t// are created via SSA Patch (which succeeds by default).\n164\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n165\t\t\t\t\t\tswitch obj.(type) {\n166\t\t\t\t\t\tcase *corev1.Namespace:\n167\t\t\t\t\t\t\treturn true, nil\n168\t\t\t\t\t\t}\n169\t\t\t\t\t\treturn false, nil\n170\t\t\t\t\t})\n171\t\t\t\t},\n172\t\t\t\twantConditions: []metav1.Condition{\n173\t\t\t\t\t{\n174\t\t\t\t\t\tType:   v1alpha1.Degraded,\n175\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n176\t\t\t\t\t\tReason: v1alpha1.ReasonReady,\n177\t\t\t\t\t},\n178\t\t\t\t\t{\n179\t\t\t\t\t\tType:    v1alpha1.Ready,\n180\t\t\t\t\t\tStatus:  metav1.ConditionTrue,\n181\t\t\t\t\t\tReason:  v1alpha1.ReasonReady,\n182\t\t\t\t\t\tMessage: \"reconciliation successful\",\n183\t\t\t\t\t},\n184\t\t\t\t},\n185\t\t\t},\n186\t\t\t{\n187\t\t\t\tname: \"irrecoverable error sets degraded true\",\n188\t\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n189\t\t\t\t\t// Empty TrustManagerConfig triggers validateTrustManagerConfig failure,\n190\t\t\t\t\t// which is wrapped as an irrecoverable error in reconcileTrustManagerDeployment.\n191\t\t\t\t\ttm := testTrustManager().Build()\n192\t\t\t\t\ttm.Spec.TrustManagerConfig = v1alpha1.TrustManagerConfig{}\n193\t\t\t\t\treturn tm\n194\t\t\t\t},\n195\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n196\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n197\t\t\t\t\t\tswitch o := obj.(type) {\n198\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n199\t\t\t\t\t\t\ttm := testTrustManager().Build()\n200\t\t\t\t\t\t\ttm.Spec.TrustManagerConfig = v1alpha1.TrustManagerConfig{}\n201\t\t\t\t\t\t\ttm.DeepCopyInto(o)\n202\t\t\t\t\t\t}\n203\t\t\t\t\t\treturn nil\n204\t\t\t\t\t})\n205\t\t\t\t},\n206\t\t\t\twantConditions: []metav1.Condition{\n207\t\t\t\t\t{\n208\t\t\t\t\t\tType:   v1alpha1.Degraded,\n209\t\t\t\t\t\tStatus: metav1.ConditionTrue,\n210\t\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n211\t\t\t\t\t},\n212\t\t\t\t\t{\n213\t\t\t\t\t\tType:   v1alpha1.Ready,\n214\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n215\t\t\t\t\t\tReason: v1alpha1.ReasonFailed,\n216\t\t\t\t\t},\n217\t\t\t\t},\n218\t\t\t},\n219\t\t\t{\n220\t\t\t\tname: \"recoverable error sets in progress\",\n221\t\t\t\tgetTrustManager: func() *v1alpha1.TrustManager {\n222\t\t\t\t\treturn testTrustManager().Build()\n223\t\t\t\t},\n224\t\t\t\tpreReq: func(r *Reconciler, m *fakes.FakeCtrlClient) {\n225\t\t\t\t\tm.GetCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) error {\n226\t\t\t\t\t\tswitch o := obj.(type) {\n227\t\t\t\t\t\tcase *v1alpha1.TrustManager:\n228\t\t\t\t\t\t\ttestTrustManager().Build().DeepCopyInto(o)\n229\t\t\t\t\t\t}\n230\t\t\t\t\t\treturn nil\n231\t\t\t\t\t})\n232\t\t\t\t\t// Namespace Exists succeeds (passes validateTrustNamespace), but\n233\t\t\t\t\t// ServiceAccount Exists returns a FromClientError\n234\t\t\t\t\tm.ExistsCalls(func(ctx context.Context, key client.ObjectKey, obj client.Object) (bool, error) {\n235\t\t\t\t\t\tswitch obj.(type) {\n236\t\t\t\t\t\tcase *corev1.Namespace:\n237\t\t\t\t\t\t\treturn true, nil\n238\t\t\t\t\t\t}\n239\t\t\t\t\t\treturn false, errTestClient\n240\t\t\t\t\t})\n241\t\t\t\t},\n242\t\t\t\twantConditions: []metav1.Condition{\n243\t\t\t\t\t{\n244\t\t\t\t\t\tType:   v1alpha1.Degraded,\n245\t\t\t\t\t\tStatus: metav1.ConditionFalse,\n246\t\t\t\t\t\tReason: v1alpha1.ReasonReady,\
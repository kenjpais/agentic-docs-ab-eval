ildRoleBinding(name string, roleRef rbacv1.RoleRef, subjects []rbacv1.Subject) *rbacv1.RoleBinding {\n301\t\treturn &rbacv1.RoleBinding{\n302\t\t\tObjectMeta: metav1.ObjectMeta{\n303\t\t\t\tName:      name,\n304\t\t\t\tNamespace: utils.Namespace(),\n305\t\t\t\tLabels: map[string]string{\n306\t\t\t\t\tutils.OperandLabelKey:   operandName,\n307\t\t\t\t\tutils.ControllerNameKey: name,\n308\t\t\t\t},\n309\t\t\t},\n310\t\t\tRoleRef:  roleRef,\n311\t\t\tSubjects: subjects,\n312\t\t}\n313\t}\n314\t\n315\tfunc buildServiceAccount(name string) *corev1.ServiceAccount {\n316\t\treturn &corev1.ServiceAccount{\n317\t\t\tObjectMeta: metav1.ObjectMeta{\n318\t\t\t\tName:      name,\n319\t\t\t\tNamespace: utils.Namespace(),\n320\t\t\t\tLabels: map[string]string{\n321\t\t\t\t\tutils.OperandLabelKey:   operandName,\n322\t\t\t\t\tutils.ControllerNameKey: name,\n323\t\t\t\t},\n324\t\t\t},\n325\t\t\tAutomountServiceAccountToken: utils.NewPtr(false),\n326\t\t}\n327\t}\n328\t\n329\tfunc buildServiceMonitor(name string) *monitoringv1.ServiceMonitor {\n330\t\treturn &monitoringv1.ServiceMonitor{\n331\t\t\tTypeMeta: metav1.TypeMeta{\n332\t\t\t\tAPIVersion: monitoringv1.SchemeGroupVersion.String(),\n333\t\t\t\tKind:       monitoringv1.ServiceMonitorsKind,\n334\t\t\t},\n335\t\t\tObjectMeta: metav1.ObjectMeta{\n336\t\t\t\tName:      name,\n337\t\t\t\tNamespace: utils.Namespace(),\n338\t\t\t},\n339\t\t\tSpec: monitoringv1.ServiceMonitorSpec{\n340\t\t\t\tEndpoints: []monitoringv1.Endpoint{\n341\t\t\t\t\t{\n342\t\t\t\t\t\tHonorLabels:     true,\n343\t\t\t\t\t\tPath:            \"/metrics\",\n344\t\t\t\t\t\tPort:            \"metrics\",\n345\t\t\t\t\t\tScheme:          utils.NewPtr(monitoringv1.Scheme(\"https\")),\n346\t\t\t\t\t\tBearerTokenFile: \"/var/run/secrets/kubernetes.io/serviceaccount/token\",\n347\t\t\t\t\t\tHTTPConfigWithProxyAndTLSFiles: monitoringv1.HTTPConfigWithProxyAndTLSFiles{\n348\t\t\t\t\t\t\tHTTPConfigWithTLSFiles: monitoringv1.HTTPConfigWithTLSFiles{\n349\t\t\t\t\t\t\t\tTLSConfig: &monitoringv1.TLSConfig{\n350\t\t\t\t\t\t\t\t\tTLSFilesConfig: monitoringv1.TLSFilesConfig{\n351\t\t\t\t\t\t\t\t\t\tCAFile: \"/etc/prometheus/configmaps/serving-certs-ca-bundle/service-ca.crt\",\n352\t\t\t\t\t\t\t\t\t},\n353\t\t\t\t\t\t\t\t\tSafeTLSConfig: monitoringv1.SafeTLSConfig{\n354\t\t\t\t\t\t\t\t\t\tServerName: utils.NewPtr(fmt.Sprintf(\"%s.%s.svc\", name, utils.Namespace())),\n355\t\t\t\t\t\t\t\t\t},\n356\t\t\t\t\t\t\t\t},\n357\t\t\t\t\t\t\t},\n358\t\t\t\t\t\t},\n359\t\t\t\t\t},\n360\t\t\t\t},\n361\t\t\t\tNamespaceSelector: monitoringv1.NamespaceSelector{\n362\t\t\t\t\tMatchNames: []string{utils.Namespace()},\n363\t\t\t\t},\n364\t\t\t\tSelector: metav1.LabelSelector{\n365\t\t\t\t\tMatchLabels: map[string]string{\n366\t\t\t\t\t\tutils.ControllerNameKey: name,\n367\t\t\t\t\t},\n368\t\t\t\t},\n369\t\t\t},\n370\t\t}\n371\t}\n372\t"}]},"parent_tool_use_id":null,"session_id":"3cb75d51-138e-4a53-b80f-5445f7ee5d40","uuid":"7f574100-8f1a-40fa-945f-3d85984b4395","timestamp":"2026-07-20T13:57:54.555Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/multiarch-tuning-operator-treatment/internal/controller/operator/objects.go","content":"package operator\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\trbacv1 \"k8s.io/api/rbac/v1\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/util/intstr\"\n\n\tmonitoringv1 \"github.com/prometheus-operator/prometheus-operator/pkg/apis/monitoring/v1\"\n\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/utils\"\n)\n\nconst (\n\tCREATE = \"create\"\n\tUPDATE = \"update\"\n\tPATCH  = \"patch\"\n\tLIST   = \"list\"\n\tWATCH  = \"watch\"\n\tGET    = \"get\"\n\tUSE    = \"use\"\n\tDELETE = \"delete\"\n\n\tserviceAccountKind = \"ServiceAccount\"\n\troleKind           = \"Role\"\n\tclusterRoleKind    = \"ClusterRole\"\n\n\t// xref: https://github.com/openshift/enhancements/blob/9b5d8a964fc/enhancements/authentication/custom-scc-preemption-prevention.md\n\trequiredSCCAnnotation   = \"openshift.io/required-scc\"\n\trequiredSCCRestrictedV2 = \"restricted-v2\"\n)\n\nfunc buildService(name string) *corev1.Service {\n\treturn &corev1.Service{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      name,\n\t\t\tNamespace: utils.Namespace(),\n\t\t\tLabels: map[string]string{\n\t\t\t\tutils.OperandLabelKey:   operandName,\n\t\t\t\tutils.ControllerNameKey: name,\n\t\t\t},\n\t\t\tAnnotations: map[string]string{\n\t\t\t\t\"service.beta.openshift.io/serving-cert-secret-name\": name,\n\t\t\t},\n\t\t},\n\t\tSpec: corev1.ServiceSpec{\n\t\t\tPorts: []corev1.ServicePort{\n\t\t\t\t{\n\t\t\t\t\tName:       \"https\",\n\t\t\t\t\tPort:       443,\n\t\t\t\t\tTargetPort: intstr.FromInt32(9443),\n\t\t\t\t\tProtocol:   corev1.ProtocolTCP,\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\tName:       \"metrics\",\n\t\t\t\t\tPort:       8443,\n\t\t\t\t\tTargetPort: intstr.FromInt32(8443),\n\t\t\t\t\tProtocol:   corev1.ProtocolTCP,\n\t\t\t\t},\n\t\t\t},\n\t\t\tSelector: map[string]string{\n\t\t\t\tutils.OperandLabelKey:   operandName,\n\t\t\t\tutils.ControllerNameKey: name,\n\t\t\t},\n\t\t},\n\t}\n}\n\nfunc buildDeployment(logVerbosity int,\n\tname string, replicas int32, serviceAccount string, finalizer string, args ...string) *appsv1.Deployment {\n\tfinalizers := make([]string, 0)\n\tif finalizer != \"\" {\n\t\tfinalizers = append(finalizers, finalizer)\n\t}\n\treturn &appsv1.Deployment{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      name,\n\t\t\tNamespace: utils.Namespace(),\n\t\t\tLabels: map[string]string{\n\t\t\t\tutils.OperandLabelKey:   operandName,\n\t\t\t\tutils.ControllerNameKey: name,\n\t\t\t},\n\t\t\tFinalizers: finalizers,\n\t\t},\n\t\tSpec: appsv1.DeploymentSpec{\n\t\t\tReplicas: utils.NewPtr(replicas),\n\t\t\tSelector: &metav1.LabelSelector{\n\t\t\t\tMatchLabels: map[string]string{\n\t\t\t\t\tutils.OperandLabelKey:   operandName,\n\t\t\t\t\t
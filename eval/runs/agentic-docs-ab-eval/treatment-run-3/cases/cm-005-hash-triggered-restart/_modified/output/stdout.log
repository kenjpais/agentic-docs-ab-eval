FromIstiodCertificate(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) (string, error) {\n\tistiodCertificate, err := r.getCertificateObject(istiocsr, resourceLabels)\n\tif err != nil {\n\t\treturn \"\", common.FromClientError(err, \"failed to fetch istiod certificate\")\n\t}\n\n\tsecretKey := client.ObjectKey{\n\t\tName:      istiodCertificate.Spec.SecretName,\n\t\tNamespace: istiodCertificate.GetNamespace(),\n\t}\n\tsecret := &corev1.Secret{}\n\tif err := r.Get(r.ctx, secretKey, secret); err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to fetch secret in issuer: %w\", err)\n\t}\n\tif err := r.updateWatchLabel(secret, istiocsr); err != nil {\n\t\treturn \"\", err\n\t}\n\n\tcertData := string(secret.Data[IstiocsrCAKeyName])\n\treturn r.createOrUpdateCAConfigMap(istiocsr, certData, resourceLabels)\n}\n```\n\n### Change 6: `createCAConfigMapFromIssuerSecret` \u2014 return `(string, error)`\n\nReplace lines 529\u2013548:\n```go\nfunc (r *Reconciler) createCAConfigMapFromIssuerSecret(istiocsr *v1alpha1.IstioCSR, issuerConfig certmanagerv1.IssuerConfig, resourceLabels map[string]string) (string, error) {\n\tif issuerConfig.CA.SecretName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"failed to fetch CA certificate configured for the %s issuer of CA type\", istiocsr.Spec.IstioCSRConfig.CertManager.IssuerRef.Name)\n\t}\n\n\tsecretKey := client.ObjectKey{\n\t\tName:      issuerConfig.CA.SecretName,\n\t\tNamespace: istiocsr.Spec.IstioCSRConfig.Istio.Namespace,\n\t}\n\tsecret := &corev1.Secret{}\n\tif err := r.Get(r.ctx, secretKey, secret); err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to fetch secret in issuer: %w\", err)\n\t}\n\tif err := r.updateWatchLabel(secret, istiocsr); err != nil {\n\t\treturn \"\", err\n\t}\n\n\tcertData := string(secret.Data[IstiocsrCAKeyName])\n\treturn r.createOrUpdateCAConfigMap(istiocsr, certData, resourceLabels)\n}\n```\n\n### Change 7: `createOrUpdateCAConfigMap` \u2014 return `(string, error)` and compute hash\n\nReplace lines 551\u2013595:\n```go\nfunc (r *Reconciler) createOrUpdateCAConfigMap(istiocsr *v1alpha1.IstioCSR, certData string, resourceLabels map[string]string) (string, error) {\n\tif certData == \"\" {\n\t\treturn \"\", fmt.Errorf(\"failed to find CA certificate\")\n\t}\n\n\tcaBundleHash := computeCABundleHash(certData)\n\n\tconfigmapKey := client.ObjectKey{\n\t\tName:      IstiocsrCAConfigMapName,\n\t\tNamespace: istiocsr.GetNamespace(),\n\t}\n\tfetched := &corev1.ConfigMap{}\n\texist, err := r.Exists(r.ctx, configmapKey, fetched)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to check if CA configmap exists: %w\", err)\n\t}\n\n\tdesired := &corev1.ConfigMap{\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      configmapKey.Name,\n\t\t\tNamespace: configmapKey.Namespace,\n\t\t\tLabels:    resourceLabels,\n\t\t},\n\t\tData: map[string]string{\n\t\t\tIstiocsrCAKeyName: certData,\n\t\t},\n\t}\n\n\tif exist && hasObjectChanged(desired, fetched) {\n\t\tr.log.V(1).Info(\"ca configmap need update\", \"name\", configmapKey)\n\t\tif err := r.UpdateWithRetry(r.ctx, desired); err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"failed to update %s configmap resource: %w\", configmapKey, err)\n\t\t}\n\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"configmap resource %s reconciled back to desired state\", configmapKey)\n\t} else {\n\t\tr.log.V(4).Info(\"configmap resource already exists and is in expected state\", \"name\", configmapKey)\n\t}\n\n\tif !exist {\n\t\tif err := r.Create(r.ctx, desired); err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"failed to create %s configmap resource: %w\", configmapKey, err)\n\t\t}\n\t\tr.eventRecorder.Eventf(istiocsr, corev1.EventTypeNormal, \"Reconciled\", \"configmap resource %s created\", configmapKey)\n\t}\n\n\treturn caBundleHash, nil\n}\n```\n\n### Change 8: Add `stampCABundleHash` function\n\nAdd after `updateVolumeWithIssuerCA` (after line 484):\n```go\n// stampCABundleHash sets the CA bundle hash annotation on the deployment's\n// pod template to trigger a rolling restart when the CA content changes.\nfunc stampCABundleHash(deployment *appsv1.Deployment, hash string) {\n\tif deployment.Spec.Template.Annotations == nil {\n\t\tdeployment.Spec.Template.Annotations = make(map[string]string)\n\t}\n\tdeployment.Spec.Template.Annotations[caConfigMapHashAnnotation] = hash\n}\n```\n\n---\n\n## File 5: MODIFY \u2014 `pkg/controller/istiocsr/utils.go`\n\n### Change: Add pod template annotations comparison in `deploymentSpecModified`\n\nIn the `deploymentSpecModified` function, replace lines 316\u2013318:\n```go\n\tif !reflect.DeepEqual(desired.Spec.Template.Labels, fetched.Spec.Template.Labels) ||\n\t\tlen(desired.Spec.Template.Spec.Containers) != len(fetched.Spec.Template.Spec.Containers) {\n\t\treturn true\n\t}\n```\n\nWith:\n```go\n\tif !reflect.DeepEqual(desired.Spec.Template.Labels, fetched.Spec.Template.Labels) ||\n\t\t!reflect.DeepEqual(desired.Spec.Template.Annotations, fetched.Spec.Template.Annotations) ||\n\t\tlen(desired.Spec.Template.Spec.Containers) != len(fetched.Spec.Template.Spec.Containers) {\n\t\treturn true\n\t}\n```\n\nThis ensures the idempotency guard works: when the CA data hasn't changed, the hash annotation matches, `deploymentSpecModified` returns `false`, and the update is skipped.\n\n---\n\n## Commands to run\n\n```bash\ncd /Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment\n\n# Verify it compiles\ngo build ./pkg/controller/istiocsr/...\n\n# Run the istiocsr tests\ngo test ./pkg/controller/istiocsr/... -v -count=1\n\n# Run the full test suite\nmake test\n```\n\n---\n\n## Summary of changes\n\n| File | Action | Purpose |\n|---|---|---|\n| `pkg/controller/istiocsr/configmaps.go` | **New** | `computeCABundleHash` \u2014 SHA-256 of PEM data |\n| `pkg/controller/istiocsr/configmaps_test.go` | **New** | Tests for hash determinism and collision resistance |\n| `pkg/controller/istiocsr/constants.go` | **Modified** | Add `caConfigMapHashAnnotation` constant |\n| `pkg/controller/istiocsr/deployments.go` | **Modified** | Thread hash through `updateVolumes` \u2192 `handleUserProvidedCA` / `handleIssuerBasedCA` \u2192 `createOrUpdateCAConfigMap`; stamp hash on pod template via `stampCABundleHash` |\n| `pkg/controller/istiocsr/utils.go` | **Modified** | Add `Spec.Template.Annotations` comparison in `deploymentSpecModified` for idempotency |\n\nThe flow mirrors trustmanager exactly: `createOrUpdateCAConfigMap` computes the hash, it bubbles up through `handleUserProvidedCA`/`handleIssuerBasedCA` \u2192 `updateVolumes` \u2192 `getDeploymentObject`, which stamps it as `operator.openshift.io/ca-configmap-hash` on the pod template. When the CA PEM data is unchanged, the hash matches the existing annotation, `deploymentSpecModified` returns false, and the update is skipped.", "stop_reason": "end_turn", "session_id": "39bbe18b-fa63-412d-8593-1709be0f4036", "total_cost_usd": 1.5252445, "usage": {"input_tokens": 2833, "cache_creation_input_tokens": 96870, "cache_read_input_tokens": 497034, "output_tokens": 26285, "server_tool_use": {"web_search_requests": 0, "web_fetch_requests": 0}, "service_tier": "standard", "cache_creation": {"ephemeral_1h_input_tokens": 0, "ephemeral_5m_input_tokens": 96870}, "inference_geo": "", "iterations": [], "speed": "standard"}, "modelUsage": {"claude-opus-4-6": {"inputTokens": 2833, "outputTokens": 26285, "cacheReadInputTokens": 497034, "cacheCreationInputTokens": 96870, "webSearchRequests": 0, "costUSD": 1.5252445, "contextWindow": 200000, "maxOutputTokens": 64000}}, "permission_denials": [], "terminal_reason": "completed", "fast_mode_state": "off", "uuid": "b57eea9f-a59f-4d29-b700-22396eae0335", "timestamp": "2026-07-20T13:53:49.709Z"}
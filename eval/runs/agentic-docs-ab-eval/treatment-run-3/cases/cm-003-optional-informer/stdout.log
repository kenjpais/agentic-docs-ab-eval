tioCSREnabled := features.IsIstioCSRFeatureGateEnabled()\n146\t\ttrustManagerEnabled := featureStatus.IsTrustManagerFeatureGateEnabled()\n147\t\n148\t\tif istioCSREnabled || trustManagerEnabled {\n149\t\t\t// Create unified manager for all enabled operand controllers\n150\t\t\tmanager, err := NewControllerManager(ControllerConfig{\n151\t\t\t\tEnableIstioCSR:     istioCSREnabled,\n152\t\t\t\tEnableTrustManager: trustManagerEnabled,\n153\t\t\t})\n154\t\t\tif err != nil {\n155\t\t\t\treturn fmt.Errorf(\"failed to create unified controller manager: %w\", err)\n156\t\t\t}\n157\t\n158\t\t\tgo func() {\n159\t\t\t\tif err := manager.Start(ctx); err != nil {\n160\t\t\t\t\tctrl.Log.Error(err, \"failed to start unified controller manager\")\n161\t\t\t\t}\n162\t\t\t}()\n163\t\t}\n164\t\n165\t\t<-ctx.Done()\n166\t\treturn nil\n167\t}\n168\t\n169\t// setupFeatureGates applies operator feature flags from UnsupportedAddonFeatures\n170\t// (--unsupported-addon-features) and builds cluster-side FeatureGateState by reading\n171\t// featuregates/cluster when served. Transient discovery or featuregates/cluster read errors\n172\t// are retried up to three times with 30s backoff; persistent failure leaves stateErr set\n173\t// on FeatureGateState without aborting the rest of startup. Returns an error only for invalid\n174\t// addon feature syntax or if ctx is canceled while waiting between retries.\n175\tfunc setupFeatureGates(ctx context.Context, configClient configv1client.Interface) (*features.FeatureGateState, error) {\n176\t\tconst (\n177\t\t\t// maxFeatureGateAttempts caps how many times we call NewFeatureGateState when discovery or\n178\t\t\t// featuregates/cluster read fails (excluding ErrNilConfigClient, which is not retried).\n179\t\t\tmaxFeatureGateAttempts = 3\n180\t\t\tfeatureGateRetryDelay  = 30 * time.Second\n181\t\t)\n182\t\n183\t\tvar featureStatus *features.FeatureGateState\n184\t\n185\t\tif err := features.SetupWithFlagValue(UnsupportedAddonFeatures); err != nil {\n186\t\t\treturn nil, fmt.Errorf(\"failed to parse addon features: %w\", err)\n187\t\t}\n188\t\n189\t\tfor attempt := 1; attempt <= maxFeatureGateAttempts; attempt++ {\n190\t\t\tfeatureStatus = features.NewFeatureGateState(ctx, configClient)\n191\t\t\terr := featureStatus.Err()\n192\t\t\tif err == nil {\n193\t\t\t\tbreak\n194\t\t\t}\n195\t\t\tif attempt == maxFeatureGateAttempts {\n196\t\t\t\tctrl.Log.Info(\"feature gate validation failed after max attempts; continuing with last state\",\n197\t\t\t\t\t\"error\", err, \"attempts\", attempt)\n198\t\t\t\tbreak\n199\t\t\t}\n200\t\t\tctrl.Log.Info(\"failed to validate featuregate settings, retrying\",\n201\t\t\t\t\"error\", err, \"attempt\", attempt, \"maxAttempts\", maxFeatureGateAttempts)\n202\t\t\tselect {\n203\t\t\tcase <-ctx.Done():\n204\t\t\t\treturn nil, fmt.Errorf(\"context cancelled: %w\", ctx.Err())\n205\t\t\tcase <-time.After(featureGateRetryDelay):\n206\t\t\t}\n207\t\t}\n208\t\n209\t\treturn featureStatus, nil\n210\t}\n211\t"}]},"parent_tool_use_id":null,"session_id":"f1d9d33f-809c-4c6f-9f52-555c6d8bf2af","uuid":"b3e9534a-4d54-4361-b2e2-6590e5f01e83","timestamp":"2026-07-20T13:44:47.963Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/operator/starter.go","content":"package operator\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tapiextensionsclient \"k8s.io/apiextensions-apiserver/pkg/client/clientset/clientset\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\n\tconfigv1 \"github.com/openshift/api/config/v1\"\n\tconfigv1client \"github.com/openshift/client-go/config/clientset/versioned\"\n\tconfiginformers \"github.com/openshift/client-go/config/informers/externalversions\"\n\t\"github.com/openshift/library-go/pkg/controller/controllercmd\"\n\t\"github.com/openshift/library-go/pkg/operator/resource/resourceapply\"\n\t\"github.com/openshift/library-go/pkg/operator/sta
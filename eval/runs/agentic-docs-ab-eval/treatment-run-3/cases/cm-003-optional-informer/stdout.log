 operator optionally enables, and is provided as a runtime arg.\n43\tvar UnsupportedAddonFeatures string\n44\t\n45\tfunc RunOperator(ctx context.Context, cc *controllercmd.ControllerContext) error {\n46\t\t// Set controller-runtime logger before any ctrl.Log usage (e.g. NewControllerManager).\n47\t\t// Uses klog so --v flag controls verbosity for both library-go and controller-runtime.\n48\t\tctrl.SetLogger(klog.NewKlogr())\n49\t\n50\t\tkubeClient, err := kubernetes.NewForConfig(cc.ProtoKubeConfig)\n51\t\tif err != nil {\n52\t\t\treturn err\n53\t\t}\n54\t\n55\t\tcertManagerOperatorClient, err := certmanoperatorclient.NewForConfig(cc.KubeConfig)\n56\t\tif err != nil {\n57\t\t\treturn err\n58\t\t}\n59\t\n60\t\tapiExtensionsClient, err := apiextensionsclient.NewForConfig(cc.KubeConfig)\n61\t\tif err != nil {\n62\t\t\treturn err\n63\t\t}\n64\t\n65\t\tcertManagerInformers := certmanoperatorinformers.NewSharedInformerFactory(certManagerOperatorClient, resyncInterval)\n66\t\n67\t\toperatorClient := &operatorclient.OperatorClient{\n68\t\t\tInformers: certManagerInformers,\n69\t\t\tClient:    certManagerOperatorClient.OperatorV1alpha1(),\n70\t\t\tClock:     cc.Clock,\n71\t\t}\n72\t\n73\t\t// perform version changes to the version getter prior to tying it up in the status controller\n74\t\t// via change-notification channel so that it only updates operator version in status once\n75\t\t// either of the workloads syncs.\n76\t\tversionRecorder := status.NewVersionGetter()\n77\t\tversionRecorder.SetVersion(\"operator\", status.VersionForOperatorFromEnv())\n78\t\n79\t\tkubeInformersForNamespaces := v1helpers.NewKubeInformersForNamespaces(kubeClient,\n80\t\t\t\"\",\n81\t\t\t\"kube-system\",\n82\t\t\toperatorclient.TargetNamespace,\n83\t\t)\n84\t\n85\t\tconfigClient, err := configv1client.NewForConfig(cc.KubeConfig)\n86\t\tif err != nil {\n87\t\t\treturn err\n88\t\t}\n89\t\n90\t\tinfraGVR := configv1.GroupVersion.WithResource(\"infrastructures\")\n91\t\toptInfraInformer, err := uti
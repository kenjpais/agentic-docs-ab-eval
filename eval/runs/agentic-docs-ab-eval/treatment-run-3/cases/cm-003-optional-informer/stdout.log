{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01RiC8PJ2oKg85ksanjHkFUu","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"maps\"\n7\t\t\"reflect\"\n8\t\n9\t\tadmissionregistrationv1 \"k8s.io/api/admissionregistration/v1\"\n10\t\tappsv1 \"k8s.io/api/apps/v1\"\n11\t\tcorev1 \"k8s.io/api/core/v1\"\n12\t\trbacv1 \"k8s.io/api/rbac/v1\"\n13\t\t\"k8s.io/apimachinery/pkg/runtime\"\n14\t\t\"k8s.io/apimachinery/pkg/runtime/serializer\"\n15\t\tutilerrors \"k8s.io/apimachinery/pkg/util/errors\"\n16\t\t\"k8s.io/client-go/util/retry\"\n17\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n18\t\t\"sigs.k8s.io/controller-runtime/pkg/controller/controllerutil\"\n19\t\n20\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n21\t\n22\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n23\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n24\t)\n25\t\n26\tvar (\n27\t\tscheme = runtime.NewScheme()\n28\t\tcodecs = serializer.NewCodecFactory(scheme)\n29\t)\n30\t\n31\tfunc init() {\n32\t\tif err := corev1.AddToScheme(scheme); err != nil {\n33\t\t\tpanic(err)\n34\t\t}\n35\t\tif err := appsv1.AddToScheme(scheme); err != nil {\n36\t\t\tpanic(err)\n37\t\t}\n38\t\tif err := rbacv1.AddToScheme(scheme); err != nil {\n39\t\t\tpanic(err)\n40\t\t}\n41\t\tif err := admissionregistrationv1.AddToScheme(scheme); err != nil {\n42\t\t\tpanic(err)\n43\t\t}\n44\t\tif err := certmanagerv1.AddToScheme(scheme); err != nil {\n45\t\t\tpanic(err)\n46\t\t}\n47\t}\n48\t\n49\t// updateStatus is for updating the status subresource of trustmanager.openshift.operator.io.\n50\tfunc (r *Reconciler) updateStatus(ctx context.Context, changed *v1alpha1.TrustManager) error {\n51\t\tnamespacedName := client.ObjectKeyFromObject(changed)\n52\t\tif err := retry.RetryOnConflict(retry.DefaultRetry, func() error {\n53\t\t\tr.log.V(4).Info(\"updating trustmanager.openshift.operator.io status\", \"request\", namespacedName)\n54\t\t\tcurrent := &v1alpha1.TrustManager{}\n55\t\t\tif err := r.Get(ctx, namespacedName, current); err != nil {\n56\t\t\t\treturn fmt.Errorf(\"failed to fetch trustmanager.openshift.operator.io %q for status update: %w\", namespacedName, err)\n57\t\t\t}\n58\t\t\tchanged.Status.DeepCopyInto(&current.Status)\n59\t\n60\t\t\tif err := r.StatusUpdate(ctx, current); err != nil {\n61\t\t\t\treturn fmt.Errorf(\"failed to update trustmanager.openshift.operator.io %q status: %w\", namespacedName, err)\n62\t\t\t}\n63\t\n64\t\t\treturn nil\n65\t\t}); err != nil {\n66\t\t\treturn err\n67\t\t}\n68\t\n69\t\treturn nil\n70\t}\n71\t\n72\t// addFinalizer adds finalizer to trustmanager.openshift.operator.io resource.\n73\tfunc (r *Reconciler) addFinalizer(ctx context.Context, trustManager *v1alpha1.TrustManager) error {\n74\t\tnamespacedName := client.ObjectKeyFromObject(trustManager)\n75\t\tif !controllerutil.ContainsFinalizer(trustManager, finalizer) {\n76\t\t\tif !controllerutil.AddFinalizer(trustManager, finalizer) {\n77\t\t\t\treturn fmt.Errorf(\"failed to add finalizer %q on trustmanager.openshift.operator.io %q\", finalizer, namespacedName)\n78\t\t\t}\n79\t\n80\t\t\t// update trustmanager.openshift.operator.io on adding finalizer.\n81\t\t\tif err := r.UpdateWithRetry(ctx, trustManager); err != nil {\n82\t\t\t\treturn fmt.Errorf(\"failed to add finalizers on %q trustmanager.openshift.operator.io with %w\", namespacedName, err)\n83\t\t\t}\n84\t\n85\t\t\tupdated := &v1alpha1.TrustManager{}\n86\t\t\tif err := r.Get(ctx, namespacedName, updated); err != nil {\n87\t\t\t\treturn fmt.Errorf(\"failed to fetch trustmanager.openshift.operator.io %q after updating finalizers: %w\", namespacedName, err)\n88\t\t\t}\n89\t\t\tupdated.DeepCopyInto(trustManager)\n90\t\t\treturn nil\n91\t\t}\n92\t\treturn nil\n93\t}\n94\t\n95\t// removeFinalizer removes finalizers added to trustmanager.openshift.operator.io resource.\n96\tfunc (r *Reconci
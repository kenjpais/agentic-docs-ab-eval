ersion().String(),\n234\t\t\t\t},\n235\t\t\t\tclock.RealClock{},\n236\t\t\t),\n237\t\t}).SetupWithManager(mgr), unableToCreateController, controllerKey, \"ClusterPodPlacementConfig\")\n238\t\tmust((&multiarchv1beta1.ClusterPodPlacementConfig{}).SetupWebhookWithManager(mgr), unableToCreateController,\n239\t\t\tcontrollerKey, \"ClusterPodPlacementConfigConversionWebhook\")\n240\t}\n241\t\n242\tfunc RunClusterPodPlacementConfigOperandControllers(mgr ctrl.Manager) {\n243\t\tconfig := ctrl.GetConfigOrDie()\n244\t\tclientset := kubernetes.NewForConfigOrDie(config)\n245\t\n246\t\tmust((&podplacement.PodReconciler{\n247\t\t\tClient:    mgr.GetClient(),\n248\t\t\tAPIReader: mgr.GetAPIReader(),\n249\t\t\tScheme:    mgr.GetScheme(),\n250\t\t\tClientSet: clientset,\n251\t\t\tRecorder:  mgr.GetEventRecorderFor(utils.OperatorName), //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n252\t\t}).SetupWithManager(mgr),\n253\t\t\tunableToCreateController, controllerKey, \"PodReconciler\")\n254\t\n255\t\tmust(mgr.Add(podplacement.NewGlobalPullSecretSyncer(clientset, globalPullSecretNamespace, globalPullSecretName)),\n256\t\t\tunableToAddRunnable, runnableKey, \"GlobalPullSecretSyncer\")\n257\t}\n258\t\n259\tfunc RunClusterPodPlacementConfigOperandWebHook(mgr ctrl.Manager) {\n260\t\tconfig := ctrl.GetConfigOrDie()\n261\t\tclientset := kubernetes.NewForConfigOrDie(config)\n262\t\tpool, err := ants.NewMultiPool(16, 16, ants.LeastTasks,\n263\t\t\tants.WithPreAlloc(true))\n264\t\tmust(err, \"unable to create multi pool for the webhook's event messages\")\n265\t\tpostFuncs = append(postFuncs, func() {\n266\t\t\terr = pool.ReleaseTimeout(30 * time.Second)\n267\t\t\tif err != nil {\n268\t\t\t\tsetupLog.Error(err, \"failed to release the worker pool\")\n269\t\t\t}\n270\t\t\tants.Release()\n271\t\t})\n272\t\thandler := podplacement.NewPodSchedulingGateMutatingWebHook(mgr.GetClient(), clientset, mgr.GetScheme(),\n273\t\t\tmgr.GetEventRecorderFor(utils.OperatorName), pool) //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n274\t\tmgr.GetWebhookServer().Register(\"/add-pod-scheduling-gate\", &webhook.Admission{Handler: handler})\n275\t}\n276\t\n277\tfunc RunPodPlacementConfigWebHook(mgr ctrl.Manager) {\n278\t\tmgr.GetWebhookServer().Register(\"/validate-multiarch-openshift-io-v1beta1-podplacementconfig\",\n279\t\t\t&webhook.Admission{Handler: podplacementconfig.NewPodPlacementConfigWebhook(mgr.GetAPIReader(), mgr.GetScheme())})\n280\t}\n281\t\n282\tfunc RunENoExecEventControllers(mgr ctrl.Manager) {\n283\t\tconfig := ctrl.GetConfigOrDie()\n284\t\tclientset := kubernetes.NewForConfigOrDie(config)\n285\t\tmust(enoexeceventhandler.NewReconciler(\n286\t\t\tmgr.GetClient(),\n287\t\t\tclientset,\n288\t\t\tmgr.GetScheme(),\n289\t\t\tmgr.GetEventRecorderFor(utils.EnoexecControllerName), //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n290\t\t).SetupWithManager(mgr), unableToCreateController, controllerKey, \"ENoExecEventController\")\n291\t}\n292\t\n293\tfunc validateFlags() error {\n294\t\tif !enableOperator && !enableClusterPodPlacementConfigOperandControllers && !enableClusterPodPlacementConfigOperandWebHook && !enableENoExecEventControllers {\n295\t\t\treturn errors.New(\"at least one of the following flags must be set: --enable-operator, --enable-ppc-controllers, --enable-ppc-webhook, --enable-enoexec-event-controllers\")\n296\t\t}\n297\t\t// no more than one of the flags can be set\n298\t\tif btoi(enableOperator)+btoi(enableClusterPodPlacementConfigOperandControllers)+btoi(enableClusterPodPlacementConfigOperandWebHook)+btoi(enableENoExecEventControllers) > 1 {\n299\t\t\treturn errors.New(\"only one of the following flags can be set: --enable-operator, --enable-ppc-controllers, --enable-ppc-webhook, --enable-enoexec-event-controllers\")\n300\t\t}\n301\t\treturn nil\n302\t}\n303\t\n304\tfunc bindFlags() {\n305\t\tflag.StringVar(&metricsAddr, \"metrics-bind-address\", \":8080\", \"The address the metric endpoint binds to.\")\n306\t\tflag.StringVar(&probeAddr, \"health-probe-bind-address\", \":8081\", \"The address the probe endpoint binds to.\")\n307\t\tflag.BoolVar(&enableLeaderElection, \"leader-elect\", false,\n308\t\t\t\"Enable leader election for controller manager. \"+\n309\t\t\t\t\"Enabling this will ensure there is only one active controller manager.\")\n310\t\tflag.StringVar(&certDir, \"cert-dir\", \"/var/run/manager/tls\", \"The directory where the TLS certs are stored\")\n311\t\t// TODO: Change the defaults to match a local secret; the OCP specific settings will be provided by the operator\n312\t\tflag.StringVar(&globalPullSecretNamespace, \"global-pull-secret-namespace\", \"openshift-config\", \"The namespace where the global pull secret is stored\")\n313\t\tflag.StringVar(&globalPullSecretName, \"global-pull-secret-name\", \"pull-secret\", \"The name of the global pull secret\")\n314\t\tflag.StringVar(&registryCertificatesConfigMapName, \"registry-certificates-configmap-name\", \"image-registry-certificates\", \"The name of the configmap that contains the registry certificates\")\n315\t\tflag.BoolVar(&enableClusterPodPlacementConfigOperandWebHook, \"enable-ppc-webhook\", false, \"Enable the pod placement config operand webhook\")\n316\t\tflag.BoolVar(&enableClusterPodPlacementConfigOperandControllers, \"enable-ppc-controllers\", false, \"Enable the pod placement config operand controllers\")\n317\t\tflag.BoolVar(&enableOperator, \"enable-operator\", false, \"Enable the operator\")\n318\t\tflag.BoolVar(&enableCPPCInformer, \"enable-cppc-informer\", false, \"Enable informer for ClusterPodPlacementConfig\")\n319\t\tflag.BoolVar(&enableENoExecEventControllers, \"enable-enoexec-event-controllers\", false, \"Enable the ENoExecEvent controllers\")\n320\t\t// This may be deprecated in the future. It is used to support the current way of setting the log level for operands\n321\t\t// If operands will start to support a controller that watches the ClusterPodPlacementConfig, this flag may be removed\n322\t\t// and the log level will be set in the ClusterPodPlacementConfig at runtime (with no need for reconciliation)\n323\t\tflag.IntVar(&initialLogLevel, \"initial-log-level\", common.LogVerbosityLevelNormal.ToZapLevelInt(), \"Initial log level. Converted to zap\")\n324\t\tklog.InitFlags(nil)\n325\t\tflag.Parse()\n326\t\t// Set the Log Level as AtomicLevel to allow runtime changes\n327\t\tutils.AtomicLevel = zapuber.NewAtomicLevelAt(zapcore.Level(int8(-initialLogLevel))) // #nosec G115 -- initialLogLevel is constrained to 0-3 range\n328\t\tzapLogger := zap.New(zap.Level(utils.AtomicLevel), zap.UseDevMode(false))\n329\t\tklog.SetLogger(zapLogger)\n330\t\tctrllog.SetLogger(zapLogger)\n331\t}\n332\t\n333\tfunc must(err error, msg string, keysAndValues ...interface{}) {\n334\t\tif err != nil {\n335\t\t\tsetupLog.Error(err, msg, keysAndValues...)\n336\t\t\tos.Exit(1)\n337\t\t}\n338\t}\n339\t\n340\tfunc btoi(b bool) int {\n341\t\tif b {\n342\t\t\treturn 1\n343\t\t}\n344\t\treturn 0\n345\t}\n346\t"}]},"parent_tool_use_id":null,"session_id":"68cd6c5c-66fa-4843-b007-051a183edb70","uuid":"7e70a10d-85d0-404a-b3dd-e7d067cb2084","timestamp":"2026-07-20T13:58:07.331Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/multiarch-tuning-operator-treatment/cmd/main.go","content":"/*\nCopyright 2023 Red Hat, Inc.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage main\n\nim
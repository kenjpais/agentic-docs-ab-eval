{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01FLDH3aDzvSscrYy9MYPpkq","type":"tool_result","content":"1\tpackage v1alpha1\n2\t\n3\timport (\n4\t\tcorev1 \"k8s.io/api/core/v1\"\n5\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n6\t)\n7\t\n8\tfunc init() {\n9\t\tSchemeBuilder.Register(&TrustManager{}, &TrustManagerList{})\n10\t}\n11\t\n12\t// TrustManagerList contains a list of TrustManager resources.\n13\t//\n14\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n15\t// +kubebuilder:object:root=true\n16\ttype TrustManagerList struct {\n17\t\tmetav1.TypeMeta `json:\",inline\"`\n18\t\n19\t\t// metadata is the standard list's metadata.\n20\t\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n21\t\tmetav1.ListMeta `json:\"metadata\"`\n22\t\tItems           []TrustManager `json:\"items\"`\n23\t}\n24\t\n25\t// TrustManager describes the configuration and information about the managed trust-manager deployment.\n26\t// The name must be `cluster` to make TrustManager a singleton, allowing only one instance per cluster.\n27\t// When a TrustManager CR is created, trust-manager operand is deployed in the cert-manager namespace.\n28\t//\n29\t// +genclient\n30\t// +genclient:nonNamespaced\n31\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n32\t// +kubebuilder:object:root=true\n33\t// +kubebuilder:subresource:status\n34\t// +kubebuilder:resource:path=trustmanagers,scope=Cluster,categories={cert-manager-operator, trust-manager},shortName=trustmanager;tm\n35\t// +kubebuilder:printcolumn:name=\"Ready\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].status\"\n36\t// +kubebuilder:printcolumn:name=\"Message\",type=\"string\",JSONPath=\".status.conditions[?(@.type=='Ready')].message\"\n37\t// +kubebuilder:printcolumn:name=\"AGE\",type=\"date\",JSONPath=\".metadata.creationTimestamp\"\n38\t// +kubebuilder:metadata:labels={\"app.kubernetes.io/name=trustmanager\", \"app.kubernetes.io/part-of=cert-manager-operator\"}\n39\t// +kubebuilder:validation:XValidation:rule=\"self.metadata.name == 'cluster'\",message=\"TrustManager is a singleton, .metadata.name must be 'cluster'\"\n40\t// +operator-sdk:csv:customresourcedefinitions:displayName=\"TrustManager\"\n41\ttype TrustManager struct {\n42\t\tmetav1.TypeMeta `json:\",inline\"`\n43\t\n44\t\t// metadata is the standard object's metadata.\n45\t\t// More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#metadata\n46\t\t// +required\n47\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n48\t\n49\t\t// spec is the specification of the desired behavior of the TrustManager.\n50\t\t// +kubebuilder:validation:Required\n51\t\t// +required\n52\t\tSpec TrustManagerSpec `json:\"spec\"`\n53\t\n54\t\t// status is the most recently observed status of the TrustManager.\n55\t\t// +kubebuilder:validation:Optional\n56\t\t// +optional\n57\t\tStatus TrustManagerStatus `json:\"status,omitempty\"`\n58\t}\n59\t\n60\t// TrustManagerSpec defines the desired state of TrustManager.\n61\t// Note: trust-manager operand is always deployed in the cert-manager namespace.\n62\ttype TrustManagerSpec struct {\n63\t\t// trustManagerConfig configures the trust-manager operand's behavior.\n64\t\t// +kubebuilder:validation:Required\n65\t\t// +required\n66\t\tTrustManagerConfig TrustManagerConfig `json:\"trustManagerConfig\"`\n67\t\n68\t\t// controllerConfig configures the operator's behavior for resource creation.\n69\t\t// +kubebuilder:validation:Optional\n70\t\t// +optional\n71\t\tControllerConfig TrustManagerControllerConfig `json:\"controllerConfig,omitempty\"`\n72\t}\n73\t\n74\t// TrustManagerConfig configures the trust-manager operand's behavior.\n75\ttype TrustManagerConfig struct {\n76\t\t// logLevel configures the verbosity of trust-manager logging.\n77\t\t// Follows [Kubernetes logging guidelines](https://github.com/kubernetes/community/blob/master/contributors/devel/sig-instrumentation/logging.md#what-method-to-use).\n78\t\t// +kubebuilder:default:=1\n79\t\t// +kubebuilder:validation:Minimum:=1\n80\t\t// +kubebuilder:validation:Maximum:=5\n81\t\t// +kubebuilder:validation:Optional\n82\t\t// +optional\n83\t\tLogLevel int32 `json:\"logLevel,omitempty\"`\n84\t\n85\t\t// logFormat specifies the output format for trust-manager logging.\n86\t\t// Supported formats are \"text\" and \"json\".\n87\t\t// +kubebuilder:validation:Enum:=\"text\";\"json\"\n88\t\t// +kubebuilder:default:=\"text\"\n89\t\t// +kubebuilder:validation:Optional\n90\t\t// +optional\n91\t\tLogFormat string `json:\"logFormat,omitempty\"`\n92\t\n93\t\t// trustNamespace is the namespace where trust-manager looks for trust sources\n94\t\t// (ConfigMaps and Secrets containing CA certificates).\n95\t\t// Defaults to \"cert-manager\" if not specified.\n96\t\t// This field is immutable once set.\n97\t\t// This field can have a maximum of 63 characters.\n98\t\t// +kubebuilder:default:=\"cert-manager\"\n99\t\t// +kubebuilder:validation:MinLength:=1\n100\t\t// +kubebuilder:validation:MaxLength:=63\n101\t\t// +kubebuilder:validation:XValidation:rule=\"oldSelf == '' || self == oldSelf\",message=\"trustNamespace is immutable once set\"\n102\t\t// +kubebuilder:validation:Optional\n103\t\t// +optional\n104\t\tTrustNamespace string `json:\"trustNamespace,omitempty\"`\n105\t\n106\t\t// secretTargets configures whether trust-manager can write trust bundles to Secrets.\n107\t\t// +kubebuilder:validation:Optional\n108\t\t// +optional\n109\t\tSecretTargets SecretTargetsConfig `json:\"secretTargets,omitempty\"`\n110\t\n111\t\t// filterExpiredCertificates controls whether trust-manager filters out\n112\t\t// expired certificates from trust bundles before distributing them.\n113\t\t// When set to \"Enabled\", expired certificates are removed from bundles.\n114\t\t// When set to \"Disabled\", expired certificates are included (default behavior).\n115\t\t// +kubeb
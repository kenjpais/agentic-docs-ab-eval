est the removal of the scheduling gate. However, since the pod is mutated and the reconciler\n42\t\t\t\t\t// removes the scheduling gate concurrently, we cannot ensure that the scheduling gate is added\n43\t\t\t\t\t// and that the following Eventually works on a pod with the scheduling gate.\n44\t\t\t\t\t// Waiting for the pod to be mutated is not enough, as the pod could be mutated and the reconciler\n45\t\t\t\t\t// could have removed the scheduling gate before our check.\n46\t\t\t\t\tEventually(func(g Gomega) {\n47\t\t\t\t\t\t// Get pod from the API server\n48\t\t\t\t\t\terr := k8sClient.Get(ctx, crclient.ObjectKeyFromObject(pod), pod)\n49\t\t\t\t\t\tg.Expect(err).NotTo(HaveOccurred(), \"failed to get pod\", err)\n50\t\t\t\t\t\tg.Expect(pod.Spec.SchedulingGates).NotTo(ContainElement(corev1.PodSchedulingGate{\n51\t\t\t\t\t\t\tName: utils.SchedulingGateName,\n52\t\t\t\t\t\t}), \"scheduling gate not removed\")\n53\t\t\t\t\t\tg.Expect(pod.Labels).To(HaveKeyWithValue(utils.SchedulingGateLabel, utils.SchedulingGateLabelValueRemoved),\n54\t\t\t\t\t\t\t\"scheduling gate annotation not found\")\n55\t\t\t\t\t\tg.Expect(pod.Labels).To(HaveKeyWithValue(utils.PreferredNodeAffinityLabel, utils.NodeAffinityLabelValueSet),\n56\t\t\t\t\t\t\t\"preferred node affinity label not found\")\n57\t\t\t\t\t\tg.Expect(pod.Labels).To(HaveKeyWithValue(utils.NodeAffinityLabel, utils.NodeAffinityLabelValueSet),\n58\t\t\t\t\t\t\t\"node affinity label not found\")\n59\t\t\t\t\t}).Should(Succeed(), \"failed to remove scheduling gate from pod\")\n60\t\t\t\t\tEventually(func(g Gomega) {\n61\t\t\t\t\t\tg.Expect(*pod).To(HaveEquivalentNodeAffinity(\n62\t\t\t\t\t\t\t&corev1.NodeAffinity{\n63\t\t\t\t\t\t\t\tRequiredDuringSchedulingIgnoredDuringExecution: &corev1.NodeSelector{\n64\t\t\t\t\t\t\t\t\tNodeSelectorTerms: []corev1.NodeSelectorTerm{\n65\t\t\t\t\t\t\t\t\t\t{\n66\t\t\t\t\t\t\t\t\t\t\tMatchExpressions: []corev1.NodeSelectorRequirement{\n67\t\t\t\t\t\t\t\t\t\t\t\t{\n68\t\t\t\t\t\t\t\t\t\t\t\t\tKey:
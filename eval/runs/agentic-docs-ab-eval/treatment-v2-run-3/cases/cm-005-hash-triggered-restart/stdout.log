els, fetched.Spec.Template.Labels) ||\n+\t\t!reflect.DeepEqual(desired.Spec.Template.Annotations, fetched.Spec.Template.Annotations) ||\n \t\tlen(desired.Spec.Template.Spec.Containers) != len(fetched.Spec.Template.Spec.Containers) {\n \t\treturn true\n \t}\n```\n\n---\n\n### 6. New file: `pkg/controller/istiocsr/configmaps_test.go`\n\n```go\npackage istiocsr\n\nimport (\n\t\"context\"\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"testing\"\n\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\tapierrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/types\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common/fakes\"\n)\n\nfunc TestComputeCABundleHash(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tcaBundle string\n\t}{\n\t\t{\n\t\t\tname:     \"computes deterministic SHA-256 hash\",\n\t\t\tcaBundle: \"-----BEGIN CERTIFICATE-----\\nMIIBfake\\n-----END CERTIFICATE-----\\n\",\n\t\t},\n\t\t{\n\t\t\tname:     \"different content produces different hash\",\n\t\t\tcaBundle: \"-----BEGIN CERTIFICATE-----\\nMIIBother\\n-----END CERTIFICATE-----\\n\",\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\thash := computeCABundleHash(tt.caBundle)\n\n\t\t\texpected := sha256.Sum256([]byte(tt.caBundle))\n\t\t\texpectedHex := hex.EncodeToString(expected[:])\n\n\t\t\tif hash != expectedHex {\n\t\t\t\tt.Errorf(\"computeCABundleHash() = %q, want %q\", hash, expectedHex)\n\t\t\t}\n\t\t\tif len(hash) != 64 {\n\t\t\t\tt.Errorf(\"expected 64-char hex string, got %d chars\", len(hash))\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestUpdateCABundleHashAnnotation(t *testing.T) {\n\ttests := []struct {\n\t\tname                string\n\t\tcaBundleHash        string\n\t\texistingAnnotations map[string]string\n\t\twantAnnotations     map[string]string\n\t}{\n\t\t{\n\t\t\tname:            \"stamps hash on deployment with no existing annotations\",\n\t\t\tcaBundleHash:    \"abc123\",\n\t\t\twantAnnotations: map[string]string{caBundleHashAnnotation: \"abc123\"},\n\t\t},\n\t\t{\n\t\t\tname:         \"preserves existing annotations and adds hash\",\n\t\t\tcaBundleHash: \"def456\",\n\t\t\texistingAnnotations: map[string]string{\n\t\t\t\t\"existing-key\": \"existing-value\",\n\t\t\t},\n\t\t\twantAnnotations: map[string]string{\n\t\t\t\t\"existing-key\":         \"existing-value\",\n\t\t\t\tcaBundleHashAnnotation: \"def456\",\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname:            \"skips when hash is empty\",\n\t\t\tcaBundleHash:    \"\",\n\t\t\twantAnnotations: nil,\n\t\t},\n\t\t{\n\t\t\tname:         \"skips when hash is empty with existing annotations\",\n\t\t\tcaBundleHash: \"\",\n\t\t\texistingAnnotations: map[string]string{\n\t\t\t\t\"existing-key\": \"existing-value\",\n\t\t\t},\n\t\t\twantAnnotations: map[string]string{\n\t\t\t\t\"existing-key\": \"existing-value\",\n\t\t\t},\n\t\t},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tdeployment := &appsv1.Deployment{\n\t\t\t\tSpec: appsv1.DeploymentSpec{\n\t\t\t\t\tTemplate: corev1.PodTemplateSpec{\n\t\t\t\t\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\t\t\t\t\tAnnotations: tt.existingAnnotations,\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t}\n\n\t\t\tupdateCABundleHashAnnotation(deployment, tt.caBundleHash)\n\n\t\t\tgot := deployment.Spec.Template.Annotations\n\t\t\tif tt.wantAnnotations == nil {\n\t\t\t\tif got != nil && len(got) != len(tt.existingAnnotations) {\n\t\t\t\t\tt.Errorf(\"annotations = %v, want unchanged from %v\", got, tt.existingAnnotations)\n\t\t\t\t}\n\t\t\t\treturn\n\t\t\t}\n\t\t\tfor k, v := range tt.wantAnnotations {\n\t\t\t\tif got[k] != v {\n\t\t\t\t\tt.Errorf(\"annotation %q = %q, want %q\", k, got[k], v)\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunc TestReadTrustedCABundle(t *testing.T
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_017zg57dEkLTUzEDjjkMmmXH","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"fmt\"\n5\t\t\"maps\"\n6\t\t\"os\"\n7\t\t\"reflect\"\n8\t\t\"slices\"\n9\t\n10\t\tappsv1 \"k8s.io/api/apps/v1\"\n11\t\tcorev1 \"k8s.io/api/core/v1\"\n12\t\t\"k8s.io/utils/ptr\"\n13\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n14\t\n15\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n16\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n17\t\t\"github.com/openshift/cert-manager-operator/pkg/operator/assets\"\n18\t)\n19\t\n20\tfunc (r *Reconciler) createOrApplyDeployment(trustManager *v1alpha1.TrustManager, resourceLabels, resourceAnnotations map[string]string, caBundleHash string) error {\n21\t\tdesired, err := r.getDeploymentObject(trustManager, resourceLabels, resourceAnnotations, caBundleHash)\n22\t\tif err != nil {\n23\t\t\treturn err\n24\t\t}\n25\t\n26\t\tdeploymentName := fmt.Sprintf(\"%s/%s\", desired.GetNamespace(), desired.GetName())\n27\t\tr.log.V(4).Info(\"reconciling deployment resource\", \"name\", deploymentName)\n28\t\n29\t\texisting := &appsv1.Deployment{}\n30\t\texists, err := r.Exists(r.ctx, client.ObjectKeyFromObject(desired), existing)\n31\t\tif err != nil {\n32\t\t\treturn common.FromClientError(err, \"failed to check if deployment %q exists\", deploymentName)\n33\t\t}\n34\t\tif exists && !deploymentModified(desired, existing) {\n35\t\t\tr.log.V(4).Info(\"deployment resource exists and is in desired state\", \"name\", deploymentName)\n36\t\t\treturn nil\n37\t\t}\n38\t\n39\t\tr.log.V(2).Info(\"deployment resource has been modified, updating to desired state\", \"name\", deploymentName)\n40\t\tif err := r.Patch(r.ctx, desired, client.Apply, client.FieldOwner(fieldOwner), client.ForceOwnership); err != nil {\n41\t\t\treturn common.FromClientError(err, \"failed to apply deployment %q\", deploymentName)\n42\t\t}\n43\t\n44\t\tr.eventRecorder.Eventf(trustManager, corev1.EventTypeNormal, \"Reconciled\", \"deployment resource %s applied\", deploymentName)\n45\t\treturn nil\n46\t}\n47\t\n48\tfunc (r *Reconciler) getDeploymentObject(trustManager *v1alpha1.TrustManager, resourceLabels, resourceAnnotations map[string]string, caBundleHash string) (*appsv1.Deployment, error) {\n49\t\tdeployment := common.DecodeObjBytes[*appsv1.Deployment](codecs, appsv1.SchemeGroupVersion, assets.MustAsset(deploymentAssetName))\n50\t\n51\t\tif err := validateDeploymentManifest(deployment); err != nil {\n52\t\t\treturn nil, common.NewIrrecoverableError(err, \"invalid trust-manager deployment manifest\")\n53\t\t}\n54\t\n55\t\tcommon.UpdateName(deployment, trustManagerDeploymentName)\n56\t\tcommon.UpdateNamespace(deployment, operandNamespace)\n57\t\tcommon.UpdateResourceLabels(deployment, resourceLabels)\n58\t\tupdateResourceAnnotations(deployment, resourceAnnotations)\n59\t\tupdatePodTemplateLabels(deployment, resourceLabels)\n60\t\tupdateDeploymentArgs(deployment, trustManager)\n61\t\n62\t\tupdateServiceAccountName(deployment)\n63\t\tupdateTLSSecretVolume(deployment)\n64\t\tupdateDefaultCAPackageVolume(\n65\t\t\tdeployment,\n66\t\t\ttrustManager.Spec.TrustManagerConfig.DefaultCAPackage,\n67\t\t\tcaBundleHash,\n68\t\t)\n69\t\n70\t\tif err := updateImage(deployment); err != nil {\n71\t\t\treturn nil, common.NewIrrecoverableError(err, \"failed to update trust-manager image\")\n72\t\t}\n73\t\n74\t\tif err := updateResourceRequirements(deployment, trustManager); err != nil {\n75\t\t\treturn nil, err\n76\t\t}\n77\t\tif err := updateAffinityRules(deployment, trustManager); err != nil {\n78\t\t\treturn nil, err\n79\t\t}\n80\t\tif err := updatePodTolerations(deployment, trustManager); err != nil {\n81\t\t\treturn nil, err\n82\t\t}\n83\t\tif err := updateNodeSelector(deployment, trustManager); err != nil {\n84\t\t\treturn nil, err\n85\t\t}\n86\t\n87\t\treturn deployment, nil\n88\t}\n89\t\n90\t// validateDeploymentManifest checks that the bindata deployment contains the\n91\t// expected container and TLS volume. Without these, the update helpers silently\n92\t// no-op and the operator would apply a deployment with stale defaults.\n93\tfunc validateDeploymentManifest(deployment *appsv1.Deployment) error {\n94\t\thasContainer := false\n95\t\tfor _, c := range deployment.Spec.Template.Spec.Containers {\n96\t\t\tif c.Name == trustManagerContainerName {\n97\t\t\t\thasContainer = true\n98\t\t\t\tbreak\n99\t\t\t}\n100\t\t}\n101\t\tif !hasContainer {\n102\t\t\treturn fmt.Errorf(\"deployment manifest missing required container %q\", trustManagerContainerName)\n103\t\t}\n104\t\n105\t\thasVolume := false\n106\t\tfor _, v := range deployment.Spec.Template.Spec.Volumes {\n107\t\t\tif v.Name == tlsVolumeName && v.Secret != nil {\n108\t\t\t\thasVolume = true\n109\t\t\t\tbreak\n110\t\t\t}\n111\t\t}\n112\t\tif !hasVolume {\n113\t\t\treturn fmt.Errorf(\"deployment manifest missing required secret volume %q\", tlsVolumeName)\n114\t\t}\n115\t\n116\t\treturn nil\n117\t}\n118\t\n119\tfunc updatePodTemplateLabels(deployment *appsv1.Deployment, resourceLabels map[string]string) {\n120\t\tdeployment.Spec.Template.Labels = resourceLabels\n121\t}\n122\t\n123\tfunc updateDeploymentArgs(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) {\n124\t\tconfig := trustManager.Spec.TrustManagerConfig\n125\t\ttrustNamespace := getTrustNamespace(trustManager)\n126\t\n127\t\targs := []string{\n128\t\t\tfmt.Sprintf(\"--log-format=%s\", config.LogFormat),\n129\t\t\tfmt.Sprintf(\"--log-level=%d\", config.LogLevel),\n130\t\t\t\"--metrics-port=9402\",\n131\t\t\t\"--readiness-probe-port=6060\",\n132\t\t\t\"--readiness-probe-path=/readyz\",\n133\t\t\t\"--leader-elect=true\",\n134\t\t\t\"--leader-election-lease-duration=15s\",\n135\t\t\t\"--leader-election-renew-deadline=10s\",\n136\t\t\tfmt.Sprintf(\"--trust-namespace=%s\", trustNamespace),\n137\t\t\t\"--webhook-host=0.0.0.0\",\n138\t\t\t\"--webhook-port=6443\",\n139\t\t\t\"--webhook-certificate-dir=/tls\",\n140\t\t}\n141\t\n142\t\tif secretTargetsEnabled(config.SecretTargets) {\n143\t\t\targs = append(args, \"--secret-targets-enabled=true\")\n144\t\t}\n145\t\n146\t\tif config.FilterExpiredCertificates == v1alpha1.FilterExpiredCertificatesPolicyEnabled {\n147\t\t\targs = append(args, \"--filter-expired-certificates=true\")\n148\t\t}\n149\t\n150\t\tif defaultCAPackageEnabled(config.DefaultCAPackage) {\n151\t\t\targs = append(args, fmt.Sprintf(\"--default-package-location=%s\", defaultCAPackageLocation))\n152\t\t}\n153\t\n154\t\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n155\t\t\tif container.Name == trustManagerContainerName {\n156\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].Args = args\n157\t\t\t}\n158\t\t}\n159\t}\n160\t\n161\t// updateDefaultCAPackageVolume adds the default CA package ConfigMap volume\n162\t// and mount to the deployment when the feature is enabled. It also sets the\n163\t// hash annotation on the pod template to trigger rolling restarts when the\n164\t// CA bundle content changes.\n165\tfunc updateDefaultCAPackageVolume(deployment *appsv1.Deployment, config v1alpha1.DefaultCAPackageConfig, caBundleHash string) {\n166\t\tif !defaultCAPackageEnabled(config) {\n167\t\t\treturn\n168\t\t}\n169\t\n170\t\tif deployment.Spec.Template.Annotations == nil {\n171\t\t\tdeployment.Spec.Template.Annotations = make(map[string]string)\n172\t\t}\n173\t\tdeployment.Spec.Template.Annotations[defaultCAPackageHashAnnotation] = caBundleHash\n174\t\n175\t\t// Remove any existing volume with the same name to avoid duplicates.\n176\t\tvar volumes []corev1.Volume\n177\t\tfor _, vol := range deployment.Spec.Template.Spec.Volumes {\n178\t\t\tif vol.Name != defaultCAPackageVolumeName {\n179\t\t\t\tvolumes = append(volumes, vol)\n180\t\t\t}\n181\t\t}\n182\t\tdeployment.Spec.Template.Spec.Volumes = append(volumes, corev1.Volume{\n183\t\t\tName: defaultCAPackageVolumeName,\n184\t\t\tVolumeSource: corev1.VolumeSource{\n185\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n186\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n187\t\t\t\t\t\tName: defaultCAPackageConfigMapName,\n188\t\t\t\t\t},\n189\t\t\t\t},\n190\t\t\t},\n191\t\t})\n192\t\n193\t\t// Remove any existing volume mount at the same path, then add ours.\n194\t\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n195\t\t\tif container.Name == trustManagerContainerName {\n196\t\t\t\tvar mounts []corev1.VolumeMount\n197\t\t\t\tfor _, vm := range container.VolumeMounts {\n198\t\t\t\t\tif vm.MountPath != defaultCAPackageMountPath {\n199\t\t\t\t\t\tmounts = append(mounts, vm)\n200\t\t\t\t\t}\n201\t\t\t\t}\n202\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts = append(mounts, corev1.VolumeMount{\n203\t\t\t\t\tName:      defaultCAPackageVolumeName,\n204\t\t\t\t\tMountPath: defaultCAPackageMountPath,\n205\t\t\t\t\tReadOnly:  true,\n206\t\t\t\t})\n207\t\t\t\tbreak\n208\t\t\t}\n209\t\t}\n210\t}\n211\t\n212\tfunc updateImage(deployment *appsv1.Deployment) error {\n213\t\timage := os.Getenv(trustManagerImageNameEnvVarName)\n214\t\tif image == \"\" {\n215\t\t\treturn fmt.Errorf(\"%s environment variable with trust-manager image not set\", trustManagerImageNameEnvVarName)\n216\t\t}\n217\t\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n218\t\t\tif container.Name == trustManagerContainerName {\n219\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].Image = image\n220\t\t\t}\n221\t\t}\n222\t\treturn nil\n223\t}\n224\t\n225\tfunc updateResourceRequirements(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) error {\n226\t\tresources := trustManager.Spec.TrustManagerConfig.Resources\n227\t\tif len(resources.Limits) == 0 && len(resources.Requests) == 0 {\n228\t\t\treturn nil\n229\t\t}\n230\t\tif err := common.ValidateResourceRequirements(resources, trustManagerConfigFieldPath); err != nil {\n231\t\t\treturn err\n232\t\t}\n233\t\tfor i := range deployment.Spec.Template.Spec.Containers {\n234\t\t\tif deployment.Spec.Template.Spec.Containers[i].Name == trustManagerContainerName {\n235\t\t\t\tdeployment.Spec.Template.Spec.Containers[i].Resources = resources\n236\t\t\t}\n237\t\t}\n238\t\treturn nil\n239\t}\n240\t\n241\tfunc updateAffinityRules(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) error {\n242\t\tif trustManager.Spec.TrustManagerConfig.Affinity == nil {\n243\t\t\treturn nil\n244\t\t}\n245\t\tif err := common.ValidateAffinityRules(trustManager.Spec.TrustManagerConfig.Affinity, trustManagerConfigFieldPath); err != nil {\n246\t\t\treturn err\n247\t\t}\n248\t\tdeployment.Spec.Template.Spec.Affinity = trustManager.Spec.TrustManagerConfig.Affinity\n249\t\treturn nil\n250\t}\n251\t\n252\tfunc updatePodTolerations(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) error {\n253\t\tif trustManager.Spec.TrustManagerConfig.Tolerations == nil {\n254\t\t\treturn nil\n255\t\t}\n256\t\tif err := common.ValidateTolerationsConfig(trustManager.Spec.TrustManagerConfig.Tolerations, trustManagerConfigFieldPath); err != nil {\n257\t\t\treturn err\n258\t\t}\n259\t\tdeployment.Spec.Template.Spec.Tolerations = trustManager.Spec.TrustManagerConfig.Tolerations\n260\t\treturn nil\n261\t}\n262\t\n263\tfunc updateNodeSelector(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) error {\n264\t\tif trustManager.Spec.TrustManagerConfig.NodeSelector == nil {\n265\t\t\treturn nil\n266\t\t}\n267\t\tif err := common.ValidateNodeSelectorConfig(trustManager.Spec.TrustManagerConfig.NodeSelector, trustManagerConfigFieldPath); err != nil {\n268\t\t\treturn err\n269\t\t}\n270\t\tif deployment.Spec.Template.Spec.NodeSelector == nil {\n271\t\t\tdeployment.Spec.Template.Spec.NodeSelector = make(map[string]string)\n272\t\t}\n273\t\t// Merge user-specified node selectors with any default selectors from the manifest.\n274\t\t// User-specified selectors take precedence.\n275\t\tfor k, v := range trustManager.Spec.TrustManagerConfig.NodeSelector {\n276\t\t\tdeployment.Spec.Template.Spec.NodeSelector[k] = v\n277\t\t}\n278\t\treturn nil\n279\t}\n280\t\n281\tfunc updateServiceAccountName(deployment *appsv1.Deployment) {\n282\t\tdeployment.Spec.Template.Spec.ServiceAccountName = trustManagerServiceAccountName\n283\t}\n284\t\n285\tconst tlsVolumeName = \"tls\"\n286\t\n287\tfunc updateTLSSecretVolume(deployment *appsv1.Deployment) {\n288\t\tfor i, vol := range deployment.Spec.Template.Spec.Volumes {\n289\t\t\tif vol.Name == tlsVolumeName && vol.Secret != nil {\n290\t\t\t\tdeployment.Spec.Template.Spec.Volumes[i].Secret.SecretName = trustManagerTLSSecretName\n291\t\t\t\treturn\n292\t\t\t}\n293\t\t}\n294\t}\n295\t\n296\t// deploymentModified compares only the fields we manage via SSA.\n297\t// For the readiness probe, only the fields explicitly set in our bindata are\n298\t// compared to avoid false positives from API-server-defaulted probe scalars\n299\t// (TimeoutSeconds, SuccessThreshold, FailureThreshold).\n300\tfunc deploymentModified(desired, existing *appsv1.Deployment) bool {\n301\t\tif managedMetadataModified(desired, existing) {\n302\t\t\treturn true\n303\t\t}\n304\t\n305\t\tif !ptr.Equal(desired.Spec.Replicas, existing.Spec.Replicas) ||\n306\t\t\t!reflect.DeepEqual(desired.Spec.Selector, existing.Spec.Selector) {\n307\t\t\treturn true\n308\t\t}\n309\t\n310\t\tif !maps.Equal(desired.Spec.Template.Labels, existing.Spec.Template.Labels) ||\n311\t\t\t!maps.Equal(desired.Spec.Template.Annotations, existing.Spec.Template.Annotations) {\n312\t\t\treturn true\n313\t\t}\n314\t\n315\t\tdesiredPodSpec := desired.Spec.Template.Spec\n316\t\texistingPodSpec := existing.Spec.Template.Spec\n317\t\n318\t\tif desiredPodSpec.ServiceAccountName != existingPodSpec.ServiceAccountName ||\n319\t\t\t!maps.Equal(desiredPodSpec.NodeSelector, existingPodSpec.NodeSelector) ||\n320\t\t\t!reflect.DeepEqual(desiredPodSpec.Volumes, existingPodSpec.Volumes) ||\n321\t\t\t!reflect.DeepEqual(desiredPodSpec.Affinity, existingPodSpec.Affinity) ||\n322\t\t\t!reflect.DeepEqual(desiredPodSpec.Tolerations, existingPodSpec.Tolerations) {\n323\t\t\treturn true\n324\t\t}\n325\t\n326\t\tif len(desiredPodSpec.Containers) != len(existingPodSpec.Containers) {\n327\t\t\treturn true\n328\t\t}\n329\t\n330\t\tfor i := range desiredPodSpec.Containers {\n331\t\t\tif containerModified(&desiredPodSpec.Containers[i], &existingPodSpec.Containers[i]) {\n332\t\t\t\treturn true\n333\t\t\t}\n334\t\t}\n335\t\n336\t\treturn false\n337\t}\n338\t\n339\tfunc containerModified(desired, existing *corev1.Container) bool {\n340\t\tif desired.Name != existing.Name ||\n341\t\t\tdesired.Image != existing.Image ||\n342\t\t\tdesired.ImagePullPolicy != existing.ImagePullPolicy {\n343\t\t\treturn true\n344\t\t}\n345\t\n346\t\tif !slices.Equal(desired.Args, existing.Args) ||\n347\t\t\t!reflect.DeepEqual(desired.Resources, existing.Resources) ||\n348\t\t\t!reflect.DeepEqual(desired.SecurityContext, existing.SecurityContext) ||\n349\t\t\t!reflect.DeepEqual(desired.VolumeMounts, existing.VolumeMounts) {\n350\t\t\treturn true\n351\t\t}\n352\t\n353\t\tif !containerPortsMatch(desired.Ports, existing.Ports) {\n354\t\t\treturn true\n355\t\t}\n356\t\n357\t\tif readinessProbeModified(desired.ReadinessProbe, existing.ReadinessProbe) {\n358\t\t\treturn true\n359\t\t}\n360\t\n361\t\treturn false\n362\t}\n363\t\n364\tfunc containerPortsMatch(desired, existing []corev1.ContainerPort) bool {\n365\t\tif len(desired) != len(existing) {\n366\t\t\treturn false\n367\t\t}\n368\t\tfor _, dp := range desired {\n369\t\t\tmatched := false\n370\t\t\tfor _, ep := range existing {\n371\t\t\t\tif dp.ContainerPort == ep.ContainerPort && dp.Name == ep.Name {\n372\t\t\t\t\tmatched = true\n373\t\t\t\t\tbreak\n374\t\t\t\t}\n375\t\t\t}\n376\t\t\tif !matched {\n377\t\t\t\treturn false\n378\t\t\t}\n379\t\t}\n380\t\treturn true\n381\t}\n382\t\n383\t// readinessProbeModified compares only the probe fields we explicitly set in\n384\t// bindata (HTTPGet, InitialDelaySeconds, PeriodSeconds), avoiding\n385\t// API-server-defaulted int32 fields like TimeoutSeconds and FailureThreshold.\n386\tfunc readinessProbeModified(desired, existing *corev1.Probe) bool {\n387\t\tif desired == nil && existing == nil {\n388\t\t\treturn false\n389\t\t}\n390\t\tif desired == nil || existing == nil {\n391\t\t\treturn true\n392\t\t}\n393\t\tif desired.InitialDelaySeconds != existing.InitialDelaySeconds ||\n394\t\t\tdesired.PeriodSeconds != existing.PeriodSeconds {\n395\t\t\treturn true\n396\t\t}\n397\t\tif desired.HTTPGet != nil && existing.HTTPGet != nil {\n398\t\t\tif desired.HTTPGet.Path != existing.HTTPGet.Path ||\n399\t\t\t\tdesired.HTTPGet.Port != existing.HTTPGet.Port {\n400\t\t\t\treturn true\n401\t\t\t}\n402\t\t} else if desired.HTTPGet != existing.HTTPGet {\n403\t\t\treturn true\n404\t\t}\n405\t\treturn false\n406\t}\n407\t"}]},"parent_tool_use_id":null,"session_id":"a84d1297-cc4c-4a5d-8b71-40ba1ca8bb7a","uuid":"13cf3a16-e623-4eed-a3ea-467e87287bf3","timestamp":"2026-07-20T17:35:30.553Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/controller/trustmanager/deployments.go","content":"package trustmanager\n\nimport (\n\t\"fmt\"\n\t\"maps\"\n\t\"os\"\n\t\"reflect\"\n\t\"slices\"\n\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\t\"k8s.io/utils/ptr\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n\t\"github.com/openshift/cert-manager-operator/pkg/operator/assets\"\n)\n\nfunc (r *Reconciler) createOrApplyDeployment(trustManager *v1alpha1.TrustManager, resourceLabels, resourceAnnotations map[string]string, caBundleHash string) error {\n\tdesired, err := r.getDeploymentObject(trustManager, resourceLabels, resourceAnnotations, caBundleHash)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdeploymentName := fmt.Sprintf(\"%s/%s\", desired.GetNamespace(), desired.GetName())\n\tr.log.V(4).Info(\"reconciling deployment resource\", \"name\", deploymentName)\n\n\texisting := &appsv1.Deployment{}\n\texists, err := r.Exists(r.ctx, client.ObjectKeyFromObject(desired), existing)\n\tif err != nil {\n\t\treturn common.FromClientError(err, \"failed to check if deployment %q exists\", deploymentName)\n\t}\n\tif exists && !deploymentModified(desired, existing) {\n\t\tr.log.V(4).Info(\"deployment resource exists and is in desired state\", \"name\", deploymentName)\n\t\treturn nil\n\t}\n\n\tr.log.V(2).Info(\"deployment resource has been modified, updating to desired state\", \"name\", deploymentName)\n\tif err := r.Patch(r.ctx, desired, client.Apply, client.FieldOwner(fieldOwner), client.ForceOwnership); err != nil {\n\t\treturn common.FromClientError(err, \"failed to apply deployment %q\", deploymentName)\n\t}\n\n\tr.eventRecorder.Eventf(trustManager, corev1.EventTypeNormal, \"Reconciled\", \"deployment resource %s applied\", deploymentName)\n\treturn nil\n}\n\nfunc (r *Reconciler) getDeploymentObject(trustManager *v1alpha1.TrustManager, resourceLabels, resourceAnnotations map[string]string, caBundleHash string) (*appsv1.Deployment, error) {\n\tdeployment := common.DecodeObjBytes[*appsv1.Deployment](codecs, appsv1.SchemeGroupVersion, assets.MustAsset(deploymentAssetName))\n\n\tif err := validateDeploymentManifest(deployment); err != nil {\n\t\treturn nil, common.NewIrrecoverableError(err, \"invalid trust-manager deployment manifest\")\n\t}\n\n\tcommon.UpdateName(deployment, trustManagerDeploymentName)\n\tcommon.UpdateNamespace(deployment, operandNamespace)\n\tcommon.UpdateResourceLabels(deployment, resourceLabels)\n\tupdateResourceAnnotations(deployment, resourceAnnotations)\n\tupdatePodTemplateLabels(deployment, resourceLabels)\n\tupdateDeploymentArgs(deployment, trustManager)\n\n\tupdateServiceAccountName(deployment)\n\tupdateTLSSecretVolume(deployment)\n\tupdateDefaultCAPackageVolume(\n\t\tdeployment,\n\t\ttrustManager.Spec.TrustManagerConfig.DefaultCAPackage,\n\t\tcaBundleHash,\n\t)\n\n\tif err := updateImage(deployment); err != nil {\n\t\treturn nil, common.NewIrrecoverableError(err, \"failed to update trust-manager image\")\n\t}\n\n\tif err := updateResourceRequirements(deployment, trustManager); err != nil {\n\t\treturn nil, err\n\t}\n\tif err := updateAffinityRules(deployment, trustManager); err != nil {\n\t\treturn nil, err\n\t}\n\tif err := updatePodTolerations(deployment, trustManager); err != nil {\n\t\treturn nil, err\n\t}\n\tif err := updateNodeSelector(deployment, trustManager); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn deployment, nil\n}\n\n// validateDeploymentManifest checks that the bindata deployment contains the\n// expected container and TLS volume. Without these, the update helpers silently\n// no-op and the operator would apply a deployment with stale defaults.\nfunc validateDeploymentManifest(deployment *appsv1.Deployment) error {\n\thasContainer := false\n\tfor _, c := range deployment.Spec.Template.Spec.Containers {\n\t\tif c.Name == trustManagerContainerName {\n\t\t\thasContainer = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !hasContainer {\n\t\treturn fmt.Errorf(\"deployment manifest missing required container %q\", trustManagerContainerName)\n\t}\n\n\thasVolume := false\n\tfor _, v := range deployment.Spec.Template.Spec.Volumes {\n\t\tif v.Name == tlsVolumeName && v.Secret != nil {\n\t\t\thasVolume = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !hasVolume {\n\t\treturn fmt.Errorf(\"deployment manifest missing required secret volume %q\", tlsVolumeName)\n\t}\n\n\treturn nil\n}\n\nfunc updatePodTemplateLabels(deployment *appsv1.Deployment, resourceLabels map[string]string) {\n\tdeployment.Spec.Template.Labels = resourceLabels\n}\n\nfunc updateDeploymentArgs(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) {\n\tconfig := trustManager.Spec.TrustManagerConfig\n\ttrustNamespace := getTrustNamespace(trustManager)\n\n\targs := []string{\n\t\tfmt.Sprintf(\"--log-format=%s\", config.LogFormat),\n\t\tfmt.Sprintf(\"--log-level=%d\", config.LogLevel),\n\t\t\"--metrics-port=9402\",\n\t\t\"--readiness-probe-port=6060\",\n\t\t\"--readiness-probe-path=/readyz\",\n\t\t\"--leader-elect=true\",\n\t\t\"--leader-election-lease-duration=15s\",\n\t\t\"--leader-election-renew-deadline=10s\",\n\t\tfmt.Sprintf(\"--trust-namespace=%s\", trustNamespace),\n\t\t\"--webhook-host=0.0.0.0\",\n\t\t\"--webhook-port=6443\",\n\t\t\"--webhook-certificate-dir=/tls\",\n\t}\n\n\tif secretTargetsEnabled(config.SecretTargets) {\n\t\targs = append(args, \"--secret-targets-enabled=true\")\n\t}\n\n\tif config.FilterExpiredCertificates == v1alpha1.FilterExpiredCertificatesPolicyEnabled {\n\t\targs = append(args, \"--filter-expired-certificates=true\")\n\t}\n\n\tif defaultCAPackageEnabled(config.DefaultCAPackage) {\n\t\targs = append(args, fmt.Sprintf(\"--default-package-location=%s\", defaultCAPackageLocation))\n\t}\n\n\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == trustManagerContainerName {\n\t\t\tdeployment.Spec.Template.Spec.Containers[i].Args = args\n\t\t}\n\t}\n}\n\n// updateDefaultCAPackageVolume adds the default CA package ConfigMap volume\n// and mount to the deployment when the feature is enabled. It also sets the\n// hash annotation on the pod template to trigger rolling restarts when the\n// CA bundle content changes.\nfunc updateDefaultCAPackageVolume(deployment *appsv1.Deployment, config v1alpha1.DefaultCAPackageConfig, caBundleHash string) {\n\tif !defaultCAPackageEnabled(config) {\n\t\treturn\n\t}\n\n\tif deployment.Spec.Template.Annotations == nil {\n\t\tdeployment.Spec.Template.Annotations = make(map[string]string)\n\t}\n\tdeployment.Spec.Template.Annotations[defaultCAPackageHashAnnotation] = caBundleHash\n\n\t// Remove any existing volume with the same name to avoid duplicates.\n\tvar volumes []corev1.Volume\n\tfor _, vol := range deployment.Spec.Template.Spec.Volumes {\n\t\tif vol.Name != defaultCAPackageVolumeName {\n\t\t\tvolumes = append(volumes, vol)\n\t\t}\n\t}\n\tdeployment.Spec.Template.Spec.Volumes = append(volumes, corev1.Volume{\n\t\tName: defaultCAPackageVolumeName,\n\t\tVolumeSource: corev1.VolumeSource{\n\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n\t\t\t\t\tName: defaultCAPackageConfigMapName,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t})\n\n\t// Remove any existing volume mount at the same path, then add ours.\n\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == trustManagerContainerName {\n\t\t\tvar mounts []corev1.VolumeMount\n\t\t\tfor _, vm := range container.VolumeMounts {\n\t\t\t\tif vm.MountPath != defaultCAPackageMountPath {\n\t\t\t\t\tmounts = append(mounts, vm)\n\t\t\t\t}\n\t\t\t}\n\t\t\tdeployment.Spec.Template.Spec.Containers[i].VolumeMounts = append(mounts, corev1.VolumeMount{\n\t\t\t\tName:      defaultCAPackageVolumeName,\n\t\t\t\tMountPath: defaultCAPackageMountPath,\n\t\t\t\tReadOnly:  true,\n\t\t\t})\n\t\t\tbreak\n\t\t}\n\t}\n}\n\nfunc updateImage(deployment *appsv1.Deployment) error {\n\timage := os.Getenv(trustManagerImageNameEnvVarName)\n\tif image == \"\" {\n\t\treturn fmt.Errorf(\"%s environment variable with trust-manager image not set\", trustManagerImageNameEnvVarName)\n\t}\n\tfor i, container := range deployment.Spec.Template.Spec.Containers {\n\t\tif container.Name == trustManagerContainerName {\n\t\t\tdeployment.Spec.Template.Spec.Containers[i].Image = image\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc updateResourceRequirements(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) error {\n\tresources := trustManager.Spec.TrustManagerConfig.Resources\n\tif len(resources.Limits) == 0 && len(resources.Requests) == 0 {\n\t\treturn nil\n\t}\n\tif err := common.ValidateResourceRequirements(resources, trustManagerConfigFieldPath); err != nil {\n\t\treturn err\n\t}\n\tfor i := range deployment.Spec.Template.Spec.Containers {\n\t\tif deployment.Spec.Template.Spec.Containers[i].Name == trustManagerContainerName {\n\t\t\tdeployment.Spec.Template.Spec.Containers[i].Resources = resources\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc updateAffinityRules(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) error {\n\tif trustManager.Spec.TrustManagerConfig.Affinity == nil {\n\t\treturn nil\n\t}\n\tif err := common.ValidateAffinityRules(trustManager.Spec.TrustManagerConfig.Affinity, trustManagerConfigFieldPath); err != nil {\n\t\treturn err\n\t}\n\tdeployment.Spec.Template.Spec.Affinity = trustManager.Spec.TrustManagerConfig.Affinity\n\treturn nil\n}\n\nfunc updatePodTolerations(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) error {\n\tif trustManager.Spec.TrustManagerConfig.Tolerations == nil {\n\t\treturn nil\n\t}\n\tif err := common.ValidateTolerationsConfig(trustManager.Spec.TrustManagerConfig.Tolerations, trustManagerConfigFieldPath); err != nil {\n\t\treturn err\n\t}\n\tdeployment.Spec.Template.Spec.Tolerations = trustManager.Spec.TrustManagerConfig.Tolerations\n\treturn nil\n}\n\nfunc updateNodeSelector(deployment *appsv1.Deployment, trustManager *v1alpha1.TrustManager) error {\n\tif trustManager.Spec.TrustManagerConfig.NodeSelector == nil {\n\t\treturn nil\n\t}\n\tif err := common.ValidateNodeSelectorConfig(trustManager.Spec.TrustManagerConfig.NodeSelector, trustManagerConfigFieldPath); err != nil {\n\t\treturn err\n\t}\n\tif deployment.Spec.Template.Spec.NodeSelector == nil {\n\t\tdeployment.Spec.Template.Spec.NodeSelector = make(map[string]string)\n\t}\n\t// Merge user-specified node selectors with any default selectors from the manifest.\n\t// User-specified selectors take precedence.\n\tfor k, v := range trustManager.Spec.TrustManagerConfig.NodeSelector {\n\t\tdeployment.Spec.Template.Spec.NodeSelector[k] = v\n\t}\n\treturn nil\n}\n\nfunc updateServiceAccountName(deployment *appsv1.Deployment) {\n\tdeployment.Spec.Template.Spec.ServiceAccountName = trustManagerServiceAccountName\n}\n\nconst tlsVolumeName = \"tls\"\n\nfunc updateTLSSecretVolume(deployment *appsv1.Deployment) {\n\tfor i, vol := range deployment.Spec.Template.Spec.Volumes {\n\t\tif vol.Name == tlsVolumeName && vol.Secret != nil {\n\t\t\tdeployment.Spec.Template.Spec.Volumes[i].Secret.SecretName = trustManagerTLSSecretName\n\t\t\treturn\n\t\t}\n\t}\n}\n\n// deploymentModified compares only the fields we manage via SSA.\n// For the readiness probe, only the fields explicitly set in our bindata are\n// compared to avoid false positives from API-server-defaulted probe scalars\n// (TimeoutSeconds, SuccessThreshold, FailureThreshold).\nfunc deploymentModified(desired, existing *appsv1.Deployment) bool {\n\tif managedMetadataModified(desired, existing) {\n\t\treturn true\n\t}\n\n\tif !ptr.Equal(desired.Spec.Replicas, existing.Spec.Replicas) ||\n\t\t!reflect.DeepEqual(desired.Spec.Selector, existing.Spec.Selector) {\n\t\treturn true\n\t}\n\n\tif !maps.Equal(desired.Spec.Template.Labels, existing.Spec.Template.Labels) ||\n\t\t!maps.Equal(desired.Spec.Template.Annotations, existing.Spec.Template.Annotations) {\n\t\treturn true\n\t}\n\n\tdesiredPodSpec := desired.Spec.Template.Spec\n\texistingPodSpec := existing.Spec.Template.Spec\n\n\tif desiredPodSpec.ServiceAccountName != existingPodSpec.ServiceAccountName ||\n\t\t!maps.Equal(desiredPodSpec.NodeSelector, existingPodSpec.NodeSelector) ||\n\t\t!reflect.DeepEqual(desiredPodSpec.Volumes, existingPodSpec.Volumes) ||\n\t\t!reflect.DeepEqual(desiredPodSpec.Affinity, existingPodSpec.Affinity) ||\n\t\t!reflect.DeepEqual(desiredPodSpec.Tolerations, existingPodSpec.Tolerations) {\n\t\treturn true\n\t}\n\n\tif len(desiredPodSpec.Containers) != len(existingPodSpec.Containers) {\n\t\treturn true\n\t}\n\n\tfor i := range desiredPodSpec.Containers {\n\t\tif containerModified(&desiredPodSpec.Containers[i], &existingPodSpec.Containers[i]) {\n\t\t\treturn true\n\t\t}\n\t}\n\n\treturn false\n}\n\nfunc containerModified(desired, existing *corev1.Container) bool {\n\tif desired.Name != existing.Name ||\n\t\tdesired.Image != existing.Image ||\n\t\tdesired.ImagePullPolicy != existing.ImagePullPolicy {\n\t\treturn true\n\t}\n\n\tif !slices.Equal(desired.Args, existing.Args) ||\n\t\t!reflect.DeepEqual(desired.Resources, existing.Resources) ||\n\t\t!reflect.DeepEqual(desired.SecurityContext, existing.SecurityContext) ||\n\t\t!reflect.DeepEqual(desired.VolumeMounts, existing.VolumeMounts) {\n\t\treturn true\n\t}\n\n\tif !containerPortsMatch(desired.Ports, existing.Ports) {\n\t\treturn true\n\t}\n\n\tif readinessProbeModified(desired.ReadinessProbe, existing.ReadinessProbe) {\n\t\treturn true\n\t}\n\n\treturn false\n}\n\nfunc containerPortsMatch(desired, existing []corev1.ContainerPort) bool {\n\tif len(desired) != len(existing) {\n\t\treturn false\n\t}\n\tfor _, dp := range desired {\n\t\tmatched := false\n\t\tfor _, ep := range existing {\n\t\t\tif dp.ContainerPort == ep.ContainerPort && dp.Name == ep.Name {\n\t\t\t\tmatched = true\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif !matched {\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n\n// readinessProbeModified compares only the probe fields we explicitly set in\n// bindata (HTTPGet, InitialDelaySeconds, PeriodSeconds), avoiding\n// API-server-defaulted int32 fields like TimeoutSeconds and FailureThreshold.\nfunc readinessProbeModified(desired, existing *corev1.Probe) bool {\n\tif desired == nil && existing == nil {\n\t\treturn false\n\t}\n\tif desired == nil || existing == nil {\n\t\treturn true\n\t}\n\tif desired.InitialDelaySeconds != existing.InitialDelaySeconds ||\n\t\tdesired.PeriodSeconds != existing.PeriodSeconds {\n\t\treturn true\n\t}\n\tif desired.HTTPGet != nil && existing.HTTPGet != nil {\n\t\tif desired.HTTPGet.Path != existing.HTTPGet.Path ||\n\t\t\tdesired.HTTPGet.Port != existing.HTTPGet.Port {\n\t\t\treturn true\n\t\t}\n\t} else if desired.HTTPGet != existing.HTTPGet {\n\t\treturn true\n\t}\n\treturn false\n}\n","numLines":407,"startLine":1,"totalLines":407}}}

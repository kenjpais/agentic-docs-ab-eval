18), remove the local const block:\n\n```go\n// BEFORE:\nfunc updateVolumeWithIssuerCA(deployment *appsv1.Deployment) {\n\tconst (\n\t\tcaVolumeName = \"root-ca\"\n\t)\n\tvar (\n\t\tdefaultMode = int32(420)\n\t)\n\n// AFTER:\nfunc updateVolumeWithIssuerCA(deployment *appsv1.Deployment) {\n\tvar (\n\t\tdefaultMode = int32(420)\n\t)\n```\n\n**Change C: Add `validateDeploymentManifest` and call it in `getDeploymentObject`**\n\nAdd the validation function (place it after `getDeploymentObject`, before `updateImage`):\n\n```go\n// validateDeploymentManifest checks that the bindata deployment contains the\n// expected container and CA volume. Without these, the update helpers silently\n// no-op and the operator would apply a deployment with stale defaults.\nfunc validateDeploymentManifest(deployment *appsv1.Deployment) error {\n\thasContainer := false\n\tfor _, c := range deployment.Spec.Template.Spec.Containers {\n\t\tif c.Name == istiocsrContainerName {\n\t\t\thasContainer = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !hasContainer {\n\t\treturn fmt.Errorf(\"deployment manifest missing required container %q\", istiocsrContainerName)\n\t}\n\n\thasVolume := false\n\tfor _, v := range deployment.Spec.Template.Spec.Volumes {\n\t\tif v.Name == caVolumeName && v.ConfigMap != nil {\n\t\t\thasVolume = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !hasVolume {\n\t\treturn fmt.Errorf(\"deployment manifest missing required configmap volume %q\", caVolumeName)\n\t}\n\n\treturn nil\n}\n```\n\nInsert the validation call in `getDeploymentObject`, right after the `decodeDeploymentObjBytes` call and before any mutations:\n\n```go\nfunc (r *Reconciler) getDeploymentObject(istiocsr *v1alpha1.IstioCSR, resourceLabels map[string]string) (*appsv1.Deployment, error) {\n\tif err := r.assertIssuerRefExists(istiocsr); err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to verify issuer in %s/%s: %w\", istiocsr.GetNamespace(), istiocsr.GetName(), err)\n\t}\n\n\tdeployment := decodeDeploymentObjBytes(assets.MustAsset(deploymentAssetName))\n\n\tif err := validateDeploymentManifest(deployment); err != nil {\n\t\treturn nil, common.NewIrrecoverableError(err, \"invalid istio-csr deployment manifest\")\n\t}\n\n\tcommon.UpdateNamespace(deployment, istiocsr.GetNamespace())\n\t// ... rest unchanged ...\n```\n\n---\n\n### 3. `pkg/controller/istiocsr/deployments_test.go` — add test\n\nAppend this test function at the end of the file:\n\n```go\nfunc TestValidateDeploymentManifest(t *testing.T) {\n\ttests := []struct {\n\t\tname       string\n\t\tdeployment *appsv1.Deployment\n\t\twantErr    string\n\t}{\n\t\t{\n\t\t\tname: \"valid deployment manifest\",\n\t\t\tdeployment: &appsv1.Deployment{\n\t\t\t\tSpec: appsv1.DeploymentSpec{\n\t\t\t\t\tTemplate: corev1.PodTemplateSpec{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t\t{Name: istiocsrContainerName},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tVolumes: []corev1.Volume{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName: caVolumeName,\n\t\t\t\t\t\t\t\t\tVolumeSource: corev1.VolumeSource{\n\t\t\t\t\t\t\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n\t\t\t\t\t\t\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n\t\t\t\t\t\t\t\t\t\t\t\tName: IstiocsrCAConfigMapName,\n\t\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t\t{\n\t\t\tname: \"missing required container\",\n\t\t\tdeployment: &appsv1.Deployment{\n\t\t\t\tSpec: appsv1.DeploymentSpec{\n\t\t\t\t\tTemplate: corev1.PodTemplateSpec{\n\t\t\t\t\t\tSpec: corev1.PodSpec{\n\t\t\t\t\t\t\tContainers: []corev1.Container{\n\t\t\t\t\t\t\t\t{Name: \"wrong-container\"},\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\tVolumes: []corev1.Volume{\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tName: caVolumeName,\n\t\t\t\t\t\t\t\t\tVolumeSource: corev1.VolumeSource{\n\t\t\t\t\t\t\t\t\t\tConfigMap: &corev1.ConfigMapVolumeSource{\n\t\t\t\t\t\t\t\t\t\t\tLocalObjectRefere
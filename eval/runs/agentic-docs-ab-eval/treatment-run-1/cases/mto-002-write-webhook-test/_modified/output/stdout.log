{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01M5rwdj6JGGBDkQE7rjECmb","type":"tool_result","content":"1\t/*\n2\tCopyright 2023 Red Hat, Inc.\n3\t\n4\tLicensed under the Apache License, Version 2.0 (the \"License\");\n5\tyou may not use this file except in compliance with the License.\n6\tYou may obtain a copy of the License at\n7\t\n8\t    http://www.apache.org/licenses/LICENSE-2.0\n9\t\n10\tUnless required by applicable law or agreed to in writing, software\n11\tdistributed under the License is distributed on an \"AS IS\" BASIS,\n12\tWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n13\tSee the License for the specific language governing permissions and\n14\tlimitations under the License.\n15\t*/\n16\t\n17\tpackage podplacement\n18\t\n19\timport (\n20\t\t\"context\"\n21\t\t\"crypto/tls\"\n22\t\t\"crypto/x509\"\n23\t\t\"encoding/base64\"\n24\t\t\"fmt\"\n25\t\n26\t\t\"net/http\"\n27\t\t\"os\"\n28\t\t\"path/filepath\"\n29\t\t\"strings\"\n30\t\t\"sync\"\n31\t\t\"testing\"\n32\t\t\"time\"\n33\t\n34\t\t\"github.com/BurntSushi/toml\"\n35\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/image\"\n36\t\n37\t\t. \"github.com/onsi/ginkgo/v2\"\n38\t\t. \"github.com/onsi/gomega\"\n39\t\n40\t\t\"go.uber.org/zap/zapcore\"\n41\t\n42\t\tv1 \"k8s.io/api/admissionregistration/v1\"\n43\t\tcorev1 \"k8s.io/api/core/v1\"\n44\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n45\t\t\"k8s.io/apimachinery/pkg/util/json\"\n46\t\t\"k8s.io/client-go/kubernetes\"\n47\t\t\"k8s.io/client-go/kubernetes/scheme\"\n48\t\t\"k8s.io/client-go/rest\"\n49\t\t\"k8s.io/client-go/tools/clientcmd\"\n50\t\t\"k8s.io/client-go/tools/clientcmd/api\"\n51\t\n52\t\tctrl \"sigs.k8s.io/controller-runtime\"\n53\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n54\t\t\"sigs.k8s.io/controller-runtime/pkg/envtest\"\n55\t\t\"sigs.k8s.io/controller-runtime/pkg/healthz\"\n56\t\tlogf \"sigs.k8s.io/controller-runtime/pkg/log\"\n57\t\t\"sigs.k8s.io/controller-runtime/pkg/log/zap\"\n58\t\t\"sigs.k8s.io/controller-runtime/pkg/webhook\"\n59\t\n60\t\t\"github.com/panjf2000/ants/v2\"\n61\t\n62\t\t\"github.com/openshift/multiarch-tuning-operator/api/common\"\n63\t\t\"github.com/openshift/multiarch-tuning-operator/api/v1alpha1\"\n64\t\t\"github.com/openshift/multiarch-tuning-operator/api/v1beta1\"\n65\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/e2e\"\n66\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/informers/clusterpodplacementconfig\"\n67\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/testing/builder\"\n68\t\ttestingutils \"github.com/openshift/multiarch-tuning-operator/pkg/testing/framework\"\n69\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/testing/image/fake/registry\"\n70\t\t\"github.com/openshift/multiarch-tuning-operator/pkg/utils\"\n71\t\t//+kubebuilder:scaffold:imports\n72\t)\n73\t\n74\t// These tests use Ginkgo (BDD-style Go testing framework). Refer to\n75\t// http://onsi.github.io/ginkgo/ to learn more about Ginkgo.\n76\t\n77\tvar (\n78\t\tcfg             *rest.Config\n79\t\tk8sClient       client.Client\n80\t\tregistryAddress string\n81\t\tregistryCert    []byte\n82\t\tstopMgr         context.CancelFunc\n83\t\tmgrStopped      chan struct{}\n84\t\ttestEnv         *envtest.Environment\n85\t\n86\t\tdir      string\n87\t\tsuiteLog = ctrl.Log.WithName(\"setup\")\n88\t)\n89\t\n90\ttype sharedData struct {\n91\t\tKubeconfig       api.Config `json:\"kubeconfig\"`\n92\t\tRegistryAddress  string     `json:\"registryAddress\"`\n93\t\tRegistryCert     []byte     `json:\"registryCert\"`\n94\t\tRegistryCertPath string     `json:\"registryCertpath\"`\n95\t}\n96\t\n97\tfunc init() {\n98\t\te2e.CommonInit()\n99\t}\n100\t\n101\tfunc TestAPIs(t *testing.T) {\n102\t\tRegisterFailHandler(Fail)\n103\t\tRunSpecs(t, \"Controllers Integration Suite\", Label(\"integration\"))\n104\t}\n105\t\n106\tvar _ = BeforeAll\n107\t\n108\tvar _ = SynchronizedBeforeSuite(func() []byte {\n109\t\tsuiteLog = zap.New(zap.WriteTo(GinkgoWriter), zap.UseDevMode(true), zap.Level(zapcore.Level(-5)))\n110\t\n111\t\tlogf.SetLogger(suiteLog)\n112\t\tSetDefaultEventuallyPollingInterval(5 * time.Millisecond)\n113\t\tSetDefaultEventuallyTimeout(5 * time.Second)\n114\t\n115\t\tBy(\"Set up a shared test environment and local registry for testing on process 1 node\")\n116\t\twg := &sync.WaitGroup{}\n117\t\ttestingutils.DecorateWithWaitGroup(wg, startTestEnv)\n118\t\ttestingutils.DecorateWithWaitGroup(wg, startRegistry)\n119\t\twg.Wait()\n120\t\ttestingutils.DecorateWithWaitGroup(wg, seedRegistry)\n121\t\ttestingutils.DecorateWithWaitGroup(wg, seedK8S)\n122\t\twg.Wait()\n123\t\n124\t\tvar err error\n125\t\tdir, err = os.MkdirTemp(\"\", \"multiarch-tuning-operator\")\n126\t\tExpect(err).NotTo(HaveOccurred())\n127\t\tExpect(dir).NotTo(BeEmpty())\n128\t\terr = os.Setenv(\"DOCKER_CERTS_DIR\", filepath.Join(dir, \"docker/certs.d\"))\n129\t\tExpect(err).NotTo(HaveOccurred())\n130\t\terr = os.Setenv(\"REGISTRIES_CERTS_DIR\", filepath.Join(dir, \"containers/registries.d\"))\n131\t\tExpect(err).NotTo(HaveOccurred())\n132\t\terr = os.Setenv(\"REGISTRIES_CONF_PATH\", filepath.Join(dir, \"containers/registries.conf\"))\n133\t\tExpect(err).NotTo(HaveOccurred())\n134\t\terr = os.Setenv(\"POLICY_CONF_PATH\", filepath.Join(dir, \"containers/policy.json\"))\n135\t\tExpect(err).NotTo(HaveOccurred())\n136\t\n137\t\t// TODO: should we continue running the manager in the BeforeSuite node?\n138\t\trunManager()\n139\t\n140\t\tBy(\"Creating the ClusterPodPlacementConfig\")\n141\t\terr = k8sClient.Create(ctx, builder.NewClusterPodPlacementConfig().\n142\t\t\tWithName(common.SingletonResourceObjectName).\n143\t\t\tWithPlugins().\n144\t\t\tWithNodeAffinityScoring(true).\n145\t\t\tWithNodeAffinityScoringTerm(utils.ArchitectureArm64, 50).\n146\t\t\tBuild())\n147\t\tExpect(err).NotTo(HaveOccurred(), \"failed to create ClusterPodPlacementConfig\")\n148\t\n149\t\tBy(\"Checking initialization of the cache with the ClusterPodPlacementConfig\")\n150\t\tppc := &v1beta1.ClusterPodPlacementConfig{}\n151\t\terr = k8sClient.Get(ctx, client.ObjectKey{Name: common.SingletonResourceObjectName}, ppc)\n152\t\tExpect(err).NotTo(HaveOccurred(), \"failed to get ClusterPodPlacementConfig\")\n153\t\n154\t\t// Wait for the informer to update by polling\n155\t\tBy(\"Waiting for the cache to reflect the ClusterPodPlacementConfig\")\n156\t\tEventually(clusterpodplacementconfig.GetClusterPodPlacementConfig).\n157\t\t\tShould(Equal(ppc), \"cache did not update with ClusterPodPlacementConfig\")\n158\t\n159\t\tBy(\"Updating the ClusterPodPlacementConfig\")\n160\t\tppc.Spec.LogVerbosity = common.LogVerbosityLevelTraceAll\n161\t\terr = k8sClient.Update(ctx, ppc)\n162\t\tExpect(err).NotTo(HaveOccurred(), \"failed to update ClusterPodPlacementConfig\")\n163\t\n164\t\tBy(\"Get the updated ClusterPodPlacementConfig\")\n165\t\terr = k8sClient.Get(ctx, client.ObjectKey{Name: common.SingletonResourceObjectName}, ppc)\n166\t\tExpect(err).NotTo(HaveOccurred(), \"failed to get ClusterPodPlacementConfig\")\n167\t\n168\t\tBy(\"Waiting for the cache to reflect the updated ClusterPodPlacementConfig\")\n169\t\tEventually(clusterpodplacementconfig.GetClusterPodPlacementConfig).\n170\t\t\tShould(Equal(ppc), \"cache did not update with new ClusterPodPlacementConfig\")\n171\t\n172\t\tBy(\"Prepare shared data and Pass to all processes\")\n173\t\t// Get cluster info and share with all processes\n174\t\tkc := testingutils.FromEnvTestConfig(cfg)\n175\t\t// The registry.perRegistryCertDirPath is used by registry.PushMockImage,\n176\t\t// need to pass to all processes\n177\t\tregistryCertPath := registry.GetCertPath()\n178\t\tdata := sharedData{\n179\t\t\tKubeconfig:       kc,\n180\t\t\tRegistryAddress:  registryAddress,\n181\t\t\tRegistryCert:     registryCert,\n182\t\t\tRegistryCertPath: registryCertPath,\n183\t\t}\n184\t\tjsonData, err := json.Marshal(data)\n185\t\tExpect(err).NotTo(HaveOccurred(), \"failed to marshal sharedData\")\n186\t\treturn jsonData\n187\t}, func(data []byte) {\n188\t\tsuiteLog = zap.New(zap.WriteTo(GinkgoWriter), zap.UseDevMode(true), zap.Level(zapcore.Level(-5)))\n189\t\n190\t\tlogf.SetLogger(suiteLog)\n191\t\tSetDefaultEventuallyPollingInterval(5 * time.Millisecond)\n192\t\tSetDefaultEventuallyTimeout(5 * time.Second)\n193\t\tvar err error\n194\t\tBy(\"Get shared data to all processes\")\n195\t\tvar sharedData sharedData\n196\t\terr = json.Unmarshal(data, &sharedData)\n197\t\tExpect(err).NotTo(HaveOccurred(), \"failed to unmarshal sharedData\")\n198\t\t// Sync registry.perRegistryCertDirPath for registry.PushMockImage\n199\t\tregistryCertPath := sharedData.RegistryCertPath\n200\t\tregistry.SetCertPath(registryCertPath)\n201\t\t// Sync registryAddress and registryCert\n202\t\tregistryAddress = sharedData.RegistryAddress\n203\t\tregistryCert = sharedData.RegistryCert\n204\t\t// Sync test cluster environment\n205\t\tkc := sharedData.Kubeconfig\n206\t\tocg := clientcmd.NewDefaultClientConfig(kc, &clientcmd.ConfigOverrides{})\n207\t\tcfg, err = ocg.ClientConfig()\n208\t\tExpect(err).NotTo(HaveOccurred(), \"Error loading kubeconfig\")\n209\t\tk8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n210\t\tExpect(err).NotTo(HaveOccurred())\n211\t\tExpect(k8sClient).NotTo(BeNil())\n212\t})\n213\t\n214\tvar _ = SynchronizedAfterSuite(func() {}, func() {\n215\t\tBy(\"Deleting the ClusterPodPlacementConfig\")\n216\t\terr := k8sClient.Delete(ctx, builder.NewClusterPodPlacementConfig().WithName(common.SingletonResourceObjectName).Build())\n217\t\tExpect(err).NotTo(HaveOccurred(), \"failed to delete ClusterPodPlacementConfig\", err)\n218\t\tEventually(testingutils.ValidateDeletion(k8sClient, ctx)).Should(Succeed(), \"the ClusterPodPlacementConfig should be deleted\")\n219\t\tBy(\"Checking the cache is empty\")\n220\t\tExpect(clusterpodplacementconfig.GetClusterPodPlacementConfig()).To(BeNil())\n221\t\n222\t\tBy(\"tearing down the test environment\")\n223\t\tif stopMgr != nil {\n224\t\t\tstopMgr()\n225\t\t}\n226\t\tif mgrStopped != nil {\n227\t\t\tselect {\n228\t\t\tcase <-mgrStopped:\n229\t\t\t\tsuiteLog.Info(\"Manager stopped successfully\")\n230\t\t\tcase <-time.After(10 * time.Second):\n231\t\t\t\tsuiteLog.Error(nil, \"Timeout waiting for manager to stop\")\n232\t\t\t}\n233\t\t}\n234\t\t// TODO: we miss a way to gracefully shutdown the registry server in the AfterSuite fixture.\n235\t\terr = testEnv.Stop()\n236\t\tExpect(err).NotTo(HaveOccurred())\n237\t})\n238\t\n239\tfunc startTestEnv() {\n240\t\tBy(\"bootstrapping test environment\")\n241\t\ttestEnv = &envtest.Environment{\n242\t\t\tCRDDirectoryPaths:     []string{filepath.Join(\"..\", \"..\", \"..\", \"config\", \"crd\", \"bases\")},\n243\t\t\tErrorIfCRDPathMissing: true,\n244\t\t\tWebhookInstallOptions: envtest.WebhookInstallOptions{\n245\t\t\t\tMutatingWebhooks: []*v1.MutatingWebhookConfiguration{getMutatingWebHook()},\n246\t\t\t},\n247\t\t}\n248\t\tvar err error\n249\t\n250\t\t// cfg is defined in this file globally.\n251\t\tcfg, err = testEnv.Start()\n252\t\tExpect(err).NotTo(HaveOccurred())\n253\t\tExpect(cfg).NotTo(BeNil())\n254\t\n255\t\tk8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n256\t\tExpect(err).NotTo(HaveOccurred())\n257\t\tExpect(k8sClient).NotTo(BeNil())\n258\t\t//+kubebuilder:scaffold:scheme\n259\t}\n260\t\n261\tfunc startRegistry() {\n262\t\tBy(\"bootstrapping test registry environment\")\n263\t\tvar (\n264\t\t\terr          error\n265\t\t\tregistryChan = make(chan error)\n266\t\t)\n267\t\tregistryAddress, registryCert, err = registry.RunRegistry(ctx, registryChan)\n268\t\tExpect(err).NotTo(HaveOccurred(), \"failed to start registry server\")\n269\t\ttestingutils.StartChannelMonitor(registryChan, \"registry server failed\")\n270\t\n271\t\t// TODO: we miss a way to gracefully shutdown the registry server in the AfterSuite fixture.\n272\t\tBy(\"Waiting for the registry server to be ready...\")\n273\t\tcaCertPool := x509.NewCertPool()\n274\t\tcaCertPool.AppendCertsFromPEM(registryCert)\n275\t\thttpClient := &http.Client{\n276\t\t\tTransport: &http.Transport{\n277\t\t\t\tTLSClientConfig: &tls.Config{\n278\t\t\t\t\tRootCAs: caCertPool,\n279\t\t\t\t},\n280\t\t\t},\n281\t\t}\n282\t\tEventually(func(g Gomega) {\n283\t\t\t// See https://github.com/distribution/distribution/blob/28c8bc6c0e4b5dfc380e0fa3058d4877fabdfa4a/registry/registry.go#L143\n284\t\t\tresp, err := httpClient.Get(fmt.Sprintf(\"https://%s/\", registryAddress))\n285\t\t\tg.Expect(err).NotTo(HaveOccurred())\n286\t\t\tg.Expect(resp.StatusCode).To(Equal(http.StatusOK))\n287\t\t}).MustPassRepeatedly(3).Should(\n288\t\t\tSucceed(), \"registry server is not ready yet\")\n289\t\tsuiteLog.Info(\"Registry server is ready\", \"registryAddress\", registryAddress)\n290\t}\n291\t\n292\tfunc seedRegistry() {\n293\t\tBy(\"Seeding the registry with images...\")\n294\t\terr := registry.SeedMockRegistry(ctx)\n295\t\tExpect(err).NotTo(HaveOccurred())\n296\t\t// Just print the seed images for debugging purposes.\n297\t\tsuiteLog.Info(\"Seed completed. The registry contains the following images:\")\n298\t\tfor _, image := range registry.GetMockImages() {\n299\t\t\tsuiteLog.Info(image.GetURL())\n300\t\t}\n301\t}\n302\t\n303\tfunc seedK8S() {\n304\t\tvar err error\n305\t\tBy(\"Create internal namespaces\")\n306\t\ttestingutils.EnsureNamespaces(ctx, k8sClient, \"openshift-config\", \"test-namespace\")\n307\t\tBy(\"Create the global pull secret\")\n308\t\tsecret := &corev1.Secret{\n309\t\t\tObjectMeta: metav1.ObjectMeta{\n310\t\t\t\tName:      \"pull-secret\",\n311\t\t\t\tNamespace: \"openshift-config\",\n312\t\t\t},\n313\t\t\tType: corev1.SecretTypeDockerConfigJson,\n314\t\t\tData: map[string][]byte{\n315\t\t\t\t\".dockerconfigjson\": []byte(fmt.Sprintf(`{\"auths\":{\"%s\":{\"auth\":\"%s\"}}}`,\n316\t\t\t\t\tregistryAddress, base64.StdEncoding.EncodeToString([]byte(fmt.Sprintf(\n317\t\t\t\t\t\t\"%s:%s\", registry.GlobalPullSecretUser, registry.GlobalPullSecretPassword))))),\n318\t\t\t},\n319\t\t}\n320\t\terr = k8sClient.Create(ctx, secret)\n321\t\tExpect(err).NotTo(HaveOccurred())\n322\t}\n323\t\n324\tfunc runManager() {\n325\t\tBy(\"Creating the manager\")\n326\t\twebhookServer := webhook.NewServer(webhook.Options{\n327\t\t\tPort:    testEnv.WebhookInstallOptions.LocalServingPort,\n328\t\t\tHost:    testEnv.WebhookInstallOptions.LocalServingHost,\n329\t\t\tCertDir: testEnv.WebhookInstallOptions.LocalServingCertDir,\n330\t\t})\n331\t\tmgr, err := ctrl.NewManager(cfg, ctrl.Options{\n332\t\t\tScheme:                 scheme.Scheme,\n333\t\t\tHealthProbeBindAddress: \":4980\",\n334\t\t\tLogger:                 suiteLog,\n335\t\t\tWebhookServer:          webhookServer,\n336\t\t})\n337\t\tExpect(err).NotTo(HaveOccurred())\n338\t\tsuiteLog.Info(\"Manager created\")\n339\t\n340\t\tclientset := kubernetes.NewForConfigOrDie(cfg)\n341\t\n342\t\tBy(\"Setting up PodPlacement controller\")\n343\t\tExpect((&PodReconciler{\n344\t\t\tClient:    mgr.GetClient(),\n345\t\t\tAPIReader: mgr.GetAPIReader(),\n346\t\t\tScheme:    mgr.GetScheme(),\n347\t\t\tClientSet: clientset,\n348\t\t\tRecorder:  mgr.GetEventRecorderFor(utils.OperatorName), //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n349\t\t}).SetupWithManager(mgr)).NotTo(HaveOccurred())\n350\t\tpool, err := ants.NewMultiPool(10, 10, ants.LeastTasks, ants.WithPreAlloc(true),\n351\t\t\tants.WithNonblocking(true))\n352\t\tExpect(err).NotTo(HaveOccurred())\n353\t\tmgr.GetWebhookServer().Register(\"/add-pod-scheduling-gate\", &webhook.Admission{\n354\t\t\tHandler: NewPodSchedulingGateMutatingWebHook(\n355\t\t\t\tmgr.GetClient(), clientset, mgr.GetScheme(), mgr.GetEventRecorderFor(utils.OperatorName), pool), //nolint:staticcheck // MULTIARCH-6087: will be fixed with events API migration\n356\t\t})\n357\t\n358\t\tpolicyConfig := []byte(`{\"default\":[{\"type\":\"insecureAcceptAnything\"}],\"transports\":{\"atomic\":{},\"docker\":{},\"docker-daemon\":{\"\":[{\"type\":\"insecureAcceptAnything\"}]}}}`)\n359\t\tregistryConfig, err := toml.Marshal(map[string]interface{}{\n360\t\t\t\"unqualified-search-registries\": []string{\"registry.access.redhat.com\", \"docker.io\"},\n361\t\t\t\"short-name-mode\":               \"\",\n362\t\t\t\"registry\":                      []string{},\n363\t\t})\n364\t\n365\t\tExpect(err).NotTo(HaveOccurred())\n366\t\tBy(\"Create containers/policy.json\")\n367\t\tcreateFile(image.PolicyConfPath(), policyConfig)\n368\t\tBy(\"Create containers/containers.conf\")\n369\t\tcreateFile(image.RegistriesConfPath(), registryConfig)\n370\t\tBy(\"Write fake image registry certificate to file\")\n371\t\tcreateFile(filepath.Join(image.DockerCertsDir(),\n372\t\t\tstrings.Replace(registryAddress, \"..\", \":\", 1), \"ca.crt\"), registryCert)\n373\t\n374\t\tBy(\"Setting up Global Pull Secret Syncer\")\n375\t\terr = mgr.Add(NewGlobalPullSecretSyncer(clientset, \"openshift-config\",\n376\t\t\t\"pull-secret\"))\n377\t\tExpect(err).NotTo(HaveOccurred())\n378\t\n379\t\terr = mgr.AddReadyzCheck(\"readyz\", healthz.Ping)\n380\t\tExpect(err).NotTo(HaveOccurred())\n381\t\n382\t\terr = v1alpha1.AddToScheme(scheme.Scheme)\n383\t\tExpect(err).NotTo(HaveOccurred())\n384\t\terr = v1beta1.AddToScheme(scheme.Scheme)\n385\t\tExpect(err).NotTo(HaveOccurred())\n386\t\n387\t\tBy(\"Setting up Cluster Podplacement Config informer\")\n388\t\terr = mgr.Add(clusterpodplacementconfig.NewCPPCSyncer(mgr))\n389\t\tExpect(err).NotTo(HaveOccurred())\n390\t\tBy(\"Checking the cache is empty\")\n391\t\tExpect(clusterpodplacementconfig.GetClusterPodPlacementConfig()).To(BeNil())\n392\t\n393\t\tBy(\"Starting the manager\")\n394\t\tmgrStopped = make(chan struct{})\n395\t\tgo func() {\n396\t\t\tdefer close(mgrStopped)\n397\t\t\tvar mgrCtx context.Context\n398\t\t\tmgrCtx, stopMgr = context.WithCancel(ctx)\n399\t\t\terr = mgr.Start(mgrCtx)\n400\t\t\tExpect(err).NotTo(HaveOccurred())\n401\t\t}()\n402\t\n403\t\tBy(\"Waiting for the manager to be ready...\")\n404\t\tEventually(func(g Gomega) {\n405\t\t\tresp, err := http.Get(\"http://127.0.0.1:4980/readyz\")\n406\t\t\tg.Expect(err).NotTo(HaveOccurred())\n407\t\t\tg.Expect(resp.StatusCode).To(Equal(http.StatusOK))\n408\t\t}).MustPassRepeatedly(3).Should(\n409\t\t\tSucceed(), \"manager is not ready yet\")\n410\t\tsuiteLog.Info(\"Manager is ready\")\n411\t\n412\t\tBy(\"Waiting for the manager cache to sync\")\n413\t\tEventually(func(g Gomega) {\n414\t\t\tg.Expect(mgr.GetCache().WaitForCacheSync(ctx)).To(BeTrue())\n415\t\t}).Should(Succeed(), \"cache did not sync\")\n416\t\tsuiteLog.Info(\"Manager cache synced\")\n417\t}\n418\t\n419\tfunc getMutatingWebHook() *v1.MutatingWebhookConfiguration {\n420\t\treturn &v1.MutatingWebhookConfiguration{\n421\t\t\tObjectMeta: metav1.ObjectMeta{\n422\t\t\t\tName: \"mutating-webhook-configuration\",\n423\t\t\t},\n424\t\t\tWebhooks: []v1.MutatingWebhook{\n425\t\t\t\t{\n426\t\t\t\t\tName:                    \"pod-placement-scheduling-gate.multiarch.openshift.io\",\n427\t\t\t\t\tAdmissionReviewVersions: []string{\"v1\"},\n428\t\t\t\t\tClientConfig: v1.WebhookClientConfig{\n429\t\t\t\t\t\tService: &v1.ServiceReference{\n430\t\t\t\t\t\t\tName: \"webhook-service\",\n431\t\t\t\t\t\t\tPath: utils.NewPtr(\"/add-pod-scheduling-gate\"),\n432\t\t\t\t\t\t},\n433\t\t\t\t\t},\n434\t\t\t\t\tFailurePolicy: utils.NewPtr(v1.Ignore),\n435\t\t\t\t\tRules: []v1.RuleWithOperations{\n436\t\t\t\t\t\t{\n437\t\t\t\t\t\t\tOperations: []v1.OperationType{\"CREATE\"},\n438\t\t\t\t\t\t\tRule: v1.Rule{\n439\t\t\t\t\t\t\t\tAPIGroups:   []string{\"\"},\n440\t\t\t\t\t\t\t\tAPIVersions: []string{\"v1\"},\n441\t\t\t\t\t\t\t\tResources:   []string{\"pods\"},\n442\t\t\t\t\t\t\t},\n443\t\t\t\t\t\t},\n444\t\t\t\t\t},\n445\t\t\t\t\tSideEffects: utils.NewPtr(v1.SideEffectClassNone),\n446\t\t\t\t},\n447\t\t\t},\n448\t\t}\n449\t}\n450\t\n451\tfunc createFile(path string, data []byte) {\n452\t\terr := os.MkdirAll(filepath.Dir(path), 0775)\n453\t\tExpect(err).NotTo(HaveOccurred())\n454\t\tf, err := os.Create(filepath.Clean(path))\n455\t\tExpect(err).NotTo(HaveOccurred())\n456\t\tdefer func() {\n457\t\t\terr = f.Close()\n458\t\t\tExpect(err).NotTo(HaveOccurred())\n459\t\t}()\n460\t\t_, err = f.Write(data)\n461\t\tExpect(err).NotTo(HaveOccurred())\n462\t}\n463\t"}]},"parent_tool_use_id":null,"session_id":"846d4319-4e4f-42e4-a20b-8a56ae2d4312","uuid":"df440a4c-72b6-4adf-98e7-e866ec2bbc47","timestamp":"2026-07-16T14:03:23.714Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/multiarch-tuning-operator-treatment/internal/controller/podplacement/suite_test.go","content":"/*\nCopyright 2023 Red Hat, Inc.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n\n    http://www.apache.org/licenses/LICENSE-2.0\n\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\npackage podplacement\n\nimport (\n\t\"context\"\n\t\"crypto/tls\"\n\t\"crypto/x509\"\n\t\"encoding/base64\"\n\t\"fmt\"\n\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/BurntSushi/toml\"\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/image\"\n\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\n\t\"go.uber.org/zap/zapcore\"\n\n\tv1 \"k8s.io/api/admissionregistration/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/apimachinery/pkg/util/json\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/client-go/kubernetes/scheme\"\n\t\"k8s.io/client-go/rest\"\n\t\"k8s.io/client-go/tools/clientcmd\"\n\t\"k8s.io/client-go/tools/clientcmd/api\"\n\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\t\"sigs.k8s.io/controller-runtime/pkg/envtest\"\n\t\"sigs.k8s.io/controller-runtime/pkg/healthz\"\n\tlogf \"sigs.k8s.io/controller-runtime/pkg/log\"\n\t\"sigs.k8s.io/controller-runtime/pkg/log/zap\"\n\t\"sigs.k8s.io/controller-runtime/pkg/webhook\"\n\n\t\"github.com/panjf2000/ants/v2\"\n\n\t\"github.com/openshift/multiarch-tuning-operator/api/common\"\n\t\"github.com/openshift/multiarch-tuning-operator/api/v1alpha1\"\n\t\"github.com/openshift/multiarch-tuning-operator/api/v1beta1\"\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/e2e\"\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/informers/clusterpodplacementconfig\"\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/testing/builder\"\n\ttestingutils \"github.com/openshift/multiarch-tuning-operator/pkg/testing/framework\"\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/testing/image/fake/registry\"\n\t\"github.com/openshift/multiarch-tuning-operator/pkg/utils\"\n\t//+kubebuilder:scaffold:imports\n)\n\n// These tests use Ginkgo (BDD-style Go testing framework). Refer to\n// http://onsi.github.io/ginkgo/ to learn more about Ginkgo.\n\nvar (\n\tcfg             *rest.Config\n\tk8sClient       client.Client\n\tregistryAddress string\n\tregistryCert    []byte\n\tstopMgr         context.CancelFunc\n\tmgrStopped      chan struct{}\n\ttestEnv         *envtest.Environment\n\n\tdir      string\n\tsuiteLog = ctrl.Log.WithName(\"setup\")\n)\n\ntype sharedData struct {\n\tKubeconfig       api.Config `json:\"kubeconfig\"`\n\tRegistryAddress  string     `json:\"registryAddress\"`\n\tRegistryCert     []byte     `json:\"registryCert\"`\n\tRegistryCertPath string     `json:\"registryCertpath\"`\n}\n\nfunc init() {\n\te2e.CommonInit()\n}\n\nfunc TestAPIs(t *testing.T) {\n\tRegisterFailHandler(Fail)\n\tRunSpecs(t, \"Controllers Integration Suite\", Label(\"integration\"))\n}\n\nvar _ = BeforeAll\n\nvar _ = SynchronizedBeforeSuite(func() []byte {\n\tsuiteLog = zap.New(zap.WriteTo(GinkgoWriter), zap.UseDevMode(true), zap.Level(zapcore.Level(-5)))\n\n\tlogf.SetLogger(suiteLog)\n\tSetDefaultEventuallyPollingInterval(5 * time.Millisecond)\n\tSetDefaultEventuallyTimeout(5 * time.Second)\n\n\tBy(\"Set up a shared test environment and local registry for testing on process 1 node\")\n\twg := &sync.WaitGroup{}\n\ttestingutils.DecorateWithWaitGroup(wg, startTestEnv)\n\ttestingutils.DecorateWithWaitGroup(wg, startRegistry)\n\twg.Wait()\n\ttestingutils.DecorateWithWaitGroup(wg, seedRegistry)\n\ttestingutils.DecorateWithWaitGroup(wg, seedK8S)\n\twg.Wait()\n\n\tvar err error\n\tdir, err = os.MkdirTemp(\"\", \"multiarch-tuning-operator\")\n\tExpect(err).NotTo(HaveOccurred())\n\tExpect(dir).NotTo(BeEmpty())\n\terr = os.Setenv(\"DOCKER_CERTS_DIR\", filepath.Join(dir, \"docker/certs.d\"))\n\tExpect(err).NotTo(HaveOccurred())\n\terr = os.Setenv(\"REGISTRIES_CERTS_DIR\", filepath.Join(dir, \"containers/registries.d\"))\n\tExpect(err).NotTo(HaveOccurred())\n\terr = os.Setenv(\"REGISTRIES_CONF_PATH\", filepath.Join(dir, \"containers/registries.conf\"))\n\tExpect(err).NotTo(HaveOccurred())\n\terr = os.Setenv(\"POLICY_CONF_PATH\", filepath.Join(dir, \"containers/policy.json\"))\n\tExpect(err).NotTo(HaveOccurred())\n\n\t// TODO: should we continue running the manager in the BeforeSuite node?\n\trunManager()\n\n\tBy(\"Creating the ClusterPodPlacementConfig\")\n\terr = k8sClient.Create(ctx, builder.NewClusterPodPlacementConfig().\n\t\tWithName(common.SingletonResourceObjectName).\n\t\tWithPlugins().\n\t\tWithNodeAffinityScoring(true).\n\t\tWithNodeAffinityScoringTerm(utils.ArchitectureArm64, 50).\n\t\tBuild())\n\tExpect(err).NotTo(HaveOccurred(), \"failed to create ClusterPodPlacementConfig\")\n\n\tBy(\"Checking initialization of the cache with the ClusterPodPlacementConfig\")\n\tppc := &v1beta1.ClusterPodPlacementConfig{}\n\terr = k8sClient.Get(ctx, client.ObjectKey{Name: common.SingletonResourceObjectName}, ppc)\n\tExpect(err).NotTo(HaveOccurred(), \"failed to get ClusterPodPlacementConfig\")\n\n\t// Wait for the informer to update by polling\n\tBy(\"Waiting for the cache to reflect the ClusterPodPlacementConfig\")\n\tEventually(clusterpodplacementconfig.GetClusterPodPlacementConfig).\n\t\tShould(Equal(ppc), \"cache did not update with ClusterPodPlacementConfig\")\n\n\tBy(\"Updating the ClusterPodPlacementConfig\")\n\tppc.Spec.LogVerbosity = common.LogVerbosityLevelTraceAll\n\terr = k8sClient.Update(ctx, ppc)\n\tExpect(err).NotTo(HaveOccurred(), \"failed to update ClusterPodPlacementConfig\")\n\n\tBy(\"Get the updated ClusterPodPlacementConfig\")\n\terr = k8sClient.Get(ctx, client.ObjectKey{Name: common.SingletonResourceObjectName}, ppc)\n\tExpect(err).NotTo(HaveOccurred(), \"failed to get ClusterPodPlacementConfig\")\n\n\tBy(\"Waiting for the cache to reflect the updated ClusterPodPlacementConfig\")\n\tEventually(clusterpodplacementconfig.GetClusterPodPlacementConfig).\n\t\tShould(Equal(ppc), \"cache did not update with new ClusterPodPlacementConfig\")\n\n\tBy(\"Prepare shared data and Pass to all processes\")\n\t// Get cluster info and share with all processes\n\tkc := testingutils.FromEnvTestConfig(cfg)\n\t// The registry.perRegistryCertDirPath is used by registry.PushMockImage,\n\t// need to pass to all processes\n\tregistryCertPath := registry.GetCertPath()\n\tdata := sharedData{\n\t\tKubeconfig:       kc,\n\t\tRegistryAddress:  registryAddress,\n\t\tRegistryCert:     registryCert,\n\t\tRegistryCertPath: registryCertPath,\n\t}\n\tjsonData, err := json.Marshal(data)\n\tExpect(err).NotTo(HaveOccurred(), \"failed to marshal sharedData\")\n\treturn jsonData\n}, func(data []byte) {\n\tsuiteLog = zap.New(zap.WriteTo(GinkgoWriter), zap.UseDevMode(true), zap.Level(zapcore.Level(-5)))\n\n\tlogf.SetLogger(suiteLog)\n\tSetDefaultEventuallyPollingInterval(5 * time.Millisecond)\n\tSetDefaultEventuallyTimeout(5 * time.Second)\n\tvar err error\n\tBy(\"Get shared data to all processes\")\n\tvar sharedData sharedData\n\terr = json.Unmarshal(data, &sharedData)\n\tExpect(err).NotTo(HaveOccurred(), \"failed to unmarshal sharedData\")\n\t// Sync registry.perRegistryCertDirPath for registry.PushMockImage\n\tregistryCertPath := sharedData.RegistryCertPath\n\tregistry.SetCertPath(registryCertPath)\n\t// Sync registryAddress and registryCert\n\tregistryAddress = sharedData.RegistryAddress\n\tregistryCert = sharedData.RegistryCert\n\t// Sync test cluster environment\n\tkc := sharedData.Kubeconfig\n\tocg := clientcmd.NewDefaultClientConfig(kc, &clientcmd.ConfigOverrides{})\n\tcfg, err = ocg.ClientConfig()\n\tExpect(err).NotTo(HaveOccurred(), \"Error loading kubeconfig\")\n\tk8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n\tExpect(err).NotTo(HaveOccurred())\n\tExpect(k8sClient).NotTo(BeNil())\n})\n\nvar _ = SynchronizedAfterSuite(func() {}, func() {\n\tBy(\"Deleting the ClusterPodPlacementConfig\")\n\terr := k8sClient.Delete(ctx, builder.NewClusterPodPlacementConfig().WithName(common.SingletonResourceObjectName).Build())\n\tExpect(err).NotTo(HaveOccurred(), \"failed to delete ClusterPodPlacementConfig\", err)\n\tEventually(testingutils.ValidateDeletion(k8sClient, ctx)).Should(Succeed(), \"the ClusterPodPlacementConfig should be deleted\")\n\tBy(\"Checking the cache is empty\")\n\tExpect(clusterpodplacementconfig.GetClusterPodPlacementConfig()).To(BeNil())\n\n\tBy(\"tearing down the test environment\")\n\tif stopMgr != nil {\n\t\tstopMgr()\n\t}\n\tif mgrStopped != nil {\n\t\tselect {\n\t\tcase <-mgrStopped:\n\t\t\tsuiteLog.Info(\"Manager stopped successfully\")\n\t\tcase <-time.After(10 * time.Second):\n\t\t\tsuiteLog.Error(nil, \"Timeout waiting for manager to stop\")\n\t\t}\n\t}\n\t// TODO: we miss a way to gracefully shutdown the registry server in the AfterSuite fixture.\n\terr = testEnv.Stop()\n\tExpect(err).NotTo(HaveOccurred())\n})\n\nfunc startTestEnv() {\n\tBy(\"bootstrapping test environment\")\n\ttestEnv = &envtest.Environment{\n\t\tCRDDirectoryPaths:     []string{filepath.Join(\"..\", \"..\", \"..\", \"config\", \"crd\", \"bases\")},\n\t\tErrorIfCRDPathMissing: true,\n\t\tWebhookInstallOptions: envtest.WebhookInstallOptions{\n\t\t\tMutatingWebhooks: []*v1.MutatingWebhookConfiguration{getMutatingWebHook()},\n\t\t},\n\t}\n\tvar err error\n\n\t// cfg is defined in this file globally.\n\tcfg, err = testEnv.Start()\n\tExpect(err).NotTo(HaveOccurred())\n\tExpect(cfg).NotTo(BeNil())\n\n\tk8sClient, err = client.New(cfg, client.Options{Scheme: scheme.Scheme})\n\tExpect(err).NotTo(HaveOccurred())\n\tExpect(k8sClient).NotTo(BeNil())\n\t//+kubebuilder:scaffold:scheme\n}\n\nfunc startRegistry() {\n\tBy(\"bootstrapping test registry environment\")\n\tvar (\n\t\terr          error\n\t\tregistryChan = make(chan error)\n\t)\n\tregistryAddress, registryCert, err = registry.RunRegistry(ctx, registryChan)\n\tExpect(err).NotTo(HaveOccurred(), \"failed to start registry server\")\n\ttestingutils.StartChannelMonitor(registryChan, \"registry server failed\")\n\n\t// TODO: we miss a way to gracefully shutdown the registry server in the AfterSuite fixture.\n\tBy(\"Waiting for the registry server to be ready...\")\n\tcaCertPool := x509.NewCertPool()\n\tcaCertPool.AppendCertsFromPEM(registryCert)\n\thttpClient := &http.Client{\n\t\tTransport: &http.Transport{\n\t\t\tTLSClientConfig: &tls.Config{\n\t\t\t\tRootCAs: caCertPool,\n\t\t\t},\n\t\t},\n\t}\n\tEventually(func(g Gomega) {\n\t\t// See https://github.com/distribution/distribution/blob/28c8bc6c0e4b5dfc380e0fa3058d4877fabdfa4a/registry/registry.go#L143\n\t\tresp, err := httpClient.Get(fmt.Sprintf(\"https://%s/\", registryAddress))\n\t\tg.Expect(err).NotTo(HaveOccurred())\n\t\tg.Expect(resp.StatusCode).To(Equal(http.StatusOK))\n\t}).MustPassRepeatedly(3).Should(\n\t\tSucceed(), \"registry server is not ready yet\")\n\tsuiteLog.Info(\"Registry server is ready\", \"registryAddress\", registryAddress)\n}\n\nfunc seedRegistry() {\n\tBy(
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01AvrZ6uzuPnccYLWeECSP6F","type":"tool_result","content":"1\tpackage trustmanager\n2\t\n3\timport (\n4\t\t\"crypto/sha256\"\n5\t\t\"encoding/hex\"\n6\t\t\"encoding/json\"\n7\t\t\"fmt\"\n8\t\t\"maps\"\n9\t\n10\t\tcorev1 \"k8s.io/api/core/v1\"\n11\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n12\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n13\t\n14\t\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n15\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n16\t)\n17\t\n18\t// caPackage represents the JSON format expected by trust-manager\n19\ttype caPackage struct {\n20\t\tName    string `json:\"name\"`\n21\t\tBundle  string `json:\"bundle\"`\n22\t\tVersion string `json:\"version\"`\n23\t}\n24\t\n25\t// createOrApplyDefaultCAPackageConfigMap reads the CNO-injected CA bundle,\n26\t// formats it into trust-manager's expected JSON package format, and creates\n27\t// or updates the package ConfigMap in the operand namespace.\n28\t// Returns the SHA-256 hash of the CA bundle content and any error.\n29\t// Returns (\"\", nil) when defaultCAPackage is disabled.\n30\tfunc (r *Reconciler) createOrApplyDefaultCAPackageConfigMap(trustManager *v1alpha1.TrustManager, resourceLabels, resourceAnnotations map[string]string) (string, error) {\n31\t\tif !defaultCAPackageEnabled(trustManager.Spec.TrustManagerConfig.DefaultCAPackage) {\n32\t\t\treturn \"\", nil\n33\t\t}\n34\t\n35\t\tcaBundle, resourceVersion, err := r.readTrustedCABundle()\n36\t\tif err != nil {\n37\t\t\treturn \"\", err\n38\t\t}\n39\t\n40\t\tpkgJSON, err := formatCAPackage(caBundle, resourceVersion)\n41\t\tif err != nil {\n42\t\t\treturn \"\", err\n43\t\t}\n44\t\n45\t\tbundleHash := computeCABundleHash(caBundle)\n46\t\n47\t\tdesired := buildDefaultCAPackageConfigMap(pkgJSON, resourceLabels, resourceAnnotations)\n48\t\n49\t\tcmName := fmt.Sprintf(\"%s/%s\", desired.GetNamespace(), desired.GetName())\n50\t\tr.log.V(4).Info(\"reconciling default CA package ConfigMap\", \"name\", cmName)\n51\t\n52\t\texisting := &corev1.ConfigMap{}\n53\t\texists, err := r.Exists(r.ctx, client.ObjectKeyFromObject(desired), existing)\n54\t\tif err != nil {\n55\t\t\treturn \"\", common.FromClientError(err, \"failed to check if ConfigMap %q exists\", cmName)\n56\t\t}\n57\t\tif exists && !configMapModified(desired, existing) {\n58\t\t\tr.log.V(4).Info(\"default CA package ConfigMap exists and is in desired state\", \"name\", cmName)\n59\t\t\treturn bundleHash, nil\n60\t\t}\n61\t\n62\t\tr.log.V(2).Info(\"default CA package ConfigMap has been modified, updating to desired state\", \"name\", cmName)\n63\t\tif err := r.Patch(r.ctx, desired, client.Apply, client.FieldOwner(fieldOwner), client.ForceOwnership); err != nil {\n64\t\t\treturn \"\", common.FromClientError(err, \"failed to apply ConfigMap %q\", cmName)\n65\t\t}\n66\t\n67\t\tr.eventRecorder.Eventf(trustManager, corev1.EventTypeNormal, \"Reconciled\", \"default CA package ConfigMap %s applied\", cmName)\n68\t\treturn bundleHash, nil\n69\t}\n70\t\n71\t// readTrustedCABundle reads the CNO-injected CA bundle from the operator namespace.\n72\t// Returns the PEM bundle, the ConfigMap's resource version, and any error.\n73\tfunc (r *Reconciler) readTrustedCABundle() (string, string, error) {\n74\t\tinjectionCM := &corev1.ConfigMap{}\n75\t\tkey := client.ObjectKey{\n76\t\t\tNamespace: common.OperatorNamespace,\n77\t\t\tName:      common.TrustedCABundleConfigMapName,\n78\t\t}\n79\t\tif err := r.Get(r.ctx, key, injectionCM); err != nil {\n80\t\t\treturn \"\", \"\", common.FromClientError(\n81\t\t\t\terr,\n82\t\t\t\t\"failed to read CA bundle ConfigMap %q in namespace %q\",\n83\t\t\t\tcommon.TrustedCABundleConfigMapName, common.OperatorNamespace,\n84\t\t\t)\n85\t\t}\n86\t\n87\t\tcaBundle, ok := injectionCM.Data[common.TrustedCABundleKey]\n88\t\tif !ok || caBundle == \"\" {\n89\t\t\treturn \"\", \"\", common.FromClientError(\n90\t\t\t\tfmt.Errorf(\"CA bundle ConfigMap %q does not contain key %q\", common.TrustedCABundleConfigMapName, common.TrustedCABundleKey),\n91\t\t\t\t\"missing key %q in ConfigMap %q\", common.TrustedCABundleKey, common.TrustedCABundleConfigMapName,\n92\t\t\t)\n93\t\t}\n94\t\n95\t\treturn caBundle, injectionCM.ResourceVersion, nil\n96\t}\n97\t\n98\t// formatCAPackage encodes the CA bundle into trust-manager's expected JSON package format.\n99\tfunc formatCAPackage(caBundle, version string) ([]byte, error) {\n100\t\tpkg := caPackage{\n101\t\t\tName:    defaultCAPackageName,\n102\t\t\tBundle:  caBundle,\n103\t\t\tVersion: version,\n104\t\t}\n105\t\t// TODO: cross check the formatting of the JSON package\n106\t\tpkgJSON, err := json.Marshal(pkg)\n107\t\tif err != nil {\n108\t\t\treturn nil, fmt.Errorf(\"failed to marshal CA package to JSON: %w\", err)\n109\t\t}\n110\t\treturn pkgJSON, nil\n111\t}\n112\t\n113\t// computeCABundleHash returns the SHA-256 hash of the CA bundle PEM content.\n114\t// The hash is used as the pod template annotation to trigger rolling restarts\n115\t// only when the actual certificate content changes.\n116\tfunc computeCABundleHash(caBundle string) string {\n117\t\thash := sha256.Sum256([]byte(caBundle))\n118\t\treturn hex.EncodeToString(hash[:])\n119\t}\n120\t\n121\t// buildDefaultCAPackageConfigMap constructs the desired ConfigMap for the\n122\t// formatted CA package in the operand namespace.\n123\tfunc buildDefaultCAPackageConfigMap(pkgJSON []byte, resourceLabels, resourceAnnotations map[string]string) *corev1.ConfigMap {\n124\t\tcm := &corev1.ConfigMap{\n125\t\t\tTypeMeta: metav1.TypeMeta{\n126\t\t\t\tAPIVersion: \"v1\",\n127\t\t\t\tKind:       \"ConfigMap\",\n128\t\t\t},\n129\t\t\tObjectMeta: metav1.ObjectMeta{\n130\t\t\t\tName:      defaultCAPackageConfigMapName,\n131\t\t\t\tNamespace: operandNamespace,\n132\t\t\t},\n133\t\t\tData: map[string]string{\n134\t\t\t\tdefaultCAPackageFilename: string(pkgJSON),\n135\t\t\t},\n136\t\t}\n137\t\tcommon.UpdateResourceLabels(cm, resourceLabels)\n138\t\tupdateResourceAnnotations(cm, resourceAnnotations)\n139\t\treturn cm\n140\t}\n141\t\n142\t// configMapModified checks whether the desired ConfigMap differs from the existing one.\n143\tfunc configMapModified(desired, existing *corev1.ConfigMap) bool {\n144\t\treturn managedMetadataModified(desired, existing) ||\n145\t\t\t!maps.Equal(desired.Data, existing.Data)\n146\t}\n147\t"}]},"parent_tool_use_id":null,"session_id":"28bc8e08-8b2b-4a57-baeb-0a1292c0555f","uuid":"91a84cda-4b9b-4ec5-9ab0-9981cc31a0c3","timestamp":"2026-07-16T14:00:32.436Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/controller/trustmanager/configmaps.go","content":"package trustmanager\n\nimport (\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"maps\"\n\n\tcorev1 \"k8s.io/api/core/v1\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n\n\t\"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n)\n\n// caPackage represents the JSON format expected by trust-manager\ntype caPackage struct {\n\tName    string `json:\"name\"`\n\tBundle  string `json:\"bundle\"`\n\tVersion string `json:\"version\"`\n}\n\n// createOrApplyDefaultCAPackageConfigMap reads the CNO-injected CA bundle,\n// formats it into trust-manager's expected JSON package format, and creates\n// or updates the package ConfigMap in the operand namespace.\n// Returns the SHA-256 hash of the CA bundle content and any error.\n// Returns (\"\", nil) when defaultCAPackage is disabled.\nfunc (r *Reconciler) createOrApplyDefaultCAPackageConfigMap(trustManager *v1alpha1.TrustManager, resourceLabels, resourceAnnotations map[string]string) (string, error) {\n\tif !defaultCAPackageEnabled(trustManager.Spec.TrustManagerConfig.DefaultCAPackage) {\n\t\treturn \"\", nil\n\t}\n\n\tcaBundle, resourceVersion, err := r.readTrustedCABundle()\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tpkgJSON, err := formatCAPackage(caBundle, resourceVersion)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tbundleHash := computeCABundleHash(caBundle)\n\n\tdesired := buildDefaultCAPackageConfigMap(pkgJSON, resourceLabels, resourceAnnotations)\n\n\tcmName := fmt.Sprintf(\"%s/%s\", desired.GetNamespace(), desired.GetName())\n\tr.log.V(4).Info(\"reconciling default CA package ConfigMap\", \"name\", cmName)\n\n\texisting := &corev1.ConfigMap{}\n\texists, err := r.Exists(r.ctx, client.ObjectKeyFromObject(desired), existing)\n\tif err != nil {\n\t\treturn \"\", common.FromClientError(err, \"failed to check if ConfigMap %q exists\", cmName)\n\t}\n\tif exists && !configMapModified(desired, existing) {\n\t\tr.log.V(4).Info(\"default CA package ConfigMap exists and is in desired state\", \"name\", cmName)\n\t\treturn bundleHash, nil\n\t}\n\n\tr.log.V(2).Info(\"default CA package ConfigMap has been modified, updating to desired state\", \"name\", cmName)\n\tif err := r.Patch(r.ctx, desired, client.Apply, client.FieldOwner(fieldOwner), client.ForceOwnership); err != nil {\n\t\treturn \"\", common.FromClientError(err, \"failed to apply ConfigMap %q\", cmName)\n\t}\n\n\tr.eventRecorder.Eventf(trustManager, corev1.EventTypeNormal, \"Reconciled\", \"default CA package ConfigMap %s applied\", cmName)\n\treturn bundleHash, nil\n}\n\n// readTrustedCABundle reads the CNO-injected CA bundle from the operator namespace.\n// Returns the PEM bundle, the ConfigMap's resource version, and any error.\nfunc (r *Reconciler) readTrustedCABundle() (string, string, error) {\n\tinjectionCM := &corev1.ConfigMap{}\n\tkey := client.ObjectKey{\n\t\tNamespace: common.OperatorNamespace,\n\t\tName:      common.TrustedCABundleConfigMapName,\n\t}\n\tif err := r.Get(r.ctx, key, injectionCM); err != nil {\n\t\treturn \"\", \"\", common.FromClientError(\n\t\t\terr,\n\t\t\t\"failed to read CA bundle ConfigMap %q in namespace %q\",\n\t\t\tcommon.TrustedCABundleConfigMapName, common.OperatorNamespace,\n\t\t)\n\t}\n\n\tcaBundle, ok := injectionCM.Data[common.TrustedCABundleKey]\n\tif !ok || caBundle == \"\" {\n\t\treturn \"\", \"\", common.FromClientError(\n\t\t\tfmt.Errorf(\"CA bundle ConfigMap %q does not contain key %q\", common.TrustedCABundleConfigMapName, common.TrustedCABundleKey),\n\t\t\t\"missing key %q in ConfigMap %q\", common.TrustedCABundleKey, common.TrustedCABundleConfigMapName,\n\t\t)\n\t}\n\n\treturn caBundle, injectionCM.ResourceVersion, nil\n}\n\n// formatCAPackage encodes the CA bundle into trust-manager's expected JSON package format.\nfunc formatCAPackage(caBundle, version string) ([]byte, error) {\n\tpkg := caPackage{\n\t\tName:    defaultCAPackageName,\n\t\tBundle:  caBundle,\n\t\tVersion: version,\n\t}\n\t// TODO: cross check the formatting of the JSON package\n\tpkgJSON, err := json.Marshal(pkg)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"failed to marshal CA package to JSON: %w\", err)\n\t}\n\treturn pkgJSON, nil\n}\n\n// computeCABundleHash returns the SHA-256 hash of the CA bundle PEM content.\n// The hash is used as the pod template annotation to trigger rolling restarts\n// only when the actual certificate content changes.\nfunc computeCABundleHash(caBundle string) string {\n\thash := sha256.Sum256([]byte(caBundle))\n\treturn hex.EncodeToString(hash[:])\n}\n\n// buildDefaultCAPackageConfigMap constructs the desired ConfigMap for the\n// formatted CA package in the operand namespace.\nfunc buildDefaultCAPackageConfigMap(pkgJSON []byte, resourceLabels, resourceAnnotations map[string]string) *corev1.ConfigMap {\n\tcm := &corev1.ConfigMap{\n\t\tTypeMeta: metav1.TypeMeta{\n\t\t\tAPIVersion: \"v1\",\n\t\t\tKind:       \"ConfigMap\",\n\t\t},\n\t\tObjectMeta: metav1.ObjectMeta{\n\t\t\tName:      defaultCAPackageConfigMapName,\n\t\t\tNamespace: operandNamespace,\n\t\t},\n\t\tData: map[string]string{\n\t\t\tdefaultCAPackageFilename: string(pkgJSON),\n\t\t},\n\t}\n\tcommon.UpdateResourceLabels(cm, resourceLabels)\n\tupdateResourceAnnotations(cm, resourceAnnotations)\n\treturn cm\n}\n\n// configMapModified checks whether the desired ConfigMap differs from the existing one.\nfunc configMapModified(desired, existing *corev1.ConfigMap) bool {\n\treturn managedMetadataModified(desired, existing) ||\n\t\t!maps.Equal(desired.Data, existing.Data)\n}\n","numLines":147,"startLine":1,"totalLines":147}}}

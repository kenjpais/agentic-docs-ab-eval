chitectures, ok := c.imageRefsCache.Get(hash); ok && !skipCache {\n52\t\t\tlog.V(3).Info(\"Cache hit\", \"architectures\", architectures, \"hash\", hash)\n53\t\t\tdefer utils.HistogramObserve(now, metrics.TimeToInspectImageGivenHit)\n54\t\t\treturn architectures, nil\n55\t\t}\n56\t\tarchitectures, err := c.registryInspector.GetCompatibleArchitecturesSet(ctx, imageReference, true, secrets)\n57\t\tif err != nil {\n58\t\t\treturn nil, err\n59\t\t}\n60\t\n61\t\tlog.V(3).Info(\"Cache miss...adding to cache\", \"architectures\", architectures, \"hash\", hash)\n62\t\tif !skipCache {\n63\t\t\tc.imageRefsCache.Add(hash, architectures)\n64\t\t}\n65\t\tdefer utils.HistogramObserve(now, metrics.TimeToInspectImageGivenMiss)\n66\t\treturn architectures, nil\n67\t}\n68\t\n69\tfunc (c *cacheProxy) GetRegistryInspector() IRegistryInspector {\n70\t\treturn c.registryInspector\n71\t}\n72\t\n73\t// clearCache purges the image metadata cache\n74\tfunc (c *cacheProxy) clearCache() {\n75\t\tc.imageRefsCache.Purge()\n76\t}\n77\t\n78\tfunc newCacheProxy() *cacheProxy {\n79\t\treturn &cacheProxy{\n80\t\t\tregistryInspector: newRegistryInspector(),\n81\t\t\timageRefsCache:    expirable.NewLRU[string, sets.Set[string]](256, nil, time.Hour*6),\n82\t\t}\n83\t}\n84\t\n85\tfunc computeHash(imageReference string, secrets []byte) string {\n86\t\th := sha256.New()\n87\t\th.Write([]byte(imageReference))\n88\t\th.Write([]byte{0})\n89\t\th.Write(secrets)\n90\t\treturn hex.EncodeToString(h.Sum(nil))\n91\t}\n92\t"}]},"parent_tool_use_id":null,"session_id":"c48cc588-15a8-4b4d-a25c-c3947184f227","uuid":"22b4fd64-ec25-49f0-917c-3dffb3d624ee","timestamp":"2026-07-16T14:03:02.611Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/multiarch-tuning-operator-treatment/pkg/image/cache.go","content":"/*\nCopyright 2023 Red Hat, Inc.\n\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\n
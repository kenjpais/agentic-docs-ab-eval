.gvr. A NotFound error from discovery is\n46\t// treated as not present (false, nil); other errors are returned.\n47\tfunc (a *apiResourceDiscoverer) Discover() (bool, error) {\n48\t\tresources, err := a.discoveryClient.ServerResourcesForGroupVersion(a.gvr.GroupVersion().String())\n49\t\tif err != nil {\n50\t\t\tif errors.IsNotFound(err) {\n51\t\t\t\treturn false, nil\n52\t\t\t}\n53\t\t\treturn false, fmt.Errorf(\"failed to discover resources: %w\", err)\n54\t\t}\n55\t\n56\t\tfor _, res := range resources.APIResources {\n57\t\t\tif res.Name == a.gvr.Resource {\n58\t\t\t\treturn true, nil\n59\t\t\t}\n60\t\t}\n61\t\n62\t\treturn false, nil\n63\t}\n64\t\n65\t// InitInformerIfAvailable calls d.Discover(), and if the resource is served it\n66\t// calls informerInitFunc and stores the result in InformerFactory; otherwise\n67\t// InformerFactory remains nil and no error is returned (the API is treated as\n68\t// unavailable).\n69\tfunc InitInformerIfAvailable[groupInformer any](\n70\t\td ResourceDiscoverer,\n71\t\tinformerInitFunc func() groupInformer,\n72\t) (*OptionalInformer[groupInformer], error) {\n73\t\to := new(OptionalInformer[groupInformer])\n74\t\n75\t\tdiscovered, err := d.Discover()\n76\t\tif err != nil {\n77\t\t\treturn nil, err\n78\t\t}\n79\t\n80\t\tif discovered {\n81\t\t\tinformer := informerInitFunc()\n82\t\t\to.InformerFactory = &informer\n83\t\t}\n84\t\n85\t\treturn o, nil\n86\t}\n87\t\n88\t// Applicable reports whether an informer factory was set (the API was present).\n89\tfunc (o *OptionalInformer[GroupInformer]) Applicable() bool {\n90\t\treturn o.InformerFactory != nil\n91\t}\n92\t"}]},"parent_tool_use_id":null,"session_id":"dd324d1c-703f-46ea-bfcf-8c61203e2c16","uuid":"66098217-1d8b-4e9a-908f-f8a0a3aaa1f3","timestamp":"2026-07-16T13:55:22.993Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/operator/utils/apidiscovery.go","content":"// Package utils provides smal
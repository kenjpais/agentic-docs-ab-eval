{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01CpP5v7gbxWkgxiBUAk3trM","type":"tool_result","content":"1\tpackage operator\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\n8\t\tadmissionregistrationv1 \"k8s.io/api/admissionregistration/v1\"\n9\t\tappsv1 \"k8s.io/api/apps/v1\"\n10\t\tcorev1 \"k8s.io/api/core/v1\"\n11\t\tnetworkingv1 \"k8s.io/api/networking/v1\"\n12\t\trbacv1 \"k8s.io/api/rbac/v1\"\n13\t\t\"k8s.io/apimachinery/pkg/labels\"\n14\t\t\"k8s.io/apimachinery/pkg/runtime\"\n15\t\t\"k8s.io/apimachinery/pkg/selection\"\n16\t\tutilruntime \"k8s.io/apimachinery/pkg/util/runtime\"\n17\t\tclientscheme \"k8s.io/client-go/kubernetes/scheme\"\n18\t\t\"k8s.io/client-go/rest\"\n19\t\tctrl \"sigs.k8s.io/controller-runtime\"\n20\t\t\"sigs.k8s.io/controller-runtime/pkg/cache\"\n21\t\t\"sigs.k8s.io/controller-runtime/pkg/client\"\n22\t\t\"sigs.k8s.io/controller-runtime/pkg/manager\"\n23\t\n24\t\tcertmanagerv1 \"github.com/cert-manager/cert-manager/pkg/apis/certmanager/v1\"\n25\t\n26\t\tconfigv1 \"github.com/openshift/api/config/v1\"\n27\t\tv1alpha1 \"github.com/openshift/cert-manager-operator/api/operator/v1alpha1\"\n28\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/common\"\n29\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/istiocsr\"\n30\t\t\"github.com/openshift/cert-manager-operator/pkg/controller/trustmanager\"\n31\t\t\"github.com/openshift/cert-manager-operator/pkg/version\"\n32\t)\n33\t\n34\tvar (\n35\t\tscheme   = runtime.NewScheme()\n36\t\tsetupLog = ctrl.Log.WithName(\"setup-manager\")\n37\t)\n38\t\n39\t// ConfigMap is intentionally excluded from both istioCSRManagedResources and\n40\t// trustManagerManagedResources. Multiple controllers need to watch ConfigMaps\n41\t// that do not carry the managed-resource label:\n42\t//\n43\t//  1. TrustManager watches both its managed ConfigMaps (e.g., the default CA\n44\t//     package ConfigMap, which carries the managed-resource label) and the\n45\t//     cert-manager-operator-trusted-ca-bundle ConfigMap (added in the OLM bundle manifest).\n46\t//     The latter does not carry the managed-resource label.\n47\t//\n48\t//  2. IstioCSR watches both its managed ConfigMaps (with the managed-resource\n49\t//     label) and user-created ConfigMaps identified by the\n50\t//     istiocsr.openshift.operator.io/watched-by label — a different label key\n51\t//     entirely from the managed-resource label (app).\n52\t//\n53\t// The cache uses a single labels.Selector per GVK. The In operator can match\n54\t// multiple values for the same key (e.g., app in (value1, value2)), but\n55\t// requirements on different keys are always ANDed. There is no way to express\n56\t// \"app in (...) OR watched-by exists\" in a single selector. A shared app label\n57\t// value could solve case 1, but case 2 requires matching across different label\n58\t// keys, which the Kubernetes label selector spec does not support.\n59\t//\n60\t// ConfigMaps therefore use the default unfiltered informer, and each controller\n61\t// applies predicate-level filtering to select only the events it cares about.\n62\t\n63\t// istioCSRManagedResources defines the resources managed by the IstioCSR controller.\n64\t// These resources will be watched with a label selector filter.\n65\tvar istioCSRManagedResources = []client.Object{\n66\t\t&certmanagerv1.Certificate{},\n67\t\t&appsv1.Deployment{},\n68\t\t&rbacv1.ClusterRole{},\n69\t\t&rbacv1.ClusterRoleBinding{},\n70\t\t&rbacv1.Role{},\n71\t\t&rbacv1.RoleBinding{},\n72\t\t&corev1.Service{},\n73\t\t&corev1.ServiceAccount{},\n74\t\t&networkingv1.NetworkPolicy{},\n75\t}\n76\t\n77\t// trustManagerManagedResources defines the resources managed by the TrustManager controller.\n78\t// These resources will be watched with a label selector filter.\n79\t//\n80\t// cert-manager Issuer (and ClusterIssuer, which is never listed here) must not use a\n81\t// managed-resource label selector: IstioCSR reconciles user-created Issuers referenced\n82\t// from the spec, which are not labeled by the operator. Those types are left out of\n83\t// ByObject so they use the manager cache’s default unfiltered informer per GVK.\n84\tvar trustManagerManagedResources = []client.Object{\n85\t\t&certmanagerv1.Certificate{},\n86\t\t&appsv1.Deployment{},\n87\t\t&rbacv1.ClusterRole{},\n88\t\t&rbacv1.ClusterRoleBinding{},\n89\t\t&rbacv1.Role{},\n90\t\t&rbacv1.RoleBinding{},\n91\t\t&corev1.Service{},\n92\t\t&corev1.ServiceAccount{},\n93\t\t&admissionregistrationv1.ValidatingWebhookConfiguration{},\n94\t}\n95\t\n96\tfunc init() {\n97\t\tutilruntime.Must(clientscheme.AddToScheme(scheme))\n98\t\tutilruntime.Must(appsv1.AddToScheme(scheme))\n99\t\tutilruntime.Must(corev1.AddToScheme(scheme))\n100\t\tutilruntime.Must(networkingv1.AddToScheme(scheme))\n101\t\tutilruntime.Must(rbacv1.AddToScheme(scheme))\n102\t\tutilruntime.Must(admissionregistrationv1.AddToScheme(scheme))\n103\t\tutilruntime.Must(certmanagerv1.AddToScheme(scheme))\n104\t\tutilruntime.Must(configv1.Install(scheme))\n105\t\tutilruntime.Must(v1alpha1.AddToScheme(scheme))\n106\t\t// +kubebuilder:scaffold:scheme\n107\t}\n108\t\n109\t// Manager holds the manager resource for the controller-runtime based controllers.\n110\ttype Manager struct {\n111\t\tmanager manager.Manager\n112\t}\n113\t\n114\t// ControllerConfig specifies which controllers to enable in the unified manager.\n115\ttype ControllerConfig struct {\n116\t\tEnableIstioCSR     bool\n117\t\tEnableTrustManager bool\n118\t}\n119\t\n120\t// NewControllerManager creates a unified manager for all enabled operand controllers.\n121\t// It shares a single metrics server, cache, and client across all controllers.\n122\tfunc NewControllerManager(config ControllerConfig) (*Manager, error) {\n123\t\tsetupLog.Info(\"setting up unified operator manager\")\n124\t\tsetupLog.Info(\"controller\", \"version\", version.Get())\n125\t\tsetupLog.Info(\"enabled controllers\", \"istioCSR\", config.EnableIstioCSR, \"trustManager\", config.EnableTrustManager)\n126\t\n127\t\tcacheBuilder := newUnifiedCacheBuilder(config)\n128\t\n129\t\tmgr, err := ctrl.NewManager(ctrl.GetConfigOrDie(), ctrl.Options{\n130\t\t\tScheme:   scheme,\n131\t\t\tNewCache: cacheBuilder,\n132\t\t\tLogger:   ctrl.Log.WithName(\"operator-manager\"),\n133\t\t})\n134\t\tif err != nil {\n135\t\t\treturn nil, fmt.Errorf(\"failed to create manager: %w\", err)\n136\t\t}\n137\t\n138\t\t// Setup enabled controllers\n139\t\tif config.EnableIstioCSR {\n140\t\t\tif err := setupIstioCSRController(mgr); err != nil {\n141\t\t\t\treturn nil, err\n142\t\t\t}\n143\t\t}\n144\t\n145\t\tif config.EnableTrustManager {\n146\t\t\tif err := setupTrustManagerController(mgr); err != nil {\n147\t\t\t\treturn nil, err\n148\t\t\t}\n149\t\t}\n150\t\n151\t\treturn &Manager{\n152\t\t\tmanager: mgr,\n153\t\t}, nil\n154\t}\n155\t\n156\t// setupIstioCSRController creates and registers the IstioCSR controller with the manager.\n157\tfunc setupIstioCSRController(mgr ctrl.Manager) error {\n158\t\tsetupLog.Info(\"setting up controller\", \"name\", istiocsr.ControllerName)\n159\t\tr, err := istiocsr.New(mgr)\n160\t\tif err != nil {\n161\t\t\treturn fmt.Errorf(\"failed to create %s reconciler object: %w\", istiocsr.ControllerName, err)\n162\t\t}\n163\t\tif err := r.SetupWithManager(mgr); err != nil {\n164\t\t\treturn fmt.Errorf(\"failed to create %s controller: %w\", istiocsr.ControllerName, err)\n165\t\t}\n166\t\treturn nil\n167\t}\n168\t\n169\t// setupTrustManagerController creates and registers the TrustManager controller with the manager.\n170\tfunc setupTrustManagerController(mgr ctrl.Manager) error {\n171\t\tsetupLog.Info(\"setting up controller\", \"name\", trustmanager.ControllerName)\n172\t\tr, err := trustmanager.New(mgr)\n173\t\tif err != nil {\n174\t\t\treturn fmt.Errorf(\"failed to create %s reconciler object: %w\", trustmanager.ControllerName, err)\n175\t\t}\n176\t\tif err := r.SetupWithManager(mgr); err != nil {\n177\t\t\treturn fmt.Errorf(\"failed to create %s controller: %w\", trustmanager.ControllerName, err)\n178\t\t}\n179\t\treturn nil\n180\t}\n181\t\n182\t// newUnifiedCacheBuilder creates a cache builder that combines cache configurations\n183\t// for all enabled controllers into a single unified cache.\n184\tfunc newUnifiedCacheBuilder(config ControllerConfig) cache.NewCacheFunc {\n185\t\treturn func(restConfig *rest.Config, opts cache.Options) (cache.Cache, error) {\n186\t\t\tobjectList, err := buildCacheObjectList(config)\n187\t\t\tif err != nil {\n188\t\t\t\treturn nil, err\n189\t\t\t}\n190\t\t\topts.ByObject = objectList\n191\t\t\treturn cache.New(restConfig, opts)\n192\t\t}\n193\t}\n194\t\n195\t// buildCacheObjectList creates the cache configuration with label selectors\n196\t// for managed resources based on enabled controllers.\n197\t// All controllers use common.ManagedResourceLabelKey as the label key.\n198\tfunc buildCacheObjectList(config ControllerConfig) (map[client.Object]cache.ByObject, error) {\n199\t\tobjectList := make(map[client.Object]cache.ByObject)\n200\t\n201\t\tif config.EnableIstioCSR {\n202\t\t\tif err := addControllerCacheConfig(objectList, istiocsr.RequestEnqueueLabelValue, istioCSRManagedResources); err != nil {\n203\t\t\t\treturn nil, fmt.Errorf(\"failed to configure IstioCSR cache: %w\", err)\n204\t\t\t}\n205\t\t\t// IstioCSR CR - no label filter needed\n206\t\t\tobjectList[&v1alpha1.IstioCSR{}] = cache.ByObject{}\n207\t\t}\n208\t\n209\t\tif config.EnableTrustManager {\n210\t\t\tif err := addControllerCacheConfig(objectList, trustmanager.RequestEnqueueLabelValue, trustManagerManagedResources); err != nil {\n211\t\t\t\treturn nil, fmt.Errorf(\"failed to configure TrustManager cache: %w\", err)\n212\t\t\t}\n213\t\t\t// TrustManager CR - no label filter needed\n214\t\t\tobjectList[&v1alpha1.TrustManager{}] = cache.ByObject{}\n215\t\t}\n216\t\n217\t\treturn objectList, nil\n218\t}\n219\t\n220\t// addControllerCacheConfig adds cache configuration for a controller's managed resources.\n221\t// All controllers use common.ManagedResourceLabelKey as the label key.\n222\t// If a resource type already exists (from another controller), the label selector is updated\n223\t// to use the 'In' operator to match resources from either controller.\n224\tfunc addControllerCacheConfig(objectList map[client.Object]cache.ByObject, labelValue string, resources []client.Object) error {\n225\t\tlabelKey := common.ManagedResourceLabelKey\n226\t\n227\t\tfor _, res := range resources {\n228\t\t\tresType := fmt.Sprintf(\"%T\", res)\n229\t\n230\t\t\tif existingKey, existing, found := findExistingCacheEntry(objectList, res); found {\n231\t\t\t\t// Resource already configured by another controller\n232\t\t\t\t// Merge label values using 'In' operator: app in (value1, value2)\n233\t\t\t\texistingReqs, _ := existing.Label.Requirements()\n234\t\t\t\tvar existingValues []string\n235\t\t\t\tfor _, req := range existingReqs {\n236\t\t\t\t\tif req.Key() == labelKey {\n237\t\t\t\t\t\texistingValues = req.Values().List()\n238\t\t\t\t\t\tbreak\n239\t\t\t\t\t}\n240\t\t\t\t}\n241\t\n242\t\t\t\t// Create new requirement with both values\n243\t\t\t\tmergedValues := append(existingValues, labelValue)\n244\t\t\t\tmergedReq, err := labels.NewRequirement(labelKey, selection.In, mergedValues)\n245\t\t\t\tif err != nil {\n246\t\t\t\t\treturn fmt.Errorf(\"failed to create merged label requirement for key %q with values %v: %w\", labelKey, mergedValues, err)\n247\t\t\t\t}\n248\t\t\t\tobjectList[existingKey] = cache.ByObject{Label: labels.NewSelector().Add(*mergedReq)}\n249\t\t\t\tsetupLog.V(4).Info(\"merged label selector for shared resource\", \"type\", resType, \"values\", mergedValues)\n250\t\t\t} else {\n251\t\t\t\t// First controller to configure this resource\n252\t\t\t\tlabelReq, err := labels.NewRequirement(labelKey, selection.Equals, []string{labelValue})\n253\t\t\t\tif err != nil {\n254\t\t\t\t\treturn fmt.Errorf(\"failed to create label requirement for key %q with value %q: %w\", labelKey, labelValue, err)\n255\t\t\t\t}\n256\t\t\t\tobjectList[res] = cache.ByObject{Label: labels.NewSelector().Add(*labelReq)}\n257\t\t\t}\n258\t\t}\n259\t\treturn nil\n260\t}\n261\t\n262\t// findExistingCacheEntry looks up an entry in the cache object map by Go type\n263\t// rather than pointer identity, since map[client.Object] uses interface comparison\n264\t// which compares pointers, not types.\n265\tfunc findExistingCacheEntry(objectList map[client.Object]cache.ByObject, target client.Object) (client.Object, cache.ByObject, bool) {\n266\t\ttargetType := reflect.TypeOf(target)\n267\t\tfor key, val := range objectList {\n268\t\t\tif reflect.TypeOf(key) == targetType {\n269\t\t\t\treturn key, val, true\n270\t\t\t}\n271\t\t}\n272\t\treturn nil, cache.ByObject{}, false\n273\t}\n274\t\n275\t// Start starts the unified controller manager synchronously until ctx is cancelled.\n276\tfunc (mgr *Manager) Start(ctx context.Context) error {\n277\t\treturn mgr.manager.Start(ctx)\n278\t}\n279\t"}]},"parent_tool_use_id":null,"session_id":"dd324d1c-703f-46ea-bfcf-8c61203e2c16","uuid":"5d596f61-354c-48a1-9e47-3030e0b5e3c3","timestamp":"2026-07-16T13:55:28.868Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/operator/setup_manager.go","content":"package operator\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"reflect\"\n\n\tadmissionregistrationv1 \"k8s.io/api/admissionregistration/v1\"\n\tappsv1 \"k8s.io/api/apps/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tnetworkingv1 \"k8s.io/api/networking/v1\"\n\trbacv1 \"k8s.io/api/rbac/v1\"\n\t\"k8s.io/apimachinery/pkg/labels\"\n\t\"k8s.io/apimachinery/pkg/runtime\"\n\t\"k8s.io/apimachinery/pkg/selection\"\n\tutilruntime \"k8s.io/apimachinery/pkg/util/runtime\"\n\tclientscheme \"k8s.io/client-go/kubernetes/scheme\"\n\t\"k8s.io/client-go/rest\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\t\"sigs.k8s.io/controller-runtime/pkg/cache
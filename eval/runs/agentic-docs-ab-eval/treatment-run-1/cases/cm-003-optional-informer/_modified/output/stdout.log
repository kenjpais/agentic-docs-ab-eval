 operator optionally enables, and is provided as a runtime arg.\n43\tvar UnsupportedAddonFeatures string\n44\t\n45\tfunc RunOperator(ctx context.Context, cc *controllercmd.ControllerContext) error {\n46\t\t// Set controller-runtime logger before any ctrl.Log usage (e.g. NewControllerManager).\n47\t\t// Uses klog so --v flag controls verbosity for both library-go and controller-runtime.\n48\t\tctrl.SetLogger(klog.NewKlogr())\n49\t\n50\t\tkubeClient, err := kubernetes.NewForConfig(cc.ProtoKubeConfig)\n51\t\tif err != nil {\n52\t\t\treturn err\n53\t\t}\n54\t\n55\t\tcertManagerOperatorClient, err := certmanoperatorclient.NewForConfig(cc.KubeConfig)\n56\t\tif err != nil {\n57\t\t\treturn err\n58\t\t}\n59\t\n60\t\tapiExtensionsClient, err := apiextensionsclient.NewForConfig(cc.KubeConfig)\n61\t\tif err != nil {\n62\t\t\treturn err\n63\t\t}\n64\t\n65\t\tcertManagerInformers := certmanoperatorinformers.NewSharedInformerFactory(certManagerOperatorClient, resyncInterval)\n66\t\n67\t\toperatorClient := &operatorclient.OperatorClient{\n68\t\t\tInformers: certManagerInformers,\n69\t\t\tClient:    certManagerOperatorClient.OperatorV1alpha1(),\n70\t\t\tClock:     cc.Clock,\n71\t\t}\n72\t\n73\t\t// perform version changes to the version getter prior to tying it up in the status controller\n74\t\t// via change-notification channel so that it only updates operator version in status once\n75\t\t// either of the workloads syncs.\n76\t\tversionRecorder := status.NewVersionGetter()\n77\t\tversionRecorder.SetVersion(\"operator\", status.VersionForOperatorFromEnv())\n78\t\n79\t\tkubeInformersForNamespaces := v1helpers.NewKubeInformersForNamespaces(kubeClient,\n80\t\t\t\"\",\n81\t\t\t\"kube-system\",\n82\t\t\toperatorclient.TargetNamespace,\n83\t\t)\n84\t\n85\t\tconfigClient, err := configv1client.NewForConfig(cc.KubeConfig)\n86\t\tif err != nil {\n87\t\t\treturn err\n88\t\t}\n89\t\n90\t\tinfraGVR := configv1.GroupVersion.WithResource(\"infrastructures\")\n91\t\toptInfraInformer, err := utils.InitInformerIfAvailable(\n92\t\t\tutils.NewResourceDiscoverer(infraGVR, configClient.Discovery()),\n93\t\t\tfunc() configinformers.SharedInformerFactory {\n94\t\t\t\treturn configinformers.NewSharedInformerFactory(configClient, resyncInterval)\n95\t\t\t},\n96\t\t)\n97\t\tif err != nil {\n98\t\t\treturn fmt.Errorf(\"failed to discover Infrastructure presence: %w\", err)\n99\t\t}\n100\t\n101\t\tcertManagerControllerSet := certmanager.NewCertManagerControllerSet(\n102\t\t\tkubeClient,\n103\t\t\tkubeInformersForNamespaces,\n104\t\t\tkubeInformersForNamespaces.InformersFor(operatorclient.TargetNamespace),\n105\t\t\t*optInfraInformer,\n106\t\t\toperatorClient,\n107\t\t\tcertManagerInformers,\n108\t\t\tresourceapply.NewKubeClientHolder(kubeClient).WithAPIExtensionsClient(apiExtensionsClient),\n109\t\t\tcc.EventRecorder,\n110\t\t\tstatus.VersionForOperandFromEnv(),\n111\t\t\tversionRecorder,\n112\t\t\tTrustedCAConfigMapName,\n113\t\t\tCloudCredentialSecret,\n114\t\t)\n115\t\tcontrollersToStart := certManagerControllerSet.ToArray()\n116\t\n117\t\tdefaultCertManagerController := certmanager.NewDefaultCertManagerController(\n118\t\t\toperatorClient,\n119\t\t\tcertManagerOperatorClient.OperatorV1alpha1(),\n120\t\t\tcc.EventRecorder,\n121\t\t)\n122\t\n123\t\tcontrollersToStart = append(controllersToStart, defaultCertManagerController)\n124\t\n125\t\tfor _, informer := range []interface{ Start(<-chan struct{}) }{\n126\t\t\tcertManagerInformers,\n127\t\t\tkubeInformersForNamespaces,\n128\t\t} {\n129\t\t\tinformer.Start(ctx.Done())\n130\t\t}\n131\t\n132\t\t// only start the informer if Infrastructure is found applicable\n133\t\tif optInfraInformer.Applicable() {\n134\t\t\t(*optInfraInformer.InformerFactory).Start(ctx.Done())\n135\t\t}\n136\t\n137\t\tfor _, controller := range controllersToStart {\n138\t\t\tgo controller.Run(ctx, 1)\n139\t\t}\n140\t\n141\t\tfeatureStatus, err := setupFeatureGates(ctx, configClient)\n142\t\tif err != nil {\n143\t\t\treturn err\n144\t\t}\n145\t\tistioCSREnabled := features.IsIstioCSRFeatureGateEnabled()\n146\t\ttrustManagerEnabled := featureStatus.IsTrustManagerFeatureGateEnabled()\n147\t\n148\t\tif istioCSREnabled || trustManagerEnabled {\n149\t\t\t// Create unified manager for all enabled operand controllers\n150\t\t\tmanager, err := NewControllerManager(ControllerConfig{\n151\t\t\t\tEnableIstioCSR:     istioCSREnabled,\n152\t\t\t\tEnableTrustManager: trustManagerEnabled,\n153\t\t\t})\n154\t\t\tif err != nil {\n155\t\t\t\treturn fmt.Errorf(\"failed to create unified controller manager: %w\", err)\n156\t\t\t}\n157\t\n158\t\t\tgo func() {\n159\t\t\t\tif err := manager.Start(ctx); err != nil {\n160\t\t\t\t\tctrl.Log.Error(err, \"failed to start unified controller manager\")\n161\t\t\t\t}\n162\t\t\t}()\n163\t\t}\n164\t\n165\t\t<-ctx.Done()\n166\t\treturn nil\n167\t}\n168\t\n169\t// setupFeatureGates applies operator feature flags from UnsupportedAddonFeatures\n170\t// (--unsupported-addon-features) and builds cluster-side FeatureGateState by reading\n171\t// featuregates/cluster when served. Transient discovery or featuregates/cluster read errors\n172\t// are retried up to three times with 30s backoff; persistent failure leaves stateErr set\n173\t// on FeatureGateState without aborting the rest of startup. Returns an error only for invalid\n174\t// addon feature syntax or if ctx is canceled while waiting between retries.\n175\tfunc setupFeatureGates(ctx context.Context, configClient configv1client.Interface) (*features.FeatureGateState, error) {\n176\t\tconst (\n177\t\t\t// maxFeatureGateAttempts caps how many times we call NewFeatureGateState when discovery or\n178\t\t\t// featuregates/cluster read fails (excluding ErrNilConfigClient, which is not retried).\n179\t\t\tmaxFeatureGateAttempts = 3\n180\t\t\tfeatureGateRetryDelay  = 30 * time.Second\n181\t\t)\n182\t\n183\t\tvar featureStatus *features.FeatureGateState\n184\t\n185\t\tif err := features.SetupWithFlagValue(UnsupportedAddonFeatures); err != nil {\n186\t\t\treturn nil, fmt.Errorf(\"failed to parse addon features: %w\", err)\n187\t\t}\n188\t\n189\t\tfor attempt := 1; attempt <= maxFeatureGateAttempts; attempt++ {\n190\t\t\tfeatureStatus = features.NewFeatureGateState(ctx, configClient)\n191\t\t\terr := featureStatus.Err()\n192\t\t\tif err == nil {\n193\t\t\t\tbreak\n194\t\t\t}\n195\t\t\tif attempt == maxFeatureGateAttempts {\n196\t\t\t\tctrl.Log.Info(\"feature gate validation failed after max attempts; continuing with last state\",\n197\t\t\t\t\t\"error\", err, \"attempts\", attempt)\n198\t\t\t\tbreak\n199\t\t\t}\n200\t\t\tctrl.Log.Info(\"failed to validate featuregate settings, retrying\",\n201\t\t\t\t\"error\", err, \"attempt\", attempt, \"maxAttempts\", maxFeatureGateAttempts)\n202\t\t\tselect {\n203\t\t\tcase <-ctx.Done():\n204\t\t\t\treturn nil, fmt.Errorf(\"context cancelled: %w\", ctx.Err())\n205\t\t\tcase <-time.After(featureGateRetryDelay):\n206\t\t\t}\n207\t\t}\n208\t\n209\t\treturn featureStatus, nil\n210\t}\n211\t"}]},"parent_tool_use_id":null,"session_id":"dd324d1c-703f-46ea-bfcf-8c61203e2c16","uuid":"1df3b060-ee53-45d0-8d60-cf0c26bcecb1","timestamp":"2026-07-16T13:55:28.674Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kpais/kpais-workspace/a_b_evals/repos/cert-manager-operator-treatment/pkg/operator/starter.go","content":"package operator\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\tapiextensionsclient \"k8s.io/apiextensions-apiserver/pkg/client/clientset/clientset\"\n\t\"k8s.io/client-go/kubernetes\"\n\t\"k8s.io/klog/v2\"\n\tctrl \"sigs.k8s.io/controller-runtime\"\n\n\tconfigv1 \"github.com/openshift/api/config/v1\"\n\tconfigv1client \"github.com/openshift/client-go/config/clientset/versioned\"\n\tconfiginformers \"github.com/openshift/client-go/config/informers/externalversions\"\n\t\"github.com/openshift/library-go/pkg/controller/controllercmd\"\n\t\"github.com/openshift/library-go/pkg/operator/resource/resourceapply\"\n\t\"github.com/openshift/library-go/pkg/operator/sta